{
  "mcpServers": {
    "totalcall-ops-local": {
      "type": "stdio",
      "command": "./scripts/with-supabase-keychain.sh",
      "args": [
        "--account",
        "local",
        "--",
        "dotnet",
        "run",
        "--project",
        "ops/mcp/TotalCall.Mcp/TotalCall.Mcp.csproj",
        "--no-build"
      ]
    },
    "totalcall-ops-production": {
      "type": "stdio",
      "command": "./scripts/with-supabase-keychain.sh",
      "args": [
        "--account",
        "production",
        "--",
        "dotnet",
        "run",
        "--project",
        "ops/mcp/TotalCall.Mcp/TotalCall.Mcp.csproj",
        "--no-build"
      ]
    },
    "supabase-local": {
      "type": "http",
      "url": "http://127.0.0.1:54321/mcp"
    }
  }
}
