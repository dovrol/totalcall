{
  "context_servers": {
    "totalcall-ops-local": {
      "command": "./scripts/with-supabase-keychain.sh",
      "args": [
        "--account",
        "local",
        "--",
        "dotnet",
        "run",
        "--project",
        "ops/mcp/TotalCall.Mcp/TotalCall.Mcp.csproj",
        "--no-build"
      ],
      "env": {}
    },
    "totalcall-ops-production": {
      "command": "./scripts/with-supabase-keychain.sh",
      "args": [
        "--account",
        "production",
        "--",
        "dotnet",
        "run",
        "--project",
        "ops/mcp/TotalCall.Mcp/TotalCall.Mcp.csproj",
        "--no-build"
      ],
      "env": {}
    },
    "supabase-local": {
      "url": "http://127.0.0.1:54321/mcp"
    }
  }
}
