        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                Competitions
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="competitions/sheffield-2026">
                Sheffield 2026
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="competitions/worlds-2026">
                Worlds 2026
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
