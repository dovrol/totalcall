@implements IDisposable
@inject CultureService Culture
@inject IStringLocalizer<SharedResource> Localizer

<div class="topnav">
    <a class="brand" href="">
        <span class="brand-mark" aria-hidden="true"></span>
        <span>
            <strong>TotalCall</strong>
            <small>@Localizer["App.Tagline"]</small>
        </span>
    </a>

    <button type="button" class="nav-toggle" @onclick="ToggleNavMenu">
        @Localizer["Nav.Menu"]
    </button>

    <nav class="@NavMenuCssClass">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            @Localizer["Nav.Competitions"]
        </NavLink>
        <NavLink class="nav-link" href="competitions/sheffield-2026">
            @Localizer["Nav.Sheffield"]
        </NavLink>
        <NavLink class="nav-link" href="competitions/worlds-2026">
            @Localizer["Nav.Worlds"]
        </NavLink>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string NavMenuCssClass => collapseNavMenu ? "topnav__links topnav__links--collapsed" : "topnav__links";

    protected override void OnInitialized()
    {
        Culture.CultureChanged += OnCultureChanged;
    }

    public void Dispose()
    {
        Culture.CultureChanged -= OnCultureChanged;
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void OnCultureChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
