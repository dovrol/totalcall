@implements IDisposable
@inject LanguageService Language

<div class="nav-header">
    <a class="brand" href="">
        <span class="brand-mark" aria-hidden="true">
            <span></span>
        </span>
        <span>
            <strong>TotalCall</strong>
            <small>@Language.Text("App.Tagline")</small>
        </span>
    </a>
    <button title="Navigation menu" class="nav-toggle" @onclick="ToggleNavMenu">
        @Language.Text("Nav.Menu")
    </button>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav-list">
        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                @Language.Text("Nav.Competitions")
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="competitions/sheffield-2026">
                @Language.Text("Nav.Sheffield")
            </NavLink>
        </div>
        <div class="nav-item">
            <NavLink class="nav-link" href="competitions/worlds-2026">
                @Language.Text("Nav.Worlds")
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override void OnInitialized()
    {
        Language.LanguageChanged += OnLanguageChanged;
    }

    public void Dispose()
    {
        Language.LanguageChanged -= OnLanguageChanged;
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void OnLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
