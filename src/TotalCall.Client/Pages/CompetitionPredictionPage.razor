@page "/competitions/{Slug}/predictions"
@using TotalCall.Client.Components.Predictions.Share
@implements IDisposable
@inject CompetitionService CompetitionService
@inject PredictionService PredictionService
@inject IPredictionValidationService PredictionValidationService
@inject CompetitionReviewBuilder ReviewBuilder
@inject PredictionSyncState PredictionSyncState
@inject IStringLocalizer<SharedResource> Localizer
@inject ToastService Toasts
@inject AuthService Auth

<PageTitle>@(competition is null ? Localizer["Predictions.PageTitle"] : $"{competition.Name} - {Localizer["Predictions.PageTitle"]}")</PageTitle>

@if (isLoading)
{
    <AppLoadingState Message="@Localizer["Predictions.Loading"]" />
}
else if (competition is null || predictionSet is null)
{
    <AppErrorState
        Title="@Localizer["Predictions.NotFoundTitle"]"
        Description="@Localizer["Predictions.NotFoundDescription"]" />
}
else if (ActiveGroup is null)
{
    <PredictionEmptyState
        Title="@Localizer["Predictions.NoModulesTitle"]"
        Description="@Localizer["Predictions.NoModulesDescription"]" />
}
else if (IsTopNGroup(ActiveGroup))
{
    <TopNWorkspace
        Competition="@competition"
        Groups="@OrderedGroups"
        ActiveGroup="@ActiveGroup"
        Answers="@predictionSet.Answers"
        ActiveModuleValidation="@GetModuleValidation(ActiveGroup.Id)"
        ModuleValidationByGroupId="@moduleValidationByGroupId"
        CanEditPredictions="@canEditPredictions"
        IsAuthenticated="@Auth.IsAuthenticated"
        SaveStatus="@CurrentSaveStatus"
        LastSavedAt="@predictionSet.SavedAt"
        SubmittedAt="@predictionSet.SubmittedAt"
        IsSubmitting="@isSubmitting"
        SubmitError="@submitError"
        GroupChanged="@SelectGroup"
        AnswerChanged="@OnAnswerChanged"
        SubmitRequested="@OnSubmitRequested"
        RetrySyncRequested="@OnRetrySyncRequested"
        ShareRequested="@OnShareRequested" />
}
else
{
    <PredictionShell
        Competition="@competition"
        Groups="@OrderedGroups"
        ActiveGroup="@ActiveGroup"
        Answers="@predictionSet.Answers"
        ActiveModuleValidation="@GetModuleValidation(ActiveGroup.Id)"
        ModuleValidationByGroupId="@moduleValidationByGroupId"
        CanEditPredictions="@canEditPredictions"
        IsAuthenticated="@Auth.IsAuthenticated"
        SaveStatus="@CurrentSaveStatus"
        LastSavedAt="@predictionSet.SavedAt"
        SubmittedAt="@predictionSet.SubmittedAt"
        IsSubmitting="@isSubmitting"
        SubmitError="@submitError"
        GroupChanged="@SelectGroup"
        AnswerChanged="@OnAnswerChanged"
        SubmitRequested="@OnSubmitRequested"
        RetrySyncRequested="@OnRetrySyncRequested"
        ShareRequested="@OnShareRequested" />
}

<ShareExportModal
    IsOpen="@isShareOpen"
    Competition="@competition"
    PredictionSet="@predictionSet"
    Review="@shareReview"
    OnClose="@CloseShare" />

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private Competition? competition;
    private PredictionSet? predictionSet;
    private PredictionValidationResult validationResult = new([]);
    private IReadOnlyDictionary<string, PredictionModuleValidationResult> moduleValidationByGroupId =
        new Dictionary<string, PredictionModuleValidationResult>(StringComparer.OrdinalIgnoreCase);
    private bool isLoading = true;
    private bool canEditPredictions;
    private string? activeGroupId;
    private bool isShareOpen;
    private bool isSubmitting;
    private string? submitError;
    private CompetitionReviewModel? shareReview;

    private IReadOnlyList<PredictionGroup> OrderedGroups => competition?
        .PredictionGroups
        .OrderBy(group => group.Order)
        .ToArray() ?? [];

    private PredictionGroup? ActiveGroup => OrderedGroups
        .FirstOrDefault(group => group.Id == activeGroupId) ??
        OrderedGroups.FirstOrDefault();

    private PredictionSaveStatus CurrentSaveStatus
    {
        get
        {
            if (predictionSet is null)
            {
                return PredictionSaveStatus.Local;
            }

            var saveStatus = PredictionSyncState.GetStatus(predictionSet.CompetitionId);
            if (saveStatus == PredictionSaveStatus.SynchronizationFailed)
            {
                return saveStatus;
            }

            return predictionSet.IsSubmitted
                ? PredictionSaveStatus.Submitted
                : saveStatus;
        }
    }

    protected override void OnInitialized()
    {
        PredictionSyncState.Changed += OnSyncStateChanged;
    }

    private static bool IsTopNGroup(PredictionGroup group)
    {
        var normalizedType = PredictionModuleType.Normalize(group.Type);
        if (!string.IsNullOrWhiteSpace(normalizedType))
        {
            return normalizedType == PredictionModuleType.TopNByCategory;
        }

        var questionTypes = group.Questions
            .Select(question => question.Type)
            .Distinct()
            .ToArray();

        return questionTypes.Length == 1 &&
               questionTypes[0] == PredictionQuestionType.AthleteRanking &&
               group.Questions.Count > 1 &&
               group.Questions.All(question => !string.IsNullOrWhiteSpace(question.CategoryId));
    }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        competition = await CompetitionService.GetCompetitionAsync(Slug);

        if (competition is not null)
        {
            predictionSet = await PredictionService.GetOrCreatePredictionSetAsync(competition);
            canEditPredictions = CompetitionService.CanEditPredictions(competition);

            RefreshValidation();

            var firstGroup = OrderedGroups.FirstOrDefault();
            if (firstGroup is not null && OrderedGroups.All(group => group.Id != activeGroupId))
            {
                activeGroupId = firstGroup.Id;
            }
        }

        isLoading = false;
    }

    private void RefreshValidation()
    {
        if (competition is null || predictionSet is null)
        {
            validationResult = new PredictionValidationResult([]);
            moduleValidationByGroupId = new Dictionary<string, PredictionModuleValidationResult>(StringComparer.OrdinalIgnoreCase);
            return;
        }

        validationResult = PredictionValidationService.Validate(competition, predictionSet);

        moduleValidationByGroupId = OrderedGroups.ToDictionary(
            group => group.Id,
            group => PredictionValidationService.ValidateModule(competition, group, predictionSet),
            StringComparer.OrdinalIgnoreCase);
    }

    private PredictionModuleValidationResult GetModuleValidation(string groupId)
    {
        if (moduleValidationByGroupId.TryGetValue(groupId, out var result))
        {
            return result;
        }

        return new PredictionModuleValidationResult(
            groupId,
            PredictionCompletionStatus.NotStarted,
            0,
            0,
            0,
            0,
            [],
            []);
    }

    private async Task OnAnswerChanged(PredictionAnswer answer)
    {
        if (competition is null || predictionSet is null || !canEditPredictions)
        {
            return;
        }

        predictionSet = PredictionService.UpdateAnswer(predictionSet, answer);
        submitError = null;
        RefreshValidation();

        await SaveAsync();
    }

    private async Task SaveAsync()
    {
        if (predictionSet is null || !canEditPredictions)
        {
            return;
        }

        try
        {
            await PredictionService.SaveAsync(predictionSet);
        }
        catch
        {
            Toasts.ShowError(Localizer["Predictions.Toast.Save.Error"]);
        }
    }

    private async Task OnSubmitRequested()
    {
        if (competition is null ||
            predictionSet is null ||
            !canEditPredictions ||
            isSubmitting ||
            CurrentSaveStatus == PredictionSaveStatus.SynchronizationFailed)
        {
            return;
        }

        isSubmitting = true;
        submitError = null;

        try
        {
            predictionSet = await PredictionService.SubmitAsync(predictionSet);
            RefreshValidation();
            Toasts.ShowSuccess(Localizer["Predictions.Toast.Submit.Success"]);
        }
        catch (Exception ex)
        {
            submitError = string.IsNullOrWhiteSpace(ex.Message)
                ? Localizer["Predictions.Toast.Submit.Error"]
                : ex.Message;
            Toasts.ShowError(Localizer["Predictions.Toast.Submit.Error"]);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task OnRetrySyncRequested()
    {
        submitError = null;
        await SaveAsync();
    }

    private Task SelectGroup(string groupId)
    {
        if (OrderedGroups.Any(group => group.Id == groupId))
        {
            activeGroupId = groupId;
        }

        return Task.CompletedTask;
    }

    private Task OnShareRequested(MouseEventArgs _)
    {
        if (competition is null || predictionSet is null)
        {
            return Task.CompletedTask;
        }

        shareReview = ReviewBuilder.Build(competition, predictionSet, canEditPredictions);
        isShareOpen = true;
        return Task.CompletedTask;
    }

    private Task CloseShare()
    {
        isShareOpen = false;
        return Task.CompletedTask;
    }

    private void OnSyncStateChanged(string competitionId)
    {
        if (predictionSet?.CompetitionId == competitionId)
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        PredictionSyncState.Changed -= OnSyncStateChanged;
    }
}
