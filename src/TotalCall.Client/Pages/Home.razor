@page "/"
@inject CompetitionService CompetitionService
@inject LanguageService Language

<PageTitle>TotalCall</PageTitle>

<div class="dashboard-hero">
    <div>
        <p class="eyebrow">@Language.Text("Home.Eyebrow")</p>
        <h1>@Language.Text("Home.Title")</h1>
        <p>@Language.Text("Home.Description")</p>
    </div>
    <div class="hero-plate" aria-hidden="true">
        <span class="hero-plate__bar"></span>
        <span class="hero-plate__disc hero-plate__disc--red"></span>
        <span class="hero-plate__disc hero-plate__disc--blue"></span>
        <span class="hero-plate__disc hero-plate__disc--yellow"></span>
    </div>
</div>

@if (competitions is null)
{
    <p class="muted">@Language.Text("Home.Loading")</p>
}
else if (competitions.Count == 0)
{
    <p class="muted">@Language.Text("Home.Empty")</p>
}
else
{
    <div class="section-heading">
        <div>
            <p class="eyebrow">@Language.Text("Home.CompetitionsLabel")</p>
            <h2>@Language.Text("Nav.Competitions")</h2>
        </div>
        <p>@Language.Text("Home.CompetitionsHint")</p>
    </div>

    <div class="competition-grid">
        @foreach (var competition in competitions)
        {
            <article class="competition-card">
                <div>
                    <p class="status-pill">@Language.Text($"Status.{competition.Status}")</p>
                    <h2>@competition.Name</h2>
                    @if (!string.IsNullOrWhiteSpace(competition.Description))
                    {
                        <p>@competition.Description</p>
                    }
                </div>
                <dl class="meta-list">
                    <div>
                        <dt>@Language.Text("Common.Starts")</dt>
                        <dd>@FormatDate(competition.StartDate)</dd>
                    </div>
                    <div>
                        <dt>@Language.Text("Common.Locks")</dt>
                        <dd>@FormatDate(competition.PredictionLockAt)</dd>
                    </div>
                </dl>
                <a class="primary-link" href="@($"competitions/{competition.Slug}")">@Language.Text("Common.OpenCompetition")</a>
            </article>
        }
    </div>
}

@code {
    private IReadOnlyList<CompetitionSummary>? competitions;

    protected override async Task OnInitializedAsync()
    {
        competitions = await CompetitionService.GetCompetitionsAsync();
    }

    private string FormatDate(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? Language.Text("Common.Tbd");
    }
}
