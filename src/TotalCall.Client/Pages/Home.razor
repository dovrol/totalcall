@page "/"
@inject CompetitionService CompetitionService
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>TotalCall</PageTitle>

<AppPageHeader
    Eyebrow="@Localizer["Home.Eyebrow"]"
    Title="@Localizer["Home.Title"]"
    Description="@Localizer["Home.Description"]">
    <Actions>
        @if (PrimaryCompetition is not null)
        {
            <AppButton Href="@($"competitions/{PrimaryCompetition.Slug}/predictions")">
                @Localizer["Competition.MakePredictions"]
            </AppButton>
        }
        <AppButton Href="#competitions" Variant="Secondary">
            @Localizer["Nav.Competitions"]
        </AppButton>
    </Actions>
    <Aside>
        <AppStatCard
            Label="@Localizer["Home.CompetitionsLabel"]"
            Value="@((competitions?.Count ?? 0).ToString())"
            Description="@Localizer["Home.CompetitionsHint"]" />
    </Aside>
</AppPageHeader>

@if (competitions is null)
{
    <AppLoadingState Message="@Localizer["Home.Loading"]" />
}
else if (competitions.Count == 0)
{
    <AppEmptyState Title="@Localizer["Home.Empty"]" />
}
else
{
    <AppSection
        Id="competitions"
        Eyebrow="@Localizer["Home.CompetitionsLabel"]"
        Title="@Localizer["Nav.Competitions"]"
        Description="@Localizer["Home.CompetitionsHint"]">
        <div class="grid gap-4 md:grid-cols-2">
            @foreach (var competition in competitions)
            {
                <CompetitionCard Competition="competition" />
            }
        </div>
    </AppSection>
}

@code {
    private IReadOnlyList<CompetitionSummary>? competitions;

    private CompetitionSummary? PrimaryCompetition => competitions?
        .FirstOrDefault(competition => competition.Status == CompetitionStatus.Upcoming);

    protected override async Task OnInitializedAsync()
    {
        competitions = await CompetitionService.GetCompetitionsAsync();
    }
}
