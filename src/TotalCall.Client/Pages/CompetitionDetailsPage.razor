@page "/competitions/{Slug}"
@inject CompetitionService CompetitionService
@inject IStringLocalizer<SharedResource> Localizer
@inject PredictionTextService Text

<PageTitle>@(competition?.Name ?? Localizer["Competition.Section"])</PageTitle>

@if (isLoading)
{
    <p class="muted">@Localizer["Competition.Loading"]</p>
}
else if (competition is null)
{
    <div class="page-header">
        <h1>@Localizer["Competition.NotFoundTitle"]</h1>
        <p>@Localizer["Competition.NotFoundDescription"]</p>
    </div>
}
else
{
    <div class="meet-header">
        <div>
            <p class="status-pill">@Localizer[$"Status.{competition.Status}"]</p>
            <h1>@competition.Name</h1>
            @if (!string.IsNullOrWhiteSpace(Text.CompetitionDescription(competition)))
            {
                <p>@Text.CompetitionDescription(competition)</p>
            }
        </div>
        <div class="meet-header__actions">
            <a class="primary-link" href="@($"competitions/{competition.Slug}/predictions")">@Localizer["Competition.MakePredictions"]</a>
            <a class="secondary-link" href="@($"competitions/{competition.Slug}/review")">@Localizer["Competition.ReviewSaved"]</a>
        </div>
    </div>

    <div class="details-grid">
        <section class="panel">
            <h2>@Localizer["Competition.Section"]</h2>
            <dl class="meta-list">
                <div>
                    <dt>@Localizer["Competition.Federation"]</dt>
                    <dd>@(competition.Federation ?? Localizer["Common.Tbd"])</dd>
                </div>
                <div>
                    <dt>@Localizer["Common.Starts"]</dt>
                    <dd>@FormatDate(competition.StartDate)</dd>
                </div>
                <div>
                    <dt>@Localizer["Common.Locks"]</dt>
                    <dd>@FormatDate(competition.PredictionLockAt)</dd>
                </div>
                <div>
                    <dt>@Localizer["Competition.ConfigVersion"]</dt>
                    <dd>@competition.ConfigVersion</dd>
                </div>
            </dl>
        </section>

        <section class="panel">
            <h2>@Localizer["Competition.Data"]</h2>
            <div class="stat-grid">
                <div class="stat-tile">
                    <span>@competition.Athletes.Count</span>
                    <small>@Localizer["Competition.Athletes"]</small>
                </div>
                <div class="stat-tile">
                    <span>@competition.Categories.Count</span>
                    <small>@Localizer["Competition.Categories"]</small>
                </div>
                <div class="stat-tile">
                    <span>@competition.PredictionGroups.Count</span>
                    <small>@Localizer["Competition.Groups"]</small>
                </div>
            </div>
        </section>
    </div>

    <section class="panel">
        <h2>@Localizer["Competition.PredictionGroups"]</h2>
        <div class="group-list">
            @foreach (var group in competition.PredictionGroups.OrderBy(group => group.Order))
            {
                <div class="group-list__item">
                    <div>
                        @if (!string.IsNullOrWhiteSpace(group.Mode))
                        {
                            <p class="prediction-group__mode">@group.Mode</p>
                        }
                        <h3>@Text.GroupTitle(competition, group)</h3>
                        @if (!string.IsNullOrWhiteSpace(Text.GroupDescription(competition, group)))
                        {
                            <p>@Text.GroupDescription(competition, group)</p>
                        }
                    </div>
                    <span>@Localizer["Competition.QuestionsCount", group.Questions.Count]</span>
                </div>
            }
        </div>
    </section>

    <div class="actions">
        <a class="primary-link" href="@($"competitions/{competition.Slug}/predictions")">@Localizer["Competition.MakePredictions"]</a>
        <a class="secondary-link" href="@($"competitions/{competition.Slug}/review")">@Localizer["Competition.ReviewSaved"]</a>
        <a class="secondary-link" href="">@Localizer["Common.BackToCompetitions"]</a>
    </div>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private Competition? competition;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        competition = await CompetitionService.GetCompetitionAsync(Slug);
        isLoading = false;
    }

    private string FormatDate(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("d MMM yyyy HH:mm") ?? Localizer["Common.Tbd"];
    }
}
