@page "/competitions/{Slug}"
@inject CompetitionService CompetitionService
@inject IStringLocalizer<SharedResource> Localizer
@inject PredictionTextService Text
@inject PredictionService PredictionService

<PageTitle>@(competition?.Name ?? Localizer["Competition.Section"])</PageTitle>

@if (isLoading)
{
    <AppLoadingState Message="@Localizer["Competition.Loading"]" />
}
else if (competition is null)
{
    <AppErrorState
        Title="@Localizer["Competition.NotFoundTitle"]"
        Description="@Localizer["Competition.NotFoundDescription"]" />
}
else
{
    <AppBreadcrumbs Items="Breadcrumbs" />

    <CompetitionPageNav Competition="competition" Active="Overview" />

    <section class="competition-overview-layout">
        <AppCard Padding="Lg" AdditionalClass="competition-overview-hero">
            <div class="competition-overview-hero__media" style="@HeroMediaStyle" aria-hidden="true"></div>

            <div class="competition-overview-hero__content">
                <CompetitionStatusBadge Status="competition.Status" />

                <h1 class="competition-overview-hero__title">@competition.Name</h1>

                <p class="competition-overview-hero__description">@Text.CompetitionDescription(competition)</p>

                <dl class="competition-overview-hero__meta">
                    <div>
                        <dt>
                            <AppIcon Name="AppIconName.Users" Size="16" />
                            <span>@Localizer["Competition.Federation"]</span>
                        </dt>
                        <dd>@(competition.Federation ?? Localizer["Common.Tbd"])</dd>
                    </div>
                    <div>
                        <dt>
                            <AppIcon Name="AppIconName.Calendar" Size="16" />
                            <span>@Localizer["Common.Starts"]</span>
                        </dt>
                        <dd>@FormatDate(competition.StartDate)</dd>
                    </div>
                    <div>
                        <dt>
                            <AppIcon Name="AppIconName.Lock" Size="16" />
                            <span>@Localizer["Common.Locks"]</span>
                        </dt>
                        <dd>@FormatDate(competition.PredictionLockAt)</dd>
                    </div>
                </dl>

                <div class="competition-overview-hero__actions">
                    <AppButton Href="@($"competitions/{competition.Slug}/predictions")" Size="Lg">
                        <span class="competition-overview-hero__action-content">
                            <span>@Localizer["Competition.MakePredictions"]</span>
                            <AppIcon Name="AppIconName.ChevronRight" Size="17" />
                        </span>
                    </AppButton>
                    <AppButton Href="@($"competitions/{competition.Slug}/review")" Variant="Secondary">
                        @Localizer["Competition.ReviewSaved"]
                    </AppButton>
                </div>
            </div>

            <div class="competition-overview-hero__badge" aria-hidden="true">
                @if (HasLogoImage)
                {
                    <img src="@competition!.CardLogoImageUrl" alt="" loading="lazy" />
                }
                else
                {
                    <AppIcon Name="AppIconName.Trophy" Size="30" />
                }
            </div>
        </AppCard>

        <AppCard Padding="Md" AdditionalClass="competition-overview-side">
            <div class="competition-overview-side__item">
                <div class="competition-overview-side__icon">
                    <AppIcon Name="AppIconName.Clock" Size="18" />
                </div>
                <div>
                    <p>@Localizer["Common.Locks"]</p>
                    <strong>@FormatDate(competition.PredictionLockAt)</strong>
                </div>
            </div>

            <div class="competition-overview-side__item">
                <div class="competition-overview-side__icon">
                    <AppIcon Name="AppIconName.Trophy" Size="18" />
                </div>
                <div>
                    <p>@Localizer["Competition.Categories"]</p>
                    <strong>@competition.Categories.Count</strong>
                </div>
            </div>

            <div class="competition-overview-side__item">
                <div class="competition-overview-side__icon">
                    <AppIcon Name="AppIconName.Check" Size="18" />
                </div>
                <div>
                    <p>@Localizer["Predictions.SavedAnswers"]</p>
                    <strong>@SavedAnswersCount</strong>
                </div>
            </div>
        </AppCard>
    </section>

    <AppSection Surface="true" Title="@Localizer["Competition.PredictionGroups"]" Description="@Localizer["Competition.ModulesHint"]">
        <div class="competition-overview-modules__grid">
            @foreach (var group in competition.PredictionGroups.OrderBy(group => group.Order))
            {
                <article class="competition-overview-module">
                    <span class="competition-overview-module__icon" aria-hidden="true">
                        <AppIcon Name="AppIconName.Medal" Size="28" />
                    </span>
                    <div class="competition-overview-module__content">
                        <h3>@Text.GroupTitle(competition, group)</h3>
                        @if (!string.IsNullOrWhiteSpace(Text.GroupDescription(competition, group)))
                        {
                            <p>@Text.GroupDescription(competition, group)</p>
                        }
                        <small>@Localizer["Competition.PicksCount", GetTotalPicks(group)]</small>
                    </div>
                    <AppButton Href="@($"competitions/{competition.Slug}/predictions")" Variant="Secondary" Size="Sm">
                        @Localizer["Competition.MakePredictions"]
                    </AppButton>
                </article>
            }
        </div>
    </AppSection>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private const string DefaultCardBackgroundImageUrl = "/assets/competitions/default-card-bg.webp";
    private static readonly char[] DisallowedInlineStyleChars = ['\r', '\n', ';'];

    private Competition? competition;
    private PredictionSet? predictionSet;
    private bool isLoading = true;

    private int SavedAnswersCount => predictionSet?.Answers.Count ?? 0;

    private bool HasLogoImage => !string.IsNullOrWhiteSpace(competition?.CardLogoImageUrl);

    private string HeroBackgroundImageUrl => string.IsNullOrWhiteSpace(competition?.CardBackgroundImageUrl)
        ? DefaultCardBackgroundImageUrl
        : competition.CardBackgroundImageUrl;

    private string HeroBackgroundPosition => NormalizeBackgroundPosition(competition?.CardBackgroundPosition);

    private string HeroMediaStyle =>
        $"--competition-overview-bg-image: url('{HeroBackgroundImageUrl}'); --competition-overview-bg-position: {HeroBackgroundPosition};";

    private IReadOnlyList<AppBreadcrumbItem> Breadcrumbs => competition is null
        ? [new AppBreadcrumbItem(Localizer["Nav.Competitions"].Value, "")]
        : [
            new AppBreadcrumbItem(Localizer["Nav.Competitions"].Value, ""),
            new AppBreadcrumbItem(competition.Name)
        ];

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        competition = await CompetitionService.GetCompetitionAsync(Slug);

        if (competition is not null)
        {
            predictionSet = await PredictionService.GetOrCreatePredictionSetAsync(competition);
        }

        isLoading = false;
    }

    private int GetTotalPicks(PredictionGroup group)
    {
        return group.Questions.Sum(question => question.Constraints.ExactSelections ?? question.Constraints.MaxSelections ?? 1);
    }

    private string FormatDate(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("d MMM yyyy HH:mm") ?? Localizer["Common.Tbd"];
    }

    private static string NormalizeBackgroundPosition(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "center";
        }

        if (value.IndexOfAny(DisallowedInlineStyleChars) >= 0)
        {
            return "center";
        }

        return value.Trim();
    }
}
