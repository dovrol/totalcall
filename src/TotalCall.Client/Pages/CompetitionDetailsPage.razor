@page "/competitions/{Slug}"
@inject CompetitionService CompetitionService
@inject IStringLocalizer<SharedResource> Localizer
@inject PredictionTextService Text
@inject PredictionService PredictionService

<PageTitle>@(competition?.Name ?? Localizer["Competition.Section"])</PageTitle>

@if (isLoading)
{
    <AppLoadingState Message="@Localizer["Competition.Loading"]" />
}
else if (competition is null)
{
    <AppErrorState
        Title="@Localizer["Competition.NotFoundTitle"]"
        Description="@Localizer["Competition.NotFoundDescription"]" />
}
else
{
    <AppBreadcrumbs Items="Breadcrumbs" />

    <CompetitionPageNav Competition="competition" Active="Overview" />

    <section class="competition-hero-layout">
        <AppCard Padding="Lg" AdditionalClass="@HeroCardClass">
            <div class="competition-hero-card__backdrop" aria-hidden="true"></div>
            <div class="competition-hero-card__content">
                <CompetitionStatusBadge Status="competition.Status" />
                <h1 class="competition-hero-card__title">@competition.Name</h1>
                <p class="competition-hero-card__description">@Text.CompetitionDescription(competition)</p>

                <dl class="competition-hero-card__meta">
                    <div>
                        <dt>
                            <span class="competition-hero-card__meta-label">
                                <AppIcon Name="AppIconName.Users" Size="16" />
                                <span>@Localizer["Competition.Federation"]</span>
                            </span>
                        </dt>
                        <dd>@(competition.Federation ?? Localizer["Common.Tbd"])</dd>
                    </div>
                    <div>
                        <dt>
                            <span class="competition-hero-card__meta-label">
                                <AppIcon Name="AppIconName.Calendar" Size="16" />
                                <span>@Localizer["Common.Starts"]</span>
                            </span>
                        </dt>
                        <dd>@FormatDate(competition.StartDate)</dd>
                    </div>
                    <div>
                        <dt>
                            <span class="competition-hero-card__meta-label">
                                <AppIcon Name="AppIconName.Lock" Size="16" />
                                <span>@Localizer["Common.Locks"]</span>
                            </span>
                        </dt>
                        <dd>@FormatDate(competition.PredictionLockAt)</dd>
                    </div>
                </dl>

                <div class="competition-hero-card__actions">
                    <AppButton Href="@($"competitions/{competition.Slug}/predictions")">
                        @Localizer["Competition.MakePredictions"]
                    </AppButton>
                    <AppButton Href="@($"competitions/{competition.Slug}/review")" Variant="Secondary">
                        @Localizer["Competition.ReviewSaved"]
                    </AppButton>
                </div>
            </div>
        </AppCard>

        <AppCard Padding="Md" AdditionalClass="competition-side-panel">
            <div class="competition-side-panel__item">
                <AppIcon Name="AppIconName.Lock" Size="16" Class="competition-side-panel__icon" />
                <p>@Localizer["Common.Locks"]</p>
                <strong>@FormatDate(competition.PredictionLockAt)</strong>
            </div>
            <div class="competition-side-panel__item">
                <AppIcon Name="AppIconName.Users" Size="16" Class="competition-side-panel__icon" />
                <p>@Localizer["Competition.Categories"]</p>
                <strong>@competition.Categories.Count</strong>
            </div>
            <div class="competition-side-panel__item">
                <AppIcon Name="AppIconName.Check" Size="16" Class="competition-side-panel__icon" />
                <p>@Localizer["Predictions.SavedAnswers"]</p>
                <strong>@SavedAnswersCount</strong>
            </div>
        </AppCard>
    </section>

    <AppSection Surface="true" Title="@Localizer["Competition.PredictionGroups"]" Description="@Localizer["Competition.ModulesHint"]">
        <div class="competition-module-grid">
            @foreach (var group in competition.PredictionGroups.OrderBy(group => group.Order))
            {
                <article class="competition-module-card">
                    <h3>@Text.GroupTitle(competition, group)</h3>
                    @if (!string.IsNullOrWhiteSpace(Text.GroupDescription(competition, group)))
                    {
                        <p>@Text.GroupDescription(competition, group)</p>
                    }
                    <span class="competition-module-card__meta">
                        <AppIcon Name="AppIconName.Target" Size="16" />
                        <span>@Localizer["Competition.QuestionsCount", group.Questions.Count]</span>
                    </span>
                </article>
            }
        </div>
    </AppSection>

    <AppSection
        Surface="true"
        Title="@Localizer["Competition.FeaturedAthletes"]"
        Description="@Localizer["Competition.FeaturedAthletesHint"]">
        <div class="featured-athletes-grid">
            @foreach (var athlete in FeaturedAthletes)
            {
                <article class="featured-athlete-card">
                    <div class="featured-athlete-card__avatar" aria-hidden="true">@GetInitials(athlete.DisplayName)</div>
                    <h3>@athlete.DisplayName</h3>
                    <p>@GetAthleteCategory(athlete.Id)</p>
                </article>
            }
        </div>
    </AppSection>

    <div class="competition-detail-actions">
        <AppButton Href="@($"competitions/{competition.Slug}/predictions")">@Localizer["Competition.MakePredictions"]</AppButton>
        <AppButton Href="@($"competitions/{competition.Slug}/review")" Variant="Secondary">@Localizer["Competition.ReviewSaved"]</AppButton>
        <AppButton Href="" Variant="Ghost">@Localizer["Common.BackToCompetitions"]</AppButton>
    </div>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private Competition? competition;
    private PredictionSet? predictionSet;
    private bool isLoading = true;
    private int SavedAnswersCount => predictionSet?.Answers.Count ?? 0;

    private string HeroCardClass => string.Join(
        " ",
        "competition-hero-card",
        competition?.Slug switch
        {
            "worlds-2026" => "competition-hero-card--worlds",
            "sheffield-2026" => "competition-hero-card--sheffield",
            _ => "competition-hero-card--default"
        });

    private IReadOnlyList<Athlete> FeaturedAthletes => competition?
        .Athletes
        .Take(6)
        .ToArray() ?? [];

    private IReadOnlyList<AppBreadcrumbItem> Breadcrumbs => competition is null
        ? [new AppBreadcrumbItem(Localizer["Nav.Competitions"].Value, "")]
        : [
            new AppBreadcrumbItem(Localizer["Nav.Competitions"].Value, ""),
            new AppBreadcrumbItem(competition.Name)
        ];

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        competition = await CompetitionService.GetCompetitionAsync(Slug);

        if (competition is not null)
        {
            predictionSet = await PredictionService.GetOrCreatePredictionSetAsync(competition);
        }

        isLoading = false;
    }

    private string FormatDate(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("d MMM yyyy HH:mm") ?? Localizer["Common.Tbd"];
    }

    private string GetAthleteCategory(string athleteId)
    {
        var category = competition?
            .Categories
            .FirstOrDefault(item => item.AthleteIds.Contains(athleteId));

        return category?.Name ?? Localizer["Common.Tbd"];
    }

    private static string GetInitials(string name)
    {
        var parts = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .ToArray();

        if (parts.Length == 0)
        {
            return "TC";
        }

        if (parts.Length == 1)
        {
            return parts[0][0].ToString().ToUpperInvariant();
        }

        return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}";
    }
}
