@page "/competitions/{Slug}/predictions"
@inject CompetitionService CompetitionService
@inject PredictionService PredictionService
@inject PredictionValidationService PredictionValidationService
@inject IStringLocalizer<SharedResource> Localizer
@inject PredictionTextService Text
@inject NavigationManager Navigation

<PageTitle>@(competition is null ? Localizer["Predictions.PageTitle"] : $"{competition.Name} - {Localizer["Predictions.PageTitle"]}")</PageTitle>

@if (isLoading)
{
    <AppLoadingState Message="@Localizer["Predictions.Loading"]" />
}
else if (competition is null || predictionSet is null)
{
    <AppErrorState
        Title="@Localizer["Predictions.NotFoundTitle"]"
        Description="@Localizer["Predictions.NotFoundDescription"]" />
}
else
{
    <section class="prediction-header">
        <div class="prediction-header__main">
            <AppBreadcrumbs Items="@Breadcrumbs" />
            <h1>@competition.Name</h1>
            <p>@Localizer["Predictions.Description"]</p>
        </div>

        <AppCard Padding="Sm" AdditionalClass="prediction-header__status">
            <p>
                <AppIcon Name="AppIconName.Lock" Size="16" />
                <span>@Localizer["Common.Locks"]</span>
            </p>
            <strong>@FormatDate(competition.PredictionLockAt)</strong>
            <span>@Localizer["Predictions.SavedLocally"]</span>
        </AppCard>
    </section>

    <CompetitionPageNav Competition="competition" Active="Predictions" />

    @if (!canEditPredictions)
    {
        <div class="notice notice--warning">
            @Localizer["Predictions.Locked"]
        </div>
    }

    @if (ActiveStep is not null)
    {
        <ol class="prediction-step-strip prediction-step-strip--wizard">
            @foreach (var step in WizardSteps)
            {
                <li class="prediction-step-strip__item">
                    <button
                        type="button"
                        class="@GetStepButtonClass(step)"
                        @onclick="() => SelectStep(step.Question.Id)">
                        <span class="prediction-step-strip__number">@GetStepNumber(step)</span>
                        <div>
                            <strong>@GetStepTitle(step)</strong>
                            <small>@GetStepState(step)</small>
                        </div>
                    </button>
                </li>
            }
        </ol>

        <div class="prediction-wizard-layout">
            <section class="prediction-group prediction-wizard-panel">
                <div class="prediction-group__header">
                    <p class="prediction-group__mode">@Localizer["Predictions.Progress"] @((ActiveStepIndex + 1).ToString()) / @WizardSteps.Count</p>
                    <h2>@GetStepTitle(ActiveStep)</h2>
                    @if (!string.IsNullOrWhiteSpace(Text.QuestionDescription(competition, ActiveStep.Question)))
                    {
                        <p>@Text.QuestionDescription(competition, ActiveStep.Question)</p>
                    }
                </div>

                <div class="prediction-group__questions">
                    <PredictionQuestionRenderer
                        Competition="competition"
                        GroupId="@ActiveStep.GroupId"
                        Question="ActiveStep.Question"
                        Answer="GetAnswer(ActiveStep.Question.Id)"
                        ValidationErrors="GetErrors(ActiveStep.Question.Id)"
                        AnswerChanged="OnAnswerChanged" />
                </div>

                <div class="prediction-wizard-panel__actions">
                    <AppButton Variant="Secondary" OnClick="GoPrevious" Disabled="@(!HasPrevious)">
                        @Localizer["Common.Back"]
                    </AppButton>
                    <AppButton OnClick="GoNextOrReview" Disabled="@(!canEditPredictions)">
                        @(HasNext ? Localizer["Common.Continue"] : Localizer["Predictions.ReviewPicks"])
                    </AppButton>
                </div>
            </section>

            <aside class="prediction-sidebar prediction-wizard-preview">
                <h2>@Localizer["Predictions.SavedAnswers"]</h2>
                <ol class="prediction-wizard-preview__list">
                    @foreach (var slot in Enumerable.Range(1, GetPositionsCount(ActiveStep.Question)))
                    {
                        var athlete = GetSelectedAthlete(ActiveStep.Question.Id, slot);

                        <li class="prediction-wizard-preview__item">
                            <span class="prediction-wizard-preview__rank">@slot</span>
                            <div class="prediction-wizard-preview__content">
                                @if (athlete is null)
                                {
                                    <strong>@Localizer["Common.NotAnswered"]</strong>
                                }
                                else
                                {
                                    <strong>@athlete.DisplayName</strong>
                                    @if (!string.IsNullOrWhiteSpace(athlete.CountryName))
                                    {
                                        <small>@athlete.CountryName</small>
                                    }
                                }
                            </div>
                        </li>
                    }
                </ol>

                <dl class="meta-list">
                    <div>
                        <dt>
                            <AppIcon Name="AppIconName.Check" Size="16" />
                            <span>@Localizer["Predictions.SavedAnswers"]</span>
                        </dt>
                        <dd>@AnsweredQuestions / @TotalQuestions</dd>
                    </div>
                    <div>
                        <dt>
                            <AppIcon Name="AppIconName.AlertCircle" Size="16" />
                            <span>@Localizer["Predictions.ValidationIssues"]</span>
                        </dt>
                        <dd>@validationResult.Errors.Count</dd>
                    </div>
                    <div>
                        <dt>
                            <AppIcon Name="AppIconName.Clock" Size="16" />
                            <span>@Localizer["Predictions.LastSaved"]</span>
                        </dt>
                        <dd>@FormatDate(predictionSet.SavedAt)</dd>
                    </div>
                </dl>

                <p class="local-note">@Localizer["Predictions.LocalNotice"]</p>

                @if (!string.IsNullOrWhiteSpace(saveStatus))
                {
                    <p class="save-status">@saveStatus</p>
                }
            </aside>
        </div>
    }
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private Competition? competition;
    private PredictionSet? predictionSet;
    private PredictionValidationResult validationResult = new([]);
    private bool isLoading = true;
    private bool canEditPredictions;
    private string? saveStatus;
    private string? activeQuestionId;

    private IReadOnlyList<PredictionWizardStep> WizardSteps => competition?
        .PredictionGroups
        .OrderBy(group => group.Order)
        .SelectMany(group => group.Questions
            .OrderBy(question => question.Order)
            .Select(question => new PredictionWizardStep(group.Id, question)))
        .ToArray() ?? [];

    private PredictionWizardStep? ActiveStep => WizardSteps
        .FirstOrDefault(step => step.Question.Id == activeQuestionId) ??
        WizardSteps.FirstOrDefault();

    private int ActiveStepIndex
    {
        get
        {
            if (ActiveStep is null)
            {
                return -1;
            }

            for (var index = 0; index < WizardSteps.Count; index++)
            {
                if (WizardSteps[index].Question.Id == ActiveStep.Question.Id)
                {
                    return index;
                }
            }

            return -1;
        }
    }

    private bool HasPrevious => ActiveStepIndex > 0;

    private bool HasNext => ActiveStepIndex >= 0 && ActiveStepIndex < WizardSteps.Count - 1;

    private IReadOnlyList<AppBreadcrumbItem> Breadcrumbs => competition is null
        ? [new AppBreadcrumbItem(Localizer["Nav.Competitions"].Value, "")]
        : [
            new AppBreadcrumbItem(Localizer["Nav.Competitions"].Value, ""),
            new AppBreadcrumbItem(competition.Name, $"competitions/{competition.Slug}"),
            new AppBreadcrumbItem(Localizer["Predictions.PageTitle"].Value)
        ];

    private int TotalQuestions => competition?.PredictionGroups.Sum(group => group.Questions.Count) ?? 0;

    private int AnsweredQuestions => predictionSet?.Answers.Count ?? 0;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        competition = await CompetitionService.GetCompetitionAsync(Slug);

        if (competition is not null)
        {
            predictionSet = await PredictionService.GetOrCreatePredictionSetAsync(competition);
            validationResult = PredictionValidationService.Validate(competition, predictionSet);
            canEditPredictions = CompetitionService.CanEditPredictions(competition);

            var firstStep = WizardSteps.FirstOrDefault();
            if (firstStep is not null && WizardSteps.All(step => step.Question.Id != activeQuestionId))
            {
                activeQuestionId = firstStep.Question.Id;
            }
        }

        isLoading = false;
    }

    private async Task OnAnswerChanged(PredictionAnswer answer)
    {
        if (competition is null || predictionSet is null || !canEditPredictions)
        {
            return;
        }

        predictionSet = PredictionService.UpdateAnswer(predictionSet, answer);
        validationResult = PredictionValidationService.Validate(competition, predictionSet);

        await SaveAsync();
    }

    private async Task SaveAsync()
    {
        if (predictionSet is null || !canEditPredictions)
        {
            return;
        }

        saveStatus = null;

        await PredictionService.SaveAsync(predictionSet);

        saveStatus = validationResult.IsValid
            ? Localizer["Predictions.SavedLocally"]
            : Localizer["Predictions.DraftSaved"];
    }

    private string FormatDate(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("d MMM yyyy HH:mm:ss") ?? Localizer["Common.Tbd"];
    }

    private void SelectStep(string questionId)
    {
        if (WizardSteps.Any(step => step.Question.Id == questionId))
        {
            activeQuestionId = questionId;
        }
    }

    private void GoPrevious()
    {
        if (!HasPrevious)
        {
            return;
        }

        activeQuestionId = WizardSteps[ActiveStepIndex - 1].Question.Id;
    }

    private void GoNextOrReview()
    {
        if (HasNext)
        {
            activeQuestionId = WizardSteps[ActiveStepIndex + 1].Question.Id;
            return;
        }

        if (competition is not null)
        {
            Navigation.NavigateTo($"competitions/{competition.Slug}/review");
        }
    }

    private PredictionAnswer? GetAnswer(string questionId)
    {
        return predictionSet?.Answers.FirstOrDefault(answer => answer.QuestionId == questionId);
    }

    private IReadOnlyList<PredictionValidationError> GetErrors(string questionId)
    {
        return validationResult.Errors
            .Where(error => error.QuestionId == questionId)
            .ToArray();
    }

    private int GetStepNumber(PredictionWizardStep step)
    {
        for (var index = 0; index < WizardSteps.Count; index++)
        {
            if (WizardSteps[index].Question.Id == step.Question.Id)
            {
                return index + 1;
            }
        }

        return 0;
    }

    private string GetStepTitle(PredictionWizardStep step)
    {
        var category = competition?.Categories.FirstOrDefault(item => item.Id == step.Question.CategoryId);

        return category?.Name ?? Text.QuestionTitle(competition!, step.Question);
    }

    private string GetStepState(PredictionWizardStep step)
    {
        return IsStepAnswered(step)
            ? Localizer["Predictions.Answered"]
            : Localizer["Predictions.NotAnswered"];
    }

    private bool IsStepAnswered(PredictionWizardStep step)
    {
        var answer = GetAnswer(step.Question.Id);
        if (answer is null)
        {
            return false;
        }

        var slots = GetPositionsCount(step.Question);
        var selected = answer.Value.AthletePlacements.Count(placement => !string.IsNullOrWhiteSpace(placement.AthleteId));

        return selected >= slots;
    }

    private string GetStepButtonClass(PredictionWizardStep step)
    {
        var isActive = ActiveStep?.Question.Id == step.Question.Id;

        return string.Join(
            " ",
            "prediction-step-strip__button",
            isActive ? "prediction-step-strip__button--active" : null);
    }

    private int GetPositionsCount(PredictionQuestion question)
    {
        return question.Constraints.ExactSelections ??
            question.Constraints.MaxSelections ??
            5;
    }

    private Athlete? GetSelectedAthlete(string questionId, int position)
    {
        var answer = GetAnswer(questionId);
        var athleteId = answer?.Value.AthletePlacements
            .FirstOrDefault(placement => placement.Position == position)?
            .AthleteId;

        if (string.IsNullOrWhiteSpace(athleteId))
        {
            return null;
        }

        return competition?.Athletes.FirstOrDefault(athlete => athlete.Id == athleteId);
    }

    private sealed record PredictionWizardStep(string GroupId, PredictionQuestion Question);
}
