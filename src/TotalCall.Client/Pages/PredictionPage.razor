@page "/competitions/{Slug}/predictions"
@inject CompetitionService CompetitionService
@inject PredictionService PredictionService
@inject PredictionValidationService PredictionValidationService
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@(competition is null ? Localizer["Predictions.PageTitle"] : $"{competition.Name} - {Localizer["Predictions.PageTitle"]}")</PageTitle>

@if (isLoading)
{
    <p class="muted">@Localizer["Predictions.Loading"]</p>
}
else if (competition is null || predictionSet is null)
{
    <div class="page-header">
        <h1>@Localizer["Predictions.NotFoundTitle"]</h1>
        <p>@Localizer["Predictions.NotFoundDescription"]</p>
    </div>
}
else
{
    <div class="meet-header">
        <div>
            <p class="eyebrow">@competition.Name</p>
            <h1>@Localizer["Predictions.PageTitle"]</h1>
            <p>@Localizer["Predictions.Description"]</p>
        </div>
        <div class="completion-card">
            <span>@CompletionPercent%</span>
            <small>@Localizer["Predictions.Progress"]</small>
            <div class="progress-track">
                <span style="@($"width: {CompletionPercent}%")"></span>
            </div>
        </div>
    </div>

    @if (!canEditPredictions)
    {
        <div class="notice notice--warning">
            @Localizer["Predictions.Locked"]
        </div>
    }

    <div class="prediction-layout">
        <div class="prediction-layout__main">
            @foreach (var group in competition.PredictionGroups.OrderBy(group => group.Order))
            {
                <PredictionGroupRenderer
                    Competition="competition"
                    Group="group"
                    Answers="predictionSet.Answers"
                    ValidationErrors="validationResult.Errors"
                    AnswerChanged="OnAnswerChanged" />
            }
        </div>

        <aside class="prediction-sidebar">
            <h2>@Localizer["Predictions.Progress"]</h2>
            <dl class="meta-list">
                <div>
                    <dt>@Localizer["Predictions.SavedAnswers"]</dt>
                    <dd>@AnsweredQuestions / @TotalQuestions</dd>
                </div>
                <div>
                    <dt>@Localizer["Predictions.ValidationIssues"]</dt>
                    <dd>@validationResult.Errors.Count</dd>
                </div>
                <div>
                    <dt>@Localizer["Predictions.LastSaved"]</dt>
                    <dd>@FormatDate(predictionSet.SavedAt)</dd>
                </div>
            </dl>

            <p class="local-note">@Localizer["Predictions.LocalNotice"]</p>

            <button type="button" class="primary-button" @onclick="SaveAsync" disabled="@isSaving">
                @(isSaving ? Localizer["Predictions.Saving"] : Localizer["Predictions.SaveNow"])
            </button>
            <a class="secondary-link sidebar-link" href="@($"competitions/{competition.Slug}/review")">@Localizer["Predictions.ReviewPicks"]</a>

            @if (!string.IsNullOrWhiteSpace(saveStatus))
            {
                <p class="save-status">@saveStatus</p>
            }
        </aside>
    </div>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private Competition? competition;
    private PredictionSet? predictionSet;
    private PredictionValidationResult validationResult = new([]);
    private bool isLoading = true;
    private bool isSaving;
    private bool canEditPredictions;
    private string? saveStatus;

    private int TotalQuestions => competition?.PredictionGroups.Sum(group => group.Questions.Count) ?? 0;

    private int AnsweredQuestions => predictionSet?.Answers.Count ?? 0;

    private int CompletionPercent => TotalQuestions == 0
        ? 0
        : Math.Min(100, (int)Math.Round(AnsweredQuestions / (double)TotalQuestions * 100));

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        competition = await CompetitionService.GetCompetitionAsync(Slug);

        if (competition is not null)
        {
            predictionSet = await PredictionService.GetOrCreatePredictionSetAsync(competition);
            validationResult = PredictionValidationService.Validate(competition, predictionSet);
            canEditPredictions = CompetitionService.CanEditPredictions(competition);
        }

        isLoading = false;
    }

    private async Task OnAnswerChanged(PredictionAnswer answer)
    {
        if (competition is null || predictionSet is null || !canEditPredictions)
        {
            return;
        }

        predictionSet = PredictionService.UpdateAnswer(predictionSet, answer);
        validationResult = PredictionValidationService.Validate(competition, predictionSet);

        await SaveAsync();
    }

    private async Task SaveAsync()
    {
        if (predictionSet is null || !canEditPredictions)
        {
            return;
        }

        isSaving = true;
        saveStatus = null;

        await PredictionService.SaveAsync(predictionSet);

        isSaving = false;
        saveStatus = validationResult.IsValid
            ? Localizer["Predictions.SavedLocally"]
            : Localizer["Predictions.DraftSaved"];
    }

    private static string FormatDate(DateTimeOffset value)
    {
        return value.ToLocalTime().ToString("d MMM yyyy HH:mm:ss");
    }
}
