@page "/competitions/{Slug}/review"
@inject CompetitionService CompetitionService
@inject PredictionService PredictionService
@inject IPredictionValidationService PredictionValidationService
@inject PredictionAnswerDisplayService AnswerDisplayService
@inject IStringLocalizer<SharedResource> Localizer
@inject PredictionTextService Text

<PageTitle>@(competition is null ? Localizer["Review.PageTitle"] : $"{competition.Name} - {Localizer["Review.PageTitle"]}")</PageTitle>

@if (isLoading)
{
    <AppLoadingState Message="@Localizer["Review.Loading"]" />
}
else if (competition is null || predictionSet is null)
{
    <AppErrorState
        Title="@Localizer["Review.NotFoundTitle"]"
        Description="@Localizer["Review.NotFoundDescription"]" />
}
else
{
    <AppPageHeader
        Breadcrumbs="@Breadcrumbs"
        Eyebrow="@Localizer["Review.PageTitle"]"
        Title="@competition.Name"
        Description="@Localizer["Review.Description"]">
        <Aside>
            <AppStatCard Label="@Localizer["Predictions.SavedAnswers"]" Value="@predictionSet.Answers.Count.ToString()" />
        </Aside>
    </AppPageHeader>

    <CompetitionPageNav Competition="competition" Active="Review" />

    @if (predictionSet.Answers.Count == 0)
    {
        <AppEmptyState
            Title="@Localizer["Review.EmptyTitle"]"
            Description="@Localizer["Review.EmptyDescription"]" />
    }
    else
    {
        @if (!validationResult.IsValid)
        {
            <div class="notice notice--warning">
                @Localizer["Review.ValidationIssues", validationResult.Errors.Count]
            </div>
        }

        <div class="review-list">
            @foreach (var group in competition.PredictionGroups.OrderBy(group => group.Order))
            {
                <AppSection Surface="true">
                    @if (!string.IsNullOrWhiteSpace(group.Mode))
                    {
                        <p class="prediction-group__mode">@group.Mode</p>
                    }
                    <h2>@Text.GroupTitle(competition, group)</h2>

                    <div class="answer-list">
                        @foreach (var question in group.Questions.OrderBy(question => question.Order))
                        {
                            var answer = GetAnswer(question.Id);

                            <article class="answer-row">
                                <div>
                                    <h3>@Text.QuestionTitle(competition, question)</h3>
                                    <p>@AnswerDisplayService.FormatAnswer(competition, question, answer)</p>
                                </div>
                                @if (HasValidationErrors(question.Id))
                                {
                                    <QuestionValidationMessage Errors="GetValidationErrors(question.Id)" />
                                }
                            </article>
                        }
                    </div>
                </AppSection>
            }
        </div>
    }

    <div class="review-actions">
        <AppButton Href="@($"competitions/{competition.Slug}/predictions")">@Localizer["Review.EditPredictions"]</AppButton>
        <AppButton Href="@($"competitions/{competition.Slug}")" Variant="Secondary">@Localizer["Common.BackToCompetition"]</AppButton>
    </div>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private Competition? competition;
    private PredictionSet? predictionSet;
    private PredictionValidationResult validationResult = new([]);
    private bool isLoading = true;

    private IReadOnlyList<AppBreadcrumbItem> Breadcrumbs => competition is null
        ? [new AppBreadcrumbItem(Localizer["Nav.Competitions"].Value, "")]
        : [
            new AppBreadcrumbItem(Localizer["Nav.Competitions"].Value, ""),
            new AppBreadcrumbItem(competition.Name, $"competitions/{competition.Slug}"),
            new AppBreadcrumbItem(Localizer["Review.PageTitle"].Value)
        ];

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        competition = await CompetitionService.GetCompetitionAsync(Slug);

        if (competition is not null)
        {
            predictionSet = await PredictionService.GetOrCreatePredictionSetAsync(competition);
            validationResult = PredictionValidationService.Validate(competition, predictionSet);
        }

        isLoading = false;
    }

    private PredictionAnswer? GetAnswer(string questionId)
    {
        return predictionSet?.Answers.FirstOrDefault(answer => answer.QuestionId == questionId);
    }

    private bool HasValidationErrors(string questionId)
    {
        return GetValidationErrors(questionId).Count > 0;
    }

    private IReadOnlyList<PredictionValidationError> GetValidationErrors(string questionId)
    {
        return validationResult.Errors
            .Where(error => error.QuestionId == questionId)
            .ToArray();
    }
}
