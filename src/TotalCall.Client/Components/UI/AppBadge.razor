<span class="@CssClass">
    @ChildContent
</span>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string Variant { get; set; } = "Neutral";

    [Parameter]
    public string? AdditionalClass { get; set; }

    private string CssClass => string.Join(
        " ",
        "app-badge",
        GetVariantClass(),
        AdditionalClass);

    private string GetVariantClass()
    {
        return Variant switch
        {
            "Success" => "app-badge--success",
            "Warning" => "app-badge--warning",
            "Danger" => "app-badge--danger",
            "Accent" => "app-badge--accent",
            _ => "app-badge--neutral"
        };
    }
}
