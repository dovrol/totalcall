        case AppIconName.Sparkles:
            <path d="M12 3l1.8 4.2L18 9l-4.2 1.8L12 15l-1.8-4.2L6 9l4.2-1.8z" />
            <path d="M5 3v3" />
            <path d="M3.5 4.5h3" />
            <path d="M19 16v5" />
            <path d="M16.5 18.5h5" />
            break;
        case AppIconName.ArrowUpDown:
            <path d="M12 5v14" />
            <path d="m7 10 5-5 5 5" />
            <path d="m17 14-5 5-5-5" />
            break;
        case AppIconName.PencilLine:
            <path d="M12 20h9" />
            <path d="m16.5 3.5 4 4L8 20l-5 1 1-5z" />
            break;
        case AppIconName.Calculator:
            <rect x="4" y="2" width="16" height="20" rx="2" />
            <line x1="8" y1="6" x2="16" y2="6" />
            <line x1="8" y1="11" x2="8" y2="11" />
            <line x1="12" y1="11" x2="12" y2="11" />
            <line x1="16" y1="11" x2="16" y2="11" />
            <line x1="8" y1="15" x2="8" y2="15" />
            <line x1="12" y1="15" x2="12" y2="15" />
            <line x1="16" y1="15" x2="16" y2="15" />
            <line x1="8" y1="19" x2="8" y2="19" />
            <line x1="12" y1="19" x2="12" y2="19" />
            <line x1="16" y1="19" x2="16" y2="19" />
            break;
        case AppIconName.ExternalLink:
            <path d="M15 3h6v6" />
            <path d="M10 14 21 3" />
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
            break;
        default:
            <circle cx="12" cy="12" r="10" />
            break;
    }
</svg>

@code {
    [Parameter, EditorRequired]
    public AppIconName Name { get; set; }

    [Parameter]
    public int Size { get; set; } = 20;

    [Parameter]
    public int StrokeWidth { get; set; } = 2;

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public bool Decorative { get; set; } = true;

    [Parameter]
    public string? AriaLabel { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => string.IsNullOrWhiteSpace(Class)
        ? "app-icon"
        : $"app-icon {Class}";

    private string AriaHidden => Decorative ? "true" : "false";

    private string? Role => Decorative ? null : "img";

    private string? ComputedAriaLabel => Decorative
        ? null
        : string.IsNullOrWhiteSpace(AriaLabel)
            ? Name.ToString()
            : AriaLabel;
}
