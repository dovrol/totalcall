        case AppIconName.BarChart:
            <path d="M3 3v16a2 2 0 0 0 2 2h16" />
            <path d="M7 16h8" />
            <path d="M7 11h12" />
            <path d="M7 6h3" />
            break;
        case AppIconName.Check:
            <path d="M20 6 9 17l-5-5" />
            break;
        case AppIconName.X:
            <path d="M18 6 6 18" />
            <path d="m6 6 12 12" />
