<AppCard AdditionalClass="text-center">
    <div class="mx-auto flex max-w-md flex-col items-center gap-3 py-4">
        <div class="flex size-11 items-center justify-center rounded-full bg-brand-surface-muted text-brand-accent" aria-hidden="true">
            <span class="text-lg font-semibold">TC</span>
        </div>
        <div class="space-y-1">
            <h2 class="text-lg font-semibold text-brand-ink">@Title</h2>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p class="text-sm leading-6 text-brand-muted">@Description</p>
            }
        </div>
        @if (Action is not null)
        {
            <div class="pt-1">
                @Action
            </div>
        }
    </div>
</AppCard>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public RenderFragment? Action { get; set; }
}
