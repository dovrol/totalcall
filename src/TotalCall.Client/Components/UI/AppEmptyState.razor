<AppCard AdditionalClass="app-empty-state-card">
    <div class="app-empty-state">
        <div class="app-empty-state__mark" aria-hidden="true">
            <span>TC</span>
        </div>
        <div class="app-empty-state__content">
            <h2 class="app-empty-state__title">@Title</h2>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p class="app-empty-state__description">@Description</p>
            }
        </div>
        @if (Action is not null)
        {
            <div class="app-empty-state__action">
                @Action
            </div>
        }
    </div>
</AppCard>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public RenderFragment? Action { get; set; }
}
