<AppCard Padding="Sm" AdditionalClass="@AdditionalClass">
    <div class="app-stat-card">
        <div class="app-stat-card__head">
            @if (Icon is not null)
            {
                <span class="app-stat-card__icon-wrap">
                    <AppIcon Name="@Icon.Value" Size="20" Class="app-stat-card__icon" />
                </span>
            }
            <div class="app-stat-card__main">
                <p class="app-stat-card__value">@Value</p>
                <p class="app-stat-card__label">@Label</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <p class="app-stat-card__description">@Description</p>
        }
    </div>
</AppCard>

@code {
    [Parameter, EditorRequired]
    public string Label { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public AppIconName? Icon { get; set; }

    [Parameter]
    public string? AdditionalClass { get; set; }
}
