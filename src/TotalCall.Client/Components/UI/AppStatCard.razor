<AppCard Padding="Sm" AdditionalClass="@AdditionalClass">
    <div class="space-y-1">
        <p class="text-xs font-medium text-brand-muted">@Label</p>
        <p class="text-2xl font-semibold text-brand-ink">@Value</p>
        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <p class="text-xs text-brand-muted">@Description</p>
        }
    </div>
</AppCard>

@code {
    [Parameter, EditorRequired]
    public string Label { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public string? AdditionalClass { get; set; }
}
