<section id="@Id" class="@CssClass">
    @if (!string.IsNullOrWhiteSpace(Title) || !string.IsNullOrWhiteSpace(Description) || Actions is not null)
    {
        <div class="mb-4 grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-end">
            <div class="space-y-1">
                @if (!string.IsNullOrWhiteSpace(Eyebrow))
                {
                    <p class="text-sm font-semibold text-brand-accent">@Eyebrow</p>
                }
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <h2 class="text-xl font-semibold text-brand-ink">@Title</h2>
                }
                @if (!string.IsNullOrWhiteSpace(Description))
                {
                    <p class="max-w-2xl text-sm leading-6 text-brand-muted">@Description</p>
                }
            </div>
            @if (Actions is not null)
            {
                <div class="flex flex-wrap gap-2">
                    @Actions
                </div>
            }
        </div>
    }

    @ChildContent
</section>

@code {
    [Parameter]
    public string? Eyebrow { get; set; }

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool Surface { get; set; }

    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public string? AdditionalClass { get; set; }

    private string CssClass => string.Join(
        " ",
        Surface ? "rounded-lg border border-brand-border bg-brand-surface p-5 shadow-card" : "space-y-4",
        AdditionalClass);
}
