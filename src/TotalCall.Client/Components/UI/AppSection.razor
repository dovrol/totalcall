<section id="@Id" class="@CssClass">
    @if (!string.IsNullOrWhiteSpace(Title) || !string.IsNullOrWhiteSpace(Description) || Actions is not null)
    {
        <div class="app-section__header">
            <div class="app-section__intro">
                @if (!string.IsNullOrWhiteSpace(Eyebrow))
                {
                    <p class="app-section__eyebrow">@Eyebrow</p>
                }
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <h2 class="app-section__title">@Title</h2>
                }
                @if (!string.IsNullOrWhiteSpace(Description))
                {
                    <p class="app-section__description">@Description</p>
                }
            </div>
            @if (Actions is not null)
            {
                <div class="app-section__actions">
                    @Actions
                </div>
            }
        </div>
    }

    @ChildContent
</section>

@code {
    [Parameter]
    public string? Eyebrow { get; set; }

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool Surface { get; set; }

    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public string? AdditionalClass { get; set; }

    private string CssClass => string.Join(
        " ",
        Surface ? "app-section app-section--surface" : "app-section",
        AdditionalClass);
}
