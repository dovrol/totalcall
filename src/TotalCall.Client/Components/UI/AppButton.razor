@if (!string.IsNullOrWhiteSpace(Href))
{
    <a @ref="element" class="@CssClass" href="@Href" aria-label="@AriaLabel" @attributes="AdditionalAttributes">
        @ChildContent
    </a>
}
else
{
    <button @ref="element" class="@CssClass" type="@ButtonType" disabled="@Disabled" aria-label="@AriaLabel" @onclick="OnClick" @attributes="AdditionalAttributes">
        @ChildContent
    </button>
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public string? AriaLabel { get; set; }

    [Parameter]
    public string Variant { get; set; } = "Primary";

    [Parameter]
    public string Size { get; set; } = "Md";

    [Parameter]
    public string ButtonType { get; set; } = "button";

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool FullWidth { get; set; }

    [Parameter]
    public string? AdditionalClass { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    public ElementReference Element => element;

    private ElementReference element;

    private string CssClass => string.Join(
        " ",
        "app-button",
        GetVariantClass(),
        GetSizeClass(),
        FullWidth ? "app-button--full" : null,
        AdditionalClass);

    private string GetVariantClass()
    {
        return Variant switch
        {
            "Secondary" => "app-button--secondary",
            "Ghost" => "app-button--ghost",
            "Subtle" => "app-button--subtle",
            _ => "app-button--primary"
        };
    }

    private string GetSizeClass()
    {
        return Size switch
        {
            "Sm" => "app-button--sm",
            "Lg" => "app-button--lg",
            _ => "app-button--md"
        };
    }
}
