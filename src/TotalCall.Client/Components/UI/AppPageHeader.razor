<header class="app-page-header">
    <div class="app-page-header__main">
        <AppBreadcrumbs Items="Breadcrumbs" />

        @if (!string.IsNullOrWhiteSpace(Eyebrow))
        {
            <p class="app-page-header__eyebrow">@Eyebrow</p>
        }
        <div class="app-page-header__content">
            <h1 class="app-page-header__title">@Title</h1>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p class="app-page-header__description">@Description</p>
            }
        </div>
        @if (Actions is not null)
        {
            <div class="app-page-header__actions">
                @Actions
            </div>
        }
    </div>
    @if (Aside is not null)
    {
        <div class="app-page-header__aside">
            @Aside
        </div>
    }
</header>

@code {
    [Parameter]
    public string? Eyebrow { get; set; }

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public RenderFragment? Aside { get; set; }

    [Parameter]
    public IReadOnlyList<AppBreadcrumbItem> Breadcrumbs { get; set; } = [];
}
