@inject IStringLocalizer<SharedResource> Localizer

<div
    class="@CssClass"
    @ondrop:preventDefault="true"
    @ondragover:preventDefault="true"
    @ondrop="() => DropRequested.InvokeAsync(Position)">
    <span class="ranking-slot__position">@Position</span>

    @if (Athlete is null)
    {
        <div class="ranking-slot__empty">
            <strong>@Localizer["Predictions.DropAthleteHere"]</strong>
            <small>@Localizer["Predictions.DragOrPickHint"]</small>
        </div>
    }
    else
    {
        <div
            class="ranking-slot__athlete"
            draggable="true"
            @ondragstart="() => DragStartRequested.InvokeAsync(Position)">
            <div class="ranking-slot__details">
                <strong>@Athlete.DisplayName</strong>
                @if (!string.IsNullOrWhiteSpace(Athlete.CountryName))
                {
                    <small class="ranking-slot__country">
                        <CountryFlag Code="@Athlete.CountryCode" CountryName="@Athlete.CountryName" />
                        <span>@Athlete.CountryName</span>
                    </small>
                }
            </div>

            <div class="ranking-slot__side">
                @if (Athlete.SeedTotalKg is not null)
                {
                    <span class="ranking-slot__total">@Athlete.SeedTotalKg.Value.ToString("0.#") kg</span>
                }

                <div class="ranking-slot__actions">
                    <button
                        type="button"
                        class="ranking-slot__action ranking-slot__action--icon"
                        @onclick="() => MoveUpRequested.InvokeAsync(Position)"
                        disabled="@(!CanMoveUp)"
                        aria-label="@Localizer["Predictions.MoveUp"]">
                        <AppIcon
                            Name="AppIconName.ChevronRight"
                            Size="13"
                            Class="ranking-slot__action-icon ranking-slot__action-icon--up" />
                    </button>
                    <button
                        type="button"
                        class="ranking-slot__action ranking-slot__action--icon"
                        @onclick="() => MoveDownRequested.InvokeAsync(Position)"
                        disabled="@(!CanMoveDown)"
                        aria-label="@Localizer["Predictions.MoveDown"]">
                        <AppIcon
                            Name="AppIconName.ChevronRight"
                            Size="13"
                            Class="ranking-slot__action-icon ranking-slot__action-icon--down" />
                    </button>
                    <button
                        type="button"
                        class="ranking-slot__action ranking-slot__action--icon"
                        @onclick="() => RemoveRequested.InvokeAsync(Position)"
                        aria-label="@Localizer["Predictions.RemoveAthlete"]">
                        <AppIcon Name="AppIconName.X" Size="14" Class="ranking-slot__action-icon" />
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Position { get; set; }

    [Parameter]
    public Athlete? Athlete { get; set; }

    [Parameter]
    public bool CanMoveUp { get; set; }

    [Parameter]
    public bool CanMoveDown { get; set; }

    [Parameter]
    public EventCallback<int> RemoveRequested { get; set; }

    [Parameter]
    public EventCallback<int> MoveUpRequested { get; set; }

    [Parameter]
    public EventCallback<int> MoveDownRequested { get; set; }

    [Parameter]
    public EventCallback<int> DropRequested { get; set; }

    [Parameter]
    public EventCallback<int> DragStartRequested { get; set; }

    private string CssClass => string.Join(
        " ",
        "ranking-slot",
        Athlete is null ? "ranking-slot--empty" : "ranking-slot--filled");
}
