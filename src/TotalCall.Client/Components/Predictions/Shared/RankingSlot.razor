@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer

<div
    class="@CssClass"
    @onclick="OnSlotClicked"
    @ondrop:preventDefault="true"
    @ondragover:preventDefault="true"
    @ondrop="() => DropRequested.InvokeAsync(Position)">
    <span class="ranking-slot__position">@Position</span>

    @if (Athlete is null)
    {
        <div class="ranking-slot__empty">
            <strong>@EmptySlotCtaLabel</strong>
            <small>@Localizer["Predictions.DragOrPickHint"]</small>
        </div>
    }
    else
    {
        <div
            class="ranking-slot__athlete"
            draggable="true"
            @ondragstart="() => DragStartRequested.InvokeAsync(Position)">
            <div class="@ContextButtonClass">
                <strong>@Athlete.DisplayName</strong>
                @if (!string.IsNullOrWhiteSpace(Athlete.CountryName))
                {
                    <small class="ranking-slot__country">
                        <CountryFlag Code="@Athlete.CountryCode" CountryName="@Athlete.CountryName" />
                        <span>@Athlete.CountryName</span>
                    </small>
                }
            </div>

            <div class="ranking-slot__side">
                @if (Athlete.SeedTotalKg is not null)
                {
                    <span class="ranking-slot__total ranking-slot__total--nominated">
                        <span>@Localizer["Predictions.NominatedShort"]</span>
                        <strong>@FormatKgValue(Athlete.SeedTotalKg)</strong>
                    </span>
                }

                @if (PredictedTotalKg is not null)
                {
                    <span class="ranking-slot__total ranking-slot__total--predicted">
                        <span>@Localizer["Predictions.PredictedShort"]</span>
                        <strong>@FormatKgValue(PredictedTotalKg)</strong>
                    </span>
                }

                <div class="ranking-slot__actions">
                    <button
                        type="button"
                        class="ranking-slot__action ranking-slot__action--edit"
                        @onclick="() => PredictionEditRequested.InvokeAsync(Position)"
                        @onclick:stopPropagation="true"
                        disabled="@(!CanEditPredictions)">
                        <AppIcon Name="AppIconName.PencilLine" Size="14" />
                        @Localizer["Predictions.EditPredictedTotal"]
                    </button>
                    <button
                        type="button"
                        class="ranking-slot__action ranking-slot__action--icon"
                        @onclick="() => MoveUpRequested.InvokeAsync(Position)"
                        @onclick:stopPropagation="true"
                        disabled="@(!CanMoveUp)"
                        aria-label="@Localizer["Predictions.MoveUp"]"
                        title="@Localizer["Predictions.MoveUp"]">
                        <AppIcon
                            Name="AppIconName.ChevronRight"
                            Size="13"
                            Class="ranking-slot__action-icon ranking-slot__action-icon--up" />
                    </button>
                    <button
                        type="button"
                        class="ranking-slot__action ranking-slot__action--icon"
                        @onclick="() => MoveDownRequested.InvokeAsync(Position)"
                        @onclick:stopPropagation="true"
                        disabled="@(!CanMoveDown)"
                        aria-label="@Localizer["Predictions.MoveDown"]"
                        title="@Localizer["Predictions.MoveDown"]">
                        <AppIcon
                            Name="AppIconName.ChevronRight"
                            Size="13"
                            Class="ranking-slot__action-icon ranking-slot__action-icon--down" />
                    </button>
                    <button
                        type="button"
                        class="@RemoveActionClass"
                        @onclick="() => RemoveRequested.InvokeAsync(Position)"
                        @onclick:stopPropagation="true"
                        aria-label="@RemoveAriaLabel"
                        title="@RemoveAriaLabel">
                        <AppIcon Name="AppIconName.Trash2" Size="14" Class="ranking-slot__action-icon" />
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(PredictedLiftSummary))
        {
            <div class="ranking-slot__prediction-summary">
                @PredictedLiftSummary
            </div>
        }

        @if (IsRemovePending)
        {
            <p class="ranking-slot__remove-hint">@Localizer["Predictions.RemoveConfirmHint"]</p>
        }

        @if (IsPredictionEditorOpen)
        {
            <section class="ranking-slot__prediction-editor" @onclick:stopPropagation="true">
                <header class="ranking-slot__prediction-editor-head">
                    <div class="ranking-slot__prediction-editor-title">
                        <strong>@Localizer["Predictions.PredictionEditorTitle"]</strong>
                    </div>

                    @if (PredictionEditorMode == "lifts")
                    {
                        <div class="@PredictionCalculatedTotalClass">
                            <span>
                                <AppIcon Name="AppIconName.Calculator" Size="12" />
                                @Localizer["Predictions.PredictedTotalAuto"]
                            </span>
                            <strong>@AutoTotalDisplay</strong>
                            <small>@Localizer["Predictions.PredictedTotalFormula"]</small>
                        </div>
                    }
                </header>

                <div class="ranking-slot__prediction-mode" role="radiogroup" aria-label="@Localizer["Predictions.PredictionMode"]">
                    <label class="ranking-slot__prediction-mode-option">
                        <input
                            type="radio"
                            name="@($"prediction-mode-{Position}")"
                            value="total"
                            checked="@(PredictionEditorMode == "total")"
                            @onchange="OnTotalModeSelected" />
                        <span>@Localizer["Predictions.PredictionModeTotal"]</span>
                    </label>
                    <label class="ranking-slot__prediction-mode-option">
                        <input
                            type="radio"
                            name="@($"prediction-mode-{Position}")"
                            value="lifts"
                            checked="@(PredictionEditorMode == "lifts")"
                            @onchange="OnLiftsModeSelected" />
                        <span>@Localizer["Predictions.PredictionModeLifts"]</span>
                    </label>
                </div>

                @if (PredictionEditorMode == "lifts")
                {
                    <div class="ranking-slot__prediction-fields ranking-slot__prediction-fields--lifts">
                        <label>
                            <span>SQ</span>
                            <input class="control" type="number" min="0" step="0.5" value="@PredictionSquatInput" @oninput="OnSquatInput" />
                        </label>
                        <label>
                            <span>BP</span>
                            <input class="control" type="number" min="0" step="0.5" value="@PredictionBenchInput" @oninput="OnBenchInput" />
                        </label>
                        <label>
                            <span>DL</span>
                            <input class="control" type="number" min="0" step="0.5" value="@PredictionDeadliftInput" @oninput="OnDeadliftInput" />
                        </label>
                    </div>
                }
                else
                {
                    <div class="ranking-slot__prediction-fields">
                        <label>
                            <span>@Localizer["Predictions.PredictedTotal"]</span>
                            <input class="control" type="number" min="0" step="0.5" value="@PredictionTotalInput" @oninput="OnTotalInput" />
                        </label>
                    </div>
                }

                <p class="ranking-slot__prediction-quick-title">@Localizer["Predictions.QuickFill"]</p>

                <div class="ranking-slot__prediction-quick-actions">
                    @if (Athlete.SeedTotalKg is not null)
                    {
                        <button type="button" class="ranking-slot__prediction-quick-action" @onclick="() => UseNominatedTotalRequested.InvokeAsync()">
                            <AppIcon Name="AppIconName.Target" Size="15" />
                            <span>@Localizer["Predictions.UseNominatedTotal"]</span>
                            <small>@FormatKgValue(Athlete.SeedTotalKg)</small>
                        </button>
                    }
                    @if (PredictionHistory?.LastResult?.TotalKg is not null)
                    {
                        <button type="button" class="ranking-slot__prediction-quick-action" @onclick="() => UseLastResultRequested.InvokeAsync()">
                            <AppIcon Name="AppIconName.Clock" Size="15" />
                            <span>@Localizer["Predictions.UseLastResult"]</span>
                            <small>@FormatLastResultMeta()</small>
                        </button>
                    }
                    @if (PredictionHistory?.Bests?.TotalKg is not null)
                    {
                        <button type="button" class="ranking-slot__prediction-quick-action" @onclick="() => UseBestResultRequested.InvokeAsync()">
                            <AppIcon Name="AppIconName.Trophy" Size="15" />
                            <span>@Localizer["Predictions.UseBestResult"]</span>
                            <small>@FormatKgValue(PredictionHistory.Bests.TotalKg)</small>
                        </button>
                    }
                    <button type="button" class="ranking-slot__prediction-quick-action ranking-slot__prediction-quick-action--ghost" @onclick="OnShowHistoryClicked">
                        <AppIcon Name="AppIconName.BarChart" Size="15" />
                        <span>@Localizer["Predictions.ShowStartHistory"]</span>
                        <small>@Localizer["FloatingWindow.OpenAsWindow"]</small>
                    </button>
                </div>

                @if (IsPredictionHistoryLoading)
                {
                    <p class="ranking-slot__prediction-empty">@Localizer["Predictions.LoadingHistory"]</p>
                }
                else if (PredictionHistory is null)
                {
                    <p class="ranking-slot__prediction-empty">@Localizer["Predictions.NoAthleteHistoryInline"]</p>
                }

                <AthleteDataSourceNote AdditionalClass="ranking-slot__prediction-source" SourceCode="@HistorySourceCode" />

                @if (!string.IsNullOrWhiteSpace(PredictionEditorError))
                {
                    <p class="ranking-slot__prediction-error">@PredictionEditorError</p>
                }

                <footer class="ranking-slot__prediction-editor-actions">
                    <button type="button" class="app-button app-button--ghost app-button--sm" @onclick="() => PredictionEditorCancelRequested.InvokeAsync()">
                        <AppIcon Name="AppIconName.X" Size="14" />
                        @Localizer["Common.Cancel"]
                    </button>
                    <button type="button" class="app-button app-button--primary app-button--sm" @onclick="() => PredictionEditorSaveRequested.InvokeAsync()">
                        <AppIcon Name="AppIconName.Check" Size="14" />
                        @Localizer["Common.Save"]
                    </button>
                </footer>
            </section>
        }
    }
</div>

@code {
    [Parameter]
    public int Position { get; set; }

    [Parameter]
    public Athlete? Athlete { get; set; }

    [Parameter]
    public AthletePlacementPick? Placement { get; set; }

    [Parameter]
    public bool CanEditPredictions { get; set; } = true;

    [Parameter]
    public bool IsContextSelected { get; set; }

    [Parameter]
    public bool IsSelectorTarget { get; set; }

    [Parameter]
    public bool IsPredictionEditorOpen { get; set; }

    [Parameter]
    public bool IsRemovePending { get; set; }

    [Parameter]
    public string PredictionEditorMode { get; set; } = "total";

    [Parameter]
    public string PredictionTotalInput { get; set; } = string.Empty;

    [Parameter]
    public string PredictionSquatInput { get; set; } = string.Empty;

    [Parameter]
    public string PredictionBenchInput { get; set; } = string.Empty;

    [Parameter]
    public string PredictionDeadliftInput { get; set; } = string.Empty;

    [Parameter]
    public string? PredictionEditorError { get; set; }

    [Parameter]
    public bool IsPredictionHistoryLoading { get; set; }

    [Parameter]
    public AthleteHistoryEntry? PredictionHistory { get; set; }

    [Parameter]
    public string HistorySourceCode { get; set; } = ExternalAthleteSources.OpenIpf;

    [Parameter]
    public bool CanMoveUp { get; set; }

    [Parameter]
    public bool CanMoveDown { get; set; }

    [Parameter]
    public EventCallback<int> PredictionEditRequested { get; set; }

    [Parameter]
    public EventCallback<string> PredictionEditorModeChanged { get; set; }

    [Parameter]
    public EventCallback<string> PredictionTotalInputChanged { get; set; }

    [Parameter]
    public EventCallback<string> PredictionSquatInputChanged { get; set; }

    [Parameter]
    public EventCallback<string> PredictionBenchInputChanged { get; set; }

    [Parameter]
    public EventCallback<string> PredictionDeadliftInputChanged { get; set; }

    [Parameter]
    public EventCallback PredictionEditorSaveRequested { get; set; }

    [Parameter]
    public EventCallback PredictionEditorCancelRequested { get; set; }

    [Parameter]
    public EventCallback UseNominatedTotalRequested { get; set; }

    [Parameter]
    public EventCallback UseLastResultRequested { get; set; }

    [Parameter]
    public EventCallback UseBestResultRequested { get; set; }

    [Parameter]
    public EventCallback<int> ShowHistoryWindowRequested { get; set; }

    [Parameter]
    public string? EmptySlotCta { get; set; }

    [Parameter]
    public EventCallback<int> RemoveRequested { get; set; }

    [Parameter]
    public EventCallback<int> MoveUpRequested { get; set; }

    [Parameter]
    public EventCallback<int> MoveDownRequested { get; set; }

    [Parameter]
    public EventCallback<int> DropRequested { get; set; }

    [Parameter]
    public EventCallback<int> DragStartRequested { get; set; }

    [Parameter]
    public EventCallback<int> SlotSelectionRequested { get; set; }

    [Parameter]
    public EventCallback<string> AthleteContextRequested { get; set; }

    private string EmptySlotCtaLabel => string.IsNullOrWhiteSpace(EmptySlotCta)
        ? Localizer["Predictions.PickAthleteCta"]
        : EmptySlotCta;

    private string CssClass => string.Join(
        " ",
        "ranking-slot",
        Athlete is null ? "ranking-slot--empty" : "ranking-slot--filled",
        CanEditPredictions ? "ranking-slot--interactive" : null,
        IsSelectorTarget ? "ranking-slot--selector-target" : null,
        IsContextSelected ? "ranking-slot--context-active" : null,
        IsPredictionEditorOpen ? "ranking-slot--prediction-active" : null);

    private string ContextButtonClass => string.Join(
        " ",
        "ranking-slot__details",
        IsContextSelected ? "ranking-slot__details--context-active" : null);

    private string RemoveAriaLabel => IsRemovePending
        ? Localizer["Predictions.RemoveConfirm"]
        : Localizer["Predictions.RemoveAthlete"];

    private string RemoveActionClass => string.Join(
        " ",
        "ranking-slot__action",
        "ranking-slot__action--icon",
        "ranking-slot__action--danger",
        IsRemovePending ? "ranking-slot__action--danger-pending" : null);

    private decimal? PredictedTotalKg => Placement?.PredictedTotalKg;

    private string? PredictedLiftSummary
    {
        get
        {
            var parts = new List<string>();

            if (Placement?.PredictedSquatKg is not null)
            {
                parts.Add($"SQ {FormatKgValue(Placement.PredictedSquatKg)}");
            }

            if (Placement?.PredictedBenchKg is not null)
            {
                parts.Add($"BP {FormatKgValue(Placement.PredictedBenchKg)}");
            }

            if (Placement?.PredictedDeadliftKg is not null)
            {
                parts.Add($"DL {FormatKgValue(Placement.PredictedDeadliftKg)}");
            }

            return parts.Count == 0 ? null : $"{string.Join("  •  ", parts)}";
        }
    }

    private decimal? CalculatedLiftTotalKg
    {
        get
        {
            var values = new[]
            {
                ParseNullableDecimal(PredictionSquatInput),
                ParseNullableDecimal(PredictionBenchInput),
                ParseNullableDecimal(PredictionDeadliftInput)
            };

            return values.Any(value => value is not null)
                ? values.Sum(value => value ?? 0m)
                : null;
        }
    }

    private string PredictionCalculatedTotalClass => string.Join(
        " ",
        "ranking-slot__prediction-calculated-total",
        CalculatedLiftTotalKg is null ? "ranking-slot__prediction-calculated-total--empty" : null);

    private string AutoTotalDisplay => CalculatedLiftTotalKg is null
        ? "—"
        : FormatKgValue(CalculatedLiftTotalKg);

    private Task OnSlotClicked(MouseEventArgs _)
    {
        if (Athlete is null)
        {
            return CanEditPredictions
                ? SlotSelectionRequested.InvokeAsync(Position)
                : Task.CompletedTask;
        }

        return AthleteContextRequested.InvokeAsync(Athlete.Id);
    }

    private Task OnShowHistoryClicked()
    {
        return ShowHistoryWindowRequested.InvokeAsync(Position);
    }

    private Task OnTotalInput(ChangeEventArgs args)
    {
        return PredictionTotalInputChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
    }

    private Task OnTotalModeSelected(ChangeEventArgs _)
    {
        return PredictionEditorModeChanged.InvokeAsync("total");
    }

    private Task OnLiftsModeSelected(ChangeEventArgs _)
    {
        return PredictionEditorModeChanged.InvokeAsync("lifts");
    }

    private Task OnSquatInput(ChangeEventArgs args)
    {
        return PredictionSquatInputChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
    }

    private Task OnBenchInput(ChangeEventArgs args)
    {
        return PredictionBenchInputChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
    }

    private Task OnDeadliftInput(ChangeEventArgs args)
    {
        return PredictionDeadliftInputChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
    }

    private string FormatKg(decimal? value)
    {
        return value is null
            ? Localizer["Common.Tbd"].Value
            : FormatKgValue(value);
    }

    private static string FormatKgValue(decimal? value)
    {
        return value is null
            ? string.Empty
            : $"{value.Value.ToString("0.#", CultureInfo.CurrentCulture)} kg";
    }

    private string FormatLastResultMeta()
    {
        if (PredictionHistory?.LastResult is null)
        {
            return string.Empty;
        }

        var total = FormatKgValue(PredictionHistory.LastResult.TotalKg);
        if (string.IsNullOrWhiteSpace(PredictionHistory.LastResult.MeetName))
        {
            return total;
        }

        return $"{total} · {PredictionHistory.LastResult.MeetName}";
    }

    private static decimal? ParseNullableDecimal(string value)
    {
        return decimal.TryParse(value, NumberStyles.Number, CultureInfo.CurrentCulture, out var parsed) ||
               decimal.TryParse(value, NumberStyles.Number, CultureInfo.InvariantCulture, out parsed)
            ? parsed
            : null;
    }
}
