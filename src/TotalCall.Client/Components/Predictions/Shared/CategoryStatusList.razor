@inject IStringLocalizer<SharedResource> Localizer

<section class="category-status-list" aria-label="@Localizer["Competition.Categories"]">
    <div class="category-status-list__head">
        <h3>@Localizer["Competition.Categories"]</h3>
        <span>@GetSectionSummary(OrderedQuestions)</span>
    </div>

    <ol class="category-status-list__groups">
        @foreach (var section in GetSections())
        {
            <li class="category-status-list__group">
                @if (!string.IsNullOrWhiteSpace(section.Label))
                {
                    <div class="category-status-list__group-head">
                        <span>@section.Label</span>
                        <strong>@GetSectionSummary(section.Questions)</strong>
                    </div>
                }

                <ol class="category-status-list__items">
                    @foreach (var question in section.Questions)
                    {
                        var status = GetStatus(question.Id);
                        var isActive = string.Equals(question.Id, ActiveQuestionId, StringComparison.OrdinalIgnoreCase);

                        <li>
                            <button
                                type="button"
                                class="@GetButtonClass(isActive, status.Status)"
                                @onclick="() => CategoryChanged.InvokeAsync(question.Id)">
                                <span class="@GetIndicatorClass(status.Status)">
                                    @if (status.Status == PredictionCompletionStatus.Complete)
                                    {
                                        <AppIcon Name="AppIconName.Check" Size="10" StrokeWidth="3" />
                                    }
                                </span>

                                <strong>@CategoryLabelSelector(question)</strong>

                                <span class="@GetStatusValueClass(status.Status)">
                                    @GetCompactStatusSummary(status)
                                </span>
                            </button>
                        </li>
                    }
                </ol>
            </li>
        }
    </ol>
</section>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<PredictionQuestion> Questions { get; set; } = [];

    [Parameter, EditorRequired]
    public IReadOnlyDictionary<string, PredictionQuestionCompletionResult> StatusByQuestionId { get; set; } =
        new Dictionary<string, PredictionQuestionCompletionResult>(StringComparer.OrdinalIgnoreCase);

    [Parameter, EditorRequired]
    public string ActiveQuestionId { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public Func<PredictionQuestion, string> CategoryLabelSelector { get; set; } = default!;

    [Parameter]
    public Func<PredictionQuestion, string?>? CategorySectionSelector { get; set; }

    [Parameter]
    public EventCallback<string> CategoryChanged { get; set; }

    private IReadOnlyList<PredictionQuestion> OrderedQuestions => Questions
        .OrderBy(question => question.Order)
        .ToArray();

    private PredictionQuestionCompletionResult GetStatus(string questionId)
    {
        if (StatusByQuestionId.TryGetValue(questionId, out var status))
        {
            return status;
        }

        return new PredictionQuestionCompletionResult(
            questionId,
            PredictionCompletionStatus.NotStarted,
            0,
            0);
    }

    private IReadOnlyList<CategoryStatusSection> GetSections()
    {
        if (CategorySectionSelector is null)
        {
            return [new CategoryStatusSection(null, OrderedQuestions)];
        }

        return OrderedQuestions
            .GroupBy(question => CategorySectionSelector(question) ?? string.Empty)
            .Select(group => new CategoryStatusSection(
                string.IsNullOrWhiteSpace(group.Key) ? null : group.Key,
                group.ToArray()))
            .ToArray();
    }

    private string GetButtonClass(bool isActive, PredictionCompletionStatus status)
    {
        return string.Join(
            " ",
            "category-status-list__button",
            $"category-status-list__button--{GetStatusSlug(status)}",
            isActive ? "category-status-list__button--active" : null);
    }

    private static string GetIndicatorClass(PredictionCompletionStatus status)
    {
        return string.Join(
            " ",
            "category-status-list__indicator",
            $"category-status-list__indicator--{GetStatusSlug(status)}");
    }

    private static string GetStatusValueClass(PredictionCompletionStatus status)
    {
        return string.Join(
            " ",
            "category-status-list__status",
            $"category-status-list__status--{GetStatusSlug(status)}");
    }

    private string GetSectionSummary(IEnumerable<PredictionQuestion> questions)
    {
        var questionList = questions.ToArray();
        var completeCount = questionList.Count(question => GetStatus(question.Id).Status == PredictionCompletionStatus.Complete);
        return $"{completeCount}/{questionList.Length}";
    }

    private string GetCompactStatusSummary(PredictionQuestionCompletionResult status)
    {
        var requiredCount = Math.Max(status.RequiredCount, 1);

        if (status.Status == PredictionCompletionStatus.Complete)
        {
            return GetStatusLabel(status.Status);
        }

        return $"{status.SelectedCount}/{requiredCount}";
    }

    private string GetStatusLabel(PredictionCompletionStatus status)
    {
        return status switch
        {
            PredictionCompletionStatus.Complete => Localizer["Predictions.Status.Complete"],
            PredictionCompletionStatus.InProgress => Localizer["Predictions.Status.InProgress"],
            _ => Localizer["Predictions.Status.NotStarted"]
        };
    }

    private static string GetStatusSlug(PredictionCompletionStatus status)
    {
        return status switch
        {
            PredictionCompletionStatus.Complete => "complete",
            PredictionCompletionStatus.InProgress => "in-progress",
            _ => "not-started"
        };
    }

    private sealed record CategoryStatusSection(string? Label, IReadOnlyList<PredictionQuestion> Questions);
}
