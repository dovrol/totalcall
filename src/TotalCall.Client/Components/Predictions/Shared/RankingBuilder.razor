<section class="ranking-builder">
    <h3>@Title</h3>

    <div class="ranking-builder__slots">
        @foreach (var position in Enumerable.Range(1, SlotsCount))
        {
            <RankingSlot
                Position="position"
                Athlete="GetAthlete(position)"
                Placement="GetPlacement(position)"
                CanEditPredictions="CanEditPredictions"
                IsContextSelected="@IsContextAthlete(GetAthlete(position))"
                IsPredictionEditorOpen="@(PredictionEditorPosition == position)"
                PredictionEditorMode="@PredictionEditorMode"
                PredictionTotalInput="@PredictionTotalInput"
                PredictionSquatInput="@PredictionSquatInput"
                PredictionBenchInput="@PredictionBenchInput"
                PredictionDeadliftInput="@PredictionDeadliftInput"
                PredictionEditorError="@PredictionEditorError"
                IsPredictionHistoryLoading="@IsPredictionHistoryLoading"
                PredictionHistory="@PredictionHistory"
                HistorySourceCode="@HistorySourceCode"
                IsSelectorTarget="@(SelectorSlotPosition == position)"
                CanMoveUp="@(position > 1)"
                CanMoveDown="@(position < SlotsCount)"
                PredictionEditRequested="PredictionEditRequested"
                PredictionEditorModeChanged="PredictionEditorModeChanged"
                PredictionTotalInputChanged="PredictionTotalInputChanged"
                PredictionSquatInputChanged="PredictionSquatInputChanged"
                PredictionBenchInputChanged="PredictionBenchInputChanged"
                PredictionDeadliftInputChanged="PredictionDeadliftInputChanged"
                PredictionEditorSaveRequested="PredictionEditorSaveRequested"
                PredictionEditorCancelRequested="PredictionEditorCancelRequested"
                UseNominatedTotalRequested="UseNominatedTotalRequested"
                UseLastResultRequested="UseLastResultRequested"
                UseBestResultRequested="UseBestResultRequested"
                ShowHistoryWindowRequested="ShowHistoryWindowRequested"
                EmptySlotCta="@EmptySlotCta"
                IsRemovePending="@(IsRemovePendingPosition == position)"
                RemoveRequested="RemoveRequested"
                MoveUpRequested="MoveUpRequested"
                MoveDownRequested="MoveDownRequested"
                DropRequested="DropToPositionRequested"
                DragStartRequested="DragStartFromSlotRequested"
                SlotSelectionRequested="SlotSelectionRequested"
                AthleteContextRequested="AthleteContextRequested" />
        }
    </div>
</section>

@code {
    [Parameter]
    public int SlotsCount { get; set; } = 5;

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyDictionary<int, Athlete> SelectedAthletesByPosition { get; set; } =
        new Dictionary<int, Athlete>();

    [Parameter]
    public IReadOnlyDictionary<int, AthletePlacementPick> PlacementsByPosition { get; set; } =
        new Dictionary<int, AthletePlacementPick>();

    [Parameter]
    public bool CanEditPredictions { get; set; } = true;

    [Parameter]
    public string? ContextAthleteId { get; set; }

    [Parameter]
    public int? SelectorSlotPosition { get; set; }

    [Parameter]
    public int? PredictionEditorPosition { get; set; }

    [Parameter]
    public string PredictionEditorMode { get; set; } = "total";

    [Parameter]
    public string PredictionTotalInput { get; set; } = string.Empty;

    [Parameter]
    public string PredictionSquatInput { get; set; } = string.Empty;

    [Parameter]
    public string PredictionBenchInput { get; set; } = string.Empty;

    [Parameter]
    public string PredictionDeadliftInput { get; set; } = string.Empty;

    [Parameter]
    public string? PredictionEditorError { get; set; }

    [Parameter]
    public bool IsPredictionHistoryLoading { get; set; }

    [Parameter]
    public AthleteHistoryEntry? PredictionHistory { get; set; }

    [Parameter]
    public string HistorySourceCode { get; set; } = ExternalAthleteSources.OpenIpf;

    [Parameter]
    public EventCallback<int> PredictionEditRequested { get; set; }

    [Parameter]
    public EventCallback<string> PredictionEditorModeChanged { get; set; }

    [Parameter]
    public EventCallback<string> PredictionTotalInputChanged { get; set; }

    [Parameter]
    public EventCallback<string> PredictionSquatInputChanged { get; set; }

    [Parameter]
    public EventCallback<string> PredictionBenchInputChanged { get; set; }

    [Parameter]
    public EventCallback<string> PredictionDeadliftInputChanged { get; set; }

    [Parameter]
    public EventCallback PredictionEditorSaveRequested { get; set; }

    [Parameter]
    public EventCallback PredictionEditorCancelRequested { get; set; }

    [Parameter]
    public EventCallback UseNominatedTotalRequested { get; set; }

    [Parameter]
    public EventCallback UseLastResultRequested { get; set; }

    [Parameter]
    public EventCallback UseBestResultRequested { get; set; }

    [Parameter]
    public EventCallback<int> ShowHistoryWindowRequested { get; set; }

    [Parameter]
    public string? EmptySlotCta { get; set; }

    [Parameter]
    public int? IsRemovePendingPosition { get; set; }

    [Parameter]
    public EventCallback<int> RemoveRequested { get; set; }

    [Parameter]
    public EventCallback<int> MoveUpRequested { get; set; }

    [Parameter]
    public EventCallback<int> MoveDownRequested { get; set; }

    [Parameter]
    public EventCallback<int> DropToPositionRequested { get; set; }

    [Parameter]
    public EventCallback<int> DragStartFromSlotRequested { get; set; }

    [Parameter]
    public EventCallback<int> SlotSelectionRequested { get; set; }

    [Parameter]
    public EventCallback<string> AthleteContextRequested { get; set; }

    private Athlete? GetAthlete(int position)
    {
        return SelectedAthletesByPosition.TryGetValue(position, out var athlete)
            ? athlete
            : null;
    }

    private AthletePlacementPick? GetPlacement(int position)
    {
        return PlacementsByPosition.TryGetValue(position, out var placement)
            ? placement
            : null;
    }

    private bool IsContextAthlete(Athlete? athlete)
    {
        return athlete is not null &&
               !string.IsNullOrWhiteSpace(ContextAthleteId) &&
               string.Equals(athlete.Id, ContextAthleteId, StringComparison.OrdinalIgnoreCase);
    }
}
