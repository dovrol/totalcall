@using System.Globalization
@using TotalCall.Client.Application.Services
@using TotalCall.Client.Domain.Athletes
@inject AthleteHistoryService AthleteHistoryService
@inject IStringLocalizer<SharedResource> Localizer

<p class="@CssClass">@Text</p>

@code {
    [Parameter]
    public string? AdditionalClass { get; set; }

    [Parameter]
    public string SourceCode { get; set; } = ExternalAthleteSources.OpenIpf;

    private AthleteDataImportStatus? status;
    private string? loadedSourceCode;

    private string CssClass => string.Join(
        " ",
        "athlete-data-source-note",
        AdditionalClass);

    private string SourceLabel => string.IsNullOrWhiteSpace(status?.SourceLabel)
        ? AthleteDataSourcePreferenceService.GetSourceLabel(SourceCode)
        : status.SourceLabel;

    private string Text => status?.LastSuccessfulImportAt is null
        ? Localizer["Predictions.SourceOnly", SourceLabel].Value
        : Localizer[
            "Predictions.SourceWithImportDate",
            SourceLabel,
            FormatImportDate(status.LastSuccessfulImportAt.Value)].Value;

    protected override async Task OnParametersSetAsync()
    {
        if (string.Equals(loadedSourceCode, SourceCode, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        status = await AthleteHistoryService.GetImportStatusAsync(SourceCode);
        loadedSourceCode = SourceCode;
    }

    private static string FormatImportDate(DateTimeOffset value)
    {
        return value.ToLocalTime().ToString("dd.MM.yyyy, HH:mm", CultureInfo.CurrentCulture);
    }
}
