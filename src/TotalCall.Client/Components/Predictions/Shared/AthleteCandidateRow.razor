@inject IStringLocalizer<SharedResource> Localizer

<article
    class="@CssClass"
    @onclick="OnContextRequested"
    draggable="@(!IsSelected)"
    @ondragstart="() => DragStartRequested.InvokeAsync(Athlete.Id)">
    <div class="athlete-candidate-row__details">
        <strong>@Athlete.DisplayName</strong>
        @if (!string.IsNullOrWhiteSpace(Athlete.CountryName))
        {
            <small class="athlete-candidate-row__country">
                <CountryFlag Code="@Athlete.CountryCode" CountryName="@Athlete.CountryName" />
                <span>@Athlete.CountryName</span>
            </small>
        }
        @if (!string.IsNullOrWhiteSpace(WeightClassLabel))
        {
            <small>@WeightClassLabel</small>
        }
    </div>

    <div class="athlete-candidate-row__meta">
        @if (Athlete.SeedTotalKg is not null)
        {
            <span class="athlete-candidate-row__total">@Athlete.SeedTotalKg.Value.ToString("0.#") kg</span>
        }
        else
        {
            <span class="athlete-candidate-row__total athlete-candidate-row__total--muted">@Localizer["Common.Tbd"]</span>
        }

        @if (IsSelected)
        {
            <span class="athlete-candidate-row__picked">@Localizer["Predictions.Picked"]</span>
        }
        else
        {
            <button
                type="button"
                class="app-button app-button--secondary app-button--sm"
                @onclick="OnPickClicked"
                @onclick:stopPropagation="true">
                @PickButtonLabel
            </button>
        }
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public Athlete Athlete { get; set; } = default!;

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public bool IsContextSelected { get; set; }

    [Parameter]
    public string? WeightClassLabel { get; set; }

    [Parameter]
    public string PickButtonLabel { get; set; } = "Pick";

    [Parameter]
    public EventCallback<string> PickRequested { get; set; }

    [Parameter]
    public EventCallback<string> DragStartRequested { get; set; }

    [Parameter]
    public EventCallback<string> ContextRequested { get; set; }

    private string CssClass => string.Join(
        " ",
        "athlete-candidate-row",
        IsSelected ? "athlete-candidate-row--selected" : null,
        IsContextSelected ? "athlete-candidate-row--context-active" : null);

    private Task OnPickClicked(MouseEventArgs _)
    {
        return PickRequested.InvokeAsync(Athlete.Id);
    }

    private Task OnContextRequested(MouseEventArgs _)
    {
        return ContextRequested.InvokeAsync(Athlete.Id);
    }
}
