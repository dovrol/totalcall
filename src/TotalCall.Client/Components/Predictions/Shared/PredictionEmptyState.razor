@inject IStringLocalizer<SharedResource> Localizer

<section class="prediction-empty-state">
    <span class="prediction-empty-state__icon" aria-hidden="true">
        <AppIcon Name="AppIconName.AlertCircle" Size="20" />
    </span>
    <div>
        <h3>@Title</h3>
        <p>@Description</p>
    </div>
</section>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Description { get; set; } = string.Empty;
}
