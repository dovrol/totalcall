@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer

<nav class="prediction-action-bar" aria-label="@Localizer["Predictions.ActionBarAria"]">
    <div class="prediction-action-bar__left">
        <AppButton
            Href="/"
            Variant="Ghost"
            Size="Sm"
            AdditionalClass="prediction-action-bar__back">
            <AppIcon Name="AppIconName.ChevronRight" Size="15" Class="prediction-action-bar__back-icon" />
            <span>@Localizer["Common.Back"]</span>
        </AppButton>
    </div>

    <div class="@StatusClass" aria-live="polite">
        <strong>@StatusLabel</strong>
        <span>@StatusDetail</span>
    </div>

    <div class="prediction-action-bar__actions">
        <AppButton
            Variant="Secondary"
            Size="Sm"
            OnClick="@OnShareClicked"
            AriaLabel="@Localizer["Share.Title"]">
            <AppIcon Name="AppIconName.Share" Size="15" />
            <span>@Localizer["Share.Trigger"]</span>
        </AppButton>

        <AppButton
            Href="@ReviewHref"
            Variant="Primary"
            Size="Sm"
            AdditionalClass="prediction-action-bar__primary">
            <AppIcon Name="AppIconName.Check" Size="15" />
            <span>@Localizer["Predictions.ReviewPicks"]</span>
        </AppButton>
    </div>
</nav>

@code {
    [Parameter, EditorRequired]
    public string CompetitionSlug { get; set; } = string.Empty;

    [Parameter]
    public PredictionSaveStatus SaveStatus { get; set; }

    [Parameter]
    public DateTimeOffset? LastSavedAt { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> ShareRequested { get; set; }

    private string ReviewHref => $"competitions/{CompetitionSlug}/review";

    private string StatusClass => SaveStatus switch
    {
        PredictionSaveStatus.Cloud => "prediction-action-bar__status prediction-action-bar__status--cloud",
        PredictionSaveStatus.SynchronizationFailed => "prediction-action-bar__status prediction-action-bar__status--failed",
        _ => "prediction-action-bar__status prediction-action-bar__status--local"
    };

    private string StatusLabel => Localizer[SaveStatus switch
    {
        PredictionSaveStatus.Cloud => "Predictions.SaveStatus.Cloud",
        PredictionSaveStatus.SynchronizationFailed => "Predictions.SaveStatus.Failed",
        _ => "Predictions.SaveStatus.Local"
    }];

    private string StatusDetail => Localizer[
        SaveStatus switch
        {
            PredictionSaveStatus.Cloud => "Predictions.SaveStatus.CloudDetail",
            PredictionSaveStatus.SynchronizationFailed => "Predictions.SaveStatus.FailedDetail",
            _ => "Predictions.SaveStatus.LocalDetail"
        },
        FormatTime(LastSavedAt)];

    private Task OnShareClicked(MouseEventArgs args)
    {
        return ShareRequested.InvokeAsync(args);
    }

    private string FormatTime(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("HH:mm", CultureInfo.CurrentCulture) ?? Localizer["Common.Tbd"];
    }
}
