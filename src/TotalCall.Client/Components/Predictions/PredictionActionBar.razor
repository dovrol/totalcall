@using System.Globalization
@implements IDisposable
@inject IStringLocalizer<SharedResource> Localizer
@inject NavigationManager Navigation
@inject IJSRuntime JS

<nav class="@ActionBarClass" aria-label="@Localizer["Predictions.ActionBarAria"]">
    <div class="prediction-action-bar__left">
        <AppButton
            Href="/"
            Variant="Ghost"
            Size="Sm"
            AdditionalClass="prediction-action-bar__back">
            <AppIcon Name="AppIconName.ChevronRight" Size="15" Class="prediction-action-bar__back-icon" />
            <span>@Localizer["Common.Back"]</span>
        </AppButton>
    </div>

    <div class="@StatusClass" aria-live="polite">
        <span class="prediction-action-bar__status-icon" aria-hidden="true">
            @if (CurrentState is SubmitBarState.Submitting)
            {
                <span class="prediction-action-bar__spinner"></span>
            }
            else
            {
                <AppIcon Name="@StatusIcon" Size="17" />
            }
        </span>
        <span class="prediction-action-bar__status-copy">
            <strong>@StatusLabel</strong>
            <span>@StatusDetail</span>
            @if ((CurrentState is SubmitBarState.Submitted or SubmitBarState.LockedSubmitted) && SubmittedAt is not null)
            {
                <span class="prediction-action-bar__status-stamp">
                    <AppIcon Name="AppIconName.Clock" Size="11" />
                    @Localizer["Predictions.Submit.SubmittedAt", FormatDateTime(SubmittedAt)]
                </span>
            }
        </span>
        @if (ShowDraftPill)
        {
            <span class="prediction-action-bar__submission-pill prediction-action-bar__submission-pill--draft">
                <span class="prediction-action-bar__submission-dot"></span>
                @DraftPillLabel
            </span>
        }
        @if (ShowDeadlinePill)
        {
            <span class="@DeadlinePillClass">
                @if (DeadlinePhase == PredictionDeadlinePhase.Urgent)
                {
                    <i class="tcl-lockchip__dot" aria-hidden="true"></i>
                    @Localizer["Predictions.Deadline.PillUrgent", FormatCountdown()]
                }
                else
                {
                    <AppIcon Name="AppIconName.Timer" Size="12" />
                    @Localizer["Predictions.Deadline.PillSoon", FormatRelativeDeadline()]
                }
            </span>
        }
    </div>

    <div class="prediction-action-bar__actions">
        <AppButton
            Href="@ParticipantsHref"
            Variant="Ghost"
            Size="Sm"
            AdditionalClass="prediction-action-bar__participants">
            <AppIcon Name="AppIconName.Users" Size="15" />
            <span>@Localizer["Predictions.Submit.Participants"]</span>
        </AppButton>

        <AppButton
            Variant="Ghost"
            Size="Sm"
            AdditionalClass="prediction-action-bar__share"
            OnClick="@OnShareClicked"
            AriaLabel="@Localizer["Share.Title"]">
            <AppIcon Name="AppIconName.Share" Size="15" />
            <span>@Localizer["Share.Trigger"]</span>
        </AppButton>

        @if (CurrentState is SubmitBarState.Guest)
        {
            <AppButton
                Variant="Primary"
                Size="Sm"
                AdditionalClass="prediction-action-bar__primary"
                OnClick="@NavigateToLogin">
                <AppIcon Name="AppIconName.Lock" Size="15" />
                <span>@Localizer["Predictions.Submit.LoginToSubmit"]</span>
            </AppButton>
        }
        else if (CurrentState is SubmitBarState.Draft)
        {
            <AppButton
                @ref="submitButton"
                Variant="Primary"
                Size="Sm"
                AdditionalClass="@PrimaryButtonClass"
                OnClick="@OpenConfirmAsync">
                <AppIcon Name="AppIconName.Check" Size="16" />
                <span>@Localizer["Predictions.Submit.SubmitTypes"]</span>
            </AppButton>
        }
        else if (CurrentState is SubmitBarState.Submitting)
        {
            <AppButton
                Variant="Primary"
                Size="Sm"
                AdditionalClass="prediction-action-bar__primary"
                Disabled="true">
                <span class="prediction-action-bar__spinner prediction-action-bar__spinner--light"></span>
                <span>@Localizer["Predictions.Submit.Submitting"]</span>
            </AppButton>
        }
        else if (CurrentState is SubmitBarState.Failed)
        {
            <AppButton
                Variant="Secondary"
                Size="Sm"
                AdditionalClass="prediction-action-bar__retry-sync"
                OnClick="@OnRetrySyncClicked">
                <AppIcon Name="AppIconName.RefreshCw" Size="15" />
                <span>@Localizer["Predictions.Submit.SyncRetry"]</span>
            </AppButton>
            <AppButton
                Variant="Primary"
                Size="Sm"
                AdditionalClass="prediction-action-bar__primary"
                Disabled="true">
                <AppIcon Name="AppIconName.Check" Size="16" />
                <span>@Localizer["Predictions.Submit.SubmitTypes"]</span>
            </AppButton>
        }
        else if (CurrentState is SubmitBarState.Error)
        {
            <AppButton
                @ref="submitButton"
                Variant="Primary"
                Size="Sm"
                AdditionalClass="prediction-action-bar__primary"
                OnClick="@RetrySubmitAsync">
                <AppIcon Name="AppIconName.RefreshCw" Size="15" />
                <span>@Localizer["Predictions.Submit.TryAgain"]</span>
            </AppButton>
        }
        else if (CurrentState is SubmitBarState.Archived)
        {
            <span class="tcl-locked-badge"><AppIcon Name="AppIconName.Trophy" Size="14" />@Localizer["Predictions.Submit.ArchiveBadge"]</span>
        }
        else if (CurrentState is SubmitBarState.LockedSubmitted or SubmitBarState.LockedDraft)
        {
            <span class="tcl-locked-badge"><AppIcon Name="AppIconName.Lock" Size="14" />@Localizer["Predictions.Submit.LockedBadge"]</span>
        }
    </div>
</nav>

@if (isConfirmOpen)
{
    <div class="submit-confirm-scrim" @onclick="CancelConfirmAsync">
        <section
            @ref="confirmDialog"
            class="submit-confirm"
            role="dialog"
            aria-modal="true"
            aria-labelledby="submit-confirm-title"
            aria-describedby="submit-confirm-description"
            tabindex="-1"
            @onkeydown="OnConfirmKeyDown"
            @onclick:stopPropagation="true">
            <div class="submit-confirm__grip" aria-hidden="true"></div>
            <div class="submit-confirm__head">
                <span class="submit-confirm__icon" aria-hidden="true">
                    <AppIcon Name="AppIconName.Check" Size="22" />
                </span>
                <h2 id="submit-confirm-title" class="submit-confirm__title">
                    @Localizer["Predictions.Submit.ConfirmTitle"]
                </h2>
                <p id="submit-confirm-description" class="submit-confirm__sub">
                    @Localizer["Predictions.Submit.ConfirmDescription"]
                </p>
            </div>

            <div class="submit-confirm__competition">
                <span class="submit-confirm__competition-copy">
                    <span>@Localizer["Predictions.Submit.Competition"]</span>
                    <strong>@CompetitionName</strong>
                </span>
                <AppBadge>
                    <AppIcon Name="AppIconName.Clock" Size="13" />
                    @Localizer["Predictions.Submit.Deadline", LockLabel]
                </AppBadge>
            </div>

            @if (HasWithdrawnPicks)
            {
                <div class="submit-confirm__warning" role="alert">
                    <span class="submit-confirm__warning-icon" aria-hidden="true">
                        <AppIcon Name="AppIconName.AlertCircle" Size="18" />
                    </span>
                    <span>
                        <strong>@Localizer["Predictions.Roster.SubmitWarningTitle"]</strong>
                        <small>@Localizer["Predictions.Roster.SubmitWarningBody", WithdrawnPickSummary]</small>
                    </span>
                </div>
            }

            <ul class="submit-confirm__list">
                <li>
                    <span class="submit-confirm__list-icon submit-confirm__list-icon--ok"><AppIcon Name="AppIconName.Users" Size="17" /></span>
                    <span>@Localizer["Predictions.Submit.ConfirmParticipants"]</span>
                </li>
                <li>
                    <span class="submit-confirm__list-icon submit-confirm__list-icon--private"><AppIcon Name="AppIconName.EyeOff" Size="17" /></span>
                    <span>@Localizer["Predictions.Submit.ConfirmAnswersPrivate"]</span>
                </li>
                <li>
                    <span class="submit-confirm__list-icon submit-confirm__list-icon--private"><AppIcon Name="AppIconName.Lock" Size="17" /></span>
                    <span>@Localizer["Predictions.Submit.ConfirmDraftsPrivate"]</span>
                </li>
                <li>
                    <span class="submit-confirm__list-icon submit-confirm__list-icon--edit"><AppIcon Name="AppIconName.PencilLine" Size="17" /></span>
                    <span>@Localizer["Predictions.Submit.ConfirmAutoUpdate"]</span>
                </li>
                <li>
                    <span class="submit-confirm__list-icon submit-confirm__list-icon--warn"><AppIcon Name="AppIconName.Lock" Size="17" /></span>
                    <span>@Localizer["Predictions.Submit.ConfirmFutureLock"]</span>
                </li>
            </ul>

            <div class="submit-confirm__foot">
                <span class="submit-confirm__esc" aria-hidden="true">
                    <kbd>Esc</kbd> / @Localizer["Predictions.Submit.ClickOutsideCancels"]
                </span>
                <AppButton
                    Variant="Ghost"
                    Size="Md"
                    AdditionalClass="submit-confirm__cancel"
                    OnClick="@CancelConfirmAsync">
                    @Localizer["Common.Cancel"]
                </AppButton>
                <AppButton
                    Variant="Primary"
                    Size="Md"
                    data-autofocus="true"
                    AdditionalClass="submit-confirm__confirm"
                    OnClick="@ConfirmSubmitAsync">
                    <AppIcon Name="AppIconName.Check" Size="16" />
                    <span>@Localizer["Predictions.Submit.SubmitTypes"]</span>
                </AppButton>
            </div>
        </section>
    </div>
}

@code {
    private enum SubmitBarState
    {
        Guest,
        Draft,
        Submitting,
        Submitted,
        Failed,
        Error,
        LockedSubmitted,
        LockedDraft,
        Archived
    }

    [Parameter, EditorRequired]
    public string CompetitionSlug { get; set; } = string.Empty;

    [Parameter]
    public string CompetitionName { get; set; } = string.Empty;

    [Parameter]
    public DateTimeOffset? PredictionLockAt { get; set; }

    [Parameter]
    public CompetitionStatus CompetitionStatus { get; set; } = CompetitionStatus.Upcoming;

    [Parameter]
    public DateTimeOffset? CompetitionEndDate { get; set; }

    [Parameter]
    public bool CanEditPredictions { get; set; } = true;

    [Parameter]
    public bool IsAuthenticated { get; set; }

    [Parameter]
    public PredictionSaveStatus SaveStatus { get; set; }

    [Parameter]
    public DateTimeOffset? LastSavedAt { get; set; }

    [Parameter]
    public DateTimeOffset? SubmittedAt { get; set; }

    [Parameter]
    public bool IsSubmitting { get; set; }

    [Parameter]
    public string? SubmitError { get; set; }

    [Parameter]
    public IReadOnlyList<string> WithdrawnPickNames { get; set; } = [];

    [Parameter]
    public EventCallback<MouseEventArgs> ShareRequested { get; set; }

    [Parameter]
    public EventCallback SubmitRequested { get; set; }

    [Parameter]
    public EventCallback RetrySyncRequested { get; set; }

    private AppButton? submitButton;
    private ElementReference confirmDialog;
    private bool isConfirmOpen;
    private bool trapFocusAfterRender;
    private bool restoreFocusAfterClose;
    private CancellationTokenSource? deadlineTickerCancellation;
    private DateTimeOffset now = DateTimeOffset.UtcNow;

    private SubmitBarState CurrentState
    {
        get
        {
            if (!CanCurrentlyEdit && DeadlinePhase == PredictionDeadlinePhase.Ended)
            {
                return SubmitBarState.Archived;
            }

            if (!CanCurrentlyEdit && DeadlinePhase == PredictionDeadlinePhase.Locked)
            {
                return SaveStatus == PredictionSaveStatus.Submitted
                    ? SubmitBarState.LockedSubmitted
                    : SubmitBarState.LockedDraft;
            }

            if (IsSubmitting)
            {
                return SubmitBarState.Submitting;
            }

            if (!string.IsNullOrWhiteSpace(SubmitError))
            {
                return SubmitBarState.Error;
            }

            if (SaveStatus == PredictionSaveStatus.SynchronizationFailed)
            {
                return SubmitBarState.Failed;
            }

            if (SaveStatus == PredictionSaveStatus.Submitted)
            {
                return SubmitBarState.Submitted;
            }

            return IsAuthenticated ? SubmitBarState.Draft : SubmitBarState.Guest;
        }
    }

    private string ActionBarClass => CurrentState switch
    {
        SubmitBarState.Submitted or SubmitBarState.LockedSubmitted => "prediction-action-bar prediction-action-bar--submitted",
        SubmitBarState.Failed => "prediction-action-bar prediction-action-bar--failed",
        SubmitBarState.Error => "prediction-action-bar prediction-action-bar--error",
        SubmitBarState.Submitting => "prediction-action-bar prediction-action-bar--submitting",
        _ => "prediction-action-bar"
    };

    private string StatusClass => CurrentState switch
    {
        SubmitBarState.Draft => "prediction-action-bar__status prediction-action-bar__status--cloud",
        SubmitBarState.Submitting => "prediction-action-bar__status prediction-action-bar__status--busy",
        SubmitBarState.Submitted or SubmitBarState.LockedSubmitted => "prediction-action-bar__status prediction-action-bar__status--submitted",
        SubmitBarState.Failed or SubmitBarState.Error => "prediction-action-bar__status prediction-action-bar__status--failed",
        _ => "prediction-action-bar__status prediction-action-bar__status--local"
    };

    private AppIconName StatusIcon => CurrentState switch
    {
        SubmitBarState.Draft => AppIconName.CloudCheck,
        SubmitBarState.Submitted or SubmitBarState.LockedSubmitted => AppIconName.Check,
        SubmitBarState.Failed => AppIconName.CloudOff,
        SubmitBarState.Error => AppIconName.AlertCircle,
        SubmitBarState.LockedDraft => AppIconName.Lock,
        SubmitBarState.Archived => AppIconName.Trophy,
        _ => AppIconName.HardDrive
    };

    private string StatusLabel => Localizer[CurrentState switch
    {
        SubmitBarState.Draft => "Predictions.SaveStatus.Cloud",
        SubmitBarState.Submitting => "Predictions.Submit.Submitting",
        SubmitBarState.Submitted or SubmitBarState.LockedSubmitted => "Predictions.Submit.Submitted",
        SubmitBarState.Failed => "Predictions.SaveStatus.Failed",
        SubmitBarState.Error => "Predictions.Submit.Error",
        SubmitBarState.LockedDraft => "Predictions.Submit.LockedDraft",
        SubmitBarState.Archived => "Predictions.Submit.Archived",
        _ => "Predictions.SaveStatus.Local"
    }];

    private string StatusDetail => CurrentState switch
    {
        SubmitBarState.Draft => Localizer["Predictions.SaveStatus.CloudDetail", FormatTime(LastSavedAt)],
        SubmitBarState.Submitting => Localizer["Predictions.Submit.SubmittingDetail"],
        SubmitBarState.Submitted => Localizer["Predictions.Submit.SubmittedDetail"],
        SubmitBarState.LockedSubmitted => Localizer["Predictions.Submit.LockedSubmittedDetail", LockLabel],
        SubmitBarState.LockedDraft => Localizer["Predictions.Submit.LockedDraftDetail", LockLabel],
        SubmitBarState.Archived => Localizer["Predictions.Submit.ArchivedDetail"],
        SubmitBarState.Failed => Localizer["Predictions.SaveStatus.FailedDetail", FormatTime(LastSavedAt)],
        SubmitBarState.Error => string.IsNullOrWhiteSpace(SubmitError)
            ? Localizer["Predictions.Submit.ErrorDetail"]
            : SubmitError,
        _ => Localizer["Predictions.SaveStatus.LocalDetail", FormatTime(LastSavedAt)]
    };

    private bool ShowDraftPill => CurrentState is SubmitBarState.Guest or SubmitBarState.Draft;

    private bool HasWithdrawnPicks => WithdrawnPickNames.Count > 0;

    private string WithdrawnPickSummary => WithdrawnPickNames.Count <= 2
        ? string.Join(", ", WithdrawnPickNames)
        : $"{string.Join(", ", WithdrawnPickNames.Take(2))} +{WithdrawnPickNames.Count - 2}";

    private string DraftPillLabel => Localizer[
        CurrentState is SubmitBarState.Guest
            ? "Predictions.Submit.DraftLocal"
            : "Predictions.Submit.DraftPrivate"];

    private string ParticipantsHref => $"competitions/{CompetitionSlug}/standings";

    private string LockLabel => PredictionLockAt?.ToLocalTime().ToString("d MMM, HH:mm", CultureInfo.CurrentCulture)
                                ?? Localizer["Common.Tbd"];

    private PredictionDeadlinePhase DeadlinePhase =>
        PredictionDeadline.Resolve(CompetitionStatus, PredictionLockAt, CompetitionEndDate, now);

    private bool CanCurrentlyEdit => PredictionDeadline.CanEdit(
        CanEditPredictions,
        CompetitionStatus,
        PredictionLockAt,
        CompetitionEndDate,
        now);

    private bool ShowDeadlinePill =>
        CanCurrentlyEdit && (DeadlinePhase is PredictionDeadlinePhase.Soon or PredictionDeadlinePhase.Urgent);

    private string DeadlinePillClass => string.Join(
        " ",
        "tcl-deadline-pill",
        DeadlinePhase == PredictionDeadlinePhase.Urgent ? "tcl-deadline-pill--urgent" : "tcl-deadline-pill--soon");

    private string PrimaryButtonClass => string.Join(
        " ",
        "prediction-action-bar__primary",
        DeadlinePhase == PredictionDeadlinePhase.Urgent ? "tcl-cta-urgent" : null);

    protected override void OnParametersSet()
    {
        now = DateTimeOffset.UtcNow;
        SyncDeadlineTicker();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (trapFocusAfterRender && isConfirmOpen)
        {
            trapFocusAfterRender = false;
            await JS.InvokeVoidAsync("totalCallActions.trapFocus", confirmDialog);
        }

        if (restoreFocusAfterClose)
        {
            restoreFocusAfterClose = false;
            try
            {
                await submitButton!.Element.FocusAsync();
            }
            catch
            {
                // The trigger may disappear after a successful submit; focus restoration is best effort then.
            }
        }
    }

    private Task OnShareClicked(MouseEventArgs args)
    {
        return ShareRequested.InvokeAsync(args);
    }

    private Task OnRetrySyncClicked(MouseEventArgs _)
    {
        return RetrySyncRequested.InvokeAsync();
    }

    private Task OpenConfirmAsync(MouseEventArgs _)
    {
        if (!CanCurrentlyEdit)
        {
            return Task.CompletedTask;
        }

        isConfirmOpen = true;
        trapFocusAfterRender = true;
        return Task.CompletedTask;
    }

    private void NavigateToLogin(MouseEventArgs _)
    {
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        var target = string.IsNullOrWhiteSpace(returnUrl)
            ? "auth/login"
            : $"auth/login?returnUrl={Uri.EscapeDataString("/" + returnUrl)}";

        Navigation.NavigateTo(target);
    }

    private async Task RetrySubmitAsync(MouseEventArgs _)
    {
        if (CanCurrentlyEdit)
        {
            await SubmitRequested.InvokeAsync();
        }
    }

    private Task CancelConfirmAsync()
    {
        isConfirmOpen = false;
        trapFocusAfterRender = false;
        restoreFocusAfterClose = true;
        return Task.CompletedTask;
    }

    private async Task ConfirmSubmitAsync(MouseEventArgs _)
    {
        isConfirmOpen = false;
        trapFocusAfterRender = false;
        if (CanCurrentlyEdit)
        {
            await SubmitRequested.InvokeAsync();
        }
    }

    private async Task OnConfirmKeyDown(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "Escape", StringComparison.OrdinalIgnoreCase))
        {
            await CancelConfirmAsync();
        }
    }

    private string FormatTime(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("HH:mm", CultureInfo.CurrentCulture) ?? Localizer["Common.Tbd"];
    }

    private string FormatDateTime(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("d MMM, HH:mm", CultureInfo.CurrentCulture) ?? Localizer["Common.Tbd"];
    }

    private string FormatRelativeDeadline()
    {
        if (PredictionLockAt is not { } value)
        {
            return Localizer["Common.Tbd"];
        }

        var local = value.ToLocalTime();
        var days = (local.Date - now.ToLocalTime().Date).Days;
        var day = days switch
        {
            0 => Localizer["Common.Today"].Value,
            1 => Localizer["Common.Tomorrow"].Value,
            _ => local.ToString("d MMM", CultureInfo.CurrentCulture)
        };

        return $"{day}, {local.ToString("HH:mm", CultureInfo.CurrentCulture)}";
    }

    private string FormatCountdown()
    {
        var remaining = PredictionDeadline.Remaining(PredictionLockAt, now) ?? TimeSpan.Zero;
        if (remaining < TimeSpan.Zero)
        {
            remaining = TimeSpan.Zero;
        }

        return $"{(int)remaining.TotalHours:00}:{remaining.Minutes:00}:{remaining.Seconds:00}";
    }

    private void SyncDeadlineTicker()
    {
        if (!CanEditPredictions ||
            CompetitionStatus != TotalCall.Client.Domain.Competitions.CompetitionStatus.Upcoming ||
            PredictionLockAt is null)
        {
            StopDeadlineTicker();
            return;
        }

        if (deadlineTickerCancellation is not null)
        {
            return;
        }

        deadlineTickerCancellation = new CancellationTokenSource();
        _ = RunDeadlineTickerAsync(deadlineTickerCancellation.Token);
    }

    private async Task RunDeadlineTickerAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(GetDeadlineTickDelay(), cancellationToken);
                now = DateTimeOffset.UtcNow;
                await InvokeAsync(StateHasChanged);

                if (!CanCurrentlyEdit)
                {
                    break;
                }
            }
        }
        catch (OperationCanceledException)
        {
            // The competition changed or the component was disposed.
        }
        finally
        {
            deadlineTickerCancellation?.Dispose();
            deadlineTickerCancellation = null;
        }
    }

    private TimeSpan GetDeadlineTickDelay()
    {
        var remaining = PredictionLockAt is { } lockAt
            ? lockAt - DateTimeOffset.UtcNow
            : TimeSpan.FromMinutes(15);

        if (remaining <= TimeSpan.FromHours(1))
        {
            return TimeSpan.FromSeconds(1);
        }

        if (remaining <= TimeSpan.FromHours(48))
        {
            return TimeSpan.FromMinutes(1);
        }

        return TimeSpan.FromMinutes(15);
    }

    private void StopDeadlineTicker()
    {
        deadlineTickerCancellation?.Cancel();
    }

    public void Dispose()
    {
        StopDeadlineTicker();
    }
}
