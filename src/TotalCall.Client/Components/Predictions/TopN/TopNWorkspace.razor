    private async Task ResetAthlete(int position)
    {
        if (!CanEditSheet || ActiveQuestion is null)
        {
            return;
        }

        var placement = FieldPlacements.FirstOrDefault(item => item.Position == position);
        if (placement is null)
        {
            return;
