    private Task ToggleCompareSelection(string athleteId)
    {
        if (string.IsNullOrWhiteSpace(athleteId))
        {
            return Task.CompletedTask;
        }

        if (!isCompareSelectionMode)
        {
            StartCompareSelection(athleteId);
            return Task.CompletedTask;
        }

        if (compareSelectedAthleteIds.Contains(athleteId))
        {
            compareSelectedAthleteIds.Remove(athleteId);
            return Task.CompletedTask;
        }

        if (compareSelectedAthleteIds.Count >= 3)
        {
            Toasts.ShowInfo(Localizer["Predictions.Compare.MaxThree"]);
            return Task.CompletedTask;
        }

        compareSelectedAthleteIds.Add(athleteId);
