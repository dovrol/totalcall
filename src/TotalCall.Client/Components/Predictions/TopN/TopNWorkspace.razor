    private Task OnCellEdited(TopNSheetEdit edit)
    {
        if (!CanEditSheet || ActiveQuestion is null)
        {
            return Task.CompletedTask;
        }

        if (!TopNPlacementEditor.TryReadOptionalPositiveDecimal(edit.Value, CultureInfo.CurrentCulture, out var parsed))
        {
            Toasts.ShowError(Localizer["Predictions.PredictionValueInvalid"]);
            return Task.CompletedTask;
        }

        var placements = FieldPlacements
            .Select(placement => placement.Position == edit.Position
                ? TopNPlacementEditor.ApplyEdit(placement, edit.Field, parsed)
                : placement)
            .ToArray();

        return EmitAnswer(placements);
    }

    private Task NudgeCell(TopNSheetEdit edit)
    {
        if (!CanEditSheet || ActiveQuestion is null)
        {
            return Task.CompletedTask;
        }

        if (!TopNPlacementEditor.TryReadNudgeDelta(edit.Value, out var delta))
        {
            return Task.CompletedTask;
        }

        var placement = FieldPlacements.FirstOrDefault(item => item.Position == edit.Position);
        if (placement is null)
        {
            return Task.CompletedTask;
        }

        var updated = FieldPlacements
            .Select(item => item.Position == edit.Position
                ? TopNPlacementEditor.ApplyNudge(item, edit.Field, delta)
                : item)
            .ToArray();

        return EmitAnswer(updated);
    }

