    private Task StepCategory(int direction)
    {
        if (ActiveQuestion is null)
        {
            return Task.CompletedTask;
        }

        var index = ActiveQuestionIndex;
        var target = Math.Clamp(index + direction, 0, OrderedQuestions.Count - 1);
        return target == index ? Task.CompletedTask : OnCategoryChanged(OrderedQuestions[target].Id);
    }

