        var athlete = Competition.Athletes.First(item =>
            string.Equals(item.Id, placement.AthleteId, StringComparison.OrdinalIgnoreCase));
        modeByPosition.Remove(position);

        var placements = FieldPlacements
            .Select(item => item.Position == position
                ? item with
                {
                    PredictedSquatKg = null,
                    PredictedBenchKg = null,
                    PredictedDeadliftKg = null,
                    PredictedTotalKg = athlete.SeedTotalKg,
                    IsAutoSeeded = true
                }
                : item)
            .ToArray();
        await EmitAnswer(placements);
        Toasts.ShowSuccess(Localizer["Predictions.Toast.ResetAthlete.Success", athlete.DisplayName]);
    }

    private async Task SortByPredictedTotal()
    {
        if (!CanEditSheet || ActiveQuestion is null)
        {
            return;
        }

        var placements = FieldPlacements;
        if (placements.Count == 0 || placements.All(placement => placement.PredictedTotalKg is null))
        {
            Toasts.ShowInfo(Localizer["Predictions.Toast.SortPredicted.Empty"]);
            return;
        }

        var sorted = placements
            .Select((placement, index) => new { placement, index })
            .OrderBy(item => item.placement.PredictedTotalKg is null ? 1 : 0)
            .ThenByDescending(item => item.placement.PredictedTotalKg ?? 0m)
            .ThenBy(item => item.index)
            .Select((item, index) => item.placement with
            {
                Position = index + 1,
                IsScored = index < ScoredPositionsCount
            })
            .ToArray();

        await CaptureReorderPositionsAsync();
        modeByPosition.Clear();
        await EmitAnswer(sorted);
        Toasts.ShowSuccess(Localizer["Predictions.Toast.SortPredicted.Success"]);
    }

