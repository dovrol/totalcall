    private async Task OnQuickFill(TopNQuickFill request)
    {
        fillPopPosition = null;

        if (!CanEditPredictions || ActiveQuestion is null)
        {
            return;
        }

        var placement = FieldPlacements.FirstOrDefault(item => item.Position == request.Position);
        if (placement is null)
        {
            return;
        }

        var athlete = Competition.Athletes.FirstOrDefault(item =>
            string.Equals(item.Id, placement.AthleteId, StringComparison.OrdinalIgnoreCase));
        if (athlete is null)
        {
            return;
        }

        await EnsureHistoryAsync(athlete.Id);
        historyByAthleteId.TryGetValue(athlete.Id, out var history);

        var updated = BuildFromSource(placement, athlete, history, request.Kind);
        if (updated is null)
        {
            return;
        }

        modeByPosition[request.Position] = HasLiftValues(updated) ? TopNEntryMode.Lifts : TopNEntryMode.Total;

        var placements = FieldPlacements
            .Select(item => item.Position == request.Position ? updated : item)
            .ToArray();

        await EmitAnswer(placements);
        Toasts.ShowSuccess(QuickFillToast(request.Kind, athlete.DisplayName));
    }

    private async Task FillDefaultsFromSource(string kind)
    {
        isBulkMenuOpen = false;

        if (!CanEditPredictions || ActiveQuestion is null)
        {
            return;
        }

        var placements = FieldPlacements.ToList();
        var defaultPositions = placements
            .Where(placement => placement.IsAutoSeeded)
            .Select(placement => placement.Position)
            .ToArray();

        if (defaultPositions.Length == 0)
        {
            Toasts.ShowInfo(Localizer["Predictions.TopN.NoDefaultRows"]);
            return;
        }

        if (kind != TopNQuickFillKind.Nominated)
        {
            // Show the spinner on the bulk button while histories load. Flag is set
            // before the first await so Blazor renders it on the yield, and only
            // actually shows when a fetch is in flight (cached athletes don't yield).
            isBulkFilling = true;
            try
            {
                foreach (var position in defaultPositions)
                {
                    var athleteId = placements.First(placement => placement.Position == position).AthleteId;
                    await EnsureHistoryAsync(athleteId);
                }
            }
            finally
            {
                isBulkFilling = false;
            }
        }

        var changed = false;
        foreach (var position in defaultPositions)
        {
            var index = placements.FindIndex(placement => placement.Position == position);
            var placement = placements[index];
            var athlete = Competition.Athletes.First(item =>
                string.Equals(item.Id, placement.AthleteId, StringComparison.OrdinalIgnoreCase));
            historyByAthleteId.TryGetValue(athlete.Id, out var history);

            var filled = BuildFromSource(placement, athlete, history, kind);
            if (filled is null)
            {
                continue;
            }

            placements[index] = filled;
            modeByPosition[position] = HasLiftValues(filled) ? TopNEntryMode.Lifts : TopNEntryMode.Total;
            changed = true;
        }

        if (!changed)
        {
            Toasts.ShowInfo(Localizer["Predictions.Toast.AutoFill.Empty"]);
            return;
        }

        await EmitAnswer(placements);
        Toasts.ShowSuccess(Localizer["Predictions.Toast.AutoFill.Success"]);
    }

    private static AthletePlacementPick? BuildFromSource(
        AthletePlacementPick placement,
        Athlete athlete,
        AthleteHistoryEntry? history,
        string kind)
    {
        return kind switch
        {
            TopNQuickFillKind.Nominated when athlete.SeedTotalKg is not null => placement with
            {
                PredictedSquatKg = null,
                PredictedBenchKg = null,
                PredictedDeadliftKg = null,
                PredictedTotalKg = athlete.SeedTotalKg,
                IsAutoSeeded = false
            },
            TopNQuickFillKind.Last when history?.LastResult?.TotalKg is not null => FromResult(
                placement,
                history.LastResult.SquatKg,
                history.LastResult.BenchKg,
                history.LastResult.DeadliftKg,
                history.LastResult.TotalKg),
            TopNQuickFillKind.Best when history?.Bests?.TotalKg is not null => FromResult(
                placement,
                history.Bests.SquatKg,
                history.Bests.BenchKg,
                history.Bests.DeadliftKg,
                history.Bests.TotalKg),
            _ => null
        };
    }

    private string QuickFillToast(string kind, string athleteName) => kind switch
    {
        TopNQuickFillKind.Nominated => Localizer["Predictions.Toast.QuickFill.Nominated", athleteName].Value,
        TopNQuickFillKind.Last => Localizer["Predictions.Toast.QuickFill.Last", athleteName].Value,
        _ => Localizer["Predictions.Toast.QuickFill.Best", athleteName].Value
    };

    private static AthletePlacementPick FromResult(
        AthletePlacementPick placement,
        decimal? squat,
        decimal? bench,
        decimal? deadlift,
        decimal? total)
    {
        if (squat is not null || bench is not null || deadlift is not null)
        {
            return placement with
            {
                PredictedSquatKg = squat,
                PredictedBenchKg = bench,
                PredictedDeadliftKg = deadlift,
                PredictedTotalKg = total ?? (squat ?? 0m) + (bench ?? 0m) + (deadlift ?? 0m),
                IsAutoSeeded = false
            };
        }

        return placement with
        {
            PredictedSquatKg = null,
            PredictedBenchKg = null,
            PredictedDeadliftKg = null,
            PredictedTotalKg = total,
            IsAutoSeeded = false
        };
    }

    // ---------- reorder ----------

    private void OnDragStart(int position)
    {
        if (!CanEditPredictions || FieldPlacements.All(placement => placement.Position != position))
        {
            return;
        }

        draggingPosition = position;
        dragOverPosition = position;
    }

    private void OnDragEnter(int position)
    {
        if (draggingPosition is not null)
        {
            dragOverPosition = position;
        }
    }

    private Task OnDrop(int position)
    {
        if (draggingPosition is null)
        {
            return Task.CompletedTask;
        }

        var from = draggingPosition.Value;
        draggingPosition = null;
        dragOverPosition = null;
        return MoveToPosition(from, position);
    }

    private void OnDragEnd()
    {
        draggingPosition = null;
        dragOverPosition = null;
    }

    private Task MoveByOffset(TopNMove move)
    {
        return MoveToPosition(move.Position, move.Position + move.Delta);
    }

    private async Task MoveToPosition(int from, int to)
    {
        if (!CanEditPredictions || ActiveQuestion is null)
        {
            return;
        }

        to = Math.Clamp(to, 1, FieldPlacements.Count);
        if (from == to)
        {
            return;
        }

        var ordered = FieldPlacements.OrderBy(placement => placement.Position).ToList();
        var source = ordered.FirstOrDefault(placement => placement.Position == from);
        if (source is null)
        {
            return;
        }

        ordered.Remove(source);

        // After removing the source the list is renumbered contiguously, so the
        // target position maps directly to the insert index. This works for both
        // upward and downward moves (the old "first placement with position >= to"
        // logic left downward moves a no-op).
        var insertIndex = Math.Clamp(to - 1, 0, ordered.Count);
        ordered.Insert(insertIndex, source);

        var renumbered = ordered
            .Select((placement, index) => placement with
            {
                Position = index + 1,
                IsScored = index < ScoredPositionsCount
            })
            .ToArray();

        await CaptureReorderPositionsAsync();
        RemapModesAfterReorder(ordered, renumbered);
        if (expandedMobilePosition == from)
        {
            expandedMobilePosition = null;
        }

        await EmitAnswer(renumbered);
    }

    private async Task CaptureReorderPositionsAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("totalCallTopN.captureReorderPositions");
            animateReorderAfterRender = true;
        }
        catch (JSException)
        {
            // Reordering still works when the optional animation script is unavailable.
        }
        catch (JSDisconnectedException)
        {
            // The app is already tearing down.
        }
    }

    private void RemapModesAfterReorder(IReadOnlyList<AthletePlacementPick> beforeOrder, IReadOnlyList<AthletePlacementPick> afterOrder)
    {
        if (modeByPosition.Count == 0)
        {
            return;
        }

        var modeByAthlete = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var placement in beforeOrder)
        {
            if (modeByPosition.TryGetValue(placement.Position, out var mode))
            {
                modeByAthlete[placement.AthleteId] = mode;
            }
        }

        modeByPosition.Clear();
        foreach (var placement in afterOrder)
        {
            if (modeByAthlete.TryGetValue(placement.AthleteId, out var mode))
            {
                modeByPosition[placement.Position] = mode;
            }
        }
    }

