    // ---------- bulk actions ----------

    private async Task ResetAthlete(int position)
    {
        if (!CanEditPredictions || ActiveQuestion is null)
        {
            return;
        }

        var placement = FieldPlacements.FirstOrDefault(item => item.Position == position);
        if (placement is null)
        {
            return;
        }

        var athlete = Competition.Athletes.First(item =>
            string.Equals(item.Id, placement.AthleteId, StringComparison.OrdinalIgnoreCase));
        modeByPosition.Remove(position);

        var placements = FieldPlacements
            .Select(item => item.Position == position
                ? item with
                {
                    PredictedSquatKg = null,
                    PredictedBenchKg = null,
                    PredictedDeadliftKg = null,
                    PredictedTotalKg = athlete.SeedTotalKg,
                    IsAutoSeeded = true
                }
                : item)
            .ToArray();
        await EmitAnswer(placements);
        Toasts.ShowSuccess(Localizer["Predictions.Toast.ResetAthlete.Success", athlete.DisplayName]);
    }

    private async Task SortByPredictedTotal()
    {
        if (!CanEditPredictions || ActiveQuestion is null)
        {
            return;
        }

        var placements = FieldPlacements;
        if (placements.Count == 0 || placements.All(placement => placement.PredictedTotalKg is null))
        {
            Toasts.ShowInfo(Localizer["Predictions.Toast.SortPredicted.Empty"]);
            return;
        }

        var sorted = placements
            .Select((placement, index) => new { placement, index })
            .OrderBy(item => item.placement.PredictedTotalKg is null ? 1 : 0)
            .ThenByDescending(item => item.placement.PredictedTotalKg ?? 0m)
            .ThenBy(item => item.index)
            .Select((item, index) => item.placement with
            {
                Position = index + 1,
                IsScored = index < ScoredPositionsCount
            })
            .ToArray();

        await CaptureReorderPositionsAsync();
        modeByPosition.Clear();
        await EmitAnswer(sorted);
        Toasts.ShowSuccess(Localizer["Predictions.Toast.SortPredicted.Success"]);
    }

    private async Task ClearCategory()
    {
        if (!CanEditPredictions || ActiveQuestion is null)
        {
            return;
        }

        selectedAthleteId = null;
        expandedMobilePosition = null;
        CancelCompareSelection();
        modeByPosition.Clear();
        await EmitAnswer(BuildDefaultFieldPlacements());
        Toasts.ShowSuccess(Localizer["Predictions.Toast.ResetField.Success"]);
    }

    // ---------- history / trend ----------

    private Task EnsureHistoryForPositionAsync(int position)
    {
        var athleteId = FieldPlacements
            .FirstOrDefault(placement => placement.Position == position)?.AthleteId;

        return string.IsNullOrWhiteSpace(athleteId)
            ? Task.CompletedTask
            : EnsureHistoryAsync(athleteId);
    }

    private async Task EnsureHistoryAsync(string athleteId)
    {
        if (string.IsNullOrWhiteSpace(athleteId) || historyByAthleteId.ContainsKey(athleteId))
        {
            return;
        }

        // Flag the row as loading so the fill popover / mobile editor can show a spinner
        // while the request is in flight. Blazor re-renders when this await yields.
        loadingAthleteIds.Add(athleteId);
        try
        {
            // The sheet only needs best/last totals here, so skip the analytics RPC.
            // The context panel fetches it on demand (with analytics) when opened.
            historyByAthleteId[athleteId] = await AthleteHistoryService.GetAthleteHistoryAsync(
                athleteId, Competition, historySourceCode, includeAnalytics: false);
        }
        catch
        {
            historyByAthleteId[athleteId] = null;
        }
        finally
        {
            loadingAthleteIds.Remove(athleteId);
        }
    }

    private async void HandleDataSourceChanged(string competitionId, string source)
    {
        if (!string.Equals(competitionId, Competition.Id, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await InvokeAsync(() =>
        {
            historySourceCode = source;
            historyByAthleteId.Clear();
            StateHasChanged();
        });
    }

    // ---------- helpers ----------

    private async Task EnsureActiveFieldSeededAsync()
    {
        if (!CanEditPredictions || ActiveQuestion is null || !seededQuestionIds.Add(ActiveQuestion.Id))
        {
            return;
        }

        var field = FieldPlacements;
        if (!HasSameField(StoredPlacements, field))
        {
            await EmitAnswer(field);
        }
    }

    private IReadOnlyList<AthletePlacementPick> BuildFieldPlacements()
    {
        if (ActiveQuestion is null)
        {
            return [];
        }

        var eligibleById = EligibleAthletes.ToDictionary(athlete => athlete.Id, StringComparer.OrdinalIgnoreCase);
        var seenAthleteIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var field = new List<AthletePlacementPick>(eligibleById.Count);

        foreach (var placement in StoredPlacements.OrderBy(item => item.Position))
        {
            if (eligibleById.ContainsKey(placement.AthleteId) && seenAthleteIds.Add(placement.AthleteId))
            {
                field.Add(placement);
            }
        }

        foreach (var athlete in EligibleAthletes)
        {
            if (!seenAthleteIds.Add(athlete.Id))
            {
                continue;
            }

            field.Add(new AthletePlacementPick
            {
                Position = field.Count + 1,
                AthleteId = athlete.Id,
                PredictedTotalKg = athlete.SeedTotalKg,
                IsAutoSeeded = true
            });
        }

        return field
            .Select((placement, index) => placement with
            {
                Position = index + 1,
                IsScored = index < ScoredPositionsCount
            })
            .ToArray();
    }

    private IReadOnlyList<AthletePlacementPick> BuildDefaultFieldPlacements()
    {
        return EligibleAthletes
            .Select((athlete, index) => new AthletePlacementPick
            {
                Position = index + 1,
                AthleteId = athlete.Id,
                PredictedTotalKg = athlete.SeedTotalKg,
                IsScored = index < ScoredPositionsCount,
                IsAutoSeeded = true
            })
            .ToArray();
    }

    private static bool HasSameField(
        IReadOnlyList<AthletePlacementPick> stored,
        IReadOnlyList<AthletePlacementPick> normalized)
    {
        if (stored.Count != normalized.Count)
        {
            return false;
        }

        for (var index = 0; index < stored.Count; index++)
        {
            if (stored[index].Position != normalized[index].Position ||
                stored[index].IsScored != normalized[index].IsScored ||
                stored[index].IsAutoSeeded != normalized[index].IsAutoSeeded ||
                !string.Equals(stored[index].AthleteId, normalized[index].AthleteId, StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }
        }

        return true;
    }

    private Task EmitAnswer(IEnumerable<AthletePlacementPick> placements)
    {
        if (ActiveQuestion is null)
        {
            return Task.CompletedTask;
        }

        var eligibleAthleteIds = EligibleAthletes
            .Select(athlete => athlete.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var sanitized = placements
            .Where(placement => !string.IsNullOrWhiteSpace(placement.AthleteId) &&
                                eligibleAthleteIds.Contains(placement.AthleteId))
            .GroupBy(placement => placement.AthleteId, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .OrderBy(placement => placement.Position)
            .Select((placement, index) => placement with
            {
                Position = index + 1,
                IsScored = index < ScoredPositionsCount
            })
            .ToArray();

        return AnswerChanged.InvokeAsync(new PredictionAnswer
        {
            GroupId = ActiveGroup.Id,
            QuestionId = ActiveQuestion.Id,
            QuestionType = ActiveQuestion.Type,
            Value = new PredictionAnswerValue { AthletePlacements = sanitized },
            UpdatedAt = DateTimeOffset.UtcNow
        });
    }

    private IReadOnlyList<AthletePlacementPick> GetPlacements(string questionId)
    {
        return Answers
            .FirstOrDefault(answer =>
                string.Equals(answer.GroupId, ActiveGroup.Id, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(answer.QuestionId, questionId, StringComparison.OrdinalIgnoreCase))
            ?.Value.AthletePlacements
            .Where(placement => !string.IsNullOrWhiteSpace(placement.AthleteId))
            .OrderBy(placement => placement.Position)
            .ToArray() ?? [];
    }

    private bool IsAthleteInActiveQuestion(string? athleteId)
    {
        if (string.IsNullOrWhiteSpace(athleteId) || ActiveQuestion is null)
        {
            return false;
        }

        if (ActiveQuestion.AthleteIds.Count == 0)
        {
            return Competition.Athletes.Any(athlete =>
                string.Equals(athlete.Id, athleteId, StringComparison.OrdinalIgnoreCase));
        }

        return ActiveQuestion.AthleteIds.Contains(athleteId, StringComparer.OrdinalIgnoreCase);
    }

    private string GetCategoryName(PredictionQuestion question)
    {
        var category = Competition.Categories.FirstOrDefault(item => item.Id == question.CategoryId);
        return category?.Name ?? Text.QuestionTitle(Competition, question);
    }

    private string ShortCategoryLabel(PredictionQuestion question)
    {
        var name = GetCategoryName(question);
        var match = ShortCategoryRegex.Match(name);
        return match.Success ? match.Groups[1].Value : name;
    }

    private string? GetCategorySectionName(PredictionQuestion question)
    {
        var category = Competition.Categories.FirstOrDefault(item => item.Id == question.CategoryId);

        return category?.Sex switch
        {
            AthleteSex.Female => Localizer["Predictions.Sidebar.WomenSection"].Value,
            AthleteSex.Male => Localizer["Predictions.Sidebar.MenSection"].Value,
            _ => null
        };
    }

    private string GetModuleTitle(PredictionGroup group) => Text.GroupTitle(Competition, group);

    private string GetStatusLabel(PredictionCompletionStatus status) => status switch
    {
        PredictionCompletionStatus.Complete => Localizer["Predictions.Status.Complete"],
        PredictionCompletionStatus.InProgress => Localizer["Predictions.Status.InProgress"],
        _ => Localizer["Predictions.Status.NotStarted"]
    };

    private static bool HasLiftValues(AthletePlacementPick? placement) =>
        placement?.PredictedSquatKg is not null ||
        placement?.PredictedBenchKg is not null ||
        placement?.PredictedDeadliftKg is not null;

    private static bool TryReadOptionalPositiveDecimal(string value, out decimal? parsed)
    {
        parsed = null;

        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        if ((!decimal.TryParse(value, NumberStyles.Number, CultureInfo.CurrentCulture, out var number) &&
             !decimal.TryParse(value, NumberStyles.Number, CultureInfo.InvariantCulture, out number)) ||
            number <= 0 ||
            number > 1500m)
        {
            return false;
        }

        parsed = number;
        return true;
    }
