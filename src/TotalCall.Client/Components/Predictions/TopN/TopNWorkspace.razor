    }

    private Task OpenSelectedComparison()
    {
        if (ActiveQuestion is null)
        {
            return Task.CompletedTask;
        }

        var slots = SelectedComparisonSlots;
        if (slots.Count < 2)
        {
            Toasts.ShowInfo(Localizer["Predictions.TopN.CompareNotEnough"]);
            return Task.CompletedTask;
        }

        var first = slots.Min(slot => slot.Position);
        var last = slots.Max(slot => slot.Position);
        var categoryName = GetCategoryName(ActiveQuestion);
        var subtitle = string.Format(
            CultureInfo.CurrentCulture,
            Localizer["Predictions.TopN.CompareSubtitle"].Value,
            categoryName,
            first,
            last);

        Windows.OpenAthleteComparison(
            competitionId: Competition.Id,
            contextId: ActiveQuestion.Id,
            categoryName: categoryName,
            scoredCount: ScoredPositionsCount,
            slots: slots,
            title: Localizer["Predictions.CompareAthletes"].Value,
            subtitle: subtitle);

        isCompareSelectionMode = false;
        compareSelectedAthleteIds.Clear();
        return Task.CompletedTask;
    }

