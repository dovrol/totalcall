@using System.Globalization
@using System.Text.RegularExpressions
@implements IAsyncDisposable
@inject IStringLocalizer<SharedResource> Localizer
@inject IJSRuntime JS
@inject PredictionTextService Text
@inject AthleteHistoryService AthleteHistoryService
@inject AthleteDataSourcePreferenceService AthleteDataSources
@inject WindowManager Windows
@inject ToastService Toasts

@if (ActiveQuestion is null)
{
    <PredictionEmptyState
        Title="@Localizer["Predictions.NoCategoriesTitle"]"
        Description="@Localizer["Predictions.NoCategoriesDescription"]" />
}
else
{
    <section class="topn-workspace @BoardModeClass">
        @if (ShowContextHeader)
        {
            <BoardContextHeader
                IsPublic="IsPublicBoard"
                Name="@(IsPublicBoard ? PublicBoardName! : Localizer["BoardHeader.MyBoardName"].Value)"
                CompetitionName="@Competition.Name"
                Rank="Score?.Rank"
                Points="@(Score?.TotalPoints ?? 0m)"
                MaxPoints="MaxResultsPoints"
                Scored="@(Score?.ScoredGroupsCount ?? 0)"
                Total="@ResultsTotalCount"
                IsFinal="@(Score?.IsFinal ?? false)"
                HasScore="@(Score is not null)"
                CategoryLabel="@ActiveCategoryLabel"
                Breakdown="ActiveBreakdown" />
        }

        @* ---------------- DESKTOP ---------------- *@
        <div class="topn-desktop">
            <TopNHeaderBar
                Competition="@Competition"
                CompetitionName="@Competition.Name"
                ModuleTitle="@Text.GroupTitle(Competition, ActiveGroup)"
                ActiveCategoryName="@GetCategoryName(ActiveQuestion)"
                StatusLine="@ActiveStatusLine"
                StatusKind="@ActiveStatusKind"
                CompletedCategories="@CompletedCategoriesCount"
                TotalCategories="@OrderedQuestions.Count"
                CompetitionStatus="@Competition.Status"
                PredictionLockAt="@Competition.PredictionLockAt"
                CompetitionEndDate="@Competition.EndDate"
                Answers="@Answers"
                CanOpenModuleMenu="@CanOpenModuleMenu"
                IsModuleMenuOpen="@isModuleMenuOpen"
                ModuleSwitchRequested="ToggleModuleMenu"
                UpdatesRequested="@OpenUpdates" />

            @if (DeadlinePhase == PredictionDeadlinePhase.Ended)
            {
                <div class="tcl-ribbon">
                    <span class="tcl-ribbon__ic" aria-hidden="true"><AppIcon Name="AppIconName.Trophy" Size="14" /></span>
                    <strong>@Localizer["Predictions.Deadline.Ended"]</strong>
                    <span class="tcl-ribbon__sub">@Localizer["Predictions.Deadline.ArchiveHint"]</span>
                    <span class="tcl-ribbon__pending">@Localizer["Predictions.Deadline.ResultsSoon"]</span>
                </div>
            }

            <TopNCategoryStrip
                Questions="OrderedQuestions"
                StatusByQuestionId="StatusByQuestionId"
                ActiveQuestionId="@ActiveQuestion.Id"
                ShortLabelSelector="ShortCategoryLabel"
                SectionSelector="GetCategorySectionName"
                CategoryChanged="OnCategoryChanged"
                StepRequested="StepCategory"
                JumpRequested="OpenPalette" />

            <div class="topn-workspace__body">
                <TopNFooterTools
                    ShowLabel="true"
                    CanEditPredictions="@CanEditSheet"
                    RefinedCount="@RefinedCount"
                    FieldCount="@FieldPlacements.Count"
                    ScoredCount="@ScoredPositionsCount"
                    DefaultCount="@DefaultCount"
                    IsBulkMenuOpen="@isBulkMenuOpen"
                    IsBulkFilling="@isBulkFilling"
                    BulkMenuToggled="ToggleBulkMenu"
                    BulkMenuClosed="CloseBulkMenu"
                    BulkFillRequested="FillDefaultsFromSource"
                    SortRequested="SortByPredictedTotal"
                    IsCompareSelectionMode="@isCompareSelectionMode"
                    CompareModeRequested="StartCompareSelection"
                    ClearRequested="ClearCategory" />

                <TopNSheet
                    Slots="SlotViews"
                    ScoredCount="@ScoredPositionsCount"
                    Results="@ActiveSheetResults"
                    CanEditPredictions="@CanEditSheet"
                    IsBulkFilling="@isBulkFilling"
                    FillPopPosition="@fillPopPosition"
                    DraggingPosition="@draggingPosition"
                    DragOverPosition="@dragOverPosition"
                    MoveRequested="MoveByOffset"
                    AthleteContextRequested="OpenContext"
                    ComparisonSelectionActive="@isCompareSelectionMode"
                    ComparisonSelectedAthleteIds="@CompareSelectedAthleteIds"
                    CompareSelectionToggled="ToggleCompareSelection"
                    ResetRequested="ResetAthlete"
                    ModeToggled="ToggleRowMode"
                    CellEdited="OnCellEdited"
                    FillPopToggled="ToggleFillPop"
                    QuickFillRequested="OnQuickFill"
                    DragStarted="OnDragStart"
                    DragEntered="OnDragEnter"
                    Dropped="OnDrop"
                    DragEnded="OnDragEnd" />

                @if (isCompareSelectionMode)
                {
                    <TopNCompareSelectionBar
                        Slots="@SelectedComparisonSlots"
                        CancelRequested="CancelCompareSelection"
                        CompareRequested="OpenSelectedComparison" />
                }
            </div>
        </div>

        @* ---------------- MOBILE ---------------- *@
        <div class="topn-mobile">
            <TopNMobileHeader
                Competition="@Competition"
                ActiveCategoryName="@GetCategoryName(ActiveQuestion)"
                CategoryIndex="@(ActiveQuestionIndex + 1)"
                TotalCategories="@OrderedQuestions.Count"
                CompletedCategories="@CompletedCategoriesCount"
                ModuleTitle="@Text.GroupTitle(Competition, ActiveGroup)"
                CompetitionStatus="@Competition.Status"
                PredictionLockAt="@Competition.PredictionLockAt"
                CompetitionEndDate="@Competition.EndDate"
                Answers="@Answers"
                StatusLine="@MobileStatusLine"
                StatusKind="@ActiveStatusKind"
                SwitcherRequested="OpenMobileSwitcher"
                UpdatesRequested="@OpenUpdates" />

            <TopNMobileList
                Slots="SlotViews"
                ScoredCount="@ScoredPositionsCount"
                Results="@ActiveSheetResults"
                CanEditPredictions="@CanEditSheet"
                IsBulkFilling="@isBulkFilling"
                ExpandedPosition="@expandedMobilePosition"
                CardToggled="ToggleMobileCard"
                MoveRequested="MoveByOffset"
                ModeToggled="ToggleRowMode"
                CellEdited="OnCellEdited"
                NudgeRequested="NudgeCell"
                QuickFillRequested="OnQuickFill"
                AthleteContextRequested="OpenContext"
                ComparisonSelectionActive="@isCompareSelectionMode"
                ComparisonSelectedAthleteIds="@CompareSelectedAthleteIds"
                CompareSelectionToggled="ToggleCompareSelection"
                ResetRequested="ResetAthlete" />

            @if (isCompareSelectionMode)
            {
                <TopNCompareSelectionBar
                    Slots="@SelectedComparisonSlots"
                    CancelRequested="CancelCompareSelection"
                    CompareRequested="OpenSelectedComparison" />
            }

            <TopNFooterTools
                CanEditPredictions="@CanEditSheet"
                RefinedCount="@RefinedCount"
                FieldCount="@FieldPlacements.Count"
                ScoredCount="@ScoredPositionsCount"
                DefaultCount="@DefaultCount"
                IsBulkMenuOpen="@isBulkMenuOpen"
                IsBulkFilling="@isBulkFilling"
                BulkMenuToggled="ToggleBulkMenu"
                BulkMenuClosed="CloseBulkMenu"
                BulkFillRequested="FillDefaultsFromSource"
                SortRequested="SortByPredictedTotal"
                IsCompareSelectionMode="@isCompareSelectionMode"
                CompareModeRequested="StartCompareSelection"
                ClearRequested="ClearCategory" />
        </div>

        @* ---------------- OVERLAYS ---------------- *@
        @if (isModuleMenuOpen && CanOpenModuleMenu)
        {
            <TopNModuleMenu
                Groups="Groups"
                ActiveGroupId="@ActiveGroup.Id"
                CompetitionName="@Competition.Name"
                ModuleTitleSelector="GetModuleTitle"
                ModuleValidationByGroupId="ModuleValidationByGroupId"
                ModuleChanged="OnModuleChanged"
                Dismissed="CloseModuleMenu" />
        }

        @if (isPaletteOpen)
        {
            <TopNCommandPalette
                Questions="OrderedQuestions"
                StatusByQuestionId="StatusByQuestionId"
                ActiveQuestionId="@ActiveQuestion.Id"
                CategoryLabelSelector="GetCategoryName"
                ShortLabelSelector="ShortCategoryLabel"
                CategoryChosen="OnPaletteCategoryChosen"
                Dismissed="ClosePalette" />
        }

        @if (isMobileSwitcherOpen)
        {
            <TopNMobileSwitcher
                CompetitionName="@Competition.Name"
                Groups="Groups"
                ActiveGroupId="@ActiveGroup.Id"
                ModuleTitleSelector="GetModuleTitle"
                ModuleValidationByGroupId="ModuleValidationByGroupId"
                Questions="OrderedQuestions"
                StatusByQuestionId="StatusByQuestionId"
                ActiveQuestionId="@ActiveQuestion.Id"
                ShortLabelSelector="ShortCategoryLabel"
                SectionSelector="GetCategorySectionName"
                ModuleChanged="OnModuleChanged"
                CategoryChanged="OnSwitcherCategoryChosen"
                Dismissed="CloseMobileSwitcher" />
        }

        <button
            type="button"
            class="@ContextScrimClass"
            tabindex="-1"
            aria-hidden="@(!IsContextOpen)"
            @onclick="CloseContext">
        </button>

        <aside class="@ContextDrawerClass" aria-hidden="@(!IsContextOpen)">
            @if (IsContextOpen)
            {
                <div class="topn-drawer__handle" aria-hidden="true"></div>
                <button
                    type="button"
                    class="topn-drawer__close"
                    aria-label="@Localizer["Predictions.CloseContext"]"
                    @onclick="CloseContext">
                    <AppIcon Name="AppIconName.X" Size="14" />
                </button>

                <TopNContextPanel
                    Competition="@Competition"
                    ActiveQuestion="@ActiveQuestion"
                    ActiveQuestionStatus="@ActiveQuestionStatus"
                    SelectedAthleteId="@selectedAthleteId"
                    SelectedAthleteRank="@SelectedAthleteRank"
                    SelectedAthletePredictedTotalKg="@SelectedAthletePredictedTotal"
                    CanEditPredictions="@CanEditSheet"
                    SelectorSlotPosition="null"
                    SelectedAthletesByPosition="SelectedAthletesByPosition"
                    AthleteContextRequested="OpenContext"
                    AthleteSelectionCleared="CloseContext"
                    UseNominatedTotalRequested="OnUseNominatedFromContext"
                    CompareAthletesRequested="OnCompareAthletesRequested" />
            }
        </aside>

        @if (IsPublicBoard)
        {
            <nav class="prediction-action-bar prediction-action-bar--public" aria-label="@Localizer["Predictions.PublicBoard.Bar.Title"]">
                <div class="prediction-action-bar__left">
                    <a class="app-button app-button--ghost app-button--sm prediction-action-bar__back tcl-back" href="@BackHref">
                        <AppIcon Name="AppIconName.ChevronRight" Size="15" Class="rb-back__ic" />
                        <span>@Localizer["Predictions.PublicBoard.Back"]</span>
                    </a>
                </div>
                <div class="prediction-action-bar__status">
                    <span class="prediction-action-bar__status-icon prediction-action-bar__status-icon--public" aria-hidden="true"><AppIcon Name="AppIconName.User" Size="17" /></span>
                    <span class="prediction-action-bar__status-copy">
                        <strong>@Localizer["Predictions.PublicBoard.Bar.Title"]</strong>
                        <span>@Localizer["Predictions.PublicBoard.Bar.Body", PublicBoardName!]</span>
                    </span>
                </div>
            </nav>
        }
        else
        {
            <PredictionActionBar
                CompetitionSlug="@Competition.Slug"
                CompetitionName="@Competition.Name"
                PredictionLockAt="@Competition.PredictionLockAt"
                CompetitionStatus="@Competition.Status"
                CompetitionEndDate="@Competition.EndDate"
                CanEditPredictions="@CanEditSheet"
                IsAuthenticated="@IsAuthenticated"
                SaveStatus="@SaveStatus"
                LastSavedAt="@LastSavedAt"
                SubmittedAt="@SubmittedAt"
                IsSubmitting="@IsSubmitting"
                SubmitError="@SubmitError"
                WithdrawnPickNames="@AffectedWithdrawnAthleteNames"
                SubmitRequested="@SubmitRequested"
                RetrySyncRequested="@RetrySyncRequested"
                ShareRequested="@ShareRequested" />
        }

        <CompetitionTimeline
            Competition="@Competition"
            Answers="@Answers"
            CanEditPredictions="@CanEditSheet"
            IsOpen="@isUpdatesOpen"
            Closed="@CloseUpdates" />
    </section>
}

@code {
    [Parameter, EditorRequired]
    public Competition Competition { get; set; } = default!;

    [Parameter, EditorRequired]
    public IReadOnlyList<PredictionGroup> Groups { get; set; } = [];

    [Parameter, EditorRequired]
    public PredictionGroup ActiveGroup { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<PredictionAnswer> Answers { get; set; } = [];

    [Parameter]
    public MyScoreSnapshot? Score { get; set; }

    /// <summary>When set, the workspace renders read-only as another user's public board.</summary>
    [Parameter]
    public string? PublicBoardName { get; set; }

    [Parameter]
    public string? BackHref { get; set; }

    [Parameter, EditorRequired]
    public PredictionModuleValidationResult ActiveModuleValidation { get; set; } = default!;

    [Parameter]
    public IReadOnlyDictionary<string, PredictionModuleValidationResult> ModuleValidationByGroupId { get; set; } =
        new Dictionary<string, PredictionModuleValidationResult>(StringComparer.OrdinalIgnoreCase);

    [Parameter]
    public bool CanEditPredictions { get; set; }

    [Parameter]
    public bool IsAuthenticated { get; set; }

    [Parameter]
    public PredictionSaveStatus SaveStatus { get; set; }

    [Parameter]
    public DateTimeOffset? LastSavedAt { get; set; }

    [Parameter]
    public DateTimeOffset? SubmittedAt { get; set; }

    [Parameter]
    public bool IsSubmitting { get; set; }

    [Parameter]
    public string? SubmitError { get; set; }

    [Parameter]
    public EventCallback<string> GroupChanged { get; set; }

    [Parameter]
    public EventCallback<PredictionAnswer> AnswerChanged { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> ShareRequested { get; set; }

    [Parameter]
    public EventCallback SubmitRequested { get; set; }

    [Parameter]
    public EventCallback RetrySyncRequested { get; set; }

    private static readonly Regex ShortCategoryRegex = new(@"(\d+\+?)\s*kg", RegexOptions.Compiled | RegexOptions.IgnoreCase);

    private string? activeQuestionId;
    private string? selectedAthleteId;
    private bool isModuleMenuOpen;
    private bool isPaletteOpen;
    private bool isMobileSwitcherOpen;
    private bool isUpdatesOpen;
    private bool isBulkMenuOpen;
    private bool isBulkFilling;
    private bool isCompareSelectionMode;
    private int? fillPopPosition;
    private int? expandedMobilePosition;
    private int? draggingPosition;
    private int? dragOverPosition;
    private bool animateReorderAfterRender;
    private string defaultMode = TopNEntryMode.Lifts;
    private string historySourceCode = ExternalAthleteSources.OpenIpf;
    private DotNetObjectReference<TopNWorkspace>? selfRef;
    private bool shortcutsAttached;
    private bool contextDragAttached;
    private bool switcherDragAttached;
    private CancellationTokenSource? deadlineTickerCancellation;

    private readonly Dictionary<int, string> modeByPosition = [];
    private readonly Dictionary<string, AthleteHistoryEntry?> historyByAthleteId = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> loadingAthleteIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> seededQuestionIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> compareSelectedAthleteIds = new(StringComparer.OrdinalIgnoreCase);

    private TopNCategoryNavigationState CategoryNavigation => TopNCategoryNavigationState.Resolve(
        ActiveGroup,
        activeQuestionId,
        ActiveModuleValidation);

    private IReadOnlyList<PredictionQuestion> OrderedQuestions => CategoryNavigation.OrderedQuestions;

    private PredictionQuestion? ActiveQuestion => CategoryNavigation.ActiveQuestion;

    private bool CanOpenModuleMenu => Groups.Count > 0;

    private IReadOnlyDictionary<string, PredictionQuestionCompletionResult> StatusByQuestionId =>
        CategoryNavigation.StatusByQuestionId;

    private PredictionQuestionCompletionResult? ActiveQuestionStatus => CategoryNavigation.ActiveQuestionStatus;

    private int ScoredPositionsCount => ActiveQuestion?.Constraints.ExactSelections ??
                                        ActiveQuestion?.Constraints.MaxSelections ??
                                        3;

    // ---------- results overlay (backend score snapshot) ----------

    private TopNResultsDisplayState ResultsState => TopNResultsDisplayState.Resolve(
        ActiveGroup,
        ActiveQuestion,
        Score);

    private bool HasResultsImported => ResultsState.HasResultsImported;

    private CategoryScoreBreakdown? ActiveBreakdown => ResultsState.ActiveBreakdown;

    private bool IsActiveCategoryScored => ResultsState.IsActiveCategoryScored;

    private IReadOnlyDictionary<string, TopNSlotResult>? ActiveSheetResults => ResultsState.ActiveSheetResults;

    private TopNWorkspaceState WorkspaceState => TopNWorkspaceState.Resolve(
        Competition,
        CanEditPredictions,
        PublicBoardName,
        DateTimeOffset.UtcNow);

    private bool ShowContextHeader => WorkspaceState.ShowContextHeader;

    private string ActiveCategoryLabel => ActiveQuestion is null ? string.Empty : GetCategoryName(ActiveQuestion);

    private IReadOnlyList<PredictionQuestion> PlacementQuestions => ResultsState.PlacementQuestions;

    private int ResultsTotalCount => ResultsState.ResultsTotalCount;

    private decimal MaxResultsPoints => ResultsState.MaxResultsPoints;

    private int ActiveSelectedCount => ActiveQuestionStatus?.SelectedCount ?? FieldPlacements.Count(placement => placement.IsScored);

    private int ActiveRequiredCount => Math.Max(1, ActiveQuestionStatus?.RequiredCount ?? ScoredPositionsCount);

    private int RefinedCount => FieldPlacements.Count(placement => !placement.IsAutoSeeded);

    private int DefaultCount => FieldPlacements.Count(placement => placement.IsAutoSeeded);

    private int ActiveQuestionIndex => CategoryNavigation.ActiveQuestionIndex;

    private int CompletedCategoriesCount => CategoryNavigation.CompletedCategoriesCount;

    private PredictionCompletionStatus ActiveStatusKind => CategoryNavigation.ActiveStatusKind;

    private string? ActiveStatusLine => ActiveQuestionStatus is null
        ? null
        : $"{ActiveQuestionStatus.SelectedCount} / {Math.Max(1, ActiveQuestionStatus.RequiredCount)} · {GetStatusLabel(ActiveQuestionStatus.Status)}";

    private string MobileStatusLine => $"{ActiveSelectedCount} / {ActiveRequiredCount}";

    private IReadOnlyList<AthletePlacementPick> StoredPlacements => ActiveQuestion is null
        ? []
        : GetPlacements(ActiveQuestion.Id);

    private TopNFieldPlacementState FieldPlacementState => TopNFieldPlacementState.Resolve(
        Competition,
        ActiveQuestion,
        StoredPlacements,
        ScoredPositionsCount);

    private IReadOnlyList<AthletePlacementPick> FieldPlacements => FieldPlacementState.FieldPlacements;

    private IReadOnlyList<string> AffectedWithdrawnAthleteNames =>
        RosterUpdateService.GetAffectedAthleteNames(Competition, Answers);

    private IReadOnlyCollection<string> CompareSelectedAthleteIds => compareSelectedAthleteIds.ToArray();

    private IReadOnlyList<AthleteComparisonWindowSlot> SelectedComparisonSlots => FieldPlacements
        .Where(placement => compareSelectedAthleteIds.Contains(placement.AthleteId))
        .OrderBy(placement => placement.Position)
        .Select(ToComparisonSlot)
        .OfType<AthleteComparisonWindowSlot>()
        .ToArray();

    private IReadOnlyList<Athlete> QuestionAthletes => FieldPlacementState.QuestionAthletes;

    private IReadOnlyList<Athlete> EligibleAthletes => FieldPlacementState.EligibleAthletes;

    private IReadOnlyDictionary<int, Athlete> SelectedAthletesByPosition => FieldPlacements
        .Select(placement => new
        {
            placement.Position,
            Athlete = Competition.Athletes.FirstOrDefault(athlete =>
                string.Equals(athlete.Id, placement.AthleteId, StringComparison.OrdinalIgnoreCase))
        })
        .Where(item => item.Athlete is not null)
        .ToDictionary(item => item.Position, item => item.Athlete!, EqualityComparer<int>.Default);

    private bool IsContextOpen => !string.IsNullOrWhiteSpace(selectedAthleteId);

    private int? SelectedAthleteRank => FieldPlacements
        .FirstOrDefault(placement => string.Equals(placement.AthleteId, selectedAthleteId, StringComparison.OrdinalIgnoreCase))
        ?.Position;

    private decimal? SelectedAthletePredictedTotal => FieldPlacements
        .FirstOrDefault(placement => string.Equals(placement.AthleteId, selectedAthleteId, StringComparison.OrdinalIgnoreCase))
        ?.PredictedTotalKg;

    private IReadOnlyList<TopNSlotView> SlotViews
    {
        get
        {
            var placements = FieldPlacements;
            var views = new List<TopNSlotView>(placements.Count);

            foreach (var placement in placements)
            {
                var athlete = Competition.Athletes.First(item =>
                    string.Equals(item.Id, placement.AthleteId, StringComparison.OrdinalIgnoreCase));

                AthleteHistoryEntry? history = null;
                historyByAthleteId.TryGetValue(athlete.Id, out history);

                views.Add(new TopNSlotView
                {
                    Position = placement.Position,
                    Athlete = athlete,
                    Placement = placement,
                    Mode = EffectiveMode(placement.Position, placement),
                    IsContextActive = string.Equals(athlete.Id, selectedAthleteId, StringComparison.OrdinalIgnoreCase),
                    IsScored = placement.IsScored,
                    IsAutoSeeded = placement.IsAutoSeeded,
                    IsWithdrawn = athlete.IsWithdrawn,
                    CanMoveUp = placement.Position > 1,
                    CanMoveDown = placement.Position < placements.Count,
                    CanUseNominated = athlete.SeedTotalKg is not null,
                    CanUseLast = history?.LastResult?.TotalKg is not null,
                    CanUseBest = history?.Bests?.TotalKg is not null,
                    IsHistoryLoading = loadingAthleteIds.Contains(athlete.Id),
                    NominatedTotalKg = athlete.SeedTotalKg,
                    LastTotalKg = history?.LastResult?.TotalKg,
                    BestTotalKg = history?.Bests?.TotalKg
                });
            }

            return views;
        }
    }

    private PredictionDeadlinePhase DeadlinePhase => WorkspaceState.DeadlinePhase;

    private bool IsPublicBoard => WorkspaceState.IsPublicBoard;

    private string BoardModeClass => WorkspaceState.BoardModeClass;

    private bool CanEditSheet => WorkspaceState.CanEditSheet;

    private string ContextScrimClass => string.Join(" ", "topn-drawer-scrim", IsContextOpen ? "is-open" : null);

    private string ContextDrawerClass => string.Join(" ", "topn-drawer", IsContextOpen ? "is-open" : null);

    protected override void OnInitialized()
    {
        AthleteDataSources.SourceChanged += HandleDataSourceChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        var source = await AthleteDataSources.GetSourceAsync(Competition);
        if (!string.Equals(historySourceCode, source, StringComparison.OrdinalIgnoreCase))
        {
            historySourceCode = source;
            historyByAthleteId.Clear();
        }

        if (ActiveQuestion is null ||
            OrderedQuestions.All(question => !string.Equals(question.Id, activeQuestionId, StringComparison.OrdinalIgnoreCase)))
        {
            activeQuestionId = OrderedQuestions.FirstOrDefault()?.Id;
        }

        if (!IsAthleteInActiveQuestion(selectedAthleteId))
        {
            selectedAthleteId = null;
        }

        if (expandedMobilePosition is not null &&
            (expandedMobilePosition < 1 || expandedMobilePosition > FieldPlacements.Count ||
             FieldPlacements.All(placement => placement.Position != expandedMobilePosition)))
        {
            expandedMobilePosition = null;
        }

        if (!CanEditSheet)
        {
            CloseEditOnlySurfaces();
        }

        SyncDeadlineTicker();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            selfRef = DotNetObjectReference.Create(this);

            try
            {
                await JS.InvokeVoidAsync("totalCallTopN.attachShortcuts", selfRef);
                shortcutsAttached = true;
            }
            catch (JSException)
            {
                // The optional shortcut script may not be available yet.
            }
            catch (JSDisconnectedException)
            {
                // The app is already tearing down.
            }
        }

        if (animateReorderAfterRender)
        {
            animateReorderAfterRender = false;

            try
            {
                await JS.InvokeVoidAsync("totalCallTopN.animateReorder");
            }
            catch (JSException)
            {
                // Reordering still works when the optional animation script is unavailable.
            }
            catch (JSDisconnectedException)
            {
                // The app is already tearing down.
            }
        }

        await SyncContextDragAsync();
        await SyncSwitcherDragAsync();

        await EnsureActiveFieldSeededAsync();
    }

    private async Task SyncContextDragAsync()
    {
        if (IsContextOpen == contextDragAttached)
        {
            return;
        }

        try
        {
            if (IsContextOpen)
            {
                await JS.InvokeVoidAsync(
                    "totalCallTopN.attachDrawerDrag", selfRef, ".topn-drawer.is-open", ".topn-drawer__handle", "CloseContextFromDrag");
            }
            else
            {
                await JS.InvokeVoidAsync("totalCallTopN.detachDrawerDrag", ".topn-drawer.is-open");
            }

            contextDragAttached = IsContextOpen;
        }
        catch (JSException)
        {
            // The optional drag script may be unavailable; the close button still works.
        }
        catch (JSDisconnectedException)
        {
            // The app is already tearing down.
        }
    }

    private async Task SyncSwitcherDragAsync()
    {
        if (isMobileSwitcherOpen == switcherDragAttached)
        {
            return;
        }

        try
        {
            if (isMobileSwitcherOpen)
            {
                await JS.InvokeVoidAsync(
                    "totalCallTopN.attachDrawerDrag", selfRef, ".ms-bottomsheet", ".ms-handle", "CloseSwitcherFromDrag");
            }
            else
            {
                await JS.InvokeVoidAsync("totalCallTopN.detachDrawerDrag", ".ms-bottomsheet");
            }

            switcherDragAttached = isMobileSwitcherOpen;
        }
        catch (JSException)
        {
            // The optional drag script may be unavailable; the scrim/close still works.
        }
        catch (JSDisconnectedException)
        {
            // The app is already tearing down.
        }
    }

    [JSInvokable]
    public Task CloseContextFromDrag()
    {
        return InvokeAsync(() =>
        {
            CloseContext();
            StateHasChanged();
        });
    }

    [JSInvokable]
    public Task CloseSwitcherFromDrag()
    {
        return InvokeAsync(() =>
        {
            CloseMobileSwitcher();
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        AthleteDataSources.SourceChanged -= HandleDataSourceChanged;
        StopDeadlineTicker();

        if (shortcutsAttached || contextDragAttached || switcherDragAttached)
        {
            try
            {
                if (shortcutsAttached)
                {
                    await JS.InvokeVoidAsync("totalCallTopN.detachShortcuts");
                }

                if (contextDragAttached || switcherDragAttached)
                {
                    await JS.InvokeVoidAsync("totalCallTopN.detachDrawerDrag");
                }
            }
            catch (JSException)
            {
                // The script is already unavailable.
            }
            catch (JSDisconnectedException)
            {
                // The app is already tearing down.
            }
        }

        selfRef?.Dispose();
    }

    private void SyncDeadlineTicker()
    {
        if (!CanEditPredictions ||
            Competition.Status != CompetitionStatus.Upcoming ||
            Competition.PredictionLockAt is null)
        {
            StopDeadlineTicker();
            return;
        }

        if (deadlineTickerCancellation is not null)
        {
            return;
        }

        deadlineTickerCancellation = new CancellationTokenSource();
        _ = RunDeadlineTickerAsync(deadlineTickerCancellation.Token);
    }

    private async Task RunDeadlineTickerAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(GetDeadlineTickDelay(), cancellationToken);
                await InvokeAsync(() =>
                {
                    if (!CanEditSheet)
                    {
                        CloseEditOnlySurfaces();
                    }

                    StateHasChanged();
                });

                if (!CanEditSheet)
                {
                    break;
                }
            }
        }
        catch (OperationCanceledException)
        {
            // The competition changed or the component was disposed.
        }
        finally
        {
            deadlineTickerCancellation?.Dispose();
            deadlineTickerCancellation = null;
        }
    }

