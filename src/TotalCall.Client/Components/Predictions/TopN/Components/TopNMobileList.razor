@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer

<div class="ms-list">
    <div class="ms-podium-head">
        <span>@Localizer["Predictions.TopN.PodiumScored"]</span>
        <span class="ms-podium-head__line"></span>
    </div>

    @if (IsBulkFilling)
    {
        @for (var index = 0; index < SkeletonCardCount; index++)
        {
            <div class="ms-card topn-mobile-skeleton__card" aria-hidden="true">
                <div class="ms-ctop">
                    <span class="topn-sheet-skeleton__bone topn-mobile-skeleton__bone--move"></span>
                    <span class="topn-sheet-skeleton__bone topn-mobile-skeleton__bone--rank"></span>
                    <span class="topn-sheet-skeleton__bone topn-mobile-skeleton__bone--avatar"></span>
                    <span class="topn-mobile-skeleton__who">
                        <span class="topn-sheet-skeleton__bone topn-mobile-skeleton__bone--name"></span>
                        <span class="topn-sheet-skeleton__bone topn-mobile-skeleton__bone--country"></span>
                    </span>
                    <span class="topn-mobile-skeleton__pred">
                        <span class="topn-sheet-skeleton__bone topn-mobile-skeleton__bone--pred-label"></span>
                        <span class="topn-sheet-skeleton__bone topn-mobile-skeleton__bone--pred-value"></span>
                    </span>
                    <span class="topn-sheet-skeleton__bone topn-mobile-skeleton__bone--chev"></span>
                </div>
                <div class="topn-mobile-skeleton__lifts">
                    <span class="topn-sheet-skeleton__bone topn-mobile-skeleton__bone--lifts"></span>
                    <span class="topn-sheet-skeleton__bone topn-mobile-skeleton__bone--mode"></span>
                </div>
            </div>

            @if (index == ScoredCount - 1)
            {
                <div class="ms-cutoff topn-mobile-skeleton__cutoff" aria-hidden="true">
                    <span class="topn-sheet-skeleton__bone topn-mobile-skeleton__bone--cutoff-label"></span>
                    <span class="ms-cutoff__line"></span>
                    <span class="topn-sheet-skeleton__bone topn-mobile-skeleton__bone--cutoff-hint"></span>
                </div>
            }
        }
    }
    else
    {
        @foreach (var slot in VisibleSlots)
    {
        var isExpanded = CanEditPredictions && ExpandedPosition == slot.Position;
        var isTotal = string.Equals(slot.Mode, TopNEntryMode.Total, StringComparison.OrdinalIgnoreCase);

        <div @key="slot.Athlete!.Id" class="@CardClass(slot, isExpanded)" data-topn-athlete-id="@slot.Athlete!.Id">
            <div class="ms-ctop">
                @if (!isExpanded)
                {
                    @if (ComparisonSelectionActive)
                    {
                        <button
                            type="button"
                            class="@MobileComparePickClass(slot)"
                            aria-label="@Localizer["Predictions.Compare.ToggleAthlete", slot.Athlete.DisplayName]"
                            aria-pressed="@CompareAriaPressed(slot)"
                            @onclick="() => CompareSelectionToggled.InvokeAsync(slot.Athlete.Id)">
                            @if (IsCompareSelected(slot))
                            {
                                <AppIcon Name="AppIconName.Check" Size="14" />
                            }
                        </button>
                    }
                    else if (CanEditPredictions)
                    {
                        <div class="ms-move">
                            <button type="button" aria-label="@Localizer["Predictions.MoveUp"]" disabled="@(!CanEditPredictions || !slot.CanMoveUp)" @onclick="() => MoveRequested.InvokeAsync(new TopNMove(slot.Position, -1))"><AppIcon Name="AppIconName.ChevronRight" Size="12" Class="ms-chevron--up" /></button>
                            <button type="button" aria-label="@Localizer["Predictions.MoveDown"]" disabled="@(!CanEditPredictions || !slot.CanMoveDown)" @onclick="() => MoveRequested.InvokeAsync(new TopNMove(slot.Position, 1))"><AppIcon Name="AppIconName.ChevronRight" Size="12" Class="ms-chevron--down" /></button>
                        </div>
                    }
                }
                <div class="@RankClass(slot.Position)">@slot.Position</div>
                <div class="ms-card__av">@Initials(slot.Athlete!)</div>
                <div class="ms-card__who">
                    <div class="ms-card__n">@slot.Athlete!.DisplayName <CountryFlag Code="@slot.Athlete.CountryCode" CountryName="@slot.Athlete.CountryName" Class="ms-card__flag" /></div>
                    <div class="ms-card__c">@CountryLine(slot.Athlete)</div>
                </div>
                @if (!isExpanded)
                {
                    <div class="ms-card__pred">
                        <div class="ms-card__pred-k">@Localizer["Predictions.PredictedShort"]</div>
                        <div class="@PredValueClass(slot.IsAutoSeeded)">@FormatPred(slot.Placement?.PredictedTotalKg)</div>
                        <div class="@SourceClass(slot.IsAutoSeeded)">@SourceText(slot)</div>
                    </div>
                }
                @if (CanEditPredictions)
                {
                    <button type="button" class="ms-card__chev" @onclick="() => CardToggled.InvokeAsync(slot.Position)" aria-label="@Localizer["Predictions.EditPredictedTotal"]">
                        <AppIcon Name="AppIconName.ChevronRight" Size="16" Class="@ChevronClass(isExpanded)" />
                    </button>
                }
            </div>

            @if (!isExpanded)
            {
                @if (CanEditPredictions)
                {
                    <button type="button" class="ms-clifts" @onclick="() => CardToggled.InvokeAsync(slot.Position)">
                        @if (slot.IsAutoSeeded)
                        {
                            <span class="ms-clifts__muted">@Localizer["Predictions.TopN.MobileTapToRefine"]</span>
                        }
                        else if (isTotal)
                        {
                            <span>@Localizer["Predictions.TopN.MobileTotalManual"]</span>
                        }
                        else
                        {
                            <span>SQ <b>@FormatPred(slot.Placement?.PredictedSquatKg)</b> <span class="ms-clifts__sep">·</span> BP <b>@FormatPred(slot.Placement?.PredictedBenchKg)</b> <span class="ms-clifts__sep">·</span> DL <b>@FormatPred(slot.Placement?.PredictedDeadliftKg)</b></span>
                        }
                        <span class="@PillClass(isTotal)">@(isTotal ? Localizer["Predictions.TopN.ModeTotalShort"] : Localizer["Predictions.TopN.ModeLiftsShort"])</span>
                    </button>
                }
                else
                {
                    <div class="ms-clifts tcl-clifts-static">
                        @if (slot.IsAutoSeeded)
                        {
                            <span class="ms-clifts__muted">@Localizer["Predictions.TopN.MobileReadonlyDefault"]</span>
                        }
                        else if (isTotal)
                        {
                            <span>@Localizer["Predictions.TopN.MobileTotalManual"]</span>
                        }
                        else
                        {
                            <span>SQ <b>@FormatPred(slot.Placement?.PredictedSquatKg)</b> <span class="ms-clifts__sep">·</span> BP <b>@FormatPred(slot.Placement?.PredictedBenchKg)</b> <span class="ms-clifts__sep">·</span> DL <b>@FormatPred(slot.Placement?.PredictedDeadliftKg)</b></span>
                        }
                        <span class="@PillClass(isTotal)">@(isTotal ? Localizer["Predictions.TopN.ModeTotalShort"] : Localizer["Predictions.TopN.ModeLiftsShort"])</span>
                    </div>
                }
            }

            @if (CanEditPredictions)
            {
                <div class="@EditRegionClass(isExpanded)" aria-hidden="@(!isExpanded)" inert="@(isExpanded ? null : string.Empty)">
                <div class="ms-edit-region__inner">
                    <div class="ms-edit">
                        @if (CanEditPredictions)
                        {
                            <div class="ms-edit__seg" role="radiogroup">
                                <button type="button" class="@EsegClass(isTotal)" @onclick="() => SetMode(slot, TopNEntryMode.Total, isTotal)">@Localizer["Predictions.TopN.ModeTotalShort"]</button>
                                <button type="button" class="@EsegClass(!isTotal)" @onclick="() => SetMode(slot, TopNEntryMode.Lifts, isTotal)">@Localizer["Predictions.TopN.ModeLiftsShort"]</button>
                            </div>
                        }

                        @if (isTotal)
                        {
                            <div class="ms-field">
                                <label>@Localizer["Predictions.PredictedTotal"]</label>
                                <div class="ms-field__inp ms-field__inp--total">
                                    <input type="text" inputmode="decimal" value="@FormatCell(slot.Placement?.PredictedTotalKg)" disabled="@(!CanEditPredictions)" @onchange="args => EmitEdit(slot.Position, TopNSheetField.Total, args)" />
                                    <span class="ms-field__u">@Localizer["Predictions.TopN.KgUnit"]</span>
                                    @if (CanEditPredictions)
                                    {
                                        <span class="ms-field__step">
                                            <button type="button" @onclick="() => Nudge(slot.Position, TopNSheetField.Total, 2.5m)" aria-label="+2,5"><AppIcon Name="AppIconName.ChevronRight" Size="11" Class="ms-chevron--up" /></button>
                                            <button type="button" @onclick="() => Nudge(slot.Position, TopNSheetField.Total, -2.5m)" aria-label="-2,5"><AppIcon Name="AppIconName.ChevronRight" Size="11" Class="ms-chevron--down" /></button>
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            @foreach (var lift in Lifts)
                            {
                                <div class="ms-field">
                                    <label>@lift.Label</label>
                                    <div class="ms-field__inp">
                                        <input type="text" inputmode="decimal" value="@FormatCell(lift.Value(slot.Placement))" disabled="@(!CanEditPredictions)" @onchange="args => EmitEdit(slot.Position, lift.Field, args)" />
                                        <span class="ms-field__u">@Localizer["Predictions.TopN.KgUnit"]</span>
                                        @if (CanEditPredictions)
                                        {
                                            <span class="ms-field__step">
                                                <button type="button" @onclick="() => Nudge(slot.Position, lift.Field, 2.5m)" aria-label="+2,5"><AppIcon Name="AppIconName.ChevronRight" Size="11" Class="ms-chevron--up" /></button>
                                                <button type="button" @onclick="() => Nudge(slot.Position, lift.Field, -2.5m)" aria-label="-2,5"><AppIcon Name="AppIconName.ChevronRight" Size="11" Class="ms-chevron--down" /></button>
                                            </span>
                                        }
                                    </div>
                                </div>
                            }

                            <div class="ms-etotal">
                                <span class="ms-etotal__k">@Localizer["Predictions.PredictedTotal"]</span>
                                <span class="ms-etotal__v">@FormatPred(slot.Placement?.PredictedTotalKg) @Localizer["Predictions.TopN.KgUnit"]</span>
                            </div>
                        }

                        @if (CanEditPredictions && (HasAnyQuickFill(slot) || slot.IsHistoryLoading))
                        {
                            <div class="ms-equick">
                                @if (slot.CanUseNominated)
                                {
                                    <button type="button" @onclick="() => QuickFillRequested.InvokeAsync(new TopNQuickFill(slot.Position, TopNQuickFillKind.Nominated))"><span class="ms-equick__ic"><AppIcon Name="AppIconName.Target" Size="12" /></span> @Localizer["Predictions.Profile.Nomination"]</button>
                                }
                                @if (slot.IsHistoryLoading)
                                {
                                    <span class="ms-equick__loading"><span class="topn-spinner" aria-hidden="true"></span> @Localizer["Predictions.LoadingHistory"]</span>
                                }
                                @if (slot.CanUseLast)
                                {
                                    <button type="button" @onclick="() => QuickFillRequested.InvokeAsync(new TopNQuickFill(slot.Position, TopNQuickFillKind.Last))"><span class="ms-equick__ic"><AppIcon Name="AppIconName.Clock" Size="12" /></span> @Localizer["Predictions.LastResult"]</button>
                                }
                                @if (slot.CanUseBest)
                                {
                                    <button type="button" @onclick="() => QuickFillRequested.InvokeAsync(new TopNQuickFill(slot.Position, TopNQuickFillKind.Best))"><span class="ms-equick__ic"><AppIcon Name="AppIconName.Trophy" Size="12" /></span> @Localizer["Predictions.BestResult"]</button>
                                }
                                <button type="button" @onclick="() => AthleteContextRequested.InvokeAsync(slot.Athlete.Id)"><span class="ms-equick__ic"><AppIcon Name="AppIconName.BarChart" Size="12" /></span> @Localizer["Predictions.Analytics"]</button>
                            </div>
                        }

                        <div class="ms-eacts">
                            @if (!slot.IsAutoSeeded && CanEditPredictions)
                            {
                                <button type="button" class="ms-eacts__reset" @onclick="() => ResetRequested.InvokeAsync(slot.Position)">
                                    <AppIcon Name="AppIconName.RotateCcw" Size="14" />
                                    <span>@Localizer["Predictions.TopN.ResetAthleteShort"]</span>
                                </button>
                            }
                            <button type="button" class="ms-eacts__save" @onclick="() => CardToggled.InvokeAsync(slot.Position)">@Localizer["Predictions.SaveAndNext"]</button>
                        </div>
                    </div>
                </div>
            </div>
            }
        </div>

        @if (slot.Position == ScoredCount)
        {
            <div class="ms-cutoff">
                <span>@Localizer["Predictions.TopN.CutoffMobile"]</span>
                <span class="ms-cutoff__line"></span>
                <span>@Localizer["Predictions.TopN.ComparisonZone"]</span>
            </div>
        }
    }

    @if (HiddenCount > 0)
    {
        <button type="button" class="ms-expander" @onclick="ToggleExpanded">
            <span>@(isExpanded ? Localizer["Predictions.TopN.CollapseField"] : Localizer["Predictions.TopN.ExpandField", HiddenCount])</span>
            <AppIcon Name="AppIconName.ChevronRight" Size="14" Class="@ExpanderIconClass" />
            <strong>@Slots.Count</strong>
        </button>
    }
    }
</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<TopNSlotView> Slots { get; set; } = [];

    [Parameter]
    public int ScoredCount { get; set; } = 3;

    [Parameter]
    public bool CanEditPredictions { get; set; }

    [Parameter]
    public bool IsBulkFilling { get; set; }

    [Parameter]
    public bool ComparisonSelectionActive { get; set; }

    [Parameter]
    public IReadOnlyCollection<string> ComparisonSelectedAthleteIds { get; set; } = [];

    [Parameter]
    public int? ExpandedPosition { get; set; }

    [Parameter]
    public EventCallback<int> CardToggled { get; set; }

    [Parameter]
    public EventCallback<TopNMove> MoveRequested { get; set; }

    [Parameter]
    public EventCallback<int> ModeToggled { get; set; }

    [Parameter]
    public EventCallback<TopNSheetEdit> CellEdited { get; set; }

    [Parameter]
    public EventCallback<TopNSheetEdit> NudgeRequested { get; set; }

    [Parameter]
    public EventCallback<TopNQuickFill> QuickFillRequested { get; set; }

    [Parameter]
    public EventCallback<string> AthleteContextRequested { get; set; }

    [Parameter]
    public EventCallback<string> CompareSelectionToggled { get; set; }

    [Parameter]
    public EventCallback<int> ResetRequested { get; set; }

    private bool isExpanded;

    private int PreviewCount => Math.Max(ScoredCount + 2, 5);

    private int HiddenCount => Math.Max(0, Slots.Count - PreviewCount);

    private IReadOnlyList<TopNSlotView> VisibleSlots => isExpanded
        ? Slots
        : Slots.Take(PreviewCount).ToArray();

    private int SkeletonCardCount => Math.Clamp(Slots.Count == 0 ? PreviewCount : Slots.Count, 5, PreviewCount);

    private sealed record LiftField(string Label, string Field, Func<AthletePlacementPick?, decimal?> Value);

    private IReadOnlyList<LiftField> Lifts =>
    [
        new(Localizer["Predictions.TopN.MobileSquat"], TopNSheetField.Squat, p => p?.PredictedSquatKg),
        new(Localizer["Predictions.TopN.MobileBench"], TopNSheetField.Bench, p => p?.PredictedBenchKg),
        new(Localizer["Predictions.TopN.MobileDeadlift"], TopNSheetField.Deadlift, p => p?.PredictedDeadliftKg),
    ];

    private void ToggleExpanded() => isExpanded = !isExpanded;

    private static bool HasAnyQuickFill(TopNSlotView slot) =>
        slot.CanUseNominated || slot.CanUseLast || slot.CanUseBest;

    private bool IsCompareSelected(TopNSlotView slot) =>
        slot.Athlete is not null &&
        ComparisonSelectedAthleteIds.Contains(slot.Athlete.Id, StringComparer.OrdinalIgnoreCase);

    private Task SetMode(TopNSlotView slot, string mode, bool isTotal)
    {
        var wantTotal = string.Equals(mode, TopNEntryMode.Total, StringComparison.OrdinalIgnoreCase);
        return isTotal == wantTotal ? Task.CompletedTask : ModeToggled.InvokeAsync(slot.Position);
    }

    private Task EmitEdit(int position, string field, ChangeEventArgs args) =>
        CellEdited.InvokeAsync(new TopNSheetEdit(position, field, args.Value?.ToString() ?? string.Empty));

    private Task Nudge(int position, string field, decimal delta) =>
        NudgeRequested.InvokeAsync(new TopNSheetEdit(position, field, delta.ToString(CultureInfo.InvariantCulture)));

    private string CardClass(TopNSlotView slot, bool expanded) => string.Join(
        " ",
        "ms-card",
        slot.Position == 1 ? "ms-card--lead" : null,
        slot.Position > PreviewCount ? "ms-card--tail" : null,
        !slot.IsAutoSeeded ? "ms-card--authored" : null,
        expanded ? "ms-card--editing" : null,
        slot.IsContextActive ? "ms-card--context" : null,
        IsCompareSelected(slot) ? "ms-card--compare-selected" : null);

    private static string RankClass(int position) => string.Join(
        " ",
        "ms-card__rk",
        position is >= 1 and <= 3 ? $"ms-card__rk--p{position}" : null);

    private static string PredValueClass(bool isAutoSeeded) =>
        isAutoSeeded ? "ms-card__pred-v ms-card__pred-v--default" : "ms-card__pred-v";

    private static string SourceClass(bool isAutoSeeded) =>
        isAutoSeeded ? "ms-card__pred-src" : "ms-card__pred-src ms-card__pred-src--mine";

    private string MobileComparePickClass(TopNSlotView slot) => string.Join(
        " ",
        "ms-compare-pick",
        IsCompareSelected(slot) ? "ms-compare-pick--on" : null);

    private string CompareAriaPressed(TopNSlotView slot) =>
        IsCompareSelected(slot) ? "true" : "false";

    private string SourceText(TopNSlotView slot)
    {
        if (slot.IsAutoSeeded)
        {
            return Localizer["Predictions.TopN.ByNomination"];
        }

        var delta = (slot.Placement?.PredictedTotalKg ?? slot.NominatedTotalKg ?? 0m) - (slot.NominatedTotalKg ?? 0m);
        return delta == 0
            ? Localizer["Predictions.TopN.EqualNom"].Value
            : $"{(delta > 0 ? "+" : string.Empty)}{delta.ToString("0.#", CultureInfo.CurrentCulture)}";
    }

    private static string PillClass(bool isTotal) =>
        isTotal ? "ms-clifts__pill ms-clifts__pill--total" : "ms-clifts__pill";

    private static string EsegClass(bool on) =>
        on ? "ms-edit__seg-btn ms-edit__seg-btn--on" : "ms-edit__seg-btn";

    private static string ChevronClass(bool expanded) =>
        expanded ? "ms-card__chev-icon ms-card__chev-icon--expanded" : "ms-card__chev-icon";

    private static string EditRegionClass(bool expanded) =>
        expanded ? "ms-edit-region ms-edit-region--open" : "ms-edit-region";

    private string ExpanderIconClass => isExpanded ? "ms-expander__icon ms-expander__icon--up" : "ms-expander__icon";

    private string CountryLine(Athlete athlete)
    {
        var country = athlete.CountryName ?? athlete.CountryCode ?? string.Empty;
        if (athlete.SeedTotalKg is null)
        {
            return country;
        }

        var nomination = $"{Localizer["Predictions.NominatedShort"]} {athlete.SeedTotalKg.Value.ToString("0.#", CultureInfo.CurrentCulture)}";
        return string.IsNullOrWhiteSpace(country) ? nomination : $"{country} · {nomination}";
    }

    private static string Initials(Athlete athlete)
    {
        var parts = athlete.DisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant(),
            _ => $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant()
        };
    }

    private static string FormatPred(decimal? value) => value?.ToString("0.#", CultureInfo.CurrentCulture) ?? "—";

    private static string FormatCell(decimal? value) => value?.ToString("0.###", CultureInfo.CurrentCulture) ?? string.Empty;
}
