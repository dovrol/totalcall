@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer

<div class="@SheetClass">
    <div class="topn-sheet__head" aria-hidden="true">
        <span class="topn-sheet__th"></span>
        <span class="topn-sheet__th">@Localizer["Predictions.TopN.ColAthlete"]</span>
        <span class="topn-sheet__th topn-sheet__th--num">SQ <small>@Localizer["Predictions.TopN.KgUnit"]</small></span>
        <span class="topn-sheet__th topn-sheet__th--num">BP <small>@Localizer["Predictions.TopN.KgUnit"]</small></span>
        <span class="topn-sheet__th topn-sheet__th--num">DL <small>@Localizer["Predictions.TopN.KgUnit"]</small></span>
        <span class="topn-sheet__th topn-sheet__th--num">@Localizer["Predictions.PredictedShort"]</span>
        <span class="topn-sheet__th topn-sheet__th--num">@(ShowResults ? Localizer["Predictions.TopN.ResultColumn"] : Localizer["Predictions.TopN.DeltaNom"])</span>
        <span class="topn-sheet__th"></span>
    </div>

    <div class="@SheetBodyClass" aria-busy="@IsBulkFilling">
        @if (IsBulkFilling)
        {
            @for (var index = 0; index < SkeletonRowCount; index++)
            {
                <div class="topn-rowgroup topn-sheet-skeleton__rowgroup" aria-hidden="true">
                    <div class="topn-row topn-sheet-skeleton__row">
                        <div class="topn-cell">
                            <div class="topn-pos">
                                <span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--grip"></span>
                                <span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--rank"></span>
                            </div>
                        </div>
                        <div class="topn-cell">
                            <div class="topn-who">
                                <span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--avatar"></span>
                                <span class="topn-sheet-skeleton__who-lines">
                                    <span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--name"></span>
                                    <span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--meta"></span>
                                    <span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--badge"></span>
                                </span>
                            </div>
                        </div>
                        <div class="topn-cell topn-cell--num"><span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--input"></span></div>
                        <div class="topn-cell topn-cell--num"><span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--input"></span></div>
                        <div class="topn-cell topn-cell--num"><span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--input"></span></div>
                        <div class="topn-cell topn-cell--num"><span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--total"></span></div>
                        <div class="topn-cell topn-cell--num"><span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--delta"></span></div>
                        <div class="topn-cell"><span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--actions"></span></div>
                    </div>
                </div>

                @if (index == ScoredCount - 1)
                {
                    <div class="topn-cutoff topn-sheet-skeleton__cutoff" aria-hidden="true">
                        <span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--cutoff-label"></span>
                        <span class="topn-cutoff__line"></span>
                        <span class="topn-sheet-skeleton__bone topn-sheet-skeleton__bone--cutoff-hint"></span>
                    </div>
                }
            }
        }
        else
        {
            @foreach (var slot in VisibleSlots)
        {
            @if (ShowDropLine(slot.Position))
            {
                <div class="topn-dropline"><span class="topn-dropline__label">@Localizer["Predictions.TopN.DropTo", slot.Position]</span></div>
            }

            var isTotal = string.Equals(slot.Mode, TopNEntryMode.Total, StringComparison.OrdinalIgnoreCase);

            <div @key="slot.Athlete!.Id" class="@RowGroupClass(slot)" data-topn-athlete-id="@slot.Athlete!.Id">
                <div
                    class="@RowClass(slot)"
                    @ondragover:preventDefault="true"
                    @ondragenter="() => DragEntered.InvokeAsync(slot.Position)"
                    @ondrop="() => Dropped.InvokeAsync(slot.Position)">
                    <div class="topn-cell">
                        <div class="topn-pos">
                            @if (ComparisonSelectionActive)
                            {
                                <button
                                    type="button"
                                    class="@ComparePickClass(slot)"
                                    aria-label="@Localizer["Predictions.Compare.ToggleAthlete", slot.Athlete.DisplayName]"
                                    aria-pressed="@CompareAriaPressed(slot)"
                                    @onclick="() => CompareSelectionToggled.InvokeAsync(slot.Athlete.Id)">
                                    @if (IsCompareSelected(slot))
                                    {
                                        <AppIcon Name="AppIconName.Check" Size="14" />
                                    }
                                </button>
                            }
                            else if (CanEditPredictions)
                            {
                                <span
                                    class="topn-grip"
                                    draggable="@DraggableValue"
                                    title="@Localizer["Predictions.TopN.DragHint"]"
                                    @ondragstart="() => DragStarted.InvokeAsync(slot.Position)"
                                    @ondragend="() => DragEnded.InvokeAsync()">
                                    <AppIcon Name="AppIconName.GripVertical" Size="14" />
                                </span>
                            }
                            <span class="@RankClass(slot.Position)">@slot.Position</span>
                            @if (CanEditPredictions && !ComparisonSelectionActive)
                            {
                                <span class="topn-pos__move">
                                    <button
                                        type="button"
                                        disabled="@(!slot.CanMoveUp)"
                                        aria-label="@Localizer["Predictions.MoveUp"]"
                                        @onclick="() => MoveRequested.InvokeAsync(new TopNMove(slot.Position, -1))">
                                        <AppIcon Name="AppIconName.ChevronRight" Size="10" Class="topn-pos__up" />
                                    </button>
                                    <button
                                        type="button"
                                        disabled="@(!slot.CanMoveDown)"
                                        aria-label="@Localizer["Predictions.MoveDown"]"
                                        @onclick="() => MoveRequested.InvokeAsync(new TopNMove(slot.Position, 1))">
                                        <AppIcon Name="AppIconName.ChevronRight" Size="10" Class="topn-pos__down" />
                                    </button>
                                </span>
                            }
                        </div>
                    </div>

                    <div class="topn-cell">
                        <div class="topn-who">
                            <span class="topn-who__av">@Initials(slot.Athlete!)</span>
                            <div class="topn-who__text">
                                <div class="topn-who__name">
                                    <span>@slot.Athlete!.DisplayName</span>
                                    <CountryFlag Code="@slot.Athlete.CountryCode" CountryName="@slot.Athlete.CountryName" Class="topn-who__flag" />
                                </div>
                                <div class="topn-who__nom">
                                    @Localizer["Predictions.NominatedShort"]
                                    <strong>@FormatKg(slot.NominatedTotalKg)</strong>
                                    @if (!string.IsNullOrWhiteSpace(slot.Athlete.CountryName))
                                    {
                                        <span> · @slot.Athlete.CountryName</span>
                                    }
                                </div>
                                <div class="topn-who__badges">
                                    <span class="@SourceBadgeClass(slot.IsAutoSeeded)">
                                        @if (!slot.IsAutoSeeded)
                                        {
                                            <span class="topn-source-badge__dot"></span>
                                        }
                                        @(slot.IsAutoSeeded ? Localizer["Predictions.TopN.ByNomination"] : Localizer["Predictions.TopN.YourPick"])
                                    </span>
                                    @if (slot.IsWithdrawn)
                                    {
                                        <span class="topn-withdrawn-badge">@Localizer["Predictions.Roster.Withdrawn"]</span>
                                    }
                                    @if (CanEditPredictions)
                                    {
                                        <button
                                            type="button"
                                            class="@ModePillClass(isTotal)"
                                            @onclick="() => ModeToggled.InvokeAsync(slot.Position)"
                                            title="@Localizer["Predictions.TopN.ToggleMode"]">
                                            <span>@(isTotal ? Localizer["Predictions.TopN.ModeTotalShort"] : Localizer["Predictions.TopN.ModeLiftsShort"])</span>
                                            <AppIcon Name="AppIconName.ArrowLeftRight" Size="10" Class="topn-modepill__swap" />
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (isTotal && CanEditPredictions)
                    {
                        <div class="topn-cell topn-cell--num"><span class="topn-input topn-input--locked">—</span></div>
                        <div class="topn-cell topn-cell--num"><span class="topn-input topn-input--locked">—</span></div>
                        <div class="topn-cell topn-cell--num"><span class="topn-input topn-input--locked">—</span></div>
                        <div class="topn-cell topn-cell--num">
                            <div class="@TotalEditClass(slot.IsAutoSeeded)">
                                <input
                                    class="topn-total-edit__input"
                                    type="text"
                                    inputmode="decimal"
                                    value="@FormatCell(slot.Placement?.PredictedTotalKg)"
                                    disabled="@(!CanEditPredictions)"
                                    @onchange="args => EmitEdit(slot.Position, TopNSheetField.Total, args)" />
                                <span class="topn-total-edit__unit">@Localizer["Predictions.TopN.KgUnit"]</span>
                            </div>
                        </div>
                    }
                    else if (isTotal)
                    {
                        <div class="topn-cell topn-cell--num"><span class="tcl-static tcl-static--muted">—</span></div>
                        <div class="topn-cell topn-cell--num"><span class="tcl-static tcl-static--muted">—</span></div>
                        <div class="topn-cell topn-cell--num"><span class="tcl-static tcl-static--muted">—</span></div>
                        <div class="topn-cell topn-cell--num">
                            <span class="@StaticValueClass(slot.Placement?.PredictedTotalKg)">@FormatPred(slot.Placement?.PredictedTotalKg)</span>
                        </div>
                    }
                    else if (!CanEditPredictions)
                    {
                        <div class="topn-cell topn-cell--num">
                            <span class="@StaticValueClass(slot.Placement?.PredictedSquatKg)">@FormatPred(slot.Placement?.PredictedSquatKg)</span>
                        </div>
                        <div class="topn-cell topn-cell--num">
                            <span class="@StaticValueClass(slot.Placement?.PredictedBenchKg)">@FormatPred(slot.Placement?.PredictedBenchKg)</span>
                        </div>
                        <div class="topn-cell topn-cell--num">
                            <span class="@StaticValueClass(slot.Placement?.PredictedDeadliftKg)">@FormatPred(slot.Placement?.PredictedDeadliftKg)</span>
                        </div>
                        <div class="topn-cell topn-cell--num">
                            <span class="@PredClass(slot.IsAutoSeeded)">
                                <small>@(slot.IsAutoSeeded ? Localizer["Predictions.TopN.ByNominationShort"] : Localizer["Predictions.PredictedShort"])</small>
                                @FormatPred(slot.Placement?.PredictedTotalKg)
                            </span>
                        </div>
                    }
                    else
                    {
                        <div class="topn-cell topn-cell--num">
                            <input class="topn-input" type="text" inputmode="decimal" value="@FormatCell(slot.Placement?.PredictedSquatKg)" placeholder="·" disabled="@(!CanEditPredictions)" @onchange="args => EmitEdit(slot.Position, TopNSheetField.Squat, args)" />
                        </div>
                        <div class="topn-cell topn-cell--num">
                            <input class="topn-input" type="text" inputmode="decimal" value="@FormatCell(slot.Placement?.PredictedBenchKg)" placeholder="·" disabled="@(!CanEditPredictions)" @onchange="args => EmitEdit(slot.Position, TopNSheetField.Bench, args)" />
                        </div>
                        <div class="topn-cell topn-cell--num">
                            <input class="topn-input" type="text" inputmode="decimal" value="@FormatCell(slot.Placement?.PredictedDeadliftKg)" placeholder="·" disabled="@(!CanEditPredictions)" @onchange="args => EmitEdit(slot.Position, TopNSheetField.Deadlift, args)" />
                        </div>
                        <div class="topn-cell topn-cell--num">
                            <span class="@PredClass(slot.IsAutoSeeded)">
                                <small>@(slot.IsAutoSeeded ? Localizer["Predictions.TopN.ByNominationShort"] : Localizer["Predictions.PredictedShort"])</small>
                                @FormatPred(slot.Placement?.PredictedTotalKg)
                            </span>
                        </div>
                    }

                    <div class="topn-cell topn-cell--num">
                        @if (ShowResults && TryGetResult(slot.Athlete!.Id, out var result) && (result.OfficialPlace is not null || result.Verdict is not null))
                        {
                            <span class="topn-result">
                                @if (result.OfficialPlace is not null)
                                {
                                    <span class="@PlaceClass(result.OfficialPlace)">
                                        @if (result.OfficialPlace is >= 1 and <= 3)
                                        {
                                            <AppIcon Name="AppIconName.Medal" Size="12" Class="rbs-place__ic" />
                                        }
                                        @PlaceLabel(result.OfficialPlace)
                                    </span>
                                }
                                @if (result.Verdict is not null)
                                {
                                    <ResultBadge Verdict="@result.Verdict" Small="true" />
                                }
                            </span>
                        }
                        else if (ShowResults)
                        {
                            <span class="rbs-muted">—</span>
                        }
                        else
                        {
                            <span class="@DeltaClass(slot)">
                                @FormatDeltaFromNom(slot)
                                <small>@Localizer["Predictions.TopN.VsNom"]</small>
                            </span>
                        }
                    </div>

                    <div class="topn-cell">
                        <div class="topn-row__acts">
                            <button type="button" class="topn-row__act topn-row__act--ctx" title="@Localizer["Predictions.Tab.Context"]" aria-label="@Localizer["Predictions.Tab.Context"]" @onclick="() => AthleteContextRequested.InvokeAsync(slot.Athlete.Id)">
                                <AppIcon Name="AppIconName.BarChart" Size="13" />
                            </button>
                            @if (CanEditPredictions)
                            {
                                <div class="topn-fillwrap">
                                    <button type="button" class="@FillButtonClass(slot.Position)" title="@Localizer["Predictions.TopN.FillFromData"]" aria-label="@Localizer["Predictions.TopN.FillFromData"]" @onclick="() => FillPopToggled.InvokeAsync(slot.Position)">
                                        <AppIcon Name="AppIconName.Sparkles" Size="13" />
                                    </button>
                                    @if (FillPopPosition == slot.Position)
                                    {
                                        <div class="@FillPopoverClass(slot.Position)">
                                            <div class="topn-fillpop__head">@Localizer["Predictions.TopN.FillFromHeading"]</div>
                                            @if (slot.CanUseNominated)
                                            {
                                                <button type="button" class="topn-fill-opt" @onclick="() => QuickFillRequested.InvokeAsync(new TopNQuickFill(slot.Position, TopNQuickFillKind.Nominated))">
                                                    <span class="topn-fill-opt__ic"><AppIcon Name="AppIconName.Target" Size="13" /></span>
                                                    <span class="topn-fill-opt__t">@Localizer["Predictions.NominatedTotal"]</span>
                                                    <span class="topn-fill-opt__v">@FormatPred(slot.NominatedTotalKg)</span>
                                                </button>
                                            }
                                            @if (slot.IsHistoryLoading)
                                            {
                                                <div class="topn-fill-opt topn-fill-opt--loading">
                                                    <span class="topn-spinner" aria-hidden="true"></span>
                                                    <span class="topn-fill-opt__t">@Localizer["Predictions.LoadingHistory"]</span>
                                                </div>
                                            }
                                            @if (slot.CanUseLast)
                                            {
                                                <button type="button" class="topn-fill-opt" @onclick="() => QuickFillRequested.InvokeAsync(new TopNQuickFill(slot.Position, TopNQuickFillKind.Last))">
                                                    <span class="topn-fill-opt__ic"><AppIcon Name="AppIconName.Clock" Size="13" /></span>
                                                    <span class="topn-fill-opt__t">@Localizer["Predictions.LastResult"]</span>
                                                    <span class="topn-fill-opt__v">@FormatPred(slot.LastTotalKg)</span>
                                                </button>
                                            }
                                            @if (slot.CanUseBest)
                                            {
                                                <button type="button" class="topn-fill-opt" @onclick="() => QuickFillRequested.InvokeAsync(new TopNQuickFill(slot.Position, TopNQuickFillKind.Best))">
                                                    <span class="topn-fill-opt__ic"><AppIcon Name="AppIconName.Trophy" Size="13" /></span>
                                                    <span class="topn-fill-opt__t">@Localizer["Predictions.BestResult"]</span>
                                                    <span class="topn-fill-opt__v">@FormatPred(slot.BestTotalKg)</span>
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                                @if (!slot.IsAutoSeeded)
                                {
                                    <button type="button" class="topn-row__act topn-row__act--reset" title="@Localizer["Predictions.TopN.ResetAthlete"]" aria-label="@Localizer["Predictions.TopN.ResetAthlete"]" @onclick="() => ResetRequested.InvokeAsync(slot.Position)">
                                        <AppIcon Name="AppIconName.RotateCcw" Size="13" />
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>

                @if (slot.IsWithdrawn && slot.IsScored)
                {
                    <div class="topn-row-warning" role="alert">
                        <AppIcon Name="AppIconName.AlertCircle" Size="14" />
                        <span>@Localizer[CanEditPredictions ? "Predictions.Roster.PickWarningEditable" : "Predictions.Roster.PickWarningLocked"]</span>
                    </div>
                }
            </div>

            @if (slot.Position == ScoredCount)
            {
                <div class="topn-cutoff">
                    <span class="topn-cutoff__label"><AppIcon Name="AppIconName.Medal" Size="13" /> @Localizer["Predictions.TopN.CutoffLabel", ScoredCount]</span>
                    <span class="topn-cutoff__line"></span>
                    <span class="topn-cutoff__hint">@(CanEditPredictions ? Localizer["Predictions.TopN.CutoffHint"] : Localizer["Predictions.TopN.CutoffHintReadonly"])</span>
                </div>
            }
        }

        @if (HiddenCount > 0)
        {
            <button type="button" class="topn-expander" @onclick="ToggleExpanded">
                <span>@(isExpanded ? Localizer["Predictions.TopN.CollapseField"] : Localizer["Predictions.TopN.ExpandField", HiddenCount])</span>
                <AppIcon Name="AppIconName.ChevronRight" Size="14" Class="@ExpanderIconClass" />
                <strong>@Localizer["Predictions.TopN.FieldCount", Slots.Count]</strong>
            </button>
        }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<TopNSlotView> Slots { get; set; } = [];

    [Parameter]
    public int ScoredCount { get; set; } = 3;

    [Parameter]
    public IReadOnlyDictionary<string, TopNSlotResult>? Results { get; set; }

    [Parameter]
    public bool CanEditPredictions { get; set; }

    [Parameter]
    public bool IsBulkFilling { get; set; }

    [Parameter]
    public bool ComparisonSelectionActive { get; set; }

    [Parameter]
    public IReadOnlyCollection<string> ComparisonSelectedAthleteIds { get; set; } = [];

    [Parameter]
    public int? FillPopPosition { get; set; }

    [Parameter]
    public int? DraggingPosition { get; set; }

    [Parameter]
    public int? DragOverPosition { get; set; }

    [Parameter]
    public EventCallback<TopNMove> MoveRequested { get; set; }

    [Parameter]
    public EventCallback<string> AthleteContextRequested { get; set; }

    [Parameter]
    public EventCallback<string> CompareSelectionToggled { get; set; }

    [Parameter]
    public EventCallback<int> ResetRequested { get; set; }

    [Parameter]
    public EventCallback<int> ModeToggled { get; set; }

    [Parameter]
    public EventCallback<TopNSheetEdit> CellEdited { get; set; }

    [Parameter]
    public EventCallback<int> FillPopToggled { get; set; }

    [Parameter]
    public EventCallback<TopNQuickFill> QuickFillRequested { get; set; }

    [Parameter]
    public EventCallback<int> DragStarted { get; set; }

    [Parameter]
    public EventCallback<int> DragEntered { get; set; }

    [Parameter]
    public EventCallback<int> Dropped { get; set; }

    [Parameter]
    public EventCallback DragEnded { get; set; }

    private bool isExpanded;

    private bool ShowResults => Results is not null;

    private bool TryGetResult(string athleteId, out TopNSlotResult result)
    {
        if (Results is not null && !string.IsNullOrEmpty(athleteId) && Results.TryGetValue(athleteId, out var found))
        {
            result = found;
            return true;
        }

        result = default!;
        return false;
    }

    private static string PlaceClass(int? place) => place switch
    {
        1 => "rbs-place rbs-place--p1",
        2 => "rbs-place rbs-place--p2",
        3 => "rbs-place rbs-place--p3",
        _ => "rbs-place rbs-place--out"
    };

    private string PlaceLabel(int? place) => place is null
        ? Localizer["Predictions.TopN.ResultOutShort"]
        : $"{place}.";

    private int PreviewCount => Math.Max(ScoredCount + 2, 5);

    private int HiddenCount => Math.Max(0, Slots.Count - PreviewCount);

    private string DraggableValue => CanEditPredictions && !ComparisonSelectionActive ? "true" : "false";

    private IReadOnlyList<TopNSlotView> VisibleSlots => isExpanded
        ? Slots
        : Slots.Take(PreviewCount).ToArray();

    private int SkeletonRowCount => Math.Clamp(Slots.Count == 0 ? 6 : Slots.Count, 5, 8);

    private string SheetClass => string.Join(
        " ",
        "topn-sheet",
        CanEditPredictions ? null : "tcl-readonly");

    private string SheetBodyClass => string.Join(
        " ",
        "topn-sheet__body",
        IsBulkFilling ? "topn-sheet__body--busy" : null);

    private void ToggleExpanded() => isExpanded = !isExpanded;

    private Task EmitEdit(int position, string field, ChangeEventArgs args) =>
        CellEdited.InvokeAsync(new TopNSheetEdit(position, field, args.Value?.ToString() ?? string.Empty));

    private bool ShowDropLine(int position) =>
        DraggingPosition is not null &&
        DragOverPosition == position &&
        DraggingPosition != position;

    private bool IsCompareSelected(TopNSlotView slot) =>
        slot.Athlete is not null &&
        ComparisonSelectedAthleteIds.Contains(slot.Athlete.Id, StringComparer.OrdinalIgnoreCase);

    private string RowGroupClass(TopNSlotView slot) => string.Join(
        " ",
        "topn-rowgroup",
        slot.IsScored ? "topn-rowgroup--scored" : null,
        slot.Position > PreviewCount ? "topn-rowgroup--tail" : null,
        !slot.IsAutoSeeded ? "topn-rowgroup--authored" : null,
        slot.IsWithdrawn ? "topn-rowgroup--withdrawn" : null,
        FillPopPosition == slot.Position ? "topn-rowgroup--popover-open" : null,
        slot.IsContextActive ? "topn-rowgroup--context" : null);

    private string RowClass(TopNSlotView slot) => string.Join(
        " ",
        "topn-row",
        slot.Position == 1 ? "topn-row--lead" : null,
        slot.IsWithdrawn ? "topn-row--withdrawn" : null,
        slot.IsContextActive ? "topn-row--context" : null,
        IsCompareSelected(slot) ? "topn-row--compare-selected" : null,
        DraggingPosition == slot.Position ? "topn-row--dragging" : null,
        DraggingPosition is not null && DraggingPosition != slot.Position ? "topn-row--shifted" : null);

    private static string RankClass(int position) => string.Join(
        " ",
        "topn-row__rank",
        position is >= 1 and <= 3 ? $"topn-row__rank--p{position}" : null);

    private static string SourceBadgeClass(bool isAutoSeeded) =>
        isAutoSeeded ? "topn-source-badge topn-source-badge--default" : "topn-source-badge topn-source-badge--mine";

    private string ComparePickClass(TopNSlotView slot) => string.Join(
        " ",
        "topn-compare-pick",
        IsCompareSelected(slot) ? "topn-compare-pick--on" : null);

    private string CompareAriaPressed(TopNSlotView slot) =>
        IsCompareSelected(slot) ? "true" : "false";

    private static string ModePillClass(bool isTotal) =>
        isTotal ? "topn-modepill topn-modepill--total" : "topn-modepill";

    private static string TotalEditClass(bool isAutoSeeded) =>
        isAutoSeeded ? "topn-total-edit topn-total-edit--default" : "topn-total-edit";

    private static string PredClass(bool isAutoSeeded) =>
        isAutoSeeded ? "topn-pred topn-pred--muted" : "topn-pred";

    private static string StaticValueClass(decimal? value) =>
        value is null ? "tcl-static tcl-static--muted" : "tcl-static";

    private string DeltaClass(TopNSlotView slot) => string.Join(
        " ",
        "topn-delta",
        slot.IsAutoSeeded ? "topn-delta--muted" : DeltaValue(slot) switch
        {
            > 0 => "topn-delta--up",
            < 0 => "topn-delta--down",
            _ => "topn-delta--equal"
        });

    private string FillButtonClass(int position) => string.Join(
        " ",
        "topn-row__act",
        "topn-row__act--fill",
        FillPopPosition == position ? "topn-row__act--fill-on" : null);

    private string FillPopoverClass(int position) => string.Join(
        " ",
        "topn-fillpop",
        "topn-fillpop--actions",
        position > ScoredCount ? "topn-fillpop--up" : null);

    private string ExpanderIconClass => isExpanded ? "topn-expander__icon topn-expander__icon--up" : "topn-expander__icon";

    private static decimal DeltaValue(TopNSlotView slot) =>
        (slot.Placement?.PredictedTotalKg ?? slot.NominatedTotalKg ?? 0m) - (slot.NominatedTotalKg ?? 0m);

    private string FormatDeltaFromNom(TopNSlotView slot)
    {
        if (slot.IsAutoSeeded)
        {
            return "—";
        }

        var delta = DeltaValue(slot);
        return delta == 0m
            ? "="
            : $"{(delta > 0 ? "+" : string.Empty)}{delta.ToString("0.#", CultureInfo.CurrentCulture)}";
    }

    private string FormatKg(decimal? value) => value is null
        ? Localizer["Common.Tbd"].Value
        : $"{value.Value.ToString("0.#", CultureInfo.CurrentCulture)} {Localizer["Predictions.TopN.KgUnit"]}";

    private static string FormatPred(decimal? value) => value?.ToString("0.#", CultureInfo.CurrentCulture) ?? "—";

    private static string FormatCell(decimal? value) => value?.ToString("0.###", CultureInfo.CurrentCulture) ?? string.Empty;

    private static string Initials(Athlete athlete)
    {
        var parts = athlete.DisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant(),
            _ => $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant()
        };
    }
}
