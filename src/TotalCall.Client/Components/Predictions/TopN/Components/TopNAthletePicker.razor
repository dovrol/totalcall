@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer

<div class="topn-picker-scrim" @onclick="() => Dismissed.InvokeAsync()">
    <div class="topn-picker" @onclick:stopPropagation="true" role="dialog" aria-modal="true">
        <div class="topn-picker__head">
            <span class="topn-picker__slot">@SlotPosition</span>
            <div class="topn-picker__title">
                @Localizer["Predictions.TopN.PickerTitle", SlotPosition]
                <small>@CategoryName · @CompetitionName</small>
            </div>
            <button type="button" class="topn-picker__close" aria-label="@Localizer["Predictions.CloseContext"]" @onclick="() => Dismissed.InvokeAsync()">
                <AppIcon Name="AppIconName.X" Size="15" />
            </button>
        </div>

        <div class="topn-picker__controls">
            <div class="topn-picker__search">
                <AppIcon Name="AppIconName.Search" Size="15" Class="topn-picker__search-icon" />
                <input
                    type="text"
                    value="@_query"
                    @oninput="OnQueryInput"
                    placeholder="@Localizer["Predictions.SearchAthletePlaceholder"]"
                    aria-label="@Localizer["Predictions.SearchAthletePlaceholder"]" />
            </div>
            <label class="topn-picker__sort">
                <span>@Localizer["Predictions.SortBy"]</span>
                <select value="@_sort" @onchange="OnSortChanged">
                    <option value="nom-desc">@Localizer["Predictions.SortNominatedDesc"]</option>
                    <option value="nom-asc">@Localizer["Predictions.SortNominatedAsc"]</option>
                    <option value="name">@Localizer["Predictions.SortNameAsc"]</option>
                </select>
            </label>
        </div>

        <div class="topn-picker__list">
            @if (VisibleAthletes.Count == 0)
            {
                <div class="topn-picker__empty">@Localizer["Predictions.TopN.PaletteNoResults"]</div>
            }
            else
            {
                @foreach (var athlete in VisibleAthletes)
                {
                    var isPicked = PickedAthleteIds.Contains(athlete.Id);

                    <div class="@RowClass(isPicked)">
                        <span class="topn-picker__rank">@SeedRank(athlete.Id)</span>
                        <span class="topn-picker__av">@Initials(athlete)</span>
                        <div class="topn-picker__who">
                            <div class="topn-picker__name">@athlete.DisplayName</div>
                            <div class="topn-picker__country">
                                <CountryFlag Code="@athlete.CountryCode" CountryName="@athlete.CountryName" Class="topn-picker__flag" />
                                <span>@(athlete.CountryName ?? athlete.CountryCode)</span>
                            </div>
                        </div>
                        <div class="topn-picker__nom">
                            <div class="topn-picker__nom-k">@Localizer["Predictions.NominatedShort"]</div>
                            <div class="topn-picker__nom-v">@FormatNom(athlete.SeedTotalKg)</div>
                        </div>
                        @if (isPicked)
                        {
                            <span class="topn-picker__taken">
                                <AppIcon Name="AppIconName.Check" Size="13" />
                                @Localizer["Predictions.Picked"]
                            </span>
                        }
                        else
                        {
                            <button type="button" class="topn-picker__pick" @onclick="() => AthletePicked.InvokeAsync(athlete.Id)">
                                @PickLabel
                            </button>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int SlotPosition { get; set; }

    [Parameter, EditorRequired]
    public string CategoryName { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string CompetitionName { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public IReadOnlyList<Athlete> Athletes { get; set; } = [];

    [Parameter]
    public IReadOnlyCollection<string> PickedAthleteIds { get; set; } = [];

    [Parameter]
    public string? PickButtonLabel { get; set; }

    [Parameter]
    public EventCallback<string> AthletePicked { get; set; }

    [Parameter]
    public EventCallback Dismissed { get; set; }

    private string _query = string.Empty;
    private string _sort = "nom-desc";
    private IReadOnlyDictionary<string, int> _seedRanks = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);

    private string PickLabel => string.IsNullOrWhiteSpace(PickButtonLabel)
        ? Localizer["Predictions.Pick"].Value
        : PickButtonLabel;

    protected override void OnParametersSet()
    {
        _seedRanks = Athletes
            .OrderByDescending(athlete => athlete.SeedTotalKg ?? 0m)
            .ThenBy(athlete => athlete.DisplayName, StringComparer.OrdinalIgnoreCase)
            .Select((athlete, index) => (athlete.Id, Rank: index + 1))
            .ToDictionary(item => item.Id, item => item.Rank, StringComparer.OrdinalIgnoreCase);
    }

    private void OnQueryInput(ChangeEventArgs args) => _query = args.Value?.ToString() ?? string.Empty;

    private void OnSortChanged(ChangeEventArgs args) => _sort = args.Value?.ToString() ?? "nom-desc";

    private IReadOnlyList<Athlete> VisibleAthletes
    {
        get
        {
            var filtered = Athletes.Where(Matches);

            return _sort switch
            {
                "nom-asc" => filtered
                    .OrderBy(athlete => athlete.SeedTotalKg ?? decimal.MaxValue)
                    .ThenBy(athlete => athlete.DisplayName, StringComparer.OrdinalIgnoreCase)
                    .ToArray(),
                "name" => filtered
                    .OrderBy(athlete => athlete.DisplayName, StringComparer.OrdinalIgnoreCase)
                    .ToArray(),
                _ => filtered
                    .OrderByDescending(athlete => athlete.SeedTotalKg ?? 0m)
                    .ThenBy(athlete => athlete.DisplayName, StringComparer.OrdinalIgnoreCase)
                    .ToArray()
            };
        }
    }

    private bool Matches(Athlete athlete)
    {
        if (string.IsNullOrWhiteSpace(_query))
        {
            return true;
        }

        return athlete.DisplayName.Contains(_query, StringComparison.OrdinalIgnoreCase) ||
               (athlete.CountryName?.Contains(_query, StringComparison.OrdinalIgnoreCase) ?? false) ||
               (athlete.CountryCode?.Contains(_query, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private int SeedRank(string athleteId) => _seedRanks.TryGetValue(athleteId, out var rank) ? rank : 0;

    private string RowClass(bool isPicked) => string.Join(
        " ",
        "topn-picker__row",
        isPicked ? "topn-picker__row--taken" : null);

    private string FormatNom(decimal? value) => value is null
        ? Localizer["Common.Tbd"].Value
        : $"{value.Value.ToString("0.#", CultureInfo.CurrentCulture)} {Localizer["Predictions.TopN.KgUnit"]}";

    private static string Initials(Athlete athlete)
    {
        var parts = athlete.DisplayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length == 0)
        {
            return "?";
        }

        if (parts.Length == 1)
        {
            return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
        }

        return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
    }
}
