@inject IStringLocalizer<SharedResource> Localizer

<nav class="prediction-action-bar prediction-action-bar--review" aria-label="@Localizer["Review.ActionBarAria"]">
    <div class="prediction-action-bar__left">
        <AppButton
            Href="@EditHref"
            Variant="Ghost"
            Size="Sm"
            AriaLabel="@Localizer["Review.EditPredictions"]"
            AdditionalClass="prediction-action-bar__back">
            <AppIcon Name="AppIconName.PencilLine" Size="15" />
            <span>@Localizer["Review.EditPredictions"]</span>
        </AppButton>
    </div>

    <div class="prediction-action-bar__status" aria-hidden="true"></div>

    <div class="prediction-action-bar__actions">
        <AppButton
            Variant="Secondary"
            Size="Sm"
            OnClick="@OnShareClicked"
            AriaLabel="@Localizer["Share.Title"]">
            <AppIcon Name="AppIconName.Share" Size="15" />
            <span>@Localizer["Share.Trigger"]</span>
        </AppButton>

        <AppButton
            Href="/"
            Variant="Primary"
            Size="Sm"
            AriaLabel="@Localizer["Review.CloseReview"]"
            AdditionalClass="prediction-action-bar__primary">
            <AppIcon Name="AppIconName.X" Size="15" />
            <span>@Localizer["Review.CloseReview"]</span>
        </AppButton>
    </div>
</nav>

@code {
    [Parameter, EditorRequired]
    public string CompetitionSlug { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<MouseEventArgs> ShareRequested { get; set; }

    private string EditHref => $"competitions/{CompetitionSlug}/predictions";

    private Task OnShareClicked(MouseEventArgs args)
    {
        return ShareRequested.InvokeAsync(args);
    }
}
