    private string GetContextTrendTileClass(AthleteAnalytics analytics)
    {
        return GetDisplayTrendKg(analytics) switch
        {
            > 0m => "prediction-context-panel__analytics-tile--trend-up",
            < 0m => "prediction-context-panel__analytics-tile--trend-down",
            _ => "prediction-context-panel__analytics-tile--trend"
        };
    }

    private string FormatPrClosenessText(AthleteAnalytics analytics)
    {
        if (analytics.LastTotalKg is null || analytics.BestTotalKg is null)
        {
            return Localizer["Predictions.Analytics.NoComparison"].Value;
        }

        var gap = analytics.LastTotalKg.Value - analytics.BestTotalKg.Value;
        var gapText = gap == 0m
            ? Localizer["Predictions.Analytics.AtPr"].Value
            : gap > 0m
                ? string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Analytics.AbovePr"].Value, FormatKg(Math.Abs(gap)))
                : string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Analytics.BelowPr"].Value, FormatKg(Math.Abs(gap)));

        if (analytics.LastTotalToBestPercent is null)
        {
            return gapText;
        }

        return $"{gapText} · {string.Format(
            CultureInfo.CurrentCulture,
            Localizer["Predictions.Analytics.PrPercent"].Value,
            analytics.LastTotalToBestPercent.Value.ToString("0.#", CultureInfo.CurrentCulture))}";
    }

    private string FormatAttemptComparisonContext(
        AthleteAttemptSuccessRate attempts,
        AthleteAttemptSuccessRate? benchmarkAttempts)
    {
        if (attempts.RatePercent is null ||
            benchmarkAttempts?.RatePercent is null ||
            benchmarkAttempts.CountedAttempts < MinimumBenchmarkCountedAttempts ||
            SelectedAthleteBenchmark is null)
        {
            return FormatAttemptCount(attempts);
        }

        var delta = attempts.RatePercent.Value - benchmarkAttempts.RatePercent.Value;
        return $"{FormatSignedPercentagePoints(delta)} {GetBenchmarkScopeLabel(SelectedAthleteBenchmark)}";
    }

    private string FormatAttemptCount(AthleteAttemptSuccessRate attempts)
    {
        return attempts.CountedAttempts == 0
            ? Localizer["Predictions.Analytics.NoCountedAttempts"].Value
            : string.Format(
                CultureInfo.CurrentCulture,
                Localizer["Predictions.Analytics.AttemptsMade"].Value,
                attempts.SuccessfulAttempts,
                attempts.CountedAttempts);
    }

    private string FormatSignedPercentagePoints(decimal value)
    {
        var prefix = value > 0 ? "+" : string.Empty;
        return string.Format(
            CultureInfo.CurrentCulture,
            Localizer["Predictions.Analytics.PercentagePointDelta"].Value,
            $"{prefix}{value.ToString("0.#", CultureInfo.CurrentCulture)}");
    }

    private string GetBenchmarkScopeLabel(AthleteAttemptBenchmark benchmark)
    {
        return benchmark.Scope switch
        {
            AthleteAttemptBenchmarkScope.Category => Localizer["Predictions.Analytics.BenchmarkCategory"],
            AthleteAttemptBenchmarkScope.Sex when benchmark.Sex == AthleteSex.Female => Localizer["Predictions.Analytics.BenchmarkWomen"],
            AthleteAttemptBenchmarkScope.Sex when benchmark.Sex == AthleteSex.Male => Localizer["Predictions.Analytics.BenchmarkMen"],
            AthleteAttemptBenchmarkScope.Sex => Localizer["Predictions.Analytics.BenchmarkSex"],
            _ => Localizer["Predictions.Analytics.BenchmarkField"]
        };
    }

