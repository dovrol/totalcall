@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer
@inject AthleteHistoryService AthleteHistoryService

<aside class="prediction-context-panel" aria-label="@Localizer["Predictions.ContextPanel"]">
    <header class="prediction-context-panel__head">
        <div class="prediction-context-panel__title-wrap">
            <h2>@Localizer["Predictions.ContextPanel"]</h2>
            <AppIcon Name="AppIconName.AlertCircle" Size="14" Class="prediction-context-panel__title-icon" />
        </div>

        @if (SelectedAthlete is not null)
        {
            <button
                type="button"
                class="prediction-context-panel__dismiss"
                aria-label="@Localizer["Predictions.ClearAthleteContext"]"
                @onclick="OnClearAthleteSelectionClicked">
                <AppIcon Name="AppIconName.X" Size="14" />
            </button>
        }
    </header>

    @if (SelectedAthlete is null)
    {
        <section class="prediction-context-panel__block">
            <h3>@(ActiveCategoryName ?? Localizer["Common.Tbd"].Value)</h3>

            <div class="prediction-context-panel__status">
                <span>@Localizer["Common.Status"]</span>
                <PredictionStatusBadge Status="@CategoryStatus.Status" />
            </div>

            <p class="prediction-context-panel__status-line">@CategoryStatusLine</p>
        </section>

        <section class="prediction-context-panel__block">
            <h3>@Localizer["Predictions.TopNominatedTotals"]</h3>

            @if (TopNominatedAthletes.Count == 0)
            {
                <p class="prediction-context-panel__empty">@Localizer["Predictions.NoAthletesDescription"]</p>
            }
            else
            {
                <ol class="prediction-context-panel__nominated-list">
                    @foreach (var athlete in TopNominatedAthletes)
                    {
                        <li>
                            <button
                                type="button"
                                class="prediction-context-panel__nominated-row"
                                @onclick="() => AthleteContextRequested.InvokeAsync(athlete.Id)">
                                <span>@athlete.DisplayName</span>
                                <strong>@FormatKg(athlete.SeedTotalKg)</strong>
                            </button>
                        </li>
                    }
                </ol>
            }
        </section>

        <section class="prediction-context-panel__notice">
            <p>
                <AppIcon Name="AppIconName.AlertCircle" Size="14" />
                <span>@Localizer["Predictions.CategoryContextHint"]</span>
            </p>
        </section>
    }
    else
    {
        <section class="prediction-context-panel__block prediction-context-panel__athlete-card">
            <div class="prediction-context-panel__athlete-main">
                <div class="prediction-context-panel__position-badge" aria-hidden="true">
                    @RankBadgeLabel
                </div>

                <div class="prediction-context-panel__athlete-meta">
                    <h3>@SelectedAthlete.DisplayName</h3>
                    @if (!string.IsNullOrWhiteSpace(SelectedAthlete.CountryName))
                    {
                        <div class="prediction-context-panel__country">
                            <CountryFlag Code="@SelectedAthlete.CountryCode" CountryName="@SelectedAthlete.CountryName" />
                            <span>@SelectedAthlete.CountryName</span>
                        </div>
                    }
                </div>
            </div>

            <dl class="prediction-context-panel__meta-list">
                <div>
                    <dt>@Localizer["Predictions.Category"]</dt>
                    <dd>@(SelectedAthleteCategoryName ?? Localizer["Common.Tbd"].Value)</dd>
                </div>
                <div>
                    <dt>@Localizer["Predictions.NominatedTotal"]</dt>
                    <dd>@FormatKg(SelectedAthlete.SeedTotalKg)</dd>
                </div>
            </dl>
        </section>

        <section class="prediction-context-panel__block">
            <h3>@Localizer["Predictions.RecentStartsShort"]</h3>

            @if (isLoadingHistory)
            {
                <p class="prediction-context-panel__empty">@Localizer["Predictions.LoadingHistory"]</p>
            }
            else if (RecentStarts.Count > 0)
            {
                <ol class="prediction-context-panel__recent-list">
                    @foreach (var result in RecentStarts)
                    {
                        <li class="prediction-context-panel__recent-item">
                            <div class="prediction-context-panel__recent-item-main">
                                <strong>@FormatRecentStartTitle(result)</strong>
                                <span class="prediction-context-panel__recent-item-lifts">@FormatLiftTriplet(result)</span>
                            </div>
                            <strong class="@GetRecentStartTotalClass(result)">@FormatKg(result.TotalKg)</strong>
                        </li>
                    }
                </ol>

                <button type="button" class="prediction-context-panel__history-link" disabled>
                    <AppIcon Name="AppIconName.TrendUp" Size="15" />
                    <span>@Localizer["Predictions.ViewFullHistory"]</span>
                </button>
            }
            else
            {
                <p class="prediction-context-panel__empty">@Localizer["Predictions.NoAthleteHistory"]</p>
            }
        </section>

        <section class="prediction-context-panel__block">
            <h3>@Localizer["Predictions.BestLifts"]</h3>
            <dl class="prediction-context-panel__best-lifts">
                <div class="prediction-context-panel__best-lift">
                    <dt>SQ</dt>
                    <dd>@FormatKg(BestSquatKg)</dd>
                </div>
                <div class="prediction-context-panel__best-lift">
                    <dt>BP</dt>
                    <dd>@FormatKg(BestBenchKg)</dd>
                </div>
                <div class="prediction-context-panel__best-lift">
                    <dt>DL</dt>
                    <dd>@FormatKg(BestDeadliftKg)</dd>
                </div>
                <div class="prediction-context-panel__best-lift prediction-context-panel__best-lift--total">
                    <dt>Total</dt>
                    <dd>@FormatKg(BestTotalKg)</dd>
                </div>
            </dl>
        </section>

        @if (TrendPoints.Count > 1)
        {
            <section class="prediction-context-panel__block">
                <h3>@Localizer["Predictions.TotalTrend", TrendPoints.Count]</h3>
                <div class="prediction-context-panel__trend-wrap">
                    <div class="prediction-context-panel__trend-range">
                        <span>@TrendUpperBoundLabel</span>
                        <span>@TrendLowerBoundLabel</span>
                    </div>
                    <svg class="prediction-context-panel__trend-chart" viewBox="0 0 100 40" preserveAspectRatio="none" aria-hidden="true">
                        <polyline points="@TrendPolylinePoints" class="prediction-context-panel__trend-line" />
                        @foreach (var point in TrendPoints)
                        {
                            <circle
                                class="prediction-context-panel__trend-dot"
                                cx="@FormatTrendAxisValue(point.X)"
                                cy="@FormatTrendAxisValue(point.Y)"
                                r="1.8" />
                        }
                    </svg>
                    <ol class="prediction-context-panel__trend-labels">
                        @foreach (var point in TrendPoints)
                        {
                            <li>@point.Label</li>
                        }
                    </ol>
                </div>
            </section>
        }

        <section class="prediction-context-panel__actions prediction-context-panel__actions--stacked">
            <button
                type="button"
                class="prediction-context-panel__action prediction-context-panel__action--primary prediction-context-panel__action--centered"
                disabled="@(!UseNominatedTotalRequested.HasDelegate)"
                @onclick="OnUseNominatedTotalClicked">
                <AppIcon Name="AppIconName.Target" Size="14" />
                <span>@Localizer["Predictions.UseNominatedTotal"]</span>
            </button>
            <button
                type="button"
                class="prediction-context-panel__action prediction-context-panel__action--centered"
                disabled="@(!CompareAthletesRequested.HasDelegate)"
                @onclick="OnCompareAthletesClicked">
                <AppIcon Name="AppIconName.UserPlus" Size="14" />
                <span>@Localizer["Predictions.CompareAthletes"]</span>
            </button>
        </section>

        @if (!string.IsNullOrWhiteSpace(SourceAttribution))
        {
            <p class="prediction-context-panel__source">@SourceAttribution</p>
        }
    }
</aside>

@code {
    [Parameter, EditorRequired]
    public Competition Competition { get; set; } = default!;

    [Parameter]
    public PredictionQuestion? ActiveQuestion { get; set; }

    [Parameter]
    public PredictionQuestionCompletionResult? ActiveQuestionStatus { get; set; }

    [Parameter]
    public string? SelectedAthleteId { get; set; }

    [Parameter]
    public int? SelectedAthleteRank { get; set; }

    [Parameter]
    public EventCallback<string> AthleteContextRequested { get; set; }

    [Parameter]
    public EventCallback AthleteSelectionCleared { get; set; }

    [Parameter]
    public EventCallback UseNominatedTotalRequested { get; set; }

    [Parameter]
    public EventCallback CompareAthletesRequested { get; set; }

    private AthleteHistoryDataset? historyDataset;
    private AthleteHistoryEntry? SelectedAthleteHistory;
    private string? loadedCompetitionId;
    private string? loadedAthleteId;
    private bool isLoadingHistory;

    private Athlete? SelectedAthlete => string.IsNullOrWhiteSpace(SelectedAthleteId)
        ? null
        : Competition.Athletes.FirstOrDefault(athlete =>
            string.Equals(athlete.Id, SelectedAthleteId, StringComparison.OrdinalIgnoreCase));

    private PredictionQuestionCompletionResult CategoryStatus => ActiveQuestionStatus ??
        new PredictionQuestionCompletionResult(
            ActiveQuestion?.Id ?? string.Empty,
            PredictionCompletionStatus.NotStarted,
            0,
            0);

    private string? ActiveCategoryName => ResolveCategoryName(ActiveQuestion?.CategoryId);

    private string CategoryStatusLine =>
        $"{CategoryStatus.SelectedCount}/{Math.Max(1, CategoryStatus.RequiredCount)} {GetStatusLabel(CategoryStatus.Status)}";

    private IReadOnlyList<Athlete> TopNominatedAthletes => GetTopNominatedAthletes();

    private string? SelectedAthleteCategoryName => ResolveCategoryName(SelectedAthlete?.WeightCategoryId);

    private string? SourceAttribution => historyDataset?.Source?.Attribution;

    private string RankBadgeLabel => SelectedAthleteRank?.ToString(CultureInfo.CurrentCulture) ?? "•";

    private IReadOnlyList<AthleteRecentResult> RecentStarts => SelectedAthleteHistory?.RecentResults
        .Take(3)
        .ToArray() ?? [];

    private decimal? BestSquatKg => SelectedAthleteHistory?.Bests?.SquatKg ??
                                    SelectedAthleteHistory?.RecentResults.Max(result => result.SquatKg);

    private decimal? BestBenchKg => SelectedAthleteHistory?.Bests?.BenchKg ??
                                    SelectedAthleteHistory?.RecentResults.Max(result => result.BenchKg);

    private decimal? BestDeadliftKg => SelectedAthleteHistory?.Bests?.DeadliftKg ??
                                       SelectedAthleteHistory?.RecentResults.Max(result => result.DeadliftKg);

    private decimal? BestTotalKg => SelectedAthleteHistory?.Bests?.TotalKg ??
                                    SelectedAthleteHistory?.RecentResults.Max(result => result.TotalKg);

    private IReadOnlyList<TrendPoint> TrendPoints => BuildTrendPoints();

    private string TrendPolylinePoints => string.Join(
        " ",
        TrendPoints.Select(point => $"{FormatTrendAxisValue(point.X)},{FormatTrendAxisValue(point.Y)}"));

    private string TrendLowerBoundLabel => TrendPoints.Count == 0
        ? FormatKg(null)
        : FormatKg(TrendPoints.Min(point => point.TotalKg));

    private string TrendUpperBoundLabel => TrendPoints.Count == 0
        ? FormatKg(null)
        : FormatKg(TrendPoints.Max(point => point.TotalKg));

    protected override async Task OnParametersSetAsync()
    {
        if (SelectedAthlete is null)
        {
            SelectedAthleteHistory = null;
            loadedAthleteId = null;
            return;
        }

        if (!string.Equals(loadedCompetitionId, Competition.Id, StringComparison.OrdinalIgnoreCase))
        {
            isLoadingHistory = true;
            historyDataset = await AthleteHistoryService.GetCompetitionHistoryAsync(Competition.Id);
            loadedCompetitionId = Competition.Id;
            loadedAthleteId = null;
            isLoadingHistory = false;
        }

        if (string.Equals(loadedAthleteId, SelectedAthlete.Id, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        isLoadingHistory = true;

        SelectedAthleteHistory = historyDataset is not null &&
                                historyDataset.Athletes.TryGetValue(SelectedAthlete.Id, out var history)
            ? history
            : null;

        loadedAthleteId = SelectedAthlete.Id;
        isLoadingHistory = false;
    }

    private Task OnClearAthleteSelectionClicked(MouseEventArgs _)
    {
        return AthleteSelectionCleared.InvokeAsync();
    }

    private Task OnUseNominatedTotalClicked(MouseEventArgs _)
    {
        return UseNominatedTotalRequested.InvokeAsync();
    }

    private Task OnCompareAthletesClicked(MouseEventArgs _)
    {
        return CompareAthletesRequested.InvokeAsync();
    }

    private IReadOnlyList<Athlete> GetTopNominatedAthletes()
    {
        if (ActiveQuestion is null)
        {
            return [];
        }

        var athletePool = ActiveQuestion.AthleteIds.Count == 0
            ? Competition.Athletes
            : Competition.Athletes
                .Where(athlete => ActiveQuestion.AthleteIds.Contains(athlete.Id))
                .ToArray();

        return athletePool
            .OrderByDescending(athlete => athlete.SeedTotalKg ?? 0m)
            .ThenBy(athlete => athlete.DisplayName, StringComparer.OrdinalIgnoreCase)
            .Take(5)
            .ToArray();
    }

    private string? ResolveCategoryName(string? categoryId)
    {
        if (string.IsNullOrWhiteSpace(categoryId))
        {
            return null;
        }

        return Competition.Categories.FirstOrDefault(category =>
            string.Equals(category.Id, categoryId, StringComparison.OrdinalIgnoreCase))?.Name;
    }

    private string FormatKg(decimal? value)
    {
        return value is null
            ? Localizer["Common.Tbd"].Value
            : $"{value.Value.ToString("0.#", CultureInfo.CurrentCulture)} kg";
    }

    private string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Localizer["Common.Tbd"];
        }

        if (DateOnly.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
        {
            return parsed.ToString("d MMM yyyy", CultureInfo.CurrentCulture);
        }

        return value;
    }

    private string FormatRecentStartTitle(AthleteRecentResult result)
    {
        var meet = string.IsNullOrWhiteSpace(result.MeetName)
            ? Localizer["Common.Tbd"].Value
            : result.MeetName.Trim();

        if (!DateOnly.TryParse(result.Date, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsedDate))
        {
            return meet;
        }

        var year = parsedDate.Year.ToString(CultureInfo.CurrentCulture);
        return meet.Contains(year, StringComparison.Ordinal)
            ? meet
            : $"{meet} {year}";
    }

    private string FormatLiftTriplet(AthleteRecentResult result)
    {
        return $"{FormatKgValue(result.SquatKg)} / {FormatKgValue(result.BenchKg)} / {FormatKgValue(result.DeadliftKg)}";
    }

    private string FormatKgValue(decimal? value)
    {
        return value is null
            ? "--"
            : value.Value.ToString("0.#", CultureInfo.CurrentCulture);
    }

    private string GetRecentStartTotalClass(AthleteRecentResult result)
    {
        return IsPersonalBest(result.TotalKg, SelectedAthleteHistory?.Bests?.TotalKg)
            ? "prediction-context-panel__recent-item-total prediction-context-panel__recent-item-total--best"
            : "prediction-context-panel__recent-item-total";
    }

    private string GetStatusLabel(PredictionCompletionStatus status)
    {
        return status switch
        {
            PredictionCompletionStatus.Complete => Localizer["Predictions.Status.Complete"],
            PredictionCompletionStatus.InProgress => Localizer["Predictions.Status.InProgress"],
            _ => Localizer["Predictions.Status.NotStarted"]
        };
    }

    private bool IsPersonalBest(decimal? value, decimal? bestValue)
    {
        if (value is null || bestValue is null)
        {
            return false;
        }

        return value.Value == bestValue.Value;
    }

    private string? GetHistoryLiftCellClass(decimal? value, decimal? bestValue)
    {
        return IsPersonalBest(value, bestValue)
            ? "prediction-context-panel__history-cell--pb"
            : null;
    }

    private IReadOnlyList<TrendPoint> BuildTrendPoints()
    {
        if (SelectedAthleteHistory?.RecentResults.Count is null or 0)
        {
            return [];
        }

        var sample = SelectedAthleteHistory.RecentResults
            .Take(6)
            .Where(result => result.TotalKg is not null)
            .ToList();

        if (sample.Count == 0)
        {
            return [];
        }

        sample.Reverse();

        var minValue = sample.Min(result => result.TotalKg ?? 0m);
        var maxValue = sample.Max(result => result.TotalKg ?? 0m);
        var range = maxValue - minValue;
        const decimal verticalSpan = 32m;
        const decimal verticalOffset = 4m;

        return sample
            .Select((result, index) =>
            {
                var x = sample.Count == 1
                    ? 50m
                    : (index * 100m) / (sample.Count - 1);
                var totalKg = result.TotalKg ?? minValue;

                var normalizedValue = range <= 0m
                    ? 0.5m
                    : (totalKg - minValue) / range;

                var y = (verticalOffset + verticalSpan) - (normalizedValue * verticalSpan);

                return new TrendPoint(
                    totalKg,
                    FormatTrendLabel(result.Date),
                    x,
                    y);
            })
            .ToArray();
    }

    private string FormatTrendLabel(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "--";
        }

        if (DateOnly.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
        {
            return parsed.ToString("MM.yyyy", CultureInfo.CurrentCulture);
        }

        return value.Length <= 7 ? value : value[..7];
    }

    private static string FormatTrendAxisValue(decimal value)
    {
        return value.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private sealed record TrendPoint(decimal TotalKg, string Label, decimal X, decimal Y);
}
