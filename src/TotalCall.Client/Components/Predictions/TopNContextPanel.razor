    private IReadOnlyList<AppTrendChartPoint> BuildTrendChartPoints(int maxResults)
    {
        if (SelectedAthleteHistory?.RecentResults.Count is null or 0)
        {
            return [];
        }

        var sample = SelectedAthleteHistory.RecentResults
            .Where(AthleteHistoryService.IsFullPowerSbdTotal)
            .Take(maxResults)
            .ToList();

        if (sample.Count == 0)
        {
            return [];
        }

        sample.Reverse();

        return sample
            .Select(result => new AppTrendChartPoint(
                result.TotalKg ?? 0m,
                FormatTrendLabel(result.Date),
                FormatTrendDetail(result)))
            .ToArray();
    }

    private string FormatTrendLabel(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "--";
        }

        if (DateOnly.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
        {
            return parsed.ToString("MMM yyyy", CultureInfo.CurrentCulture);
        }

        return value.Length <= 7 ? value : value[..7];
    }

    private string FormatTrendDetail(AthleteRecentResult result)
    {
        return $"{FormatKg(result.TotalKg)} · {FormatBodyweightInline(result.BodyweightKg)}";
    }

    private string GetAthleteInitials(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return "--";
        }

        var parts = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(part => part[0].ToString(CultureInfo.CurrentCulture))
            .ToArray();

        if (parts.Length == 0)
        {
            return "--";
        }

        return string.Concat(parts).ToUpper(CultureInfo.CurrentCulture);
    }

    private string GetSelectorSortLabel(string mode)
    {
        return mode switch
        {
            "nominated-asc" => Localizer["Predictions.SortNominatedAsc"].Value,
            "name-asc" => Localizer["Predictions.SortNameAsc"].Value,
            _ => Localizer["Predictions.SortNominatedDesc"].Value
        };
    }
