@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer
@inject AthleteHistoryService AthleteHistoryService
@inject WindowManager Windows
@inject ToastService Toasts

<aside class="prediction-context-panel" aria-label="@Localizer["Predictions.ContextPanel"]">
    <header class="prediction-context-panel__head">
        <div class="prediction-context-panel__title-wrap">
            <h2>@PanelTitle</h2>
            @if (!IsSelectorMode)
            {
                <AppIcon Name="AppIconName.AlertCircle" Size="14" Class="prediction-context-panel__title-icon" />
            }
        </div>

        @if (CanDismissPanel)
        {
            <button
                type="button"
                class="prediction-context-panel__dismiss"
                aria-label="@DismissAriaLabel"
                @onclick="OnDismissClicked">
                <AppIcon Name="AppIconName.X" Size="14" />
            </button>
        }
    </header>

    @if (IsSelectorMode)
    {
        <section class="prediction-context-panel__block prediction-context-panel__selector">
            @if (CurrentSlotAthlete is not null)
            {
                <p class="prediction-context-panel__selector-current">
                    @Localizer["Predictions.CurrentSlotAthlete", CurrentSlotAthlete.DisplayName]
                </p>
            }

            <div class="prediction-context-panel__selector-controls">
                <label class="prediction-context-panel__selector-search">
                    <AppIcon Name="AppIconName.Search" Size="16" Class="prediction-context-panel__selector-search-icon" />
                    <input
                        class="control prediction-context-panel__selector-search-input"
                        type="search"
                        @bind="selectorSearchTerm"
                        @bind:event="oninput"
                        placeholder="@SelectorSearchPlaceholder" />
                </label>

                <label class="prediction-context-panel__selector-sort">
                    <span>@Localizer["Predictions.SortBy"]:</span>
                    <select class="control prediction-context-panel__selector-sort-select" value="@selectorSortMode" @onchange="OnSelectorSortModeChanged">
                        <option value="nominated-desc">@Localizer["Predictions.SortNominatedDesc"]</option>
                        <option value="nominated-asc">@Localizer["Predictions.SortNominatedAsc"]</option>
                        <option value="name-asc">@Localizer["Predictions.SortNameAsc"]</option>
                    </select>
                </label>
            </div>

            <div class="prediction-context-panel__selector-list">
                @if (FilteredSelectorAthletes.Count == 0)
                {
                    <PredictionEmptyState
                        Title="@Localizer["Predictions.NoAthletesTitle"]"
                        Description="@Localizer["Predictions.NoAthletesDescription"]" />
                }
                else
                {
                    @foreach (var entry in FilteredSelectorAthletes.Select((athlete, index) => new { Athlete = athlete, Index = index }))
                    {
                        <article class="@GetSelectorRowClass(entry.Athlete)">
                            <span class="prediction-context-panel__selector-rank">@(entry.Index + 1)</span>

                            <div class="prediction-context-panel__selector-meta">
                                <strong>@entry.Athlete.DisplayName</strong>
                                <small>
                                    <CountryFlag Code="@entry.Athlete.CountryCode" CountryName="@entry.Athlete.CountryName" />
                                    <span>@(entry.Athlete.CountryName ?? Localizer["Common.Tbd"].Value)</span>
                                </small>
                            </div>

                            <strong class="prediction-context-panel__selector-total">@FormatKg(entry.Athlete.SeedTotalKg)</strong>

                            <button
                                type="button"
                                class="app-button app-button--primary app-button--sm prediction-context-panel__selector-pick"
                                disabled="@(!CanEditPredictions)"
                                @onclick="() => OnSelectorAthletePickedClicked(entry.Athlete.Id)">
                                @Localizer["Predictions.Pick"]
                            </button>
                        </article>
                    }
                }
            </div>
        </section>
    }
    else if (SelectedAthlete is null)
    {
        <section class="prediction-context-panel__block prediction-context-panel__category-card">
            <div class="prediction-context-panel__category-head">
                <h3>@(ActiveCategoryName ?? Localizer["Common.Tbd"].Value)</h3>
                <span class="@GetCategoryStatusPillClass()">@CategoryStatusLine</span>
            </div>

            <dl class="prediction-context-panel__category-stats">
                <div>
                    <dt>@Localizer["Predictions.Starts"]</dt>
                    <dd>@FormatCategoryAthleteCount()</dd>
                </div>
                <div>
                    <dt>@Localizer["Predictions.NominatedRange"]</dt>
                    <dd>@NominatedTotalRange</dd>
                </div>
            </dl>
        </section>

        <section class="prediction-context-panel__block prediction-context-panel__nominated-card">
            <h3>@Localizer["Predictions.TopNominatedTotals"]</h3>

            @if (DisplayedNominatedAthletes.Count == 0)
            {
                <p class="prediction-context-panel__empty">@Localizer["Predictions.NoAthletesDescription"]</p>
            }
            else
            {
                <ol class="prediction-context-panel__nominated-list">
                    @foreach (var entry in DisplayedNominatedAthletes.Select((athlete, index) => new { Athlete = athlete, Index = index }))
                    {
                        <li>
                            <button
                                type="button"
                                class="prediction-context-panel__nominated-row"
                                @onclick="() => AthleteContextRequested.InvokeAsync(entry.Athlete.Id)">
                                <span class="prediction-context-panel__nominated-rank">@(entry.Index + 1)</span>

                                <span class="prediction-context-panel__nominated-meta">
                                    <strong>@entry.Athlete.DisplayName</strong>
                                    <small>
                                        <CountryFlag Code="@entry.Athlete.CountryCode" CountryName="@entry.Athlete.CountryName" />
                                        <span>@(entry.Athlete.CountryName ?? Localizer["Common.Tbd"].Value)</span>
                                    </small>
                                </span>

                                <strong class="prediction-context-panel__nominated-total">@FormatKg(entry.Athlete.SeedTotalKg)</strong>
                            </button>
                        </li>
                    }
                </ol>

                @if (AllNominatedAthletes.Count > NominatedPreviewCount)
                {
                    <button type="button" class="prediction-context-panel__show-all" @onclick="ToggleShowAllNominated">
                        <AppIcon Name="AppIconName.Users" Size="15" />
                        <span>@ShowAllNominatedLabel</span>
                    </button>
                }
            }
        </section>

        <section class="prediction-context-panel__notice">
            <p>
                <AppIcon Name="AppIconName.AlertCircle" Size="14" />
                <span>@CategoryContextHint</span>
            </p>
        </section>
    }
    else
    {
        <div class="prediction-context-panel__athlete-content">
            <section class="prediction-context-panel__athlete-card">
                <div class="prediction-context-panel__athlete-main">
                    <span class="prediction-context-panel__avatar" aria-hidden="true">@GetAthleteInitials(SelectedAthlete.DisplayName)</span>

                    <div class="prediction-context-panel__athlete-meta">
                        <h3>@SelectedAthlete.DisplayName</h3>
                        @if (!string.IsNullOrWhiteSpace(SelectedAthlete.CountryName))
                        {
                            <div class="prediction-context-panel__country">
                                <CountryFlag Code="@SelectedAthlete.CountryCode" CountryName="@SelectedAthlete.CountryName" />
                                <span>@SelectedAthlete.CountryName</span>
                            </div>
                        }
                    </div>

                    @if (SelectedAthleteRank is not null)
                    {
                        <span class="prediction-context-panel__ranking-pill">
                            @Localizer["Predictions.RankingBadge", SelectedAthleteRank.Value]
                        </span>
                    }
                </div>

                <dl class="prediction-context-panel__meta-list prediction-context-panel__meta-list--split">
                    <div>
                        <dt>@Localizer["Predictions.Category"]</dt>
                        <dd>@(SelectedAthleteCategoryName ?? Localizer["Common.Tbd"].Value)</dd>
                    </div>
                    <div>
                        <dt>@Localizer["Predictions.NominatedTotal"]</dt>
                        <dd class="prediction-context-panel__meta-value--accent">@FormatKg(SelectedAthlete.SeedTotalKg)</dd>
                    </div>
                </dl>

                <div class="prediction-context-panel__athlete-actions">
                    <button type="button" class="prediction-context-panel__history-link" @onclick="OnShowHistoryWindowClicked">
                        <AppIcon Name="AppIconName.BarChart" Size="17" />
                        <span>@Localizer["Predictions.ShowStartHistory"]</span>
                    </button>
                </div>
            </section>

            <section class="prediction-context-panel__block prediction-context-panel__analytics-card">
                <h3>@Localizer["Predictions.Analytics"]</h3>

                @if (isLoadingHistory)
                {
                    <p class="prediction-context-panel__empty">@Localizer["Predictions.LoadingHistory"]</p>
                }
                else if (SelectedAthleteAnalytics is { } analytics)
                {
                    <dl class="prediction-context-panel__analytics-grid">
                        <div class="prediction-context-panel__analytics-tile prediction-context-panel__analytics-tile--pr">
                            <dt>@Localizer["Predictions.BestResult"]</dt>
                            <dd>@FormatKg(analytics.BestTotalKg)</dd>
                        </div>
                        <div class="prediction-context-panel__analytics-tile prediction-context-panel__analytics-tile--recent">
                            <dt>@Localizer["Predictions.LastResult"]</dt>
                            <dd>@FormatKg(analytics.LastTotalKg)</dd>
                            <small>@FormatPrClosenessText(analytics)</small>
                        </div>
                        <div class="prediction-context-panel__analytics-tile prediction-context-panel__analytics-tile--average">
                            <dt>@Localizer["Predictions.Analytics.Last3Avg"]</dt>
                            <dd>@FormatKg(analytics.Last3AvgTotalKg)</dd>
                        </div>
                        <div class="prediction-context-panel__analytics-tile @GetContextTrendTileClass(analytics)">
                            <dt>@GetTrendPeriodLabel(analytics)</dt>
                            <dd>@FormatTrendValue(analytics)</dd>
                        </div>
                        <div class="prediction-context-panel__analytics-tile prediction-context-panel__analytics-tile--attempts">
                            <dt>@Localizer["Predictions.Analytics.AttemptSuccessOverall"]</dt>
                            <dd>@FormatAttemptRate(analytics.OverallAttempts)</dd>
                            <small>@FormatAttemptComparisonContext(analytics.OverallAttempts, SelectedAthleteBenchmark?.OverallAttempts)</small>
                        </div>
                        <div class="prediction-context-panel__analytics-tile prediction-context-panel__analytics-tile--score">
                            <dt>@Localizer["Predictions.Analytics.BestScore"]</dt>
                            <dd class="prediction-context-panel__score-pair">
                                <span>GL @FormatScore(analytics.BestGoodliftPoints)</span>
                                <span>DOTS @FormatScore(analytics.BestDotsPoints)</span>
                            </dd>
                        </div>
                    </dl>
                }
                else
                {
                    <p class="prediction-context-panel__empty">@Localizer["Predictions.AnalyticsUnavailable"]</p>
                }
            </section>

            @if (ContextTrendChartPoints.Count > 1)
            {
                <section class="prediction-context-panel__block prediction-context-panel__trend-card">
                    <h3>@string.Format(Localizer["Predictions.TotalTrend"].Value, ContextTrendChartPoints.Count)</h3>
                    <AppTrendChart
                        Points="@ContextTrendChartPoints"
                        Variant="AppTrendChartVariant.Compact"
                        AdditionalClass="app-trend-chart--context"
                        AriaLabel="@Localizer["Predictions.TotalTrend", ContextTrendChartPoints.Count]" />
                </section>
            }

            <section class="prediction-context-panel__block prediction-context-panel__best-card">
                <h3>@Localizer["Predictions.LifetimePrs"]</h3>
                <dl class="prediction-context-panel__best-lifts">
                    <div class="prediction-context-panel__best-lift">
                        <dt>SQ</dt>
                        <dd>@FormatKg(BestSquatKg)</dd>
                    </div>
                    <div class="prediction-context-panel__best-lift">
                        <dt>BP</dt>
                        <dd>@FormatKg(BestBenchKg)</dd>
                    </div>
                    <div class="prediction-context-panel__best-lift">
                        <dt>DL</dt>
                        <dd>@FormatKg(BestDeadliftKg)</dd>
                    </div>
                    <div class="prediction-context-panel__best-lift prediction-context-panel__best-lift--total">
                        <dt>Total</dt>
                        <dd>@FormatKg(BestTotalKg)</dd>
                    </div>
                </dl>
            </section>

            <AthleteDataSourceNote AdditionalClass="prediction-context-panel__source" />
        </div>

    }
</aside>

@code {
    [Parameter, EditorRequired]
    public Competition Competition { get; set; } = default!;

    [Parameter]
    public PredictionQuestion? ActiveQuestion { get; set; }

    [Parameter]
    public PredictionQuestionCompletionResult? ActiveQuestionStatus { get; set; }

    [Parameter]
    public string? SelectedAthleteId { get; set; }

    [Parameter]
    public int? SelectedAthleteRank { get; set; }

    [Parameter]
    public bool CanEditPredictions { get; set; } = true;

    [Parameter]
    public int? SelectorSlotPosition { get; set; }

    [Parameter]
    public IReadOnlyDictionary<int, Athlete> SelectedAthletesByPosition { get; set; } =
        new Dictionary<int, Athlete>(EqualityComparer<int>.Default);

    [Parameter]
    public EventCallback<string> AthleteContextRequested { get; set; }

    [Parameter]
    public EventCallback AthleteSelectionCleared { get; set; }

    [Parameter]
    public EventCallback<string> SelectorAthletePicked { get; set; }

    [Parameter]
    public EventCallback SelectorDismissRequested { get; set; }

    [Parameter]
    public EventCallback UseNominatedTotalRequested { get; set; }

    [Parameter]
    public EventCallback CompareAthletesRequested { get; set; }

    private AthleteHistoryEntry? SelectedAthleteHistory;
    private AthleteAttemptBenchmark? SelectedAthleteBenchmark;
    private string? loadedAthleteId;
    private bool isLoadingHistory;
    private bool showAllNominated;
    private string selectorSearchTerm = string.Empty;
    private string selectorSortMode = "nominated-desc";
    private int? previousSelectorSlotPosition;
    private string? previousActiveQuestionId;
    private const int NominatedPreviewCount = 5;
    private const int MinimumBenchmarkCountedAttempts = 30;

    private Athlete? SelectedAthlete => string.IsNullOrWhiteSpace(SelectedAthleteId)
        ? null
        : Competition.Athletes.FirstOrDefault(athlete =>
            string.Equals(athlete.Id, SelectedAthleteId, StringComparison.OrdinalIgnoreCase));

    private PredictionQuestionCompletionResult CategoryStatus => ActiveQuestionStatus ??
        new PredictionQuestionCompletionResult(
            ActiveQuestion?.Id ?? string.Empty,
            PredictionCompletionStatus.NotStarted,
            0,
            0);

    private string? ActiveCategoryName => ResolveCategoryName(ActiveQuestion?.CategoryId);

    private string CategoryStatusLine =>
        $"{CategoryStatus.SelectedCount} / {Math.Max(1, CategoryStatus.RequiredCount)} · {GetStatusLabel(CategoryStatus.Status)}";

    private IReadOnlyList<Athlete> AllNominatedAthletes => GetAllNominatedAthletes();

    private IReadOnlyList<Athlete> DisplayedNominatedAthletes => showAllNominated
        ? AllNominatedAthletes
        : AllNominatedAthletes.Take(NominatedPreviewCount).ToArray();

    private IReadOnlyList<Athlete> FilteredSelectorAthletes => GetFilteredSelectorAthletes();

    private bool IsSelectorMode => SelectorSlotPosition is not null;

    private Athlete? CurrentSlotAthlete => SelectorSlotPosition is not null &&
                                          SelectedAthletesByPosition.TryGetValue(SelectorSlotPosition.Value, out var athlete)
        ? athlete
        : null;

    private bool CanDismissPanel => IsSelectorMode;

    private string DismissAriaLabel => IsSelectorMode
        ? SelectorAthleteSex == AthleteSex.Male
            ? Localizer["Predictions.CloseSelectorMale"]
            : Localizer["Predictions.CloseSelector"]
        : Localizer["Predictions.ClearAthleteContext"];

    private string PanelTitle => IsSelectorMode
        ? SelectorAthleteSex == AthleteSex.Male
            ? Localizer["Predictions.SelectAthleteForSlotMale", SelectorSlotPosition!.Value]
            : Localizer["Predictions.SelectAthleteForSlot", SelectorSlotPosition!.Value]
        : SelectedAthlete is null
            ? Localizer["Predictions.CategoryContextPanel"]
            : SelectedAthlete.Sex == AthleteSex.Female
                ? Localizer["Predictions.ContextPanelFemale"]
                : Localizer["Predictions.ContextPanel"];

    private string SelectorSearchPlaceholder => SelectorAthleteSex == AthleteSex.Male
        ? Localizer["Predictions.SelectorSearchPlaceholderMale"]
        : Localizer["Predictions.SelectorSearchPlaceholder"];

    private string? SelectedAthleteCategoryName => ResolveCategoryName(SelectedAthlete?.WeightCategoryId);

    private string ShowAllNominatedLabel => showAllNominated
        ? Localizer["Predictions.ShowTopNominated", NominatedPreviewCount].Value
        : Localizer["Predictions.ShowAllAthletes", AllNominatedAthletes.Count].Value;

    private string CategoryContextHint => SelectorAthleteSex == AthleteSex.Male
        ? Localizer["Predictions.CategoryContextHintMale"].Value
        : Localizer["Predictions.CategoryContextHint"].Value;

    private int CategoryAthleteCount => ActiveQuestion is null
        ? 0
        : ActiveQuestion.AthleteIds.Count == 0
            ? Competition.Athletes.Count
            : ActiveQuestion.AthleteIds.Count;

    private string NominatedTotalRange
    {
        get
        {
            var totals = AllNominatedAthletes
                .Select(athlete => athlete.SeedTotalKg)
                .OfType<decimal>()
                .ToArray();

            return totals.Length == 0
                ? Localizer["Common.Tbd"].Value
                : $"{FormatKgValue(totals.Min())}-{FormatKg(totals.Max())}";
        }
    }

    private AthleteAnalytics? SelectedAthleteAnalytics => SelectedAthleteHistory?.Analytics;

    private decimal? BestSquatKg => SelectedAthleteHistory?.Bests?.SquatKg ??
                                    SelectedAthleteHistory?.RecentResults.Max(result => result.SquatKg);

    private decimal? BestBenchKg => SelectedAthleteHistory?.Bests?.BenchKg ??
                                    SelectedAthleteHistory?.RecentResults.Max(result => result.BenchKg);

    private decimal? BestDeadliftKg => SelectedAthleteHistory?.Bests?.DeadliftKg ??
                                       SelectedAthleteHistory?.RecentResults.Max(result => result.DeadliftKg);

    private decimal? BestTotalKg => SelectedAthleteHistory?.Bests?.TotalKg ??
                                    SelectedAthleteHistory?.RecentResults
                                        .Where(AthleteHistoryService.IsFullPowerSbdTotal)
                                        .Max(result => result.TotalKg);

    private IReadOnlyList<AppTrendChartPoint> ContextTrendChartPoints => BuildTrendChartPoints(4);

    private AthleteSex SelectorAthleteSex
    {
        get
        {
            if (ActiveQuestion is null)
            {
                return AthleteSex.Unspecified;
            }

            var athletePool = ActiveQuestion.AthleteIds.Count == 0
                ? Competition.Athletes
                : Competition.Athletes
                    .Where(athlete => ActiveQuestion.AthleteIds.Contains(athlete.Id, StringComparer.OrdinalIgnoreCase))
                    .ToArray();

            var knownSexes = athletePool
                .Select(athlete => athlete.Sex)
                .Where(sex => sex != AthleteSex.Unspecified)
                .Distinct()
                .ToArray();

            return knownSexes.Length == 1
                ? knownSexes[0]
                : AthleteSex.Unspecified;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.Equals(previousActiveQuestionId, ActiveQuestion?.Id, StringComparison.OrdinalIgnoreCase))
        {
            showAllNominated = false;
            previousActiveQuestionId = ActiveQuestion?.Id;
        }

        if (previousSelectorSlotPosition != SelectorSlotPosition)
        {
            selectorSearchTerm = string.Empty;
            selectorSortMode = "nominated-desc";
            previousSelectorSlotPosition = SelectorSlotPosition;
        }

        if (SelectedAthlete is null)
        {
            SelectedAthleteHistory = null;
            SelectedAthleteBenchmark = null;
            loadedAthleteId = null;
            return;
        }

        if (string.Equals(loadedAthleteId, SelectedAthlete.Id, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        isLoadingHistory = true;

        try
        {
            var historyTask = AthleteHistoryService.GetAthleteHistoryAsync(SelectedAthlete.Id, Competition);
            var benchmarkTask = AthleteHistoryService.GetAttemptBenchmarkAsync(Competition, SelectedAthlete);

            SelectedAthleteHistory = await historyTask;
            SelectedAthleteBenchmark = await benchmarkTask;
        }
        catch
        {
            SelectedAthleteHistory = null;
            SelectedAthleteBenchmark = null;
        }

        loadedAthleteId = SelectedAthlete.Id;
        isLoadingHistory = false;
    }

    private Task OnDismissClicked(MouseEventArgs _)
    {
        if (IsSelectorMode)
        {
            return SelectorDismissRequested.InvokeAsync();
        }

        return OnClearAthleteSelectionClicked(_);
    }

    private Task OnClearAthleteSelectionClicked(MouseEventArgs _)
    {
        return AthleteSelectionCleared.InvokeAsync();
    }

    private Task OnUseNominatedTotalClicked(MouseEventArgs _)
    {
        return UseNominatedTotalRequested.InvokeAsync();
    }

    private Task OnCompareAthletesClicked(MouseEventArgs _)
    {
        return CompareAthletesRequested.InvokeAsync();
    }

    private Task OnSelectorAthletePickedClicked(string athleteId)
    {
        return SelectorAthletePicked.InvokeAsync(athleteId);
    }

    private Task OnSelectorSortModeChanged(ChangeEventArgs args)
    {
        var nextSortMode = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(nextSortMode) || string.Equals(selectorSortMode, nextSortMode, StringComparison.Ordinal))
        {
            return Task.CompletedTask;
        }

        selectorSortMode = nextSortMode;
        Toasts.ShowInfo(Localizer["Predictions.Toast.SortList.Success", GetSelectorSortLabel(selectorSortMode)]);
        return Task.CompletedTask;
    }

    private Task OnShowHistoryWindowClicked(MouseEventArgs _)
    {
        if (SelectedAthlete is null)
        {
            return Task.CompletedTask;
        }

        Windows.OpenAthleteHistory(
            competitionId: Competition.Id,
            athleteId: SelectedAthlete.Id,
            athleteName: SelectedAthlete.DisplayName,
            countryCode: SelectedAthlete.CountryCode,
            countryName: SelectedAthlete.CountryName,
            categoryName: SelectedAthleteCategoryName,
            nominatedTotalKg: SelectedAthlete.SeedTotalKg,
            title: Localizer["Predictions.HistoryDialogTitle", SelectedAthlete.DisplayName]);

        return Task.CompletedTask;
    }

    private void ToggleShowAllNominated()
    {
        showAllNominated = !showAllNominated;
    }

    private IReadOnlyList<Athlete> GetAllNominatedAthletes()
    {
        if (ActiveQuestion is null)
        {
            return [];
        }

        var athletePool = ActiveQuestion.AthleteIds.Count == 0
            ? Competition.Athletes
            : Competition.Athletes
                .Where(athlete => ActiveQuestion.AthleteIds.Contains(athlete.Id))
                .ToArray();

        return athletePool
            .OrderByDescending(athlete => athlete.SeedTotalKg ?? 0m)
            .ThenBy(athlete => athlete.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private IReadOnlyList<Athlete> GetFilteredSelectorAthletes()
    {
        if (ActiveQuestion is null)
        {
            return [];
        }

        var athletePool = ActiveQuestion.AthleteIds.Count == 0
            ? Competition.Athletes
            : Competition.Athletes
                .Where(athlete => ActiveQuestion.AthleteIds.Contains(athlete.Id))
                .ToArray();

        var filtered = athletePool
            .Where(MatchesSelectorSearch)
            .ToArray();

        return selectorSortMode switch
        {
            "nominated-asc" => filtered
                .OrderBy(athlete => athlete.SeedTotalKg ?? decimal.MaxValue)
                .ThenBy(athlete => athlete.DisplayName, StringComparer.OrdinalIgnoreCase)
                .ToArray(),
            "name-asc" => filtered
                .OrderBy(athlete => athlete.DisplayName, StringComparer.OrdinalIgnoreCase)
                .ToArray(),
            _ => filtered
                .OrderByDescending(athlete => athlete.SeedTotalKg ?? 0m)
                .ThenBy(athlete => athlete.DisplayName, StringComparer.OrdinalIgnoreCase)
                .ToArray()
        };
    }

    private bool MatchesSelectorSearch(Athlete athlete)
    {
        if (string.IsNullOrWhiteSpace(selectorSearchTerm))
        {
            return true;
        }

        return athlete.DisplayName.Contains(selectorSearchTerm, StringComparison.OrdinalIgnoreCase) ||
               (!string.IsNullOrWhiteSpace(athlete.CountryName) &&
                athlete.CountryName.Contains(selectorSearchTerm, StringComparison.OrdinalIgnoreCase));
    }

    private string GetSelectorRowClass(Athlete athlete)
    {
        return string.Join(
            " ",
            "prediction-context-panel__selector-row",
            IsCurrentSlotAthlete(athlete) ? "prediction-context-panel__selector-row--current-slot" : null,
            IsAthleteSelectedInRanking(athlete.Id) ? "prediction-context-panel__selector-row--picked" : null);
    }

    private bool IsCurrentSlotAthlete(Athlete athlete)
    {
        return CurrentSlotAthlete is not null &&
               string.Equals(CurrentSlotAthlete.Id, athlete.Id, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsAthleteSelectedInRanking(string athleteId)
    {
        return SelectedAthletesByPosition.Values.Any(athlete =>
            string.Equals(athlete.Id, athleteId, StringComparison.OrdinalIgnoreCase));
    }

    private string? ResolveCategoryName(string? categoryId)
    {
        if (string.IsNullOrWhiteSpace(categoryId))
        {
            return null;
        }

        return Competition.Categories.FirstOrDefault(category =>
            string.Equals(category.Id, categoryId, StringComparison.OrdinalIgnoreCase))?.Name;
    }

    private string FormatKg(decimal? value)
    {
        return value is null
            ? Localizer["Common.Tbd"].Value
            : $"{value.Value.ToString("0.#", CultureInfo.CurrentCulture)} kg";
    }

    private string FormatCategoryAthleteCount()
    {
        var key = SelectorAthleteSex switch
        {
            AthleteSex.Female => "Predictions.AthleteCountFemale",
            AthleteSex.Male => "Predictions.AthleteCountMale",
            _ => "Predictions.AthleteCount"
        };

        return Localizer[key, CategoryAthleteCount].Value;
    }

    private string FormatKgValue(decimal? value)
    {
        return value is null
            ? "--"
            : value.Value.ToString("0.#", CultureInfo.CurrentCulture);
    }

    private string FormatScore(decimal? value)
    {
        return value is null
            ? "--"
            : value.Value.ToString("0.#", CultureInfo.CurrentCulture);
    }

    private string FormatAttemptRate(AthleteAttemptSuccessRate attempts)
    {
        return attempts.RatePercent is null
            ? "--"
            : $"{attempts.RatePercent.Value.ToString("0.#", CultureInfo.CurrentCulture)}%";
    }

    private string FormatSignedKg(decimal? value)
    {
        if (value is null)
        {
            return "--";
        }

        var prefix = value.Value > 0 ? "+" : string.Empty;
        return $"{prefix}{FormatKg(value)}";
    }

    private decimal? GetDisplayTrendKg(AthleteAnalytics analytics)
    {
        return analytics.RecentTotalTrendKg ?? analytics.TotalTrendKg;
    }

    private string GetTrendPeriodLabel(AthleteAnalytics analytics)
    {
        return analytics.RecentTotalTrendStarts is null
            ? Localizer["Predictions.TotalTrendShort"].Value
            : string.Format(
                CultureInfo.CurrentCulture,
                Localizer["Predictions.Analytics.TrendStarts"].Value,
                analytics.RecentTotalTrendStarts.Value);
    }

    private string FormatTrendValue(AthleteAnalytics analytics)
    {
        var trend = GetDisplayTrendKg(analytics);

        return trend is null
            ? Localizer["Predictions.Analytics.TrendUnavailable"].Value
            : FormatSignedKg(trend);
    }

    private string GetContextTrendTileClass(AthleteAnalytics analytics)
    {
        return GetDisplayTrendKg(analytics) switch
        {
            > 0m => "prediction-context-panel__analytics-tile--trend-up",
            < 0m => "prediction-context-panel__analytics-tile--trend-down",
            _ => "prediction-context-panel__analytics-tile--trend"
        };
    }

    private string FormatPrClosenessText(AthleteAnalytics analytics)
    {
        if (analytics.LastTotalKg is null || analytics.BestTotalKg is null)
        {
            return Localizer["Predictions.Analytics.NoComparison"].Value;
        }

        var gap = analytics.LastTotalKg.Value - analytics.BestTotalKg.Value;
        var gapText = gap == 0m
            ? Localizer["Predictions.Analytics.AtPr"].Value
            : gap > 0m
                ? string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Analytics.AbovePr"].Value, FormatKg(Math.Abs(gap)))
                : string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Analytics.BelowPr"].Value, FormatKg(Math.Abs(gap)));

        if (analytics.LastTotalToBestPercent is null)
        {
            return gapText;
        }

        return $"{gapText} · {string.Format(
            CultureInfo.CurrentCulture,
            Localizer["Predictions.Analytics.PrPercent"].Value,
            analytics.LastTotalToBestPercent.Value.ToString("0.#", CultureInfo.CurrentCulture))}";
    }

    private string FormatAttemptComparisonContext(
        AthleteAttemptSuccessRate attempts,
        AthleteAttemptSuccessRate? benchmarkAttempts)
    {
        if (attempts.RatePercent is null ||
            benchmarkAttempts?.RatePercent is null ||
            benchmarkAttempts.CountedAttempts < MinimumBenchmarkCountedAttempts ||
            SelectedAthleteBenchmark is null)
        {
            return FormatAttemptCount(attempts);
        }

        var delta = attempts.RatePercent.Value - benchmarkAttempts.RatePercent.Value;
        return $"{FormatSignedPercentagePoints(delta)} {GetBenchmarkScopeLabel(SelectedAthleteBenchmark)}";
    }

    private string FormatAttemptCount(AthleteAttemptSuccessRate attempts)
    {
        return attempts.CountedAttempts == 0
            ? Localizer["Predictions.Analytics.NoCountedAttempts"].Value
            : string.Format(
                CultureInfo.CurrentCulture,
                Localizer["Predictions.Analytics.AttemptsMade"].Value,
                attempts.SuccessfulAttempts,
                attempts.CountedAttempts);
    }

    private string FormatSignedPercentagePoints(decimal value)
    {
        var prefix = value > 0 ? "+" : string.Empty;
        return string.Format(
            CultureInfo.CurrentCulture,
            Localizer["Predictions.Analytics.PercentagePointDelta"].Value,
            $"{prefix}{value.ToString("0.#", CultureInfo.CurrentCulture)}");
    }

    private string GetBenchmarkScopeLabel(AthleteAttemptBenchmark benchmark)
    {
        return benchmark.Scope switch
        {
            AthleteAttemptBenchmarkScope.Category => Localizer["Predictions.Analytics.BenchmarkCategory"],
            AthleteAttemptBenchmarkScope.Sex when benchmark.Sex == AthleteSex.Female => Localizer["Predictions.Analytics.BenchmarkWomen"],
            AthleteAttemptBenchmarkScope.Sex when benchmark.Sex == AthleteSex.Male => Localizer["Predictions.Analytics.BenchmarkMen"],
            AthleteAttemptBenchmarkScope.Sex => Localizer["Predictions.Analytics.BenchmarkSex"],
            _ => Localizer["Predictions.Analytics.BenchmarkField"]
        };
    }

    private string FormatBodyweight(decimal? value)
    {
        return value is null
            ? Localizer["Common.Tbd"].Value
            : $"{value.Value.ToString("0.##", CultureInfo.CurrentCulture)} kg";
    }

    private string FormatBodyweightInline(decimal? value)
    {
        return $"{Localizer["Predictions.BodyweightShort"]}: {FormatBodyweight(value)}";
    }

    private string GetStatusLabel(PredictionCompletionStatus status)
    {
        return status switch
        {
            PredictionCompletionStatus.Complete => Localizer["Predictions.Status.Complete"],
            PredictionCompletionStatus.InProgress => Localizer["Predictions.Status.InProgress"],
            _ => Localizer["Predictions.Status.NotStarted"]
        };
    }

    private string GetCategoryStatusPillClass()
    {
        return string.Join(
            " ",
            "prediction-context-panel__category-status",
            CategoryStatus.Status switch
            {
                PredictionCompletionStatus.Complete => "prediction-context-panel__category-status--complete",
                PredictionCompletionStatus.InProgress => "prediction-context-panel__category-status--in-progress",
                _ => "prediction-context-panel__category-status--not-started"
            });
    }

    private IReadOnlyList<AppTrendChartPoint> BuildTrendChartPoints(int maxResults)
    {
        if (SelectedAthleteHistory?.RecentResults.Count is null or 0)
        {
            return [];
        }

        var sample = SelectedAthleteHistory.RecentResults
            .Where(AthleteHistoryService.IsFullPowerSbdTotal)
            .Take(maxResults)
            .ToList();

        if (sample.Count == 0)
        {
            return [];
        }

        sample.Reverse();

        return sample
            .Select(result => new AppTrendChartPoint(
                result.TotalKg ?? 0m,
                FormatTrendLabel(result.Date),
                FormatTrendDetail(result)))
            .ToArray();
    }

    private string FormatTrendLabel(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "--";
        }

        if (DateOnly.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
        {
            return parsed.ToString("MMM yyyy", CultureInfo.CurrentCulture);
        }

        return value.Length <= 7 ? value : value[..7];
    }

    private string FormatTrendDetail(AthleteRecentResult result)
    {
        return $"{FormatKg(result.TotalKg)} · {FormatBodyweightInline(result.BodyweightKg)}";
    }

    private string GetAthleteInitials(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return "--";
        }

        var parts = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(part => part[0].ToString(CultureInfo.CurrentCulture))
            .ToArray();

        if (parts.Length == 0)
        {
            return "--";
        }

        return string.Concat(parts).ToUpper(CultureInfo.CurrentCulture);
    }

    private string GetSelectorSortLabel(string mode)
    {
        return mode switch
        {
            "nominated-asc" => Localizer["Predictions.SortNominatedAsc"].Value,
            "name-asc" => Localizer["Predictions.SortNameAsc"].Value,
            _ => Localizer["Predictions.SortNominatedDesc"].Value
        };
    }
