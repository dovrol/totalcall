            : $"{value.Value.ToString("0.#", CultureInfo.CurrentCulture)} kg";
    }

    private string FormatCategoryAthleteCount()
    {
        var key = SelectorAthleteSex switch
        {
            AthleteSex.Female => "Predictions.AthleteCountFemale",
            AthleteSex.Male => "Predictions.AthleteCountMale",
            _ => "Predictions.AthleteCount"
