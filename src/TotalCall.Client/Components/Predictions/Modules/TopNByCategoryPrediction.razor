    private async Task SavePredictionEditor()
    {
        if (!CanEditPredictions || ActiveQuestion is null || predictionEditorPosition is null)
        {
            return;
        }

        var placement = GetPlacements(ActiveQuestion.Id)
            .FirstOrDefault(item => item.Position == predictionEditorPosition.Value);

        if (placement is null)
        {
            ClosePredictionEditor();
            return;
        }

        decimal? squat = null;
        decimal? bench = null;
        decimal? deadlift = null;
        decimal? total;

        if (predictionEditorMode == "lifts")
        {
            if (!TryReadOptionalPositiveDecimal(predictionSquatInput, out squat) ||
                !TryReadOptionalPositiveDecimal(predictionBenchInput, out bench) ||
                !TryReadOptionalPositiveDecimal(predictionDeadliftInput, out deadlift))
            {
                predictionEditorError = Localizer["Predictions.PredictionValueInvalid"];
                return;
            }

            total = squat is not null || bench is not null || deadlift is not null
                ? (squat ?? 0m) + (bench ?? 0m) + (deadlift ?? 0m)
                : null;
        }
        else
        {
            if (!TryReadOptionalPositiveDecimal(predictionTotalInput, out total))
            {
                predictionEditorError = Localizer["Predictions.PredictionValueInvalid"];
                return;
            }
        }

        var athleteName = GetSelectedAthlete(placement.Position)?.DisplayName;
        var placements = GetPlacements(ActiveQuestion.Id)
            .Select(item => item.Position == placement.Position
                ? item with
                {
                    PredictedSquatKg = squat,
                    PredictedBenchKg = bench,
                    PredictedDeadliftKg = deadlift,
                    PredictedTotalKg = total
                }
                : item)
            .ToArray();

        ClosePredictionEditor();
        pendingRemovalPosition = null;
        await EmitAnswer(placements);

        if (!string.IsNullOrWhiteSpace(athleteName))
        {
            Toasts.ShowSuccess(Localizer["Predictions.Toast.PredictionSaved.Success", athleteName]);
        }
    }

    private Task CancelPredictionEditor()
    {
        ClosePredictionEditor();
        pendingRemovalPosition = null;
        return Task.CompletedTask;
    }

    private Task UseNominatedTotalForEditedAthlete()
    {
        var athlete = predictionEditorPosition is null ? null : GetSelectedAthlete(predictionEditorPosition.Value);
        if (athlete?.SeedTotalKg is null)
        {
            return Task.CompletedTask;
        }

        predictionEditorMode = "total";
        predictionTotalInput = FormatInputValue(athlete.SeedTotalKg);
        predictionEditorError = null;
        pendingRemovalPosition = null;
        Toasts.ShowSuccess(Localizer["Predictions.Toast.QuickFill.Nominated", athlete.DisplayName]);
        return Task.CompletedTask;
    }

    private Task UseLastResultForEditedAthlete()
    {
        if (predictionHistory?.LastResult?.TotalKg is null)
        {
            return Task.CompletedTask;
        }

        ApplyHistoryResult(
            predictionHistory.LastResult.SquatKg,
            predictionHistory.LastResult.BenchKg,
            predictionHistory.LastResult.DeadliftKg,
            predictionHistory.LastResult.TotalKg);

        pendingRemovalPosition = null;
        Toasts.ShowSuccess(Localizer["Predictions.Toast.QuickFill.Last", GetEditorAthlete()?.DisplayName ?? Localizer["Common.Tbd"].Value]);
        return Task.CompletedTask;
    }

    private Task UseBestResultForEditedAthlete()
    {
        if (predictionHistory?.Bests?.TotalKg is null)
        {
            return Task.CompletedTask;
        }

        ApplyHistoryResult(
            predictionHistory.Bests.SquatKg,
            predictionHistory.Bests.BenchKg,
            predictionHistory.Bests.DeadliftKg,
            predictionHistory.Bests.TotalKg);

        pendingRemovalPosition = null;
        Toasts.ShowSuccess(Localizer["Predictions.Toast.QuickFill.Best", GetEditorAthlete()?.DisplayName ?? Localizer["Common.Tbd"].Value]);
        return Task.CompletedTask;
    }

    private void ApplyHistoryResult(decimal? squat, decimal? bench, decimal? deadlift, decimal? total)
    {
        if (squat is not null || bench is not null || deadlift is not null)
        {
            predictionEditorMode = "lifts";
            predictionSquatInput = FormatInputValue(squat);
            predictionBenchInput = FormatInputValue(bench);
            predictionDeadliftInput = FormatInputValue(deadlift);
        }
        else
        {
            predictionEditorMode = "total";
            predictionTotalInput = FormatInputValue(total);
        }

        predictionEditorError = null;
    }

    private void ClosePredictionEditor()
    {
        predictionEditorPosition = null;
        predictionEditorError = null;
    }

    private async Task LoadPredictionHistoryAsync(bool forceReloadAthlete = false)
    {
        var athlete = predictionEditorPosition is null ? null : GetSelectedAthlete(predictionEditorPosition.Value);
        if (athlete is null)
        {
            predictionHistory = null;
            loadedPredictionHistoryAthleteId = null;
            return;
        }

        if (!forceReloadAthlete &&
            string.Equals(loadedPredictionHistoryAthleteId, athlete.Id, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        isPredictionHistoryLoading = true;

        try
        {
            predictionHistory = await AthleteHistoryService.GetAthleteHistoryAsync(athlete.Id, Competition, historySourceCode);
        }
        catch
        {
            predictionHistory = null;
        }

        loadedPredictionHistoryAthleteId = athlete.Id;
        isPredictionHistoryLoading = false;
    }

    private async Task SetSelectorSlotPosition(int? slotPosition)
    {
        if (localSelectorSlotPosition == slotPosition)
        {
            return;
        }

        localSelectorSlotPosition = slotPosition;

        if (SelectorSlotPositionChanged.HasDelegate)
        {
            await SelectorSlotPositionChanged.InvokeAsync(slotPosition);
        }
    }

    private Task EmitAnswer(IEnumerable<AthletePlacementPick> placements)
    {
        if (ActiveQuestion is null)
        {
            return Task.CompletedTask;
        }

        var sanitizedPlacements = placements
            .Where(placement =>
                placement.Position >= 1 &&
                placement.Position <= SlotsCount &&
                !string.IsNullOrWhiteSpace(placement.AthleteId))
            .GroupBy(placement => placement.Position)
            .Select(grouping => grouping.First())
            .OrderBy(placement => placement.Position)
            .ToArray();

        return AnswerChanged.InvokeAsync(new PredictionAnswer
        {
            GroupId = Group.Id,
            QuestionId = ActiveQuestion.Id,
            QuestionType = ActiveQuestion.Type,
            Value = new PredictionAnswerValue
            {
                AthletePlacements = sanitizedPlacements
            },
            UpdatedAt = DateTimeOffset.UtcNow
        });
    }

    private IReadOnlyList<AthletePlacementPick> GetPlacements(string questionId)
    {
        return GetAnswer(questionId)?.Value.AthletePlacements
            .Where(placement => !string.IsNullOrWhiteSpace(placement.AthleteId))
            .OrderBy(placement => placement.Position)
            .ToArray() ?? [];
    }

    private PredictionAnswer? GetAnswer(string questionId)
    {
        return Answers.FirstOrDefault(answer => answer.QuestionId == questionId);
    }

    private Athlete? GetSelectedAthlete(int position)
    {
        if (ActiveQuestion is null)
        {
            return null;
        }

        var athleteId = GetPlacements(ActiveQuestion.Id)
            .FirstOrDefault(placement => placement.Position == position)?
            .AthleteId;

        if (string.IsNullOrWhiteSpace(athleteId))
        {
            return null;
        }

        return Competition.Athletes.FirstOrDefault(athlete => athlete.Id == athleteId);
    }

    private AthletePlacementPick? GetPlacementByAthleteId(string? athleteId)
    {
        if (string.IsNullOrWhiteSpace(athleteId) || ActiveQuestion is null)
        {
            return null;
        }

        return GetPlacements(ActiveQuestion.Id)
            .FirstOrDefault(placement => string.Equals(placement.AthleteId, athleteId, StringComparison.OrdinalIgnoreCase));
    }

    private static bool TryReadOptionalPositiveDecimal(string value, out decimal? parsed)
    {
        parsed = null;

        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        if ((!decimal.TryParse(value, NumberStyles.Number, CultureInfo.CurrentCulture, out var number) &&
             !decimal.TryParse(value, NumberStyles.Number, CultureInfo.InvariantCulture, out number)) ||
            number <= 0 ||
            number > 1500m)
        {
            return false;
        }

        parsed = number;
        return true;
    }

    private static string FormatInputValue(decimal? value)
    {
        // HTML number inputs require invariant decimal separator (dot).
        return value?.ToString("0.###", CultureInfo.InvariantCulture) ?? string.Empty;
    }

    private static bool HasAnyPredictionValues(AthletePlacementPick placement)
    {
        return placement.PredictedTotalKg is not null ||
               placement.PredictedSquatKg is not null ||
               placement.PredictedBenchKg is not null ||
               placement.PredictedDeadliftKg is not null;
    }

