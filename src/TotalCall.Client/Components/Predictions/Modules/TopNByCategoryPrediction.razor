    private int? GetFirstAvailableSlotPosition()
    {
        for (var position = 1; position <= SlotsCount; position++)
        {
            if (GetSelectedAthlete(position) is null)
            {
                return position;
            }
        }

        return null;
    }

    private bool IsAthleteEligibleForActiveQuestion(string? athleteId)
    {
        if (string.IsNullOrWhiteSpace(athleteId) || ActiveQuestion is null)
        {
            return false;
        }

        if (ActiveQuestion.AthleteIds.Count == 0)
        {
            return Competition.Athletes.Any(athlete =>
                string.Equals(athlete.Id, athleteId, StringComparison.OrdinalIgnoreCase));
        }

        return ActiveQuestion.AthleteIds.Contains(athleteId, StringComparer.OrdinalIgnoreCase);
    }

    private string GetCategoryName(PredictionQuestion question)
    {
        var category = Competition.Categories.FirstOrDefault(item => item.Id == question.CategoryId);
        return category?.Name ?? Text.QuestionTitle(Competition, question);
    }

    private string GetCategoryStatusLine(string questionId)
    {
        if (!StatusByQuestionId.TryGetValue(questionId, out var status))
        {
            return "0/0";
        }

        var requiredCount = Math.Max(1, status.RequiredCount);
        return $"{status.SelectedCount} / {requiredCount} · {GetStatusLabel(status.Status)}";
    }

    private string GetHeaderStatusClass(string questionId)
    {
        var status = StatusByQuestionId.TryGetValue(questionId, out var result)
            ? result.Status
            : PredictionCompletionStatus.NotStarted;

        return string.Join(
            " ",
            "topn-module__header-status",
            status switch
            {
                PredictionCompletionStatus.Complete => "topn-module__header-status--complete",
                PredictionCompletionStatus.InProgress => "topn-module__header-status--in-progress",
                _ => "topn-module__header-status--not-started"
            });
    }

    private string GetStatusLabel(PredictionCompletionStatus status)
    {
        return status switch
        {
            PredictionCompletionStatus.Complete => Localizer["Predictions.Status.Complete"],
            PredictionCompletionStatus.InProgress => Localizer["Predictions.Status.InProgress"],
            _ => Localizer["Predictions.Status.NotStarted"]
        };
    }

    private string GetWorkspaceTabClass(TopNWorkspaceTab tab)
    {
        return string.Join(
            " ",
            "topn-module__desktop-tab",
            activeWorkspaceTab == tab ? "topn-module__desktop-tab--active" : null);
    }

    private string GetWorkspacePaneClass(TopNWorkspaceTab tab)
    {
        return string.Join(
            " ",
            tab switch
            {
                TopNWorkspaceTab.Ranking => "topn-module__workspace",
                _ => "topn-module__inline-context"
            },
            activeWorkspaceTab == tab ? "is-pane-active" : null);
    }

    private enum TopNWorkspaceTab
    {
        Ranking = 0,
        Context = 1
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var editorAthlete = GetEditorAthlete();
        var editorAthleteId = editorAthlete?.Id;

        if (!string.Equals(lastEditorAthleteIdForWindows, editorAthleteId, StringComparison.OrdinalIgnoreCase))
        {
            if (!string.IsNullOrWhiteSpace(lastEditorAthleteIdForWindows))
            {
                Windows.UpdateAthleteHistorySlotContext(lastEditorAthleteIdForWindows, null);
            }

            lastEditorAthleteIdForWindows = editorAthleteId;
        }

        if (!string.IsNullOrWhiteSpace(editorAthleteId))
        {
            Windows.UpdateAthleteHistorySlotContext(
                editorAthleteId!,
                BuildSlotContext(editorAthlete, predictionEditorPosition));
        }

        await Task.CompletedTask;
    }

    public void Dispose()
    {
        Windows.AthleteHistoryActionRequested -= HandleAthleteHistoryActionRequested;
        AthleteDataSources.SourceChanged -= HandleDataSourceChanged;
    }

    private async void HandleDataSourceChanged(string competitionId, string source)
    {
        if (!string.Equals(competitionId, Competition.Id, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await InvokeAsync(async () =>
        {
            historySourceCode = source;
            loadedPredictionHistoryAthleteId = null;
            await LoadPredictionHistoryAsync(forceReloadAthlete: true);
            StateHasChanged();
        });
    }

    private Task OpenHistoryWindowForSlot(int position)
    {
        var athlete = GetSelectedAthlete(position);
        if (athlete is null)
        {
            return Task.CompletedTask;
        }

        return OpenHistoryWindow(athlete, position);
    }

    private Task OpenHistoryWindow(Athlete athlete, int? slotPosition)
    {
        var slotContext = BuildSlotContext(athlete, slotPosition);

        Windows.OpenAthleteHistory(
            competitionId: Competition.Id,
            athleteId: athlete.Id,
            athleteName: athlete.DisplayName,
            countryCode: athlete.CountryCode,
            countryName: athlete.CountryName,
            categoryName: ResolveCategoryNameForAthlete(athlete),
            nominatedTotalKg: athlete.SeedTotalKg,
            title: Localizer["Predictions.HistoryDialogTitle", athlete.DisplayName],
            slotContext: slotContext,
            predictedTotalKg: GetPlacementByAthleteId(athlete.Id)?.PredictedTotalKg);

        return Task.CompletedTask;
    }

    private AthleteHistorySlotContext? BuildSlotContext(Athlete? athlete, int? slotPosition)
    {
        if (athlete is null ||
            predictionEditorPosition is null ||
            slotPosition is null ||
            predictionEditorPosition != slotPosition)
        {
            return null;
        }

        var editorAthlete = GetEditorAthlete();
        if (editorAthlete is null ||
            !string.Equals(editorAthlete.Id, athlete.Id, StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return new AthleteHistorySlotContext(
            SlotPosition: predictionEditorPosition.Value,
            EditorAthleteId: athlete.Id,
            CanUseLast: predictionHistory?.LastResult?.TotalKg is not null,
            CanUseBest: predictionHistory?.Bests?.TotalKg is not null,
            CanUseNominated: athlete.SeedTotalKg is not null);
    }

    private Athlete? GetEditorAthlete()
    {
        return predictionEditorPosition is null
            ? null
            : GetSelectedAthlete(predictionEditorPosition.Value);
    }

    private string? ResolveCategoryNameForAthlete(Athlete athlete)
    {
        if (string.IsNullOrWhiteSpace(athlete.WeightCategoryId))
        {
            return null;
        }

        return Competition.Categories
            .FirstOrDefault(category => string.Equals(category.Id, athlete.WeightCategoryId, StringComparison.OrdinalIgnoreCase))
            ?.Name;
    }

    private void HandleAthleteHistoryActionRequested(string windowId, AthleteHistoryAction action)
    {
        var descriptor = Windows.Windows
            .OfType<AthleteHistoryWindowDescriptor>()
            .FirstOrDefault(window => string.Equals(window.Id, windowId, StringComparison.Ordinal));

        if (descriptor?.SlotContext is null ||
            predictionEditorPosition is null ||
            descriptor.SlotContext.SlotPosition != predictionEditorPosition.Value)
        {
            return;
        }

        var editorAthlete = GetEditorAthlete();
        if (editorAthlete is null ||
            !string.Equals(editorAthlete.Id, descriptor.SlotContext.EditorAthleteId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _ = action switch
        {
            AthleteHistoryAction.UseLastResult => UseLastResultForEditedAthlete(),
            AthleteHistoryAction.UseBestResult => UseBestResultForEditedAthlete(),
            AthleteHistoryAction.UseNominatedTotal => UseNominatedTotalForEditedAthlete(),
            _ => Task.CompletedTask
        };

        InvokeAsync(StateHasChanged);
    }
}
