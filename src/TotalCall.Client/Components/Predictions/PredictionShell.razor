@inject IStringLocalizer<SharedResource> Localizer

<section class="prediction-shell">
    <div class="prediction-shell__frame">
        <aside class="prediction-shell__left-rail">
            <div class="prediction-shell__left-rail-inner">
                <PredictionModuleNav
                    Competition="@Competition"
                    Groups="@Groups"
                    ActiveGroupId="@ActiveGroup.Id"
                    ModuleValidationByGroupId="@ModuleValidationByGroupId"
                    GroupChanged="@OnGroupChanged" />
            </div>
        </aside>

        <div class="prediction-shell__main-area">
            <div class="prediction-shell__content-row">
                <div class="prediction-shell__center-column">
                    <PredictionHeader
                        Competition="@Competition"
                        ActiveGroup="@ActiveGroup"
                        ModuleValidation="@ActiveModuleValidation"
                        CanEditPredictions="@CanEditNow"
                        Answers="@Answers"
                        UpdatesRequested="@OpenUpdates" />

                    @if (!CanEditNow)
                    {
                        <div class="notice notice--warning">
                            @Localizer["Predictions.Locked"]
                        </div>
                    }

                    <section class="prediction-shell__module" aria-label="@Localizer["Predictions.ActiveModuleAria"]">
                        <PredictionModuleRenderer
                            Competition="@Competition"
                            Group="@ActiveGroup" />
                    </section>
                </div>

                <aside class="prediction-shell__summary-rail">
                    <div class="prediction-shell__summary-rail-content">
                        <div class="prediction-shell__summary-panel-wrap">
                            <PredictionSummaryPanel
                                Competition="@Competition"
                                Group="@ActiveGroup"
                                ModuleValidation="@ActiveModuleValidation" />
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </div>

    <PredictionActionBar
        CompetitionSlug="@Competition.Slug"
        CompetitionName="@Competition.Name"
        PredictionLockAt="@Competition.PredictionLockAt"
        CompetitionStatus="@Competition.Status"
        CompetitionEndDate="@Competition.EndDate"
        CanEditPredictions="@CanEditNow"
        IsAuthenticated="@IsAuthenticated"
        SaveStatus="@SaveStatus"
        LastSavedAt="@LastSavedAt"
        SubmittedAt="@SubmittedAt"
        IsSubmitting="@IsSubmitting"
        SubmitError="@SubmitError"
        WithdrawnPickNames="@AffectedWithdrawnAthleteNames"
        SubmitRequested="@SubmitRequested"
        RetrySyncRequested="@RetrySyncRequested"
        ShareRequested="@ShareRequested" />

    <CompetitionTimeline
        Competition="@Competition"
        Answers="@Answers"
        CanEditPredictions="@CanEditNow"
        IsOpen="@isUpdatesOpen"
        Closed="@CloseUpdates" />
</section>

@code {
    [Parameter, EditorRequired]
    public Competition Competition { get; set; } = default!;

    [Parameter, EditorRequired]
    public IReadOnlyList<PredictionGroup> Groups { get; set; } = [];

    [Parameter, EditorRequired]
    public PredictionGroup ActiveGroup { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<PredictionAnswer> Answers { get; set; } = [];

    [Parameter, EditorRequired]
    public PredictionModuleValidationResult ActiveModuleValidation { get; set; } = default!;

    [Parameter]
    public IReadOnlyDictionary<string, PredictionModuleValidationResult> ModuleValidationByGroupId { get; set; } =
        new Dictionary<string, PredictionModuleValidationResult>(StringComparer.OrdinalIgnoreCase);

    [Parameter]
    public bool CanEditPredictions { get; set; }

    [Parameter]
    public bool IsAuthenticated { get; set; }

    [Parameter]
    public PredictionSaveStatus SaveStatus { get; set; }

    [Parameter]
    public DateTimeOffset? LastSavedAt { get; set; }

    [Parameter]
    public DateTimeOffset? SubmittedAt { get; set; }

    [Parameter]
    public bool IsSubmitting { get; set; }

    [Parameter]
    public string? SubmitError { get; set; }

    [Parameter]
    public EventCallback<string> GroupChanged { get; set; }

    [Parameter]
    public EventCallback<PredictionAnswer> AnswerChanged { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> ShareRequested { get; set; }

    [Parameter]
    public EventCallback SubmitRequested { get; set; }

    [Parameter]
    public EventCallback RetrySyncRequested { get; set; }

    private bool isUpdatesOpen;

    private bool CanEditNow => PredictionDeadline.CanEdit(
        CanEditPredictions,
        Competition.Status,
        Competition.PredictionLockAt,
        Competition.EndDate,
        DateTimeOffset.UtcNow);

    private IReadOnlyList<string> AffectedWithdrawnAthleteNames =>
        RosterUpdateService.GetAffectedAthleteNames(Competition, Answers);

    private Task OnGroupChanged(string groupId)
    {
        return GroupChanged.InvokeAsync(groupId);
    }

    private Task OpenUpdates(MouseEventArgs _)
    {
        isUpdatesOpen = true;
        return Task.CompletedTask;
    }

    private Task CloseUpdates()
    {
        isUpdatesOpen = false;
        return Task.CompletedTask;
    }
}
