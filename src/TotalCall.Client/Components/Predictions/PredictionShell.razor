@inject IStringLocalizer<SharedResource> Localizer
@inject PredictionTextService Text

<section class="prediction-shell">
    <div class="prediction-shell__frame">
        <aside class="prediction-shell__left-rail">
            <div class="prediction-shell__left-rail-inner">
                <PredictionModuleNav
                    Competition="@Competition"
                    Groups="@Groups"
                    ActiveGroupId="@ActiveGroup.Id"
                    ModuleValidationByGroupId="@ModuleValidationByGroupId"
                    GroupChanged="@OnGroupChanged" />

                @if (IsTopNActiveGroup && OrderedTopNQuestions.Count > 0)
                {
                    <CategoryStatusList
                        Questions="OrderedTopNQuestions"
                        StatusByQuestionId="TopNStatusByQuestionId"
                        ActiveQuestionId="@CurrentTopNQuestionId"
                        CategoryLabelSelector="GetTopNCategoryName"
                        CategoryChanged="OnTopNQuestionChanged" />
                }
            </div>
        </aside>

        <div class="prediction-shell__top-row">
            <PredictionHeader
                Competition="@Competition"
                ActiveGroup="@ActiveGroup"
                ModuleValidation="@ActiveModuleValidation"
                SaveStatus="@SaveStatus"
                LastSavedAt="@LastSavedAt"
                CanEditPredictions="@CanEditPredictions" />
        </div>

        <div class="prediction-shell__center-column">
            @if (!CanEditPredictions)
            {
                <div class="notice notice--warning">
                    @Localizer["Predictions.Locked"]
                </div>
            }

            <section class="prediction-shell__module" aria-label="@Localizer["Predictions.ActiveModuleAria"]">
                <PredictionModuleRenderer
                    Competition="@Competition"
                    Group="@ActiveGroup"
                    Answers="@Answers.Where(answer => answer.GroupId == ActiveGroup.Id).ToArray()"
                    ModuleValidation="@ActiveModuleValidation"
                    CanEditPredictions="@CanEditPredictions"
                    SaveStatus="@SaveStatus"
                    LastSavedAt="@LastSavedAt"
                    ShowSummaryAction="false"
                    ShowCompactModuleInfo="false"
                    UseExternalTopNSidebar="@IsTopNActiveGroup"
                    ActiveTopNQuestionId="@CurrentTopNQuestionId"
                    ActiveTopNAthleteId="@selectedTopNAthleteId"
                    TopNQuestionChanged="@OnTopNQuestionChanged"
                    TopNAthleteContextRequested="@OnTopNAthleteContextRequested"
                    SummaryRequested="@OpenSummaryDrawer"
                    AnswerChanged="@AnswerChanged" />
            </section>
        </div>

        <aside class="@SummaryRailClass">
            <div class="prediction-shell__summary-rail-content">
                <div class="prediction-shell__summary-panel-wrap">
                    @if (IsTopNActiveGroup)
                    {
                        <TopNContextPanel
                            Competition="@Competition"
                            ActiveQuestion="@CurrentTopNQuestion"
                            ActiveQuestionStatus="@CurrentTopNQuestionStatus"
                            SelectedAthleteId="@selectedTopNAthleteId"
                            SelectedAthleteRank="@SelectedTopNAthleteRank"
                            AthleteContextRequested="@OnTopNAthleteContextRequested"
                            AthleteSelectionCleared="@OnTopNAthleteSelectionCleared"
                            UseNominatedTotalRequested="@OnTopNUseNominatedTotalRequested"
                            CompareAthletesRequested="@OnTopNCompareAthletesRequested" />
                    }
                    else
                    {
                        <PredictionSummaryPanel
                            Competition="@Competition"
                            Group="@ActiveGroup"
                            ModuleValidation="@ActiveModuleValidation"
                            SaveStatus="@SaveStatus"
                            LastSavedAt="@LastSavedAt" />
                    }
                </div>
            </div>
        </aside>
    </div>

    <button
        type="button"
        class="@SummaryBackdropClass"
        aria-hidden="@(!isSummaryDrawerOpen)"
        tabindex="-1"
        @onclick="OnSummaryBackdropClicked">
    </button>

    <aside class="@SummaryDrawerClass" aria-hidden="@(!isSummaryDrawerOpen)">
        <button
            type="button"
            class="prediction-shell__summary-drawer-close"
            aria-label="@Localizer["Predictions.CloseContext"]"
            @onclick="OnCloseSummaryClicked">
            <AppIcon Name="AppIconName.X" Size="14" />
        </button>

        @if (IsTopNActiveGroup)
        {
            <TopNContextPanel
                Competition="@Competition"
                ActiveQuestion="@CurrentTopNQuestion"
                ActiveQuestionStatus="@CurrentTopNQuestionStatus"
                SelectedAthleteId="@selectedTopNAthleteId"
                SelectedAthleteRank="@SelectedTopNAthleteRank"
                AthleteContextRequested="@OnTopNAthleteContextRequested"
                AthleteSelectionCleared="@OnTopNAthleteSelectionCleared"
                UseNominatedTotalRequested="@OnTopNUseNominatedTotalRequested"
                CompareAthletesRequested="@OnTopNCompareAthletesRequested" />
        }
        else
        {
            <PredictionSummaryPanel
                Competition="@Competition"
                Group="@ActiveGroup"
                ModuleValidation="@ActiveModuleValidation"
                SaveStatus="@SaveStatus"
                LastSavedAt="@LastSavedAt" />
        }
    </aside>

    <PredictionNavigationBar
        HasPrevious="@HasPreviousGroup"
        HasNext="@HasNextGroup"
        CanEditPredictions="@CanEditPredictions"
        ActiveModuleValidation="@ActiveModuleValidation"
        PreviousRequested="@GoPrevious"
        NextRequested="@GoNextOrReview"
        ReviewRequested="@ReviewRequested" />

    <PredictionMobileBottomBar
        HasNext="@HasNextGroup"
        CanEditPredictions="@CanEditPredictions"
        ActiveModuleValidation="@ActiveModuleValidation"
        NextRequested="@GoNextOrReview"
        ReviewRequested="@ReviewRequested" />
</section>

@code {
    [Parameter, EditorRequired]
    public Competition Competition { get; set; } = default!;

    [Parameter, EditorRequired]
    public IReadOnlyList<PredictionGroup> Groups { get; set; } = [];

    [Parameter, EditorRequired]
    public PredictionGroup ActiveGroup { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<PredictionAnswer> Answers { get; set; } = [];

    [Parameter, EditorRequired]
    public PredictionModuleValidationResult ActiveModuleValidation { get; set; } = default!;

    [Parameter]
    public IReadOnlyDictionary<string, PredictionModuleValidationResult> ModuleValidationByGroupId { get; set; } =
        new Dictionary<string, PredictionModuleValidationResult>(StringComparer.OrdinalIgnoreCase);

    [Parameter]
    public bool CanEditPredictions { get; set; }

    [Parameter]
    public string? SaveStatus { get; set; }

    [Parameter]
    public DateTimeOffset? LastSavedAt { get; set; }

    [Parameter]
    public EventCallback<string> GroupChanged { get; set; }

    [Parameter]
    public EventCallback<PredictionAnswer> AnswerChanged { get; set; }

    [Parameter]
    public EventCallback ReviewRequested { get; set; }

    private int ActiveGroupIndex => GetGroupIndex(ActiveGroup.Id);

    private bool HasPreviousGroup => ActiveGroupIndex > 0;

    private bool HasNextGroup => ActiveGroupIndex >= 0 && ActiveGroupIndex < Groups.Count - 1;

    private bool HasMultipleGroups => Groups.Count > 1;
    private string? activeTopNQuestionId;
    private string? selectedTopNAthleteId;
    private bool isSummaryDrawerOpen;
    private const string SummaryRailClass = "prediction-shell__summary-rail";

    private string SummaryDrawerClass => string.Join(
        " ",
        "prediction-shell__summary-drawer",
        isSummaryDrawerOpen ? "is-open" : null);

    private string SummaryBackdropClass => string.Join(
        " ",
        "prediction-shell__summary-backdrop",
        isSummaryDrawerOpen ? "is-open" : null);

    private bool IsTopNActiveGroup => ResolveGroupType(ActiveGroup) == PredictionModuleType.TopNByCategory;

    private IReadOnlyList<PredictionQuestion> OrderedTopNQuestions => IsTopNActiveGroup
        ? ActiveGroup.Questions.OrderBy(question => question.Order).ToArray()
        : [];

    private IReadOnlyDictionary<string, PredictionQuestionCompletionResult> TopNStatusByQuestionId => IsTopNActiveGroup
        ? ActiveModuleValidation.Questions.ToDictionary(result => result.QuestionId, StringComparer.OrdinalIgnoreCase)
        : new Dictionary<string, PredictionQuestionCompletionResult>(StringComparer.OrdinalIgnoreCase);

    private string CurrentTopNQuestionId => activeTopNQuestionId ??
        OrderedTopNQuestions.FirstOrDefault()?.Id ??
        string.Empty;

    private PredictionQuestion? CurrentTopNQuestion => OrderedTopNQuestions
        .FirstOrDefault(question => string.Equals(question.Id, CurrentTopNQuestionId, StringComparison.OrdinalIgnoreCase));

    private PredictionQuestionCompletionResult? CurrentTopNQuestionStatus => CurrentTopNQuestion is null
        ? null
        : TopNStatusByQuestionId.TryGetValue(CurrentTopNQuestion.Id, out var status)
            ? status
            : null;

    private int? SelectedTopNAthleteRank => GetSelectedAthleteRank(selectedTopNAthleteId);

    protected override void OnParametersSet()
    {
        if (!IsTopNActiveGroup)
        {
            activeTopNQuestionId = null;
            selectedTopNAthleteId = null;
            return;
        }

        if (string.IsNullOrWhiteSpace(activeTopNQuestionId) ||
            OrderedTopNQuestions.All(question => !string.Equals(question.Id, activeTopNQuestionId, StringComparison.OrdinalIgnoreCase)))
        {
            activeTopNQuestionId = OrderedTopNQuestions.FirstOrDefault()?.Id;
        }

        if (!IsAthleteInCurrentTopNQuestion(selectedTopNAthleteId))
        {
            selectedTopNAthleteId = null;
        }
    }

    private int GetGroupIndex(string groupId)
    {
        for (var index = 0; index < Groups.Count; index++)
        {
            if (Groups[index].Id == groupId)
            {
                return index;
            }
        }

        return -1;
    }

    private async Task GoPrevious()
    {
        if (!HasPreviousGroup)
        {
            return;
        }

        selectedTopNAthleteId = null;
        isSummaryDrawerOpen = false;
        await GroupChanged.InvokeAsync(Groups[ActiveGroupIndex - 1].Id);
    }

    private async Task GoNextOrReview()
    {
        if (HasNextGroup)
        {
            selectedTopNAthleteId = null;
            isSummaryDrawerOpen = false;
            await GroupChanged.InvokeAsync(Groups[ActiveGroupIndex + 1].Id);
            return;
        }

        await ReviewRequested.InvokeAsync();
    }

    private Task OpenSummaryDrawer()
    {
        isSummaryDrawerOpen = true;
        return Task.CompletedTask;
    }

    private Task OnSummaryBackdropClicked(MouseEventArgs _)
    {
        isSummaryDrawerOpen = false;
        return Task.CompletedTask;
    }

    private Task OnCloseSummaryClicked(MouseEventArgs _)
    {
        isSummaryDrawerOpen = false;
        return Task.CompletedTask;
    }

    private async Task OnGroupChanged(string groupId)
    {
        selectedTopNAthleteId = null;
        isSummaryDrawerOpen = false;
        await GroupChanged.InvokeAsync(groupId);
    }

    private Task OnTopNQuestionChanged(string questionId)
    {
        if (OrderedTopNQuestions.Any(question => string.Equals(question.Id, questionId, StringComparison.OrdinalIgnoreCase)))
        {
            activeTopNQuestionId = questionId;

            if (!IsAthleteInCurrentTopNQuestion(selectedTopNAthleteId))
            {
                selectedTopNAthleteId = null;
            }

            return InvokeAsync(StateHasChanged);
        }

        return Task.CompletedTask;
    }

    private Task OnTopNAthleteContextRequested(string athleteId)
    {
        if (string.IsNullOrWhiteSpace(athleteId))
        {
            selectedTopNAthleteId = null;
            return Task.CompletedTask;
        }

        selectedTopNAthleteId = athleteId;
        return Task.CompletedTask;
    }

    private Task OnTopNAthleteSelectionCleared()
    {
        selectedTopNAthleteId = null;
        return Task.CompletedTask;
    }

    private Task OnTopNCompareAthletesRequested()
    {
        isSummaryDrawerOpen = false;
        return Task.CompletedTask;
    }

    private Task OnTopNUseNominatedTotalRequested()
    {
        if (!CanEditPredictions || CurrentTopNQuestion is null)
        {
            return Task.CompletedTask;
        }

        var slotsCount = CurrentTopNQuestion.Constraints.ExactSelections ??
                         CurrentTopNQuestion.Constraints.MaxSelections ??
                         5;

        var athletePool = CurrentTopNQuestion.AthleteIds.Count == 0
            ? Competition.Athletes
            : Competition.Athletes
                .Where(athlete => CurrentTopNQuestion.AthleteIds.Contains(athlete.Id))
                .ToArray();

        var placements = athletePool
            .OrderByDescending(athlete => athlete.SeedTotalKg ?? 0m)
            .ThenBy(athlete => athlete.DisplayName, StringComparer.OrdinalIgnoreCase)
            .Take(slotsCount)
            .Select((athlete, index) => new AthletePlacementPick
            {
                Position = index + 1,
                AthleteId = athlete.Id
            })
            .ToArray();

        return AnswerChanged.InvokeAsync(new PredictionAnswer
        {
            GroupId = ActiveGroup.Id,
            QuestionId = CurrentTopNQuestion.Id,
            QuestionType = CurrentTopNQuestion.Type,
            Value = new PredictionAnswerValue
            {
                AthletePlacements = placements
            },
            UpdatedAt = DateTimeOffset.UtcNow
        });
    }

    private string GetTopNCategoryName(PredictionQuestion question)
    {
        var category = Competition.Categories.FirstOrDefault(item => item.Id == question.CategoryId);
        return category?.Name ?? Text.QuestionTitle(Competition, question);
    }

    private bool IsAthleteInCurrentTopNQuestion(string? athleteId)
    {
        if (string.IsNullOrWhiteSpace(athleteId) || CurrentTopNQuestion is null)
        {
            return false;
        }

        if (CurrentTopNQuestion.AthleteIds.Count == 0)
        {
            return Competition.Athletes.Any(athlete =>
                string.Equals(athlete.Id, athleteId, StringComparison.OrdinalIgnoreCase));
        }

        return CurrentTopNQuestion.AthleteIds.Contains(athleteId, StringComparer.OrdinalIgnoreCase);
    }

    private int? GetSelectedAthleteRank(string? athleteId)
    {
        if (string.IsNullOrWhiteSpace(athleteId) || CurrentTopNQuestion is null)
        {
            return null;
        }

        var placements = Answers
            .FirstOrDefault(answer =>
                string.Equals(answer.GroupId, ActiveGroup.Id, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(answer.QuestionId, CurrentTopNQuestion.Id, StringComparison.OrdinalIgnoreCase))
            ?.Value.AthletePlacements ?? [];

        return placements
            .FirstOrDefault(placement => string.Equals(placement.AthleteId, athleteId, StringComparison.OrdinalIgnoreCase))
            ?.Position;
    }

    private static string ResolveGroupType(PredictionGroup group)
    {
        var normalizedType = PredictionModuleType.Normalize(group.Type);
        if (!string.IsNullOrWhiteSpace(normalizedType))
        {
            return normalizedType;
        }

        var questionTypes = group.Questions
            .Select(question => question.Type)
            .Distinct()
            .ToArray();

        if (questionTypes.Length == 1 &&
            questionTypes[0] == PredictionQuestionType.AthleteRanking &&
            group.Questions.Count > 1 &&
            group.Questions.All(question => !string.IsNullOrWhiteSpace(question.CategoryId)))
        {
            return PredictionModuleType.TopNByCategory;
        }

        return string.Empty;
    }
}
