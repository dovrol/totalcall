@using System.Globalization
@using TotalCall.Client.Application.Services
@using TotalCall.Client.Application.Windows
@using TotalCall.Client.Domain.Athletes
@inject AthleteHistoryService AthleteHistoryService
@inject AthleteDataSourcePreferenceService AthleteDataSources
@inject CompetitionService CompetitionService
@inject WindowManager Windows
@inject IStringLocalizer<SharedResource> Localizer

<FloatingWindow Descriptor="Descriptor" AdditionalClass="floating-window--athlete-history">
    <section class="ap">
        <div class="ap-id">
            <span class="ph" aria-hidden="true">@GetAthleteInitials(Descriptor.AthleteName)</span>
            <div class="ap-id__meta">
                <div class="nm">@Descriptor.AthleteName</div>
                <div class="ct">
                    <CountryFlag Code="@Descriptor.CountryCode" CountryName="@Descriptor.CountryName" />
                    <span>@(Descriptor.CountryName ?? Localizer["Common.Tbd"].Value)</span>
                </div>
            </div>
            <div class="id-right">
                @if (!string.IsNullOrWhiteSpace(Descriptor.CategoryName))
                {
                    <span class="pill cat">@Descriptor.CategoryName</span>
                }
                @if (availableSources.Count > 1)
                {
                    <div class="seg" role="group" aria-label="@Localizer["Predictions.DataSource"]">
                        @foreach (var source in availableSources)
                        {
                            <button
                                type="button"
                                class="@(IsCurrentSource(source) ? "on" : null)"
                                disabled="@isLoading"
                                @onclick="() => OnSourceChangedAsync(source)">
                                @AthleteDataSourcePreferenceService.GetSourceLabel(source)
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

        @if (HasActiveSlotActions)
        {
            <div class="ap-quick" aria-label="@Localizer["FloatingWindow.HistoryActionsLabel"]">
                <span class="ap-quick__hint">@string.Format(Localizer["FloatingWindow.ApplyToSlot"].Value, Descriptor.SlotContext!.SlotPosition)</span>
                <div class="ap-quick__row">
                    <button
                        type="button"
                        class="app-button app-button--secondary app-button--sm"
                        disabled="@(!CanUseLast)"
                        @onclick="OnUseLast">
                        <AppIcon Name="AppIconName.Clock" Size="14" />
                        @Localizer["Predictions.UseLastResult"]
                    </button>
                    <button
                        type="button"
                        class="app-button app-button--secondary app-button--sm"
                        disabled="@(!CanUseBest)"
                        @onclick="OnUseBest">
                        <AppIcon Name="AppIconName.Trophy" Size="14" />
                        @Localizer["Predictions.UseBestResult"]
                    </button>
                    <button
                        type="button"
                        class="app-button app-button--secondary app-button--sm"
                        disabled="@(!CanUseNominated)"
                        @onclick="OnUseNominated">
                        <AppIcon Name="AppIconName.Target" Size="14" />
                        @Localizer["Predictions.UseNominatedTotal"]
                    </button>
                </div>
            </div>
        }

        @if (isLoading)
        {
            <p class="ap-empty">@Localizer["Predictions.LoadingHistory"]</p>
        }
        else if (isError)
        {
            <p class="ap-empty">@Localizer["Predictions.HistoryLoadError"]</p>
        }
        else if (History is null)
        {
            <div class="ap-empty-state">
                <p class="ap-empty">@Localizer["Predictions.NoAthleteHistoryForSource", CurrentSourceLabel]</p>
                @if (AlternateSource is { } alternateSource)
                {
                    <button
                        type="button"
                        class="app-button app-button--secondary app-button--sm"
                        @onclick="() => OnSourceChangedAsync(alternateSource)">
                        @Localizer["Predictions.TryDataSource", AthleteDataSourcePreferenceService.GetSourceLabel(alternateSource)]
                    </button>
                }
            </div>
        }
        else
        {
            @if (Verdict.IsAvailable || Descriptor.NominatedTotalKg is not null)
            {
                <div class="@VerdictClass">
                    @if (Verdict.IsAvailable)
                    {
                        <div class="vd-main">
                            <span class="vd-flag"><span class="pulse"></span> @FormPhaseLabel(Verdict.Phase)</span>
                            <h2>@VerdictHeadline(Verdict)</h2>
                            @{
                                var facts = BuildVerdictFacts();
                            }
                            @if (facts.Count > 0)
                            {
                                <div class="vd-line">
                                    @for (var i = 0; i < facts.Count; i++)
                                    {
                                        if (i > 0)
                                        {
                                            <span class="vd-sep"> · </span>
                                        }
                                        <span>@facts[i].Label <b>@facts[i].Value</b></span>
                                    }
                                </div>
                            }
                            @if (Verdict.HasMeter)
                            {
                                <div class="vd-meter">
                                    <div class="meter-lbl"><span>@Localizer["Predictions.Profile.NominationChance"]</span><b>@TierLabel(Verdict.Tier)</b></div>
                                    <div class="meter">
                                        @for (var i = 1; i <= 5; i++)
                                        {
                                            <i class="@(i <= Verdict.MeterOn ? "on" : null)"></i>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    @if (Descriptor.NominatedTotalKg is not null)
                    {
                        <div class="vd-dual">
                            <div class="dual-col">
                                <div class="k">@Localizer["Predictions.Profile.Nomination"]</div>
                                <div class="v">@FormatKgValue(Descriptor.NominatedTotalKg)</div>
                            </div>
                            @if (Descriptor.PredictedTotalKg is not null)
                            {
                                <div class="dual-delta @DeltaClass">
                                    <AppIcon Name="AppIconName.ArrowRight" Size="18" Class="arr" />
                                    <span class="d">@DeltaText</span>
                                </div>
                                <div class="dual-col pred">
                                    <div class="k">@Localizer["Predictions.Profile.Projection"]</div>
                                    <div class="v">@FormatKgValue(Descriptor.PredictedTotalKg)</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            @if (SignalModels.Count > 0)
            {
                <div class="sec-h"><span class="t">@Localizer["Predictions.Profile.KeySignals"]</span><span class="ln"></span></div>
                <div class="signals">
                    @foreach (var signal in SignalModels)
                    {
                        var described = DescribeSignal(signal);
                        <div class="sig @described.Tone">
                            <div class="si"><AppIcon Name="@SignalIcon(signal)" Size="15" /></div>
                            <div>
                                <div class="sk">@described.Label</div>
                                <div class="sv">
                                    @described.Value
                                    @if (!string.IsNullOrWhiteSpace(described.Sub))
                                    {
                                        <small>@described.Sub</small>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (Analytics is { } metricsAnalytics && MetricColumns > 0)
            {
                <div class="sec-h"><span class="t">@Localizer["Predictions.Profile.Metrics"]</span><span class="ln"></span></div>
                <div class="metrics c@(MetricColumns)">
                    @if (metricsAnalytics.BestTotalKg is not null)
                    {
                        <div class="mc good">
                            <div class="k">@Localizer["Predictions.BestResult"]</div>
                            <div class="v">@FormatKg(metricsAnalytics.BestTotalKg)</div>
                            <div class="s">@GetBest12MonthText(metricsAnalytics)</div>
                        </div>
                    }
                    @if (metricsAnalytics.Last3AvgTotalKg is not null)
                    {
                        <div class="mc">
                            <div class="k">@Localizer["Predictions.Analytics.Last3Avg"]</div>
                            <div class="v">@FormatKg(metricsAnalytics.Last3AvgTotalKg)</div>
                            <div class="s">@GetAverageVsLastText(metricsAnalytics.Last3AvgTotalKg, metricsAnalytics.LastTotalKg)</div>
                        </div>
                    }
                    @if (HasScore(metricsAnalytics))
                    {
                        <div class="mc">
                            <div class="k">@Localizer["Predictions.Metric.GlDots"]</div>
                            <div class="dots-row">
                                <span><span class="lab">GL</span> @FormatScore(metricsAnalytics.BestGoodliftPoints)</span>
                                <span><span class="lab">DOTS</span> @FormatScore(metricsAnalytics.BestDotsPoints)</span>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (TrendPoints.Count > 1)
            {
                <div class="sec-h"><span class="t">@GetTrendChartScopeLabel()</span><span class="ln"></span></div>
                <div class="chart-card">
                    <AppTrendChart
                        Points="@TrendPoints"
                        Variant="AppTrendChartVariant.Full"
                        AdditionalClass="app-trend-chart--athlete-history-window"
                        AriaLabel="@GetTrendChartScopeLabel()" />
                </div>
            }

            @if (AttemptRows.Count > 0)
            {
                <div class="sec-h">
                    <span class="t">@Localizer["Predictions.Analytics.LiftAttemptSuccess"]</span>
                    <span class="ln"></span>
                    @if (AttemptBenchmark is not null)
                    {
                        <span class="note">@GetBenchmarkScopeLabel(AttemptBenchmark)</span>
                    }
                </div>
                <div class="att">
                    @foreach (var attempt in AttemptRows)
                    {
                        <div class="att-row">
                            <div class="att-top">
                                <span class="att-lift">@attempt.Label</span>
                                <span class="att-pct">@attempt.Rate</span>
                            </div>
                            <div class="att-bar @(attempt.Partial ? "partial" : null)">
                                <i style="width: @attempt.Width;"></i>
                            </div>
                            <div class="att-meta">
                                <span>@attempt.Count</span>
                                @if (!string.IsNullOrWhiteSpace(attempt.Delta))
                                {
                                    <span class="vs @attempt.DeltaClass">@attempt.Delta</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            @if (PrCards.Count > 0)
            {
                <div class="sec-h"><span class="t">@Localizer["Predictions.LifetimePrs"]</span><span class="ln"></span></div>
                <div class="metrics c@(PrCards.Count)">
                    @foreach (var pr in PrCards)
                    {
                        <div class="mc @(pr.Accent ? "accent" : null)">
                            <div class="k">@pr.Label</div>
                            <div class="v">@pr.Value</div>
                        </div>
                    }
                </div>
            }

            @if (RecentResults.Count > 0)
            {
                <div class="sec-h"><span class="t">@Localizer["Predictions.RecentStarts"]</span><span class="ln"></span></div>

                <div class="ap-starts ap-starts--table">
                    <table class="tbl">
                        <thead>
                            <tr>
                                <th>@Localizer["Predictions.History.Date"]</th>
                                <th>@Localizer["Predictions.History.Meet"]</th>
                                <th class="num">@Localizer["Predictions.BodyweightShort"]</th>
                                <th class="num">SQ</th>
                                <th class="num">BP</th>
                                <th class="num">DL</th>
                                <th class="num">Total</th>
                                <th style="text-align:center;">@Localizer["Predictions.History.Place"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in RecentResults)
                            {
                                <tr class="@(IsBestStart(result) ? "best" : null)">
                                    <td style="color: var(--text-primary); font-weight: 700;">@FormatDate(result.Date)</td>
                                    <td class="meet">
                                        @FormatRecentStartTitle(result)
                                        @if (!string.IsNullOrWhiteSpace(result.Federation))
                                        {
                                            <small>@result.Federation</small>
                                        }
                                    </td>
                                    <td class="num">@FormatBodyweightValue(result.BodyweightKg)</td>
                                    <td class="num">@FormatKgValue(result.SquatKg)</td>
                                    <td class="num">@FormatKgValue(result.BenchKg)</td>
                                    <td class="num">@FormatKgValue(result.DeadliftKg)</td>
                                    <td class="num total">@FormatKgValue(result.TotalKg)</td>
                                    <td style="text-align:center;">
                                        <span class="plc @(IsFirstPlace(result.Placing) ? "p1" : null)">@FormatPlacing(result.Placing)</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="ap-starts ap-starts--cards">
                    @foreach (var result in RecentResults)
                    {
                        <div class="mstart @(IsBestStart(result) ? "best" : null)">
                            <div class="ms-top">
                                <span class="plc @(IsFirstPlace(result.Placing) ? "p1" : null)">@FormatPlacing(result.Placing)</span>
                                <div class="ms-meet-wrap">
                                    <div class="ms-meet">@FormatRecentStartTitle(result)</div>
                                    <div class="ms-date">@FormatDate(result.Date)@(string.IsNullOrWhiteSpace(result.Federation) ? "" : " · " + result.Federation)</div>
                                </div>
                                @if (result.BodyweightKg is not null)
                                {
                                    <span class="ms-bw">@Localizer["Predictions.BodyweightShort"] @FormatBodyweightValue(result.BodyweightKg)</span>
                                }
                            </div>
                            <div class="ms-lifts">
                                <div class="ms-l"><div class="k">SQ</div><div class="v">@FormatKgValue(result.SquatKg)</div></div>
                                <div class="ms-l"><div class="k">BP</div><div class="v">@FormatKgValue(result.BenchKg)</div></div>
                                <div class="ms-l"><div class="k">DL</div><div class="v">@FormatKgValue(result.DeadliftKg)</div></div>
                                <div class="ms-l tot"><div class="k">Total</div><div class="v">@FormatKgValue(result.TotalKg)</div></div>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="ap-foot">
                <AthleteDataSourceNote SourceCode="@currentSource" />
            </div>
        }
    </section>
</FloatingWindow>

@code {
    [Parameter, EditorRequired]
    public AthleteHistoryWindowDescriptor Descriptor { get; set; } = default!;

    private AthleteHistoryEntry? History;
    private AthleteAttemptBenchmark? AttemptBenchmark;
    private Competition? competition;
    private IReadOnlyList<string> availableSources = [];
    private string currentSource = ExternalAthleteSources.OpenIpf;
    private string? loadedAthleteId;
    private string? loadedSourceCode;
    private bool isLoading;
    private bool isError;
    private const int MinimumBenchmarkCountedAttempts = AthleteInsightBuilder.MinimumBenchmarkCountedAttempts;

    private AthleteHistorySlotContext? Slot => Descriptor.SlotContext;

    private bool HasActiveSlotActions => Slot is not null;

    private bool CanUseLast => Slot is { CanUseLast: true } && History?.LastResult?.TotalKg is not null;

    private bool CanUseBest => Slot is { CanUseBest: true } && History?.Bests?.TotalKg is not null;

    private bool CanUseNominated => Slot is { CanUseNominated: true } && Descriptor.NominatedTotalKg is not null;

    private IReadOnlyList<AthleteRecentResult> RecentResults => History?.RecentResults ?? [];

    private AthleteAnalytics? Analytics => History?.Analytics;

    private string CurrentSourceLabel => AthleteDataSourcePreferenceService.GetSourceLabel(currentSource);

    private string? AlternateSource => availableSources.FirstOrDefault(source =>
        !string.Equals(source, currentSource, StringComparison.OrdinalIgnoreCase));

    private decimal? BestSquatKg => History?.Bests?.SquatKg ??
                                    History?.RecentResults.Max(result => result.SquatKg);

    private decimal? BestBenchKg => History?.Bests?.BenchKg ??
                                    History?.RecentResults.Max(result => result.BenchKg);

    private decimal? BestDeadliftKg => History?.Bests?.DeadliftKg ??
                                       History?.RecentResults.Max(result => result.DeadliftKg);

    private decimal? BestTotalKg => History?.Bests?.TotalKg ??
                                    History?.RecentResults
                                        .Where(AthleteHistoryService.IsFullPowerSbdTotal)
                                        .Max(result => result.TotalKg);

    private IReadOnlyList<AppTrendChartPoint> TrendPoints => BuildTrendPoints();

    // ---- derived verdict + signals (presentation over real analytics) ----

    private AthleteFormVerdict Verdict => AthleteInsightBuilder.BuildVerdict(Analytics, Descriptor.NominatedTotalKg);

    private IReadOnlyList<AthleteSignal> SignalModels =>
        AthleteInsightBuilder.BuildSignals(Analytics, AttemptBenchmark, Descriptor.NominatedTotalKg);

    private string VerdictClass => Verdict.Tone == AthleteVerdictTone.Caution ? "verdict warn" : "verdict";

    private decimal? PredictionDelta => Descriptor.PredictedTotalKg is { } predicted && Descriptor.NominatedTotalKg is { } nominated
        ? predicted - nominated
        : null;

    private string DeltaText => PredictionDelta is { } delta
        ? (delta > 0 ? "+" : string.Empty) + FormatKgValue(delta)
        : string.Empty;

    private string DeltaClass => PredictionDelta switch
    {
        > 0m => "up",
        < 0m => "down",
        _ => "flat"
    };

    private int MetricColumns
    {
        get
        {
            if (Analytics is not { } analytics)
            {
                return 0;
            }

            var count = 0;
            if (analytics.BestTotalKg is not null) { count++; }
            if (analytics.Last3AvgTotalKg is not null) { count++; }
            if (HasScore(analytics)) { count++; }
            return count;
        }
    }

    private static bool HasScore(AthleteAnalytics analytics) =>
        analytics.BestGoodliftPoints is not null || analytics.BestDotsPoints is not null;

    private IReadOnlyList<AttemptSummary> AttemptRows => Analytics is { } analytics
        ? BuildAttemptSummaries(analytics).Where(row => row.Rate != "--").ToArray()
        : [];

    private IReadOnlyList<PrCard> PrCards
    {
        get
        {
            var cards = new List<PrCard>(4);
            if (BestSquatKg is not null) { cards.Add(new PrCard("SQ", FormatKg(BestSquatKg), false)); }
            if (BestBenchKg is not null) { cards.Add(new PrCard("BP", FormatKg(BestBenchKg), false)); }
            if (BestDeadliftKg is not null) { cards.Add(new PrCard("DL", FormatKg(BestDeadliftKg), false)); }
            if (BestTotalKg is not null) { cards.Add(new PrCard("Total", FormatKg(BestTotalKg), true)); }
            return cards;
        }
    }

    private bool IsCurrentSource(string source) =>
        string.Equals(source, currentSource, StringComparison.OrdinalIgnoreCase);

    private string FormPhaseLabel(AthleteFormPhase phase) => phase switch
    {
        AthleteFormPhase.Peak => Localizer["Predictions.Profile.FormPeak"],
        AthleteFormPhase.Rising => Localizer["Predictions.Profile.FormRising"],
        AthleteFormPhase.Declining => Localizer["Predictions.Profile.FormDeclining"],
        _ => Localizer["Predictions.Profile.FormStable"]
    };

    private string VerdictHeadline(AthleteFormVerdict verdict) => verdict.Tier switch
    {
        AthleteRealizationTier.High => Localizer["Predictions.Profile.VerdictHigh"],
        AthleteRealizationTier.Moderate => Localizer["Predictions.Profile.VerdictModerate"],
        AthleteRealizationTier.Low => Localizer["Predictions.Profile.VerdictLow"],
        _ => Localizer["Predictions.Profile.VerdictForm"]
    };

    private string TierLabel(AthleteRealizationTier tier) => tier switch
    {
        AthleteRealizationTier.High => Localizer["Predictions.Profile.LevelHigh"],
        AthleteRealizationTier.Moderate => Localizer["Predictions.Profile.LevelModerate"],
        _ => Localizer["Predictions.Profile.LevelLow"]
    };

    private static AppIconName SignalIcon(AthleteSignal signal) => signal.Kind switch
    {
        AthleteSignalKind.Trend => signal.Tone == AthleteSignalTone.Down
            ? AppIconName.TrendDown
            : signal.Tone == AthleteSignalTone.Up
                ? AppIconName.TrendUp
                : AppIconName.ArrowRight,
        AthleteSignalKind.LastStart => AppIconName.CircleDot,
        AthleteSignalKind.AttemptSuccess => AppIconName.Check,
        AthleteSignalKind.Stability => AppIconName.Waves,
        _ => AppIconName.MoreHorizontal
    };

    private (string Label, string Value, string? Sub, string Tone) DescribeSignal(AthleteSignal signal)
    {
        var tone = signal.Tone switch
        {
            AthleteSignalTone.Up => "up",
            AthleteSignalTone.Accent => "acc",
            AthleteSignalTone.Down => "down",
            _ => "vio"
        };

        switch (signal.Kind)
        {
            case AthleteSignalKind.Trend:
                var trendLabel = signal.Count is { } starts
                    ? string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Analytics.TrendStarts"].Value, starts)
                    : Localizer["Predictions.TotalTrendShort"].Value;
                return (trendLabel, FormatSignedKg(signal.Value), null, tone);

            case AthleteSignalKind.LastStart:
                var value = signal.LastEqualsPr
                    ? Localizer["Predictions.Signal.AtPr"].Value
                    : signal.Value is { } prPercent
                        ? string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Analytics.PrPercent"].Value, prPercent.ToString("0", CultureInfo.CurrentCulture))
                        : "--";
                var nominationSub = signal.Secondary is { } pct
                    ? string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Signal.NominationPct"].Value, pct.ToString("0", CultureInfo.CurrentCulture))
                    : null;
                return (Localizer["Predictions.Signal.LastStart"].Value, value, nominationSub, tone);

            case AthleteSignalKind.AttemptSuccess:
                var attemptSub = signal.Secondary is { } pp && AttemptBenchmark is not null
                    ? $"{FormatSignedPercentagePoints(pp)} {GetBenchmarkScopeLabel(AttemptBenchmark)}"
                    : null;
                return (Localizer["Predictions.Analytics.AttemptSuccessOverall"].Value, FormatPercent(signal.Value), attemptSub, tone);

            default:
                return (Localizer["Predictions.Signal.Stability"].Value, $"±{FormatKg(signal.Value)}", null, tone);
        }
    }

    private IReadOnlyList<VerdictFact> BuildVerdictFacts()
    {
        if (Analytics is not { } analytics)
        {
            return [];
        }

        var facts = new List<VerdictFact>(3);

        if (analytics.LastTotalKg is not null)
        {
            var atPr = analytics.LastTotalToBestPercent is >= 99.5m;
            var value = atPr
                ? $"{FormatKg(analytics.LastTotalKg)} {Localizer["Predictions.Signal.AtPr"].Value}"
                : FormatKg(analytics.LastTotalKg);
            facts.Add(new VerdictFact(Localizer["Predictions.LastTotal"].Value, value));
        }

        var trend = analytics.RecentTotalTrendKg ?? analytics.TotalTrendKg;
        if (trend is not null)
        {
            facts.Add(new VerdictFact(Localizer["Predictions.TotalTrendShort"].Value, FormatSignedKg(trend)));
        }

        if (analytics.OverallAttempts.RatePercent is not null)
        {
            facts.Add(new VerdictFact(
                Localizer["Predictions.Analytics.AttemptSuccessOverall"].Value,
                FormatAttemptRate(analytics.OverallAttempts)));
        }

        return facts;
    }

    private static bool IsFirstPlace(string? placing) =>
        string.Equals(placing?.Trim(), "1", StringComparison.Ordinal);

    private string FormatPlacing(string? placing) =>
        string.IsNullOrWhiteSpace(placing) ? "—" : placing.Trim();

    private bool IsBestStart(AthleteRecentResult result) =>
        BestTotalKg is not null &&
        result.TotalKg is not null &&
        AthleteHistoryService.IsFullPowerSbdTotal(result) &&
        result.TotalKg.Value == BestTotalKg.Value;

    protected override async Task OnParametersSetAsync()
    {
        competition = await CompetitionService.GetCompetitionAsync(Descriptor.CompetitionId);
        availableSources = competition is null
            ? [ExternalAthleteSources.OpenIpf]
            : AthleteDataSources.GetAvailableSources(competition);
        var source = competition is null
            ? ExternalAthleteSources.OpenIpf
            : await AthleteDataSources.GetSourceAsync(competition);

        if (string.Equals(loadedAthleteId, Descriptor.AthleteId, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(loadedSourceCode, source, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await LoadHistoryAsync(source);
    }

    private async Task LoadHistoryAsync(string source)
    {
        currentSource = source;
        isLoading = true;
        isError = false;
        StateHasChanged();

        try
        {
            var athlete = competition?.Athletes.FirstOrDefault(item =>
                string.Equals(item.Id, Descriptor.AthleteId, StringComparison.OrdinalIgnoreCase));
            var historyTask = AthleteHistoryService.GetAthleteHistoryAsync(Descriptor.AthleteId, competition, source);
            var benchmarkTask = competition is null || athlete is null
                ? Task.FromResult<AthleteAttemptBenchmark?>(null)
                : AthleteHistoryService.GetAttemptBenchmarkAsync(competition, athlete, source);

            History = await historyTask;
            AttemptBenchmark = await benchmarkTask;
        }
        catch
        {
            History = null;
            AttemptBenchmark = null;
            isError = true;
        }

        loadedAthleteId = Descriptor.AthleteId;
        loadedSourceCode = source;
        isLoading = false;
    }

    private async Task OnSourceChangedAsync(string source)
    {
        if (competition is null ||
            string.Equals(source, currentSource, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await AthleteDataSources.SetSourceAsync(competition, source);
        await LoadHistoryAsync(source);
    }

    private Task OnUseLast()
    {
        Windows.RequestAthleteHistoryAction(Descriptor.Id, AthleteHistoryAction.UseLastResult);
        return Task.CompletedTask;
    }

    private Task OnUseBest()
    {
        Windows.RequestAthleteHistoryAction(Descriptor.Id, AthleteHistoryAction.UseBestResult);
        return Task.CompletedTask;
    }

    private Task OnUseNominated()
    {
        Windows.RequestAthleteHistoryAction(Descriptor.Id, AthleteHistoryAction.UseNominatedTotal);
        return Task.CompletedTask;
    }

    private IReadOnlyList<AppTrendChartPoint> BuildTrendPoints()
    {
        if (History?.RecentResults.Count is null or 0)
        {
            return [];
        }

        var sample = History.RecentResults
            .Where(AthleteHistoryService.IsFullPowerSbdTotal)
            .Take(8)
            .ToList();

        if (sample.Count == 0)
        {
            return [];
        }

        sample.Reverse();

        return sample
            .Select(result => new AppTrendChartPoint(
                result.TotalKg ?? 0m,
                FormatTrendLabel(result.Date),
                FormatTrendDetail(result)))
            .ToArray();
    }

    private IReadOnlyList<AttemptSummary> BuildAttemptSummaries(AthleteAnalytics analytics)
    {
        return
        [
            BuildAttemptSummary("SQ", analytics.SquatAttempts, AttemptBenchmark?.SquatAttempts),
            BuildAttemptSummary("BP", analytics.BenchAttempts, AttemptBenchmark?.BenchAttempts),
            BuildAttemptSummary("DL", analytics.DeadliftAttempts, AttemptBenchmark?.DeadliftAttempts),
            BuildAttemptSummary(
                Localizer["Predictions.Analytics.ThirdAttempts"].Value,
                analytics.ThirdAttempts,
                AttemptBenchmark?.ThirdAttempts,
                true)
        ];
    }

    private AttemptSummary BuildAttemptSummary(
        string label,
        AthleteAttemptSuccessRate attempts,
        AthleteAttemptSuccessRate? benchmarkAttempts,
        bool isHighPressure = false)
    {
        var rate = attempts.RatePercent;
        var width = rate is null
            ? "0%"
            : $"{Math.Clamp(rate.Value, 0m, 100m).ToString("0.##", CultureInfo.InvariantCulture)}%";

        var delta = FormatAttemptBenchmarkDelta(attempts, benchmarkAttempts);

        return new AttemptSummary(
            label,
            FormatAttemptRate(attempts),
            FormatAttemptCount(attempts),
            delta,
            GetAttemptDeltaClass(attempts, benchmarkAttempts),
            width,
            rate is not null and < 100m || isHighPressure && rate is not null);
    }

    private string GetBest12MonthText(AthleteAnalytics analytics)
    {
        return analytics.Best12MonthTotalKg is null
            ? Localizer["Predictions.Analytics.NoRecent12M"].Value
            : string.Format(
                CultureInfo.CurrentCulture,
                Localizer["Predictions.Analytics.Best12M"].Value,
                FormatKg(analytics.Best12MonthTotalKg));
    }

    private string FormatAttemptBenchmarkDelta(
        AthleteAttemptSuccessRate attempts,
        AthleteAttemptSuccessRate? benchmarkAttempts)
    {
        var delta = AthleteInsightBuilder.ResolveBenchmarkDeltaPp(attempts, benchmarkAttempts);
        return delta is null || AttemptBenchmark is null
            ? string.Empty
            : $"{FormatSignedPercentagePoints(delta.Value)} {GetBenchmarkScopeLabel(AttemptBenchmark)}";
    }

    private string FormatSignedPercentagePoints(decimal value)
    {
        var prefix = value > 0 ? "+" : string.Empty;
        return string.Format(
            CultureInfo.CurrentCulture,
            Localizer["Predictions.Analytics.PercentagePointDelta"].Value,
            $"{prefix}{value.ToString("0.#", CultureInfo.CurrentCulture)}");
    }

    private string GetAttemptDeltaClass(
        AthleteAttemptSuccessRate attempts,
        AthleteAttemptSuccessRate? benchmarkAttempts)
    {
        var delta = AthleteInsightBuilder.ResolveBenchmarkDeltaPp(attempts, benchmarkAttempts);
        return delta switch
        {
            > 0m => "att-delta att-delta--up",
            < 0m => "att-delta att-delta--down",
            _ => "att-delta"
        };
    }

    private string GetBenchmarkScopeLabel(AthleteAttemptBenchmark benchmark)
    {
        return benchmark.Scope switch
        {
            AthleteAttemptBenchmarkScope.Category => Localizer["Predictions.Analytics.BenchmarkCategory"],
            AthleteAttemptBenchmarkScope.Sex when benchmark.Sex == AthleteSex.Female => Localizer["Predictions.Analytics.BenchmarkWomen"],
            AthleteAttemptBenchmarkScope.Sex when benchmark.Sex == AthleteSex.Male => Localizer["Predictions.Analytics.BenchmarkMen"],
            AthleteAttemptBenchmarkScope.Sex => Localizer["Predictions.Analytics.BenchmarkSex"],
            _ => Localizer["Predictions.Analytics.BenchmarkField"]
        };
    }

    private string GetAverageVsLastText(decimal? average, decimal? lastTotal)
    {
        if (average is null || lastTotal is null)
        {
            return Localizer["Predictions.Analytics.NoComparison"].Value;
        }

        var diff = lastTotal.Value - average.Value;
        if (diff == 0m)
        {
            return Localizer["Predictions.Analytics.EqualLast"].Value;
        }

        return diff > 0m
            ? string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Analytics.LastAboveAverage"].Value, FormatKg(diff))
            : string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Analytics.LastBelowAverage"].Value, FormatKg(Math.Abs(diff)));
    }

    private string GetTrendChartScopeLabel()
    {
        return string.Format(
            CultureInfo.CurrentCulture,
            Localizer["Predictions.TotalTrend"].Value,
            TrendPoints.Count);
    }

    private string FormatKg(decimal? value)
    {
        return value is null
            ? Localizer["Common.Tbd"].Value
            : $"{value.Value.ToString("0.#", CultureInfo.CurrentCulture)} kg";
    }

    private string FormatKgValue(decimal? value)
    {
        return value is null
            ? "--"
            : value.Value.ToString("0.#", CultureInfo.CurrentCulture);
    }

    private string FormatSignedKg(decimal? value)
    {
        if (value is null)
        {
            return "--";
        }

        var prefix = value.Value > 0 ? "+" : string.Empty;
        return $"{prefix}{FormatKg(value)}";
    }

    private string FormatScore(decimal? value)
    {
        return value is null
            ? "--"
            : value.Value.ToString("0.#", CultureInfo.CurrentCulture);
    }

    private string FormatPercent(decimal? value)
    {
        return value is null
            ? "--"
            : $"{value.Value.ToString("0.#", CultureInfo.CurrentCulture)}%";
    }

    private string FormatAttemptRate(AthleteAttemptSuccessRate attempts)
    {
        return attempts.RatePercent is null
            ? "--"
            : $"{attempts.RatePercent.Value.ToString("0.#", CultureInfo.CurrentCulture)}%";
    }

    private string FormatAttemptCount(AthleteAttemptSuccessRate attempts)
    {
        return attempts.CountedAttempts == 0
            ? Localizer["Predictions.Analytics.NoCountedAttempts"].Value
            : string.Format(
                CultureInfo.CurrentCulture,
                Localizer["Predictions.Analytics.AttemptsMade"].Value,
                attempts.SuccessfulAttempts,
                attempts.CountedAttempts);
    }

    private string FormatBodyweightValue(decimal? value)
    {
        return value is null
            ? "--"
            : value.Value.ToString("0.##", CultureInfo.CurrentCulture);
    }

    private string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Localizer["Common.Tbd"];
        }

        if (DateOnly.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
        {
            return parsed.ToString("d MMM yyyy", CultureInfo.CurrentCulture);
        }

        return value;
    }

    private string FormatRecentStartTitle(AthleteRecentResult result)
    {
        var meet = string.IsNullOrWhiteSpace(result.MeetName)
            ? Localizer["Common.Tbd"].Value
            : result.MeetName.Trim();

        if (!DateOnly.TryParse(result.Date, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsedDate))
        {
            return meet;
        }

        var year = parsedDate.Year.ToString(CultureInfo.CurrentCulture);
        return meet.Contains(year, StringComparison.Ordinal)
            ? meet
            : $"{meet} {year}";
    }

    private string FormatTrendLabel(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "--";
        }

        if (DateOnly.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
        {
            return parsed.ToString("MMM yyyy", CultureInfo.CurrentCulture);
        }

        return value.Length <= 7 ? value : value[..7];
    }

    private string FormatTrendDetail(AthleteRecentResult result)
    {
        return $"{FormatKg(result.TotalKg)} · {FormatBodyweightInline(result.BodyweightKg)}";
    }

    private string FormatBodyweightInline(decimal? value)
    {
        var formatted = value is null
            ? Localizer["Common.Tbd"].Value
            : $"{value.Value.ToString("0.##", CultureInfo.CurrentCulture)} kg";
        return $"{Localizer["Predictions.BodyweightShort"]}: {formatted}";
    }

    private string GetAthleteInitials(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return "--";
        }

        var parts = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(part => part[0].ToString(CultureInfo.CurrentCulture))
            .ToArray();

        return parts.Length == 0
            ? "--"
            : string.Concat(parts).ToUpper(CultureInfo.CurrentCulture);
    }

    private sealed record AttemptSummary(
        string Label,
        string Rate,
        string Count,
        string Delta,
        string DeltaClass,
        string Width,
        bool Partial);

    private sealed record VerdictFact(string Label, string Value);

    private sealed record PrCard(string Label, string Value, bool Accent);
}
