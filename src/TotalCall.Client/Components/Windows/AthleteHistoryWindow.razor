@using System.Globalization
@using TotalCall.Client.Application.Services
@using TotalCall.Client.Application.Windows
@using TotalCall.Client.Domain.Athletes
@inject AthleteHistoryService AthleteHistoryService
@inject AthleteDataSourcePreferenceService AthleteDataSources
@inject CompetitionService CompetitionService
@inject WindowManager Windows
@inject IStringLocalizer<SharedResource> Localizer

<FloatingWindow Descriptor="Descriptor" AdditionalClass="floating-window--athlete-history">
    <section class="athlete-history-window">
        <header class="athlete-history-window__identity">
            <span class="athlete-history-window__avatar" aria-hidden="true">@GetAthleteInitials(Descriptor.AthleteName)</span>
            <div class="athlete-history-window__identity-meta">
                <strong>@Descriptor.AthleteName</strong>
                <small>
                    <CountryFlag Code="@Descriptor.CountryCode" CountryName="@Descriptor.CountryName" />
                    <span>@(Descriptor.CountryName ?? Localizer["Common.Tbd"].Value)</span>
                </small>
            </div>
        </header>

        <dl class="athlete-history-window__meta">
            <div>
                <dt>@Localizer["Predictions.Category"]</dt>
                <dd>@(Descriptor.CategoryName ?? Localizer["Common.Tbd"].Value)</dd>
            </div>
            <div>
                <dt>@Localizer["Predictions.NominatedTotal"]</dt>
                <dd class="athlete-history-window__meta-value--accent">@FormatKg(Descriptor.NominatedTotalKg)</dd>
            </div>
        </dl>

        @if (availableSources.Count > 1)
        {
            <section class="athlete-history-window__source-picker" aria-label="@Localizer["Predictions.DataSource"]">
                <span>@Localizer["Predictions.DataSource"]</span>
                <div class="segmented athlete-history-window__source-segmented">
                    @foreach (var source in availableSources)
                    {
                        <button
                            type="button"
                            class="@GetSourceButtonClass(source)"
                            disabled="@isLoading"
                            @onclick="() => OnSourceChangedAsync(source)">
                            @AthleteDataSourcePreferenceService.GetSourceLabel(source)
                        </button>
                    }
                </div>
            </section>
        }

        @if (HasActiveSlotActions)
        {
            <section class="athlete-history-window__actions" aria-label="@Localizer["FloatingWindow.HistoryActionsLabel"]">
                <p class="athlete-history-window__actions-hint">
                    @string.Format(Localizer["FloatingWindow.ApplyToSlot"].Value, Descriptor.SlotContext!.SlotPosition)
                </p>
                <div class="athlete-history-window__actions-row">
                    <button
                        type="button"
                        class="app-button app-button--secondary app-button--sm"
                        disabled="@(!CanUseLast)"
                        @onclick="OnUseLast">
                        <AppIcon Name="AppIconName.Clock" Size="14" />
                        @Localizer["Predictions.UseLastResult"]
                    </button>
                    <button
                        type="button"
                        class="app-button app-button--secondary app-button--sm"
                        disabled="@(!CanUseBest)"
                        @onclick="OnUseBest">
                        <AppIcon Name="AppIconName.Trophy" Size="14" />
                        @Localizer["Predictions.UseBestResult"]
                    </button>
                    <button
                        type="button"
                        class="app-button app-button--secondary app-button--sm"
                        disabled="@(!CanUseNominated)"
                        @onclick="OnUseNominated">
                        <AppIcon Name="AppIconName.Target" Size="14" />
                        @Localizer["Predictions.UseNominatedTotal"]
                    </button>
                </div>
            </section>
        }
        else
        {
            <p class="athlete-history-window__no-context">
                <AppIcon Name="AppIconName.AlertCircle" Size="14" />
                <span>@Localizer["FloatingWindow.NoSlotContextHint"]</span>
            </p>
        }

        @if (isLoading)
        {
            <p class="athlete-history-window__empty">@Localizer["Predictions.LoadingHistory"]</p>
        }
        else if (isError)
        {
            <p class="athlete-history-window__empty">@Localizer["Predictions.HistoryLoadError"]</p>
        }
        else if (History is null)
        {
            <div class="athlete-history-window__empty-state">
                <p class="athlete-history-window__empty">
                    @Localizer["Predictions.NoAthleteHistoryForSource", CurrentSourceLabel]
                </p>
                @if (AlternateSource is { } alternateSource)
                {
                    <button
                        type="button"
                        class="app-button app-button--secondary app-button--sm"
                        @onclick="() => OnSourceChangedAsync(alternateSource)">
                        @Localizer["Predictions.TryDataSource", AthleteDataSourcePreferenceService.GetSourceLabel(alternateSource)]
                    </button>
                }
            </div>
        }
        else
        {
            @if (Analytics is { } analytics)
            {
                <section class="athlete-history-window__analytics athlete-history-window__analytics--insight">
                    <header class="athlete-history-window__section-head">
                        <h3>@Localizer["Predictions.Analytics.AthleteDashboard"]</h3>
                        <span class="athlete-history-window__pill">
                            <AppIcon Name="AppIconName.TrendUp" Size="13" />
                            @FormatDataRange(analytics)
                        </span>
                    </header>

                    @if (!string.IsNullOrWhiteSpace(GetAnalyticsNotice(analytics)))
                    {
                        <p class="athlete-history-window__analytics-note">@GetAnalyticsNotice(analytics)</p>
                    }

                    <dl class="athlete-history-window__summary-grid">
                        <div class="athlete-history-window__summary-card athlete-history-window__summary-card--recent">
                            <dt>@Localizer["Predictions.LastTotal"]</dt>
                            <dd>@FormatKg(analytics.LastTotalKg)</dd>
                            <small>@GetLastTotalSubtitle(analytics)</small>
                        </div>
                        <div class="athlete-history-window__summary-card athlete-history-window__summary-card--pr">
                            <dt>@Localizer["Predictions.BestResult"]</dt>
                            <dd>@FormatKg(analytics.BestTotalKg)</dd>
                            <small>@GetBest12MonthText(analytics)</small>
                        </div>
                        <div class="athlete-history-window__summary-card athlete-history-window__summary-card--average">
                            <dt>@Localizer["Predictions.Analytics.Last3Avg"]</dt>
                            <dd>@FormatKg(analytics.Last3AvgTotalKg)</dd>
                            <small>@GetAverageVsLastText(analytics.Last3AvgTotalKg, analytics.LastTotalKg)</small>
                        </div>
                        <div class="athlete-history-window__summary-card athlete-history-window__summary-card--average">
                            <dt>@Localizer["Predictions.Analytics.Last5Avg"]</dt>
                            <dd>@FormatKg(analytics.Last5AvgTotalKg)</dd>
                            <small>@FormatStabilitySummary(analytics)</small>
                        </div>
                        <div class="athlete-history-window__summary-card athlete-history-window__summary-card--score">
                            <dt>@Localizer["Predictions.Analytics.BestScore"]</dt>
                            <dd class="athlete-history-window__score-pair">
                                <span><span>Best GL</span><strong>@FormatScore(analytics.BestGoodliftPoints)</strong></span>
                                <span><span>Best DOTS</span><strong>@FormatScore(analytics.BestDotsPoints)</strong></span>
                            </dd>
                        </div>
                        <div class="athlete-history-window__summary-card athlete-history-window__summary-card--attempts">
                            <dt>@Localizer["Predictions.Analytics.AttemptSuccessOverall"]</dt>
                            <dd>@FormatAttemptRate(analytics.OverallAttempts)</dd>
                            <small>@FormatAttemptComparisonContext(analytics.OverallAttempts, AttemptBenchmark?.OverallAttempts)</small>
                        </div>
                    </dl>

                    <div class="athlete-history-window__insight-strip">
                        <span class="@GetTrendValueClass(GetDisplayTrendKg(analytics))">
                            @FormatTrendInsight(analytics)
                        </span>
                        <span>@FormatPrClosenessText(analytics)</span>
                        <span>@FormatStabilitySummary(analytics)</span>
                    </div>
                </section>

                <section class="athlete-history-window__attempts" aria-label="@Localizer["Predictions.Analytics.LiftAttemptSuccess"]">
                    <header class="athlete-history-window__section-head">
                        <h3>@Localizer["Predictions.Analytics.LiftAttemptSuccess"]</h3>
                        @if (AttemptBenchmark is not null)
                        {
                            <span class="athlete-history-window__pill">@GetBenchmarkScopeLabel(AttemptBenchmark)</span>
                        }
                    </header>

                    <div class="athlete-history-window__attempts-panel">
                        <div>
                            <span class="athlete-history-window__eyebrow">@Localizer["Predictions.Analytics.AttemptSuccessOverall"]</span>
                            <strong>@FormatAttemptRate(analytics.OverallAttempts)</strong>
                            <small>@FormatAttemptComparisonContext(analytics.OverallAttempts, AttemptBenchmark?.OverallAttempts)</small>
                        </div>
                        <dl class="athlete-history-window__attempt-bars">
                            @foreach (var attempt in BuildAttemptSummaries(analytics))
                            {
                                <div>
                                    <dt>
                                        <span>@attempt.Label</span>
                                        <strong>@attempt.Rate</strong>
                                    </dt>
                                    <dd>
                                        <span class="athlete-history-window__attempt-track">
                                            <span class="@attempt.BarClass" style="width: @attempt.Width;"></span>
                                        </span>
                                        <small>@attempt.Count</small>
                                        @if (!string.IsNullOrWhiteSpace(attempt.Delta))
                                        {
                                            <small class="@attempt.DeltaClass">@attempt.Delta</small>
                                        }
                                    </dd>
                                </div>
                            }
                        </dl>
                    </div>
                </section>
            }
            else
            {
                <section class="athlete-history-window__analytics">
                    <header class="athlete-history-window__section-head">
                        <h3>@Localizer["Predictions.Analytics"]</h3>
                    </header>
                    <p class="athlete-history-window__empty">@Localizer["Predictions.AnalyticsUnavailable"]</p>
                </section>
            }

            @if (TrendPoints.Count > 1)
            {
                <section class="athlete-history-window__trend">
                    <header class="athlete-history-window__section-head">
                        <h3>@GetTrendChartScopeLabel()</h3>
                        <span class="athlete-history-window__pill">
                            <AppIcon Name="AppIconName.BarChart" Size="13" />
                            Total (kg)
                        </span>
                    </header>
                    <AppTrendChart
                        Points="@TrendPoints"
                        Variant="AppTrendChartVariant.Full"
                        AdditionalClass="app-trend-chart--athlete-history-window"
                        AriaLabel="@GetTrendChartScopeLabel()" />
                </section>
            }

            <section class="athlete-history-window__bests">
                <header class="athlete-history-window__section-head">
                    <h3>@Localizer["Predictions.LifetimePrs"]</h3>
                </header>
                <dl class="athlete-history-window__bests-list">
                    <div>
                        <dt>SQ</dt>
                        <dd>@FormatKg(BestSquatKg)</dd>
                    </div>
                    <div>
                        <dt>BP</dt>
                        <dd>@FormatKg(BestBenchKg)</dd>
                    </div>
                    <div>
                        <dt>DL</dt>
                        <dd>@FormatKg(BestDeadliftKg)</dd>
                    </div>
                    <div class="athlete-history-window__bests-total">
                        <dt>Total</dt>
                        <dd>@FormatKg(BestTotalKg)</dd>
                    </div>
                </dl>
            </section>

            <section class="athlete-history-window__starts">
                <header class="athlete-history-window__section-head">
                    <h3>@Localizer["Predictions.RecentStarts"]</h3>
                </header>

                @if (RecentResults.Count == 0)
                {
                    <p class="athlete-history-window__empty">@Localizer["Predictions.NoAthleteHistory"]</p>
                }
                else
                {
                    <div class="athlete-history-window__starts-table-wrap">
                        <table class="athlete-history-window__starts-table">
                            <thead>
                                <tr>
                                    <th>@Localizer["Predictions.History.Date"]</th>
                                    <th>@Localizer["Predictions.History.Meet"]</th>
                                    <th>@Localizer["Predictions.History.Bodyweight"]</th>
                                    <th>SQ</th>
                                    <th>BP</th>
                                    <th>DL</th>
                                    <th>Total</th>
                                    <th>@Localizer["Predictions.History.Place"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var result in RecentResults)
                                {
                                    <tr>
                                        <td>@FormatDate(result.Date)</td>
                                        <td>
                                            @FormatRecentStartTitle(result)
                                            @if (!string.IsNullOrWhiteSpace(result.Federation))
                                            {
                                                <small>@result.Federation</small>
                                            }
                                        </td>
                                        <td>@FormatBodyweightValue(result.BodyweightKg)</td>
                                        <td class="@LiftCellClass(result.SquatKg, BestSquatKg)">@FormatKgValue(result.SquatKg)</td>
                                        <td class="@LiftCellClass(result.BenchKg, BestBenchKg)">@FormatKgValue(result.BenchKg)</td>
                                        <td class="@LiftCellClass(result.DeadliftKg, BestDeadliftKg)">@FormatKgValue(result.DeadliftKg)</td>
                                        <td class="@LiftCellClass(result.TotalKg, BestTotalKg)">@FormatKgValue(result.TotalKg)</td>
                                        <td>@(string.IsNullOrWhiteSpace(result.Placing) ? "—" : result.Placing)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        }

        <footer class="athlete-history-window__source">
            <AthleteDataSourceNote SourceCode="@currentSource" />
        </footer>
    </section>
</FloatingWindow>

@code {
    [Parameter, EditorRequired]
    public AthleteHistoryWindowDescriptor Descriptor { get; set; } = default!;

    private AthleteHistoryEntry? History;
    private AthleteAttemptBenchmark? AttemptBenchmark;
    private Competition? competition;
    private IReadOnlyList<string> availableSources = [];
    private string currentSource = ExternalAthleteSources.OpenIpf;
    private string? loadedAthleteId;
    private string? loadedSourceCode;
    private bool isLoading;
    private bool isError;
    private const int MinimumBenchmarkCountedAttempts = 30;

    private AthleteHistorySlotContext? Slot => Descriptor.SlotContext;

    private bool HasActiveSlotActions => Slot is not null;

    private bool CanUseLast => Slot is { CanUseLast: true } && History?.LastResult?.TotalKg is not null;

    private bool CanUseBest => Slot is { CanUseBest: true } && History?.Bests?.TotalKg is not null;

    private bool CanUseNominated => Slot is { CanUseNominated: true } && Descriptor.NominatedTotalKg is not null;

    private IReadOnlyList<AthleteRecentResult> RecentResults => History?.RecentResults ?? [];

    private AthleteAnalytics? Analytics => History?.Analytics;

    private string CurrentSourceLabel => AthleteDataSourcePreferenceService.GetSourceLabel(currentSource);

    private string? AlternateSource => availableSources.FirstOrDefault(source =>
        !string.Equals(source, currentSource, StringComparison.OrdinalIgnoreCase));

    private decimal? BestSquatKg => History?.Bests?.SquatKg ??
                                    History?.RecentResults.Max(result => result.SquatKg);

    private decimal? BestBenchKg => History?.Bests?.BenchKg ??
                                    History?.RecentResults.Max(result => result.BenchKg);

    private decimal? BestDeadliftKg => History?.Bests?.DeadliftKg ??
                                       History?.RecentResults.Max(result => result.DeadliftKg);

    private decimal? BestTotalKg => History?.Bests?.TotalKg ??
                                    History?.RecentResults
                                        .Where(AthleteHistoryService.IsFullPowerSbdTotal)
                                        .Max(result => result.TotalKg);

    private IReadOnlyList<AppTrendChartPoint> TrendPoints => BuildTrendPoints();

    protected override async Task OnParametersSetAsync()
    {
        competition = await CompetitionService.GetCompetitionAsync(Descriptor.CompetitionId);
        availableSources = competition is null
            ? [ExternalAthleteSources.OpenIpf]
            : AthleteDataSources.GetAvailableSources(competition);
        var source = competition is null
            ? ExternalAthleteSources.OpenIpf
            : await AthleteDataSources.GetSourceAsync(competition);

        if (string.Equals(loadedAthleteId, Descriptor.AthleteId, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(loadedSourceCode, source, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await LoadHistoryAsync(source);
    }

    private async Task LoadHistoryAsync(string source)
    {
        currentSource = source;
        isLoading = true;
        isError = false;
        StateHasChanged();

        try
        {
            var athlete = competition?.Athletes.FirstOrDefault(item =>
                string.Equals(item.Id, Descriptor.AthleteId, StringComparison.OrdinalIgnoreCase));
            var historyTask = AthleteHistoryService.GetAthleteHistoryAsync(Descriptor.AthleteId, competition, source);
            var benchmarkTask = competition is null || athlete is null
                ? Task.FromResult<AthleteAttemptBenchmark?>(null)
                : AthleteHistoryService.GetAttemptBenchmarkAsync(competition, athlete, source);

            History = await historyTask;
            AttemptBenchmark = await benchmarkTask;
        }
        catch
        {
            History = null;
            AttemptBenchmark = null;
            isError = true;
        }

        loadedAthleteId = Descriptor.AthleteId;
        loadedSourceCode = source;
        isLoading = false;
    }

    private async Task OnSourceChangedAsync(string source)
    {
        if (competition is null ||
            string.Equals(source, currentSource, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await AthleteDataSources.SetSourceAsync(competition, source);
        await LoadHistoryAsync(source);
    }

    private string GetSourceButtonClass(string source)
    {
        return string.Join(
            " ",
            "segmented__button",
            string.Equals(source, currentSource, StringComparison.OrdinalIgnoreCase)
                ? "segmented__button--active"
                : null);
    }

    private Task OnUseLast()
    {
        Windows.RequestAthleteHistoryAction(Descriptor.Id, AthleteHistoryAction.UseLastResult);
        return Task.CompletedTask;
    }

    private Task OnUseBest()
    {
        Windows.RequestAthleteHistoryAction(Descriptor.Id, AthleteHistoryAction.UseBestResult);
        return Task.CompletedTask;
    }

    private Task OnUseNominated()
    {
        Windows.RequestAthleteHistoryAction(Descriptor.Id, AthleteHistoryAction.UseNominatedTotal);
        return Task.CompletedTask;
    }

    private IReadOnlyList<AppTrendChartPoint> BuildTrendPoints()
    {
        if (History?.RecentResults.Count is null or 0)
        {
            return [];
        }

        var sample = History.RecentResults
            .Where(AthleteHistoryService.IsFullPowerSbdTotal)
            .Take(8)
            .ToList();

        if (sample.Count == 0)
        {
            return [];
        }

        sample.Reverse();

        return sample
            .Select(result => new AppTrendChartPoint(
                result.TotalKg ?? 0m,
                FormatTrendLabel(result.Date),
                FormatTrendDetail(result)))
            .ToArray();
    }


    private IReadOnlyList<AttemptSummary> BuildAttemptSummaries(AthleteAnalytics analytics)
    {
        return
        [
            BuildAttemptSummary("SQ", analytics.SquatAttempts, AttemptBenchmark?.SquatAttempts),
            BuildAttemptSummary("BP", analytics.BenchAttempts, AttemptBenchmark?.BenchAttempts),
            BuildAttemptSummary("DL", analytics.DeadliftAttempts, AttemptBenchmark?.DeadliftAttempts),
            BuildAttemptSummary(
                Localizer["Predictions.Analytics.ThirdAttempts"].Value,
                analytics.ThirdAttempts,
                AttemptBenchmark?.ThirdAttempts,
                true)
        ];
    }

    private AttemptSummary BuildAttemptSummary(
        string label,
        AthleteAttemptSuccessRate attempts,
        AthleteAttemptSuccessRate? benchmarkAttempts,
        bool isHighPressure = false)
    {
        var rate = attempts.RatePercent;
        var width = rate is null
            ? "0%"
            : $"{Math.Clamp(rate.Value, 0m, 100m).ToString("0.##", CultureInfo.InvariantCulture)}%";

        var barClass = string.Join(
            " ",
            "athlete-history-window__attempt-fill",
            isHighPressure ? "athlete-history-window__attempt-fill--pressure" : null,
            rate is >= 80m ? "athlete-history-window__attempt-fill--strong" : null,
            rate is > 0m and < 60m ? "athlete-history-window__attempt-fill--risk" : null);
        var delta = FormatAttemptBenchmarkDelta(attempts, benchmarkAttempts);

        return new AttemptSummary(
            label,
            FormatAttemptRate(attempts),
            FormatAttemptCount(attempts),
            delta,
            GetAttemptDeltaClass(attempts, benchmarkAttempts),
            width,
            barClass);
    }

    private string FormatDataRange(AthleteAnalytics analytics)
    {
        var starts = string.Format(
            CultureInfo.CurrentCulture,
            Localizer["Predictions.StartsCount"].Value,
            analytics.StartsCount);

        return analytics.FirstStartYear is null || analytics.LastStartYear is null
            ? starts
            : $"{starts} · {FormatYearRange(analytics.FirstStartYear.Value, analytics.LastStartYear.Value)}";
    }

    private string FormatYearRange(int firstYear, int lastYear)
    {
        return firstYear == lastYear
            ? firstYear.ToString(CultureInfo.CurrentCulture)
            : $"{firstYear.ToString(CultureInfo.CurrentCulture)}–{lastYear.ToString(CultureInfo.CurrentCulture)}";
    }

    private string GetLastTotalSubtitle(AthleteAnalytics analytics)
    {
        var parts = new List<string>();

        if (!string.IsNullOrWhiteSpace(History?.LastResult?.MeetName))
        {
            parts.Add(FormatRecentStartTitle(new AthleteRecentResult
            {
                Date = History.LastResult.Date,
                MeetName = History.LastResult.MeetName
            }));
        }

        var closeness = FormatPrClosenessText(analytics);
        if (!string.IsNullOrWhiteSpace(closeness))
        {
            parts.Add(closeness);
        }

        return parts.Count == 0 ? Localizer["Predictions.Analytics.NoComparison"].Value : string.Join(" · ", parts);
    }

    private string FormatPrClosenessText(AthleteAnalytics analytics)
    {
        if (analytics.LastTotalKg is null || analytics.BestTotalKg is null)
        {
            return Localizer["Predictions.Analytics.NoComparison"].Value;
        }

        var gap = analytics.LastTotalKg.Value - analytics.BestTotalKg.Value;
        var percentText = analytics.LastTotalToBestPercent is null
            ? null
            : string.Format(
                CultureInfo.CurrentCulture,
                Localizer["Predictions.Analytics.PrPercent"].Value,
                analytics.LastTotalToBestPercent.Value.ToString("0.#", CultureInfo.CurrentCulture));

        var gapText = gap == 0m
            ? Localizer["Predictions.Analytics.AtPr"].Value
            : gap > 0m
                ? string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Analytics.AbovePr"].Value, FormatKg(Math.Abs(gap)))
                : string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Analytics.BelowPr"].Value, FormatKg(Math.Abs(gap)));

        return string.IsNullOrWhiteSpace(percentText)
            ? gapText
            : $"{gapText} · {percentText}";
    }

    private string GetBest12MonthText(AthleteAnalytics analytics)
    {
        return analytics.Best12MonthTotalKg is null
            ? Localizer["Predictions.Analytics.NoRecent12M"].Value
            : string.Format(
                CultureInfo.CurrentCulture,
                Localizer["Predictions.Analytics.Best12M"].Value,
                FormatKg(analytics.Best12MonthTotalKg));
    }

    private string FormatStabilitySummary(AthleteAnalytics analytics)
    {
        if (analytics.TotalStabilityKg is null)
        {
            return Localizer["Predictions.Analytics.StabilityUnavailable"].Value;
        }

        return string.Format(
            CultureInfo.CurrentCulture,
            Localizer["Predictions.Analytics.StabilitySummary"].Value,
            FormatKg(analytics.TotalStabilityKg),
            analytics.TotalStabilityStarts);
    }

    private decimal? GetDisplayTrendKg(AthleteAnalytics analytics)
    {
        return analytics.RecentTotalTrendKg ?? analytics.TotalTrendKg;
    }

    private string GetTrendPeriodLabel(AthleteAnalytics analytics)
    {
        return analytics.RecentTotalTrendStarts is null
            ? Localizer["Predictions.Analytics.TrendUnavailable"].Value
            : string.Format(
                CultureInfo.CurrentCulture,
                Localizer["Predictions.Analytics.TrendStarts"].Value,
                analytics.RecentTotalTrendStarts.Value);
    }

    private string FormatTrendInsight(AthleteAnalytics analytics)
    {
        var trend = GetDisplayTrendKg(analytics);

        return trend is null
            ? Localizer["Predictions.Analytics.TrendUnavailable"].Value
            : $"{GetTrendPeriodLabel(analytics)}: {FormatSignedKg(trend)}";
    }

    private string GetTrendChartScopeLabel()
    {
        return string.Format(
            CultureInfo.CurrentCulture,
            Localizer["Predictions.TotalTrend"].Value,
            TrendPoints.Count);
    }

    private string FormatAttemptBenchmarkDelta(
        AthleteAttemptSuccessRate attempts,
        AthleteAttemptSuccessRate? benchmarkAttempts)
    {
        if (attempts.RatePercent is null ||
            benchmarkAttempts?.RatePercent is null ||
            benchmarkAttempts.CountedAttempts < MinimumBenchmarkCountedAttempts ||
            AttemptBenchmark is null)
        {
            return string.Empty;
        }

        var delta = attempts.RatePercent.Value - benchmarkAttempts.RatePercent.Value;
        return $"{FormatSignedPercentagePoints(delta)} {GetBenchmarkScopeLabel(AttemptBenchmark)}";
    }

    private string FormatAttemptComparisonContext(
        AthleteAttemptSuccessRate attempts,
        AthleteAttemptSuccessRate? benchmarkAttempts)
    {
        var delta = FormatAttemptBenchmarkDelta(attempts, benchmarkAttempts);
        return string.IsNullOrWhiteSpace(delta)
            ? FormatAttemptCount(attempts)
            : delta;
    }

    private string FormatSignedPercentagePoints(decimal value)
    {
        var prefix = value > 0 ? "+" : string.Empty;
        return string.Format(
            CultureInfo.CurrentCulture,
            Localizer["Predictions.Analytics.PercentagePointDelta"].Value,
            $"{prefix}{value.ToString("0.#", CultureInfo.CurrentCulture)}");
    }

    private string GetAttemptDeltaClass(
        AthleteAttemptSuccessRate attempts,
        AthleteAttemptSuccessRate? benchmarkAttempts)
    {
        if (attempts.RatePercent is null ||
            benchmarkAttempts?.RatePercent is null ||
            benchmarkAttempts.CountedAttempts < MinimumBenchmarkCountedAttempts)
        {
            return "athlete-history-window__attempt-delta";
        }

        var delta = attempts.RatePercent.Value - benchmarkAttempts.RatePercent.Value;
        return delta switch
        {
            > 0m => "athlete-history-window__attempt-delta athlete-history-window__attempt-delta--up",
            < 0m => "athlete-history-window__attempt-delta athlete-history-window__attempt-delta--down",
            _ => "athlete-history-window__attempt-delta"
        };
    }

    private string GetBenchmarkScopeLabel(AthleteAttemptBenchmark benchmark)
    {
        return benchmark.Scope switch
        {
            AthleteAttemptBenchmarkScope.Category => Localizer["Predictions.Analytics.BenchmarkCategory"],
            AthleteAttemptBenchmarkScope.Sex when benchmark.Sex == AthleteSex.Female => Localizer["Predictions.Analytics.BenchmarkWomen"],
            AthleteAttemptBenchmarkScope.Sex when benchmark.Sex == AthleteSex.Male => Localizer["Predictions.Analytics.BenchmarkMen"],
            AthleteAttemptBenchmarkScope.Sex => Localizer["Predictions.Analytics.BenchmarkSex"],
            _ => Localizer["Predictions.Analytics.BenchmarkField"]
        };
    }

    private string GetAverageVsLastText(decimal? average, decimal? lastTotal)
    {
        if (average is null || lastTotal is null)
        {
            return Localizer["Predictions.Analytics.NoComparison"].Value;
        }

        var diff = lastTotal.Value - average.Value;
        if (diff == 0m)
        {
            return Localizer["Predictions.Analytics.EqualLast"].Value;
        }

        return diff > 0m
            ? string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Analytics.LastAboveAverage"].Value, FormatKg(diff))
            : string.Format(CultureInfo.CurrentCulture, Localizer["Predictions.Analytics.LastBelowAverage"].Value, FormatKg(Math.Abs(diff)));
    }

    private string FormatKg(decimal? value)
    {
        return value is null
            ? Localizer["Common.Tbd"].Value
            : $"{value.Value.ToString("0.#", CultureInfo.CurrentCulture)} kg";
    }

    private string FormatKgValue(decimal? value)
    {
        return value is null
            ? "--"
            : value.Value.ToString("0.#", CultureInfo.CurrentCulture);
    }

    private string FormatSignedKg(decimal? value)
    {
        if (value is null)
        {
            return "--";
        }

        var prefix = value.Value > 0 ? "+" : string.Empty;
        return $"{prefix}{FormatKg(value)}";
    }

    private string FormatScore(decimal? value)
    {
        return value is null
            ? "--"
            : value.Value.ToString("0.#", CultureInfo.CurrentCulture);
    }

    private string FormatAttemptRate(AthleteAttemptSuccessRate attempts)
    {
        return attempts.RatePercent is null
            ? "--"
            : $"{attempts.RatePercent.Value.ToString("0.#", CultureInfo.CurrentCulture)}%";
    }

    private string FormatAttemptCount(AthleteAttemptSuccessRate attempts)
    {
        return attempts.CountedAttempts == 0
            ? Localizer["Predictions.Analytics.NoCountedAttempts"].Value
            : string.Format(
                CultureInfo.CurrentCulture,
                Localizer["Predictions.Analytics.AttemptsMade"].Value,
                attempts.SuccessfulAttempts,
                attempts.CountedAttempts);
    }

    private string GetTrendValueClass(decimal? value)
    {
        return value switch
        {
            > 0 => "athlete-history-window__trend-value athlete-history-window__trend-value--up",
            < 0 => "athlete-history-window__trend-value athlete-history-window__trend-value--down",
            _ => "athlete-history-window__trend-value"
        };
    }

    private string? GetAnalyticsNotice(AthleteAnalytics analytics)
    {
        if (analytics.StartsCount < 3 || analytics.TotalMetricStartsCount < 3)
        {
            return Localizer["Predictions.AnalyticsLimitedSample"].Value;
        }

        return analytics.Last3AvgTotalKg is null ||
               analytics.Last5AvgTotalKg is null ||
               analytics.TotalTrendKg is null ||
               analytics.BestDotsPoints is null ||
               analytics.BestGoodliftPoints is null ||
               analytics.OverallAttempts.RatePercent is null ||
               analytics.ThirdAttempts.RatePercent is null
            ? Localizer["Predictions.AnalyticsPartial"].Value
            : null;
    }

    private string FormatBodyweightValue(decimal? value)
    {
        return value is null
            ? "--"
            : value.Value.ToString("0.##", CultureInfo.CurrentCulture);
    }

    private string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Localizer["Common.Tbd"];
        }

        if (DateOnly.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
        {
            return parsed.ToString("d MMM yyyy", CultureInfo.CurrentCulture);
        }

        return value;
    }

    private string FormatRecentStartTitle(AthleteRecentResult result)
    {
        var meet = string.IsNullOrWhiteSpace(result.MeetName)
            ? Localizer["Common.Tbd"].Value
            : result.MeetName.Trim();

        if (!DateOnly.TryParse(result.Date, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsedDate))
        {
            return meet;
        }

        var year = parsedDate.Year.ToString(CultureInfo.CurrentCulture);
        return meet.Contains(year, StringComparison.Ordinal)
            ? meet
            : $"{meet} {year}";
    }

    private string FormatTrendLabel(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "--";
        }

        if (DateOnly.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
        {
            return parsed.ToString("MMM yyyy", CultureInfo.CurrentCulture);
        }

        return value.Length <= 7 ? value : value[..7];
    }

    private string FormatTrendDetail(AthleteRecentResult result)
    {
        return $"{FormatKg(result.TotalKg)} · {FormatBodyweightInline(result.BodyweightKg)}";
    }

    private string FormatBodyweightInline(decimal? value)
    {
        var formatted = value is null
            ? Localizer["Common.Tbd"].Value
            : $"{value.Value.ToString("0.##", CultureInfo.CurrentCulture)} kg";
        return $"{Localizer["Predictions.BodyweightShort"]}: {formatted}";
    }

    private string LiftCellClass(decimal? value, decimal? best)
    {
        return value is not null && best is not null && value.Value == best.Value
            ? "athlete-history-window__cell--pb"
            : string.Empty;
    }

    private string GetAthleteInitials(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return "--";
        }

        var parts = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(part => part[0].ToString(CultureInfo.CurrentCulture))
            .ToArray();

        return parts.Length == 0
            ? "--"
            : string.Concat(parts).ToUpper(CultureInfo.CurrentCulture);
    }
    private sealed record AttemptSummary(
        string Label,
        string Rate,
        string Count,
        string Delta,
        string DeltaClass,
        string Width,
        string BarClass);
}
