@using TotalCall.Client.Application.Services
@using TotalCall.Client.Application.Windows
@implements IDisposable
@inject WindowManager Windows
@inject IStringLocalizer<SharedResource> Localizer

@if (HasVisibleWindows || HasMinimizedWindows)
{
    <div class="floating-window-host" data-floating-window-host>
        @foreach (var descriptor in VisibleWindows)
        {
            @RenderWindow(descriptor)
        }

        @if (HasMinimizedWindows)
        {
            <div class="floating-window-host__taskbar" role="toolbar" aria-label="@Localizer["FloatingWindow.MinimizedListLabel"]">
                @foreach (var descriptor in MinimizedWindows)
                {
                    <button
                        type="button"
                        class="floating-window-host__taskbar-item"
                        aria-label="@string.Format(Localizer["FloatingWindow.RestoreFormat"], descriptor.Title)"
                        title="@string.Format(Localizer["FloatingWindow.RestoreFormat"], descriptor.Title)"
                        @onclick="() => OnRestore(descriptor.Id)">
                        <AppIcon Name="AppIconName.BarChart" Size="14" />
                        <span>@descriptor.Title</span>
                    </button>
                }
            </div>
        }
    </div>
}

@code {
    private IReadOnlyList<FloatingWindowDescriptor> VisibleWindows =>
        Windows.Windows.Where(window => !window.IsMinimized).ToArray();

    private IReadOnlyList<FloatingWindowDescriptor> MinimizedWindows =>
        Windows.Windows.Where(window => window.IsMinimized).ToArray();

    private bool HasVisibleWindows => VisibleWindows.Count > 0;

    private bool HasMinimizedWindows => MinimizedWindows.Count > 0;

    protected override void OnInitialized()
    {
        Windows.StateChanged += HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private RenderFragment RenderWindow(FloatingWindowDescriptor descriptor) => builder =>
    {
        switch (descriptor)
        {
            case AthleteHistoryWindowDescriptor athleteHistory:
                builder.OpenComponent<AthleteHistoryWindow>(0);
                builder.SetKey(athleteHistory.Id);
                builder.AddAttribute(1, "Descriptor", athleteHistory);
                builder.CloseComponent();
                break;
        }
    };

    private void OnRestore(string windowId)
    {
        Windows.Minimize(windowId, false);
    }

    public void Dispose()
    {
        Windows.StateChanged -= HandleStateChanged;
    }
}
