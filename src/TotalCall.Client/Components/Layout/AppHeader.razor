@inject IStringLocalizer<SharedResource> Localizer

<header class="sticky top-0 z-20 border-b border-brand-border bg-white/90 backdrop-blur">
    <PageContainer AdditionalClass="py-3">
        <div class="grid gap-3 sm:grid-cols-[auto_1fr_auto] sm:items-center">
            <div class="flex items-center justify-between gap-3">
                <a class="focus-ring inline-flex min-h-11 items-center gap-3 rounded-lg text-brand-ink no-underline" href="">
                    <span class="relative flex size-10 shrink-0 items-center justify-center rounded-lg bg-brand-ink" aria-hidden="true">
                        <span class="absolute left-2 right-2 top-1/2 h-1 -translate-y-1/2 rounded-full bg-white"></span>
                        <span class="absolute bottom-2 left-1.5 top-2 w-1 rounded-full bg-brand-danger"></span>
                        <span class="absolute bottom-2 right-1.5 top-2 w-1 rounded-full bg-brand-accent"></span>
                    </span>
                    <span class="grid gap-0.5">
                        <strong class="text-base font-semibold leading-none">TotalCall</strong>
                        <span class="text-xs font-medium leading-none text-brand-muted">@Localizer["App.Tagline"]</span>
                    </span>
                </a>

                <button
                    type="button"
                    class="focus-ring inline-flex min-h-10 items-center rounded-lg border border-brand-border bg-brand-surface px-3 text-sm font-semibold text-brand-ink sm:hidden"
                    aria-expanded="@(!isCollapsed)"
                    @onclick="ToggleMenu">
                    @Localizer["Nav.Menu"]
                </button>
            </div>

            <nav class="@NavClass" aria-label="Main navigation">
                <NavLink class="focus-ring inline-flex min-h-10 items-center rounded-lg px-3 text-sm font-medium text-brand-steel no-underline hover:bg-brand-surface-muted" ActiveClass="bg-brand-ink text-white hover:bg-brand-ink" href="" Match="NavLinkMatch.All">
                    @Localizer["Nav.Competitions"]
                </NavLink>
            </nav>

            <div class="@ActionsClass">
                <LanguageSwitcher />
            </div>
        </div>
    </PageContainer>
</header>

@code {
    private bool isCollapsed = true;

    private string NavClass => string.Join(
        " ",
        "grid gap-1 sm:flex sm:items-center sm:justify-center",
        isCollapsed ? "hidden sm:flex" : "grid");

    private string ActionsClass => string.Join(
        " ",
        "justify-self-start sm:justify-self-end",
        isCollapsed ? "hidden sm:block" : "block");

    private void ToggleMenu()
    {
        isCollapsed = !isCollapsed;
    }
}
