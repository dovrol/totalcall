@inject ThemeService Theme
@inject IStringLocalizer<SharedResource> Localizer

<div class="theme-toggle" role="group" aria-label="@Localizer["Theme.Toggle"]">
    <button
        type="button"
        class='@GetButtonClass("dark")'
        aria-pressed='@IsTheme("dark")'
        @onclick='() => SetTheme("dark")'>
        <AppIcon Name="AppIconName.Moon" Size="14" />
        <span>@Localizer["Theme.Dark"]</span>
    </button>

    <button
        type="button"
        class='@GetButtonClass("light")'
        aria-pressed='@IsTheme("light")'
        @onclick='() => SetTheme("light")'>
        <AppIcon Name="AppIconName.Sun" Size="14" />
        <span>@Localizer["Theme.Light"]</span>
    </button>
</div>

@code {
    private async Task SetTheme(string theme)
    {
        await Theme.SetThemeAsync(theme);
    }

    private bool IsTheme(string theme)
    {
        return string.Equals(Theme.CurrentTheme, theme, StringComparison.OrdinalIgnoreCase);
    }

    private string GetButtonClass(string theme)
    {
        return IsTheme(theme)
            ? "theme-toggle__button theme-toggle__button--active"
            : "theme-toggle__button";
    }
}
