@inject IStringLocalizer<SharedResource> Localizer

<aside class="app-sidebar">
    <div class="app-sidebar__top">
        <AppLogo />

        <div class="app-sidebar__controls">
            <ThemeToggle />
            <LanguageSwitcher />
        </div>
    </div>

    <div class="app-sidebar__nav-wrap">
        <nav class="app-sidebar__nav" aria-label="Main navigation">
            <NavLink class="sidebar-nav-link" ActiveClass="active" href="" Match="NavLinkMatch.All">
                @Localizer["Nav.Competitions"]
            </NavLink>
        </nav>
    </div>
</aside>
