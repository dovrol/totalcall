@inject IStringLocalizer<SharedResource> Localizer

<header class="app-topbar">
    <div class="app-topbar__inner">
        <AppLogo AdditionalClass="app-topbar__brand" />

        <nav class="app-topbar__nav" aria-label="Main navigation">
            <NavLink class="topbar-nav-link" ActiveClass="active" href="" Match="NavLinkMatch.Prefix">
                <AppIcon Name="AppIconName.Trophy" Size="16" />
                @Localizer["Nav.Competitions"]
            </NavLink>
            <span class="topbar-nav-link topbar-nav-link--soon" aria-disabled="true">
                <AppIcon Name="AppIconName.BarChart" Size="16" />
                <span>@Localizer["Nav.Ranking"]</span>
                <span class="topbar-nav-link__soon">@Localizer["Nav.ComingSoon"]</span>
            </span>
        </nav>

        <div class="app-topbar__controls">
            <AuthMenu />
        </div>
    </div>
</header>

<nav class="app-mobile-nav" aria-label="@Localizer["Nav.Menu"]">
    <NavLink class="app-mobile-nav__link" ActiveClass="active" href="" Match="NavLinkMatch.Prefix">
        <AppIcon Name="AppIconName.Trophy" Size="18" />
        <span>@Localizer["Nav.Competitions"]</span>
    </NavLink>
    <button type="button" class="app-mobile-nav__link app-mobile-nav__link--soon" disabled>
        <AppIcon Name="AppIconName.BarChart" Size="18" />
        <span>@Localizer["Nav.Ranking"]</span>
    </button>
    <AuthMenu DisplayMode="MobileNav" />
</nav>
