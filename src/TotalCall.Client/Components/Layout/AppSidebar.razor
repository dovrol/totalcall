@inject IStringLocalizer<SharedResource> Localizer

<header class="app-topbar">
    <div class="app-topbar__inner">
        <AppLogo AdditionalClass="app-topbar__brand" />

        <nav class="app-topbar__nav" aria-label="Main navigation">
            <NavLink class="topbar-nav-link" ActiveClass="active" href="" Match="NavLinkMatch.All">
                <AppIcon Name="AppIconName.Trophy" Size="16" />
                @Localizer["Nav.Competitions"]
            </NavLink>
            <NavLink class="topbar-nav-link" ActiveClass="active" href="competitions/worlds-2026">
                <AppIcon Name="AppIconName.Users" Size="16" />
                @Localizer["Nav.Worlds"]
            </NavLink>
        </nav>

        <div class="app-topbar__controls">
            <ThemeToggle />
            <LanguageSwitcher />
        </div>
    </div>
</header>

<nav class="app-mobile-nav" aria-label="@Localizer["Nav.Menu"]">
    <NavLink class="app-mobile-nav__link" ActiveClass="active" href="" Match="NavLinkMatch.All">
        <AppIcon Name="AppIconName.Trophy" Size="18" />
        <span>@Localizer["Nav.Competitions"]</span>
    </NavLink>
    <NavLink class="app-mobile-nav__link" ActiveClass="active" href="competitions/worlds-2026">
        <AppIcon Name="AppIconName.Users" Size="18" />
        <span>@Localizer["Nav.WorldsShort"]</span>
    </NavLink>
</nav>
