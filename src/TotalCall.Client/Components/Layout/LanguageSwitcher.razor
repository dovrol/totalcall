@inject CultureService Culture
@inject NavigationManager Navigation

<div class="language-switcher" aria-label="Culture">
    @foreach (var option in Culture.SupportedCultures)
    {
        <button
            type="button"
            class="@GetButtonClass(option.CultureName)"
            aria-pressed="@IsCurrentCulture(option.CultureName)"
            @onclick="() => SetCulture(option.CultureName)">
            <span class="language-switcher__code">@option.Label</span>
            <span class="language-switcher__name">@GetNativeName(option.CultureName)</span>
        </button>
    }
</div>

@code {
    private async Task SetCulture(string cultureName)
    {
        var changed = await Culture.SetCultureAsync(cultureName);

        if (changed)
        {
            Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
        }
    }

    private bool IsCurrentCulture(string cultureName)
    {
        return string.Equals(Culture.CurrentCultureName, cultureName, StringComparison.OrdinalIgnoreCase);
    }

    private string GetButtonClass(string cultureName)
    {
        return IsCurrentCulture(cultureName)
            ? "language-switcher__button language-switcher__button--active"
            : "language-switcher__button";
    }

    private static string GetNativeName(string cultureName)
    {
        return string.Equals(cultureName, "en-US", StringComparison.OrdinalIgnoreCase)
            ? "English"
            : "Polski";
    }
}
