<div class="@CssClass">
    @ChildContent
</div>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? AdditionalClass { get; set; }

    private string CssClass => string.Join(" ", "mx-auto w-full max-w-6xl px-4 sm:px-5 lg:px-8", AdditionalClass);
}
