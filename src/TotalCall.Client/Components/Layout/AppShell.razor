@implements IDisposable
@inject CultureService Culture
@inject AppInfoService AppInfo
@inject IStringLocalizer<SharedResource> Localizer

<div class="app-shell app-shell-background">
    <AppSidebar />

    <main class="app-shell__main">
        <PageContainer AdditionalClass="app-shell__content">
            <article class="app-shell__article" @key="Culture.CurrentCultureName">
                @ChildContent
            </article>

            <footer class="app-shell__meta">
                <small>@Localizer["App.VersionLine", AppInfo.FullDisplayVersion]</small>
            </footer>
        </PageContainer>
    </main>
</div>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    protected override void OnInitialized()
    {
        Culture.CultureChanged += OnCultureChanged;
    }

    public void Dispose()
    {
        Culture.CultureChanged -= OnCultureChanged;
    }

    private void OnCultureChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
