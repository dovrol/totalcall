@implements IDisposable
@inject CultureService Culture
@inject AppInfoService AppInfo
@inject ChangelogService Changelog
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> Localizer

<div class="@ShellClass">
    <AppSidebar />

    <main class="app-shell__main">
        <PageContainer AdditionalClass="app-shell__content">
            <article class="app-shell__article" @key="Culture.CurrentCultureName">
                @ChildContent
            </article>

            <footer class="app-shell__meta">
                <div class="app-shell__meta-row">
                    <button
                        type="button"
                        class="app-shell__version-btn"
                        title="@Localizer["WhatsNew.HistoryButtonTitle"]"
                        @onclick="HandleOpenHistoryAsync">
                        @Localizer["App.VersionLine", AppInfo.FullDisplayVersion]
                    </button>
                    <span class="app-shell__meta-sep" aria-hidden="true">·</span>
                    <button
                        type="button"
                        class="app-shell__version-btn"
                        @onclick="HandleOpenPrivacy">
                        @Localizer["Privacy.FooterLink"]
                    </button>
                </div>
            </footer>
        </PageContainer>
    </main>
</div>

<FloatingWindowHost />

<WhatsNewModal
    IsOpen="isWhatsNewOpen"
    IsHistoryView="isHistoryView"
    Entries="modalEntries"
    OnClose="HandleWhatsNewCloseAsync" />

<PrivacyInfoModal
    IsOpen="isPrivacyOpen"
    OnClose="HandlePrivacyCloseAsync" />

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private IReadOnlyList<ChangelogEntry> modalEntries = [];
    private bool isWhatsNewOpen;
    private bool isHistoryView;
    private bool isPrivacyOpen;

    protected override void OnInitialized()
    {
        Culture.CultureChanged += OnCultureChanged;
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private string ShellClass
    {
        get
        {
            var baseClass = "app-shell app-shell-background";
            return IsWorkingScreen(NavigationManager.Uri)
                ? $"{baseClass} app-shell--no-mobile-tabs"
                : baseClass;
        }
    }

    private static bool IsWorkingScreen(string uri)
    {
        if (!Uri.TryCreate(uri, UriKind.Absolute, out var parsed))
        {
            return false;
        }

        var path = parsed.AbsolutePath;
        return path.Contains("/predictions", StringComparison.OrdinalIgnoreCase)
            || path.Contains("/review", StringComparison.OrdinalIgnoreCase);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var entries = await Changelog.GetUnseenEntriesAsync();

            if (entries.Count == 0)
            {
                return;
            }

            modalEntries = entries;
            isHistoryView = false;
            isWhatsNewOpen = true;

            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Release notes are non-critical — never block the app on failure.
        }
    }

    public void Dispose()
    {
        Culture.CultureChanged -= OnCultureChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private void OnCultureChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task HandleOpenHistoryAsync()
    {
        try
        {
            modalEntries = await Changelog.GetAllEntriesAsync();
            isHistoryView = true;
            isWhatsNewOpen = true;
        }
        catch
        {
            // Non-critical.
        }
    }

    private async Task HandleWhatsNewCloseAsync()
    {
        isWhatsNewOpen = false;

        if (!isHistoryView)
        {
            await Changelog.MarkCurrentVersionSeenAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private void HandleOpenPrivacy()
    {
        isPrivacyOpen = true;
    }

    private async Task HandlePrivacyCloseAsync()
    {
        isPrivacyOpen = false;
        await InvokeAsync(StateHasChanged);
    }
}
