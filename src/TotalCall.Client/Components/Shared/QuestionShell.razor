@inject IStringLocalizer<SharedResource> Localizer
@inject PredictionTextService Text

<div class="question-shell">
    <div class="question-shell__text">
        <div class="question-shell__heading">
            <h3>@Text.QuestionTitle(Competition, Question)</h3>
            <span class="question-badge">
                @(Question.Required ? Localizer["Common.Required"] : Localizer["Common.Optional"])
            </span>
        </div>
        @if (!string.IsNullOrWhiteSpace(Text.QuestionDescription(Competition, Question)))
        {
            <p>@Text.QuestionDescription(Competition, Question)</p>
        }
    </div>

    <div class="question-shell__control">
        @ChildContent
    </div>

    <QuestionValidationMessage Errors="ValidationErrors" />
</div>

@code {
    [Parameter, EditorRequired]
    public Competition Competition { get; set; } = default!;

    [Parameter, EditorRequired]
    public PredictionQuestion Question { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<PredictionValidationError> ValidationErrors { get; set; } = [];

    [Parameter, EditorRequired]
    public RenderFragment ChildContent { get; set; } = default!;
}
