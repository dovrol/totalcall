@inject LanguageService Language

@if (Errors.Count > 0)
{
    <ul class="validation-list">
        @foreach (var error in Errors)
        {
            <li>@Language.Validation(error)</li>
        }
    </ul>
}

@code {
    [Parameter]
    public IReadOnlyList<PredictionValidationError> Errors { get; set; } = [];
}
