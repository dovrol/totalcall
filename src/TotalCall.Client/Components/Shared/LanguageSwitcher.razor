@inject CultureService Culture

<div class="language-switcher" aria-label="Culture">
    @foreach (var option in Culture.SupportedCultures)
    {
        <button
            type="button"
            class="@GetButtonClass(option.CultureName)"
            @onclick="() => SetCulture(option.CultureName)">
            @option.Label
        </button>
    }
</div>

@code {
    private async Task SetCulture(string cultureName)
    {
        await Culture.SetCultureAsync(cultureName);
    }

    private string GetButtonClass(string cultureName)
    {
        return string.Equals(Culture.CurrentCultureName, cultureName, StringComparison.OrdinalIgnoreCase)
            ? "language-switcher__button language-switcher__button--active"
            : "language-switcher__button";
    }
}
