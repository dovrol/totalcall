@inject IStringLocalizer<SharedResource> Localizer

<AppCard Padding="Lg" AdditionalClass="competition-card">
    <div class="competition-card__top">
        <CompetitionStatusBadge Status="Competition.Status" />

        <h3 class="competition-card__title">@Competition.Name</h3>
    </div>

    <dl class="competition-card__meta">
        <div>
            <dt>@Localizer["Common.Starts"]</dt>
            <dd>@FormatDate(Competition.StartDate)</dd>
        </div>
    </dl>

    <div class="competition-card__actions">
        <AppButton Href="@PrimaryActionHref" Variant="@PrimaryActionVariant" FullWidth="true">
            @PrimaryActionLabel
        </AppButton>
    </div>
</AppCard>

@code {
    [Parameter, EditorRequired]
    public CompetitionSummary Competition { get; set; } = default!;

    private string PrimaryActionHref => Competition.Status switch
    {
        CompetitionStatus.Upcoming => $"competitions/{Competition.Slug}/predictions",
        CompetitionStatus.Completed => $"competitions/{Competition.Slug}",
        _ => $"competitions/{Competition.Slug}"
    };

    private string PrimaryActionLabel => Competition.Status switch
    {
        CompetitionStatus.Upcoming => Localizer["Competition.MakePredictions"],
        CompetitionStatus.Completed => Localizer["Competition.ViewResults"],
        _ => Localizer["Common.OpenCompetition"]
    };

    private string PrimaryActionVariant => Competition.Status == CompetitionStatus.Upcoming
        ? "Primary"
        : "Secondary";

    private string FormatDate(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("d MMM yyyy HH:mm") ?? Localizer["Common.Tbd"];
    }
}
