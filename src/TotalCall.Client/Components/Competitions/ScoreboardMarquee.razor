@inject IStringLocalizer<SharedResource> Localizer

<section class="sb-marquee">
    <div class="sb-marquee__lead">
        <span class="sb-marquee__eyebrow">
            <span class="sb-marquee__pulse"></span>
            @EyebrowText
        </span>
        <h1 class="sb-marquee__title">
            @Competition.Name<text> </text><em>·</em><text> </text>@(Competition.City ?? Localizer["Common.Tbd"].Value)
        </h1>
        <div class="sb-marquee__meta">
            @if (Competition.StartDate is { } start)
            {
                <span><strong>@start.ToLocalTime().ToString("dd MMM yyyy")</strong></span>
            }
            @if (Competition.PredictionLockAt is { } lockAt)
            {
                <span>@lockAt.ToLocalTime().ToString("HH:mm")</span>
            }
            @if (Competition.ModulesCount is { } modules)
            {
                <span>@Localizer["Scoreboard.ModulesCount", modules]</span>
            }
        </div>
    </div>

    @if (Competition.PredictionLockAt is { } target)
    {
        <ScoreboardClock Target="target" />
    }
</section>

@code {
    [Parameter, EditorRequired]
    public CompetitionSummary Competition { get; set; } = default!;

    private string EyebrowText => Competition.Status == CompetitionStatus.Locked
        ? Localizer["Scoreboard.Eyebrow.Awaiting"]
        : Localizer["Scoreboard.Eyebrow.LocksIn"];
}
