@inject IStringLocalizer<SharedResource> Localizer

<dl class="competition-meta">
    <div>
        <dt>
            <span class="competition-meta__label">
                <AppIcon Name="AppIconName.Calendar" Size="16" />
                <span>@Localizer["Common.Starts"]</span>
            </span>
        </dt>
        <dd>@FormatDate(StartDate)</dd>
    </div>
    <div>
        <dt>
            <span class="competition-meta__label">
                <AppIcon Name="AppIconName.Lock" Size="16" />
                <span>@Localizer["Common.Locks"]</span>
            </span>
        </dt>
        <dd>@FormatDate(PredictionLockAt)</dd>
    </div>
</dl>

@code {
    [Parameter]
    public DateTimeOffset? StartDate { get; set; }

    [Parameter]
    public DateTimeOffset? PredictionLockAt { get; set; }

    private string FormatDate(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("d MMM yyyy HH:mm") ?? Localizer["Common.Tbd"];
    }
}
