@inject IStringLocalizer<SharedResource> Localizer

<nav class="competition-page-nav" aria-label="@Localizer["Competition.Navigation"]">
    <a class="@GetClass("Overview")" href="@($"competitions/{Competition.Slug}")">
        @Localizer["Nav.Overview"]
    </a>
    <a class="@GetClass("Predictions")" href="@($"competitions/{Competition.Slug}/predictions")">
        @Localizer["Nav.Predictions"]
    </a>
    <a class="@GetClass("Review")" href="@($"competitions/{Competition.Slug}/review")">
        @Localizer["Nav.Review"]
    </a>
</nav>

@code {
    [Parameter, EditorRequired]
    public Competition Competition { get; set; } = default!;

    [Parameter, EditorRequired]
    public string Active { get; set; } = string.Empty;

    private string GetClass(string key)
    {
        var isActive = string.Equals(Active, key, StringComparison.OrdinalIgnoreCase);

        return string.Join(
            " ",
            "competition-page-nav__link",
            isActive
                ? "competition-page-nav__link--active"
                : null);
    }
}
