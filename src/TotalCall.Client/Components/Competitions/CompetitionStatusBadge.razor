@inject IStringLocalizer<SharedResource> Localizer

<AppBadge Variant="@Variant">
    <span class="competition-status-badge__content">
        <AppIcon Name="@Icon" Size="16" Class="competition-status-badge__icon" />
        <span>@Localizer[$"Status.{Status}"]</span>
    </span>
</AppBadge>

@code {
    [Parameter]
    public CompetitionStatus Status { get; set; }

    private string Variant => Status switch
    {
        CompetitionStatus.Upcoming => "Success",
        CompetitionStatus.Locked => "Warning",
        CompetitionStatus.Completed => "Accent",
        CompetitionStatus.Archived => "Neutral",
        _ => "Neutral"
    };

    private AppIconName Icon => Status switch
    {
        CompetitionStatus.Upcoming => AppIconName.Unlock,
        CompetitionStatus.Locked => AppIconName.Lock,
        CompetitionStatus.Completed => AppIconName.Check,
        CompetitionStatus.Archived => AppIconName.X,
        _ => AppIconName.AlertCircle
    };
}
