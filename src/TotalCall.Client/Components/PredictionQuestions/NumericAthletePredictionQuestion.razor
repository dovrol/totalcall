@inject IStringLocalizer<SharedResource> Localizer

<QuestionShell Competition="Competition" Question="Question" ValidationErrors="ValidationErrors">
    <div class="inline-fields">
        <label class="field">
            <span>@Localizer["Common.Athlete"]</span>
            <select value="@Answer?.Value.SelectedAthleteId" @onchange="SetAthlete">
                <option value="">@Localizer["Common.SelectAthlete"]</option>
                @foreach (var athlete in GetEligibleAthletes())
                {
                    <option value="@athlete.Id">@athlete.DisplayName</option>
                }
            </select>
        </label>
        <label class="field">
            <span>@(Question.Constraints.Unit ?? Localizer["Common.Value"])</span>
            <input
                type="number"
                min="@Question.Constraints.MinValue"
                max="@Question.Constraints.MaxValue"
                step="@Question.Constraints.Step"
                value="@Answer?.Value.NumericValue"
                @onchange="SetNumericValue" />
        </label>
    </div>
</QuestionShell>

@code {
    [Parameter, EditorRequired]
    public Competition Competition { get; set; } = default!;

    [Parameter, EditorRequired]
    public string GroupId { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public PredictionQuestion Question { get; set; } = default!;

    [Parameter]
    public PredictionAnswer? Answer { get; set; }

    [Parameter]
    public IReadOnlyList<PredictionValidationError> ValidationErrors { get; set; } = [];

    [Parameter]
    public EventCallback<PredictionAnswer> AnswerChanged { get; set; }

    private async Task SetAthlete(ChangeEventArgs eventArgs)
    {
        await AnswerChanged.InvokeAsync(CreateAnswer(Answer?.Value.NumericValue, eventArgs.Value?.ToString()));
    }

    private async Task SetNumericValue(ChangeEventArgs eventArgs)
    {
        var value = decimal.TryParse(eventArgs.Value?.ToString(), out var numericValue)
            ? numericValue
            : (decimal?)null;

        await AnswerChanged.InvokeAsync(CreateAnswer(value, Answer?.Value.SelectedAthleteId));
    }

    private IReadOnlyList<Athlete> GetEligibleAthletes()
    {
        return Question.AthleteIds.Count == 0
            ? Competition.Athletes
            : Competition.Athletes.Where(athlete => Question.AthleteIds.Contains(athlete.Id)).ToArray();
    }

    private PredictionAnswer CreateAnswer(decimal? numericValue, string? athleteId)
    {
        return new PredictionAnswer
        {
            GroupId = GroupId,
            QuestionId = Question.Id,
            QuestionType = Question.Type,
            Value = new PredictionAnswerValue
            {
                NumericValue = numericValue,
                SelectedAthleteId = athleteId
            },
            UpdatedAt = DateTimeOffset.UtcNow
        };
    }
}
