@inject IStringLocalizer<SharedResource> Localizer

<QuestionShell Competition="Competition" Question="Question" ValidationErrors="ValidationErrors">
    <label class="field">
        <span>@(Question.Constraints.Unit ?? Localizer["Common.Value"])</span>
        <input
            type="number"
            min="@Question.Constraints.MinValue"
            max="@Question.Constraints.MaxValue"
            step="@Question.Constraints.Step"
            value="@Answer?.Value.NumericValue"
            @onchange="SetNumericValue" />
    </label>
</QuestionShell>

@code {
    [Parameter, EditorRequired]
    public Competition Competition { get; set; } = default!;

    [Parameter, EditorRequired]
    public string GroupId { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public PredictionQuestion Question { get; set; } = default!;

    [Parameter]
    public PredictionAnswer? Answer { get; set; }

    [Parameter]
    public IReadOnlyList<PredictionValidationError> ValidationErrors { get; set; } = [];

    [Parameter]
    public EventCallback<PredictionAnswer> AnswerChanged { get; set; }

    private async Task SetNumericValue(ChangeEventArgs eventArgs)
    {
        var value = decimal.TryParse(eventArgs.Value?.ToString(), out var numericValue)
            ? numericValue
            : (decimal?)null;

        await AnswerChanged.InvokeAsync(new PredictionAnswer
        {
            GroupId = GroupId,
            QuestionId = Question.Id,
            QuestionType = Question.Type,
            Value = new PredictionAnswerValue { NumericValue = value },
            UpdatedAt = DateTimeOffset.UtcNow
        });
    }
}
