@inject LanguageService Language

<QuestionShell Question="Question" ValidationErrors="ValidationErrors">
    <div class="segmented">
        <button type="button" class="@GetButtonClass(true)" @onclick="() => SetValue(true)">@Language.Text("Common.Yes")</button>
        <button type="button" class="@GetButtonClass(false)" @onclick="() => SetValue(false)">@Language.Text("Common.No")</button>
    </div>
</QuestionShell>

@code {
    [Parameter, EditorRequired]
    public string GroupId { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public PredictionQuestion Question { get; set; } = default!;

    [Parameter]
    public PredictionAnswer? Answer { get; set; }

    [Parameter]
    public IReadOnlyList<PredictionValidationError> ValidationErrors { get; set; } = [];

    [Parameter]
    public EventCallback<PredictionAnswer> AnswerChanged { get; set; }

    private async Task SetValue(bool value)
    {
        await AnswerChanged.InvokeAsync(new PredictionAnswer
        {
            GroupId = GroupId,
            QuestionId = Question.Id,
            QuestionType = Question.Type,
            Value = new PredictionAnswerValue { BooleanValue = value },
            UpdatedAt = DateTimeOffset.UtcNow
        });
    }

    private string GetButtonClass(bool value)
    {
        return Answer?.Value.BooleanValue == value
            ? "segmented__button segmented__button--active"
            : "segmented__button";
    }
}
