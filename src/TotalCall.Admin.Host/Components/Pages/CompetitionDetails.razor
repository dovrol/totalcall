@page "/competitions/{CompetitionId}"
@using TotalCall.Operations.Admin
@using TotalCall.Operations.Competitions
@inject AdminCompetitionService CompetitionService
@inject AdminRuntimeOptions RuntimeOptions

<PageTitle>Competition details</PageTitle>

<section class="page-heading">
    <p class="eyebrow">Competition</p>
    <h1>@(_view?.Detail.Competition.Name ?? CompetitionId)</h1>
</section>

<section class="panel">
    <div class="panel-heading">
        <h2>Overview</h2>
        <span class="state @(RuntimeOptions.IsConfigured ? "state-ok" : "state-missing")">
            <span class="state-dot"></span>
            @(RuntimeOptions.IsConfigured ? "Configured" : "Missing credentials")
        </span>
    </div>

    @if (!RuntimeOptions.IsConfigured)
    {
        <p class="muted">Competition details require server-side Supabase credentials.</p>
    }
    else
    {
        <button class="button-primary" type="button" @onclick="LoadAsync" disabled="@_isLoading">
            @(_isLoading ? "Refreshing" : "Refresh")
        </button>
    }
</section>

@if (!string.IsNullOrWhiteSpace(_loadError))
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Load status</h2>
            <span class="state state-missing">
                <span class="state-dot"></span>
                Failed
            </span>
        </div>
        <p class="muted">@_loadError</p>
    </section>
}

@if (_view is not null)
{
    var competition = _view.Detail.Competition;

    <section class="panel">
        <div class="panel-heading">
            <h2>Runtime state</h2>
            <span class="state @CompetitionStatusClass(competition.Status)">
                <span class="state-dot"></span>
                @competition.Status
            </span>
        </div>

        <dl class="status-list status-list--wide">
            <div>
                <dt>Competition id</dt>
                <dd>@competition.Id</dd>
            </div>
            <div>
                <dt>Slug</dt>
                <dd>@competition.Slug</dd>
            </div>
            <div>
                <dt>Active config</dt>
                <dd>@(competition.ActiveVersion ?? "Unpublished")</dd>
            </div>
            <div>
                <dt>Prediction open</dt>
                <dd>@FormatDate(competition.PredictionOpenAt)</dd>
            </div>
            <div>
                <dt>Prediction lock</dt>
                <dd>@FormatDate(competition.PredictionLockAt)</dd>
            </div>
            <div>
                <dt>Competition end</dt>
                <dd>@FormatDate(competition.EndDate)</dd>
            </div>
            <div>
                <dt>Official results</dt>
                <dd>@(competition.OfficialResultsStatus ?? "Not imported")</dd>
            </div>
        </dl>
    </section>

    <section class="panel">
        <div class="panel-heading">
            <h2>Config versions</h2>
            <span class="state state-neutral">
                <span class="state-dot"></span>
                @_view.Detail.Versions.Count version(s)
            </span>
        </div>

        @if (_view.Detail.Versions.Count == 0)
        {
            <p class="muted">No config versions are stored for this competition.</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Version</th>
                            <th>State</th>
                            <th>Published</th>
                            <th>Created</th>
                            <th>Version id</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var version in _view.Detail.Versions)
                        {
                            <tr>
                                <td><strong>@version.Version</strong></td>
                                <td>
                                    <span class="state @(version.IsActive ? "state-ok" : "state-neutral")">
                                        <span class="state-dot"></span>
                                        @(version.IsActive ? "Active" : "Stored")
                                    </span>
                                </td>
                                <td>@FormatDate(version.PublishedAt)</td>
                                <td>@FormatDate(version.CreatedAt)</td>
                                <td>@version.Id</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    @if (_diff is not null)
    {
        <section class="panel">
            <div class="panel-heading">
                <h2>Config drift</h2>
                <span class="state @ConfigDriftClass(_diff)">
                    <span class="state-dot"></span>
                    @ConfigDriftLabel(_diff)
                </span>
            </div>

            <p class="notice">
                Compares the local dev/import JSON against the config this competition is
                currently published at. Local JSON is a source artifact, not the live config.
            </p>

            <dl class="status-list status-list--wide">
                <div>
                    <dt>Local path</dt>
                    <dd>@_diff.LocalPath</dd>
                </div>
                <div>
                    <dt>Local config version</dt>
                    <dd>@(_diff.LocalConfigVersion ?? "Unavailable")</dd>
                </div>
                <div>
                    <dt>Active version</dt>
                    <dd>@(_diff.ActiveVersion ?? "Unpublished")</dd>
                </div>
                <div>
                    <dt>Local hash</dt>
                    <dd>@ShortHash(_diff.Diff?.LocalHash)</dd>
                </div>
                <div>
                    <dt>Active hash</dt>
                    <dd>@ShortHash(_diff.Diff?.RemoteHash)</dd>
                </div>
            </dl>

            @if (!string.IsNullOrWhiteSpace(_diff.LocalError))
            {
                <p class="muted">@_diff.LocalError</p>
            }
            else if (!_diff.HasActiveVersion)
            {
                <p class="muted">No active config version is published, so there is nothing to compare against.</p>
            }
            else if (_diff.Diff is { IsIdentical: true })
            {
                <p class="muted">Local JSON matches the active version exactly.</p>
            }
            else if (_diff.Diff is { Differences.Count: > 0 } diff)
            {
                <div class="table-wrap">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Path</th>
                                <th>Change</th>
                                <th>Local</th>
                                <th>Active</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in diff.Differences)
                            {
                                <tr>
                                    <td>@entry.Path</td>
                                    <td>@DiffKindLabel(entry.Kind)</td>
                                    <td>@(entry.LocalValue ?? "—")</td>
                                    <td>@(entry.RemoteValue ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (diff.Truncated)
                {
                    <p class="muted">Showing the first @diff.Differences.Count differences; more were omitted.</p>
                }
            }
        </section>
    }

    <section class="panel">
        <div class="panel-heading">
            <h2>Recent operations</h2>
            <span class="state state-neutral">
                <span class="state-dot"></span>
                @_view.RecentOperations.Count operation(s)
            </span>
        </div>

        @if (_view.RecentOperations.Count == 0)
        {
            <p class="muted">No admin operations have been recorded for this competition.</p>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Finished</th>
                            <th>Operation</th>
                            <th>Status</th>
                            <th>Error</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var operation in _view.RecentOperations)
                        {
                            <tr>
                                <td>@FormatDate(operation.FinishedAt)</td>
                                <td>@FormatOperationType(operation.OperationType)</td>
                                <td>
                                    <span class="state @OperationStatusClass(operation.Status)">
                                        <span class="state-dot"></span>
                                        @operation.Status
                                    </span>
                                </td>
                                <td>@(operation.ErrorMessage ?? "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="panel">
        <div class="panel-heading">
            <h2>Next actions</h2>
        </div>

        <div class="workflow-list">
            <div class="workflow-row">
                <div>
                    <strong>Publish config</strong>
                    <span>Use the config validation form on the competitions page.</span>
                </div>
                <a class="button-secondary" href="/competitions">Open</a>
            </div>
            <div class="workflow-row">
                <div>
                    <strong>Import results</strong>
                    <span>Import official results and recompute score snapshots.</span>
                </div>
                <a class="button-secondary" href="/results">Open</a>
            </div>
        </div>
    </section>
}
else if (RuntimeOptions.IsConfigured && !_isLoading && string.IsNullOrWhiteSpace(_loadError))
{
    <section class="panel">
        <p class="muted">Competition was not found.</p>
    </section>
}

@code {
    [Parameter]
    public string CompetitionId { get; set; } = string.Empty;

    private AdminCompetitionDetailView? _view;
    private AdminCompetitionConfigDiffView? _diff;
    private string? _loadError;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        if (RuntimeOptions.IsConfigured)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadError = null;
        _diff = null;
        try
        {
            _view = await CompetitionService.GetDetailAsync(CompetitionId, CancellationToken.None);
            if (_view is not null)
            {
                await LoadConfigDiffAsync(_view.Detail.Competition);
            }
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            _view = null;
            _loadError = $"Competition details could not be loaded: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    // Config drift is best-effort enrichment; a failure here must not take down
    // the rest of the details page.
    private async Task LoadConfigDiffAsync(CompetitionAdminRow competition)
    {
        try
        {
            _diff = await CompetitionService.GetConfigDiffAsync(
                competition.Id,
                competition.Slug,
                CancellationToken.None);
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            _diff = new AdminCompetitionConfigDiffView(
                $"src/TotalCall.Client/wwwroot/data/competitions/{competition.Slug}.json",
                LocalAvailable: false,
                LocalConfigVersion: null,
                LocalError: $"Config drift could not be computed: {ex.Message}",
                HasActiveVersion: false,
                ActiveVersion: null,
                Diff: null);
        }
    }

    private static string FormatDate(DateTimeOffset? value) =>
        value is null ? "Unavailable" : value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private static string FormatOperationType(string operationType) => operationType switch
    {
        AdminOperationType.CompetitionConfigPublish => "Competition config publish",
        AdminOperationType.OfficialResultsImport => "Official results import",
        _ => operationType
    };

    private static string CompetitionStatusClass(string status) => status switch
    {
        "completed" or "archived" => "state-ok",
        "locked" => "state-neutral",
        _ => "state-ok"
    };

    private static string OperationStatusClass(string status) => status switch
    {
        AdminOperationStatus.Succeeded => "state-ok",
        AdminOperationStatus.Failed => "state-missing",
        _ => "state-neutral"
    };

    private static string ConfigDriftClass(AdminCompetitionConfigDiffView diff)
    {
        if (!string.IsNullOrWhiteSpace(diff.LocalError) || !diff.HasActiveVersion || !diff.LocalAvailable)
        {
            return "state-neutral";
        }

        return diff.Diff is { IsIdentical: true } ? "state-ok" : "state-missing";
    }

    private static string ConfigDriftLabel(AdminCompetitionConfigDiffView diff)
    {
        if (!string.IsNullOrWhiteSpace(diff.LocalError) || !diff.LocalAvailable)
        {
            return "Local JSON unavailable";
        }

        if (!diff.HasActiveVersion)
        {
            return "No active version";
        }

        return diff.Diff is { IsIdentical: true } ? "In sync" : "Drift detected";
    }

    private static string DiffKindLabel(ConfigDiffKind kind) => kind switch
    {
        ConfigDiffKind.LocalOnly => "Only in local",
        ConfigDiffKind.RemoteOnly => "Only in active",
        _ => "Changed"
    };

    private static string ShortHash(string? hash) =>
        string.IsNullOrWhiteSpace(hash) ? "Unavailable" : hash[..Math.Min(12, hash.Length)];
}
