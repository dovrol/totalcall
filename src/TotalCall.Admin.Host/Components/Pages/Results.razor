@page "/results"
@using System.ComponentModel.DataAnnotations
@using TotalCall.Operations.Results
@inject OfficialResultsImporter ResultsImporter
@inject AdminOperationAuditService AuditService
@inject AdminRuntimeOptions RuntimeOptions

<PageTitle>Results import</PageTitle>

<section class="page-heading">
    <p class="eyebrow">Results</p>
    <h1>Official results import</h1>
</section>

<section class="panel">
    <div class="panel-heading">
        <h2>Import file</h2>
        <span class="state @(RuntimeOptions.IsConfigured ? "state-neutral" : "state-missing")">
            <span class="state-dot"></span>
            @(RuntimeOptions.IsConfigured ? "Confirmation required" : "Missing credentials")
        </span>
    </div>

    <p class="notice">
        Imports official result groups, then recomputes score snapshots for submitted predictions.
    </p>

    <EditForm Model="_form" OnValidSubmit="ImportResultsAsync" class="form-stack">
        <DataAnnotationsValidator />
        <div class="field">
            <label for="results-competition-id">Competition id</label>
            <InputText id="results-competition-id" @bind-Value="_form.CompetitionId" />
            <ValidationMessage For="@(() => _form.CompetitionId)" />
        </div>
        <div class="field">
            <label for="results-json-path">Results JSON path</label>
            <InputText id="results-json-path" @bind-Value="_form.ResultsJsonPath" />
            <ValidationMessage For="@(() => _form.ResultsJsonPath)" />
        </div>
        <div class="field">
            <label for="results-confirmation">Type @RequiredImportConfirmation to import</label>
            <InputText id="results-confirmation" @bind-Value="_form.ConfirmationText" />
            <ValidationMessage For="@(() => _form.ConfirmationText)" />
        </div>
        <div class="form-actions">
            <button class="button-secondary" type="button" @onclick="DryRunAsync"
                    disabled="@(!CanDryRun || _isDryRunning || _isImporting)">
                @(_isDryRunning ? "Validating" : "Validate (dry run)")
            </button>
            <button class="button-primary" type="submit" disabled="@(!CanImport || _isImporting || _isDryRunning)">
                @(_isImporting ? "Importing" : "Import results")
            </button>
        </div>
    </EditForm>
</section>

@if (!string.IsNullOrWhiteSpace(_dryRunError))
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Dry run status</h2>
            <span class="state state-missing">
                <span class="state-dot"></span>
                Failed
            </span>
        </div>
        <p class="muted">@_dryRunError</p>
    </section>
}

@if (_dryRunResult is not null)
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Dry run preview</h2>
            <span class="state @(_dryRunResult.IsValid ? "state-ok" : "state-missing")">
                <span class="state-dot"></span>
                @(_dryRunResult.IsValid ? "Would import" : "Blocked")
            </span>
        </div>

        <p class="notice">No data was written. This previews what an import would do.</p>

        <dl class="status-list status-list--wide">
            <div>
                <dt>Status</dt>
                <dd>@(_dryRunResult.Status ?? "Unavailable")</dd>
            </div>
            <div>
                <dt>Groups in file</dt>
                <dd>@_dryRunResult.GroupsInFile (@_dryRunResult.FinalGroupsInFile final / @_dryRunResult.PendingGroupsInFile pending)</dd>
            </div>
            <div>
                <dt>Athletes referenced</dt>
                <dd>@_dryRunResult.DistinctAthletesReferenced</dd>
            </div>
            <div>
                <dt>Active config version</dt>
                <dd>@(_dryRunResult.ActiveConfigVersion ?? "Unavailable")</dd>
            </div>
            <div>
                <dt>Results hash</dt>
                <dd>@ShortHash(_dryRunResult.ResultsHash)</dd>
            </div>
            <div>
                <dt>Compared to imported</dt>
                <dd>@ComparedToImportedLabel(_dryRunResult)</dd>
            </div>
        </dl>
    </section>

    @if (_dryRunResult.ValidationErrors.Count > 0)
    {
        <section class="panel">
            <div class="panel-heading">
                <h2>Validation errors</h2>
                <span class="state state-missing">
                    <span class="state-dot"></span>
                    @_dryRunResult.ValidationErrors.Count issue(s)
                </span>
            </div>

            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Message</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var errorIndex = 0;
                        }
                        @foreach (var error in _dryRunResult.ValidationErrors)
                        {
                            errorIndex++;
                            <tr>
                                <td>@errorIndex</td>
                                <td>@error</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }

    <section class="panel">
        <div class="panel-heading">
            <h2>Dry run log</h2>
        </div>

        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Level</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _dryRunResult.Logs)
                    {
                        <tr>
                            <td class="log-level log-level-@entry.Level">@entry.Level</td>
                            <td>@entry.Message</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@if (!string.IsNullOrWhiteSpace(_importError))
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Import status</h2>
            <span class="state state-missing">
                <span class="state-dot"></span>
                Failed
            </span>
        </div>
        <p class="muted">@_importError</p>
    </section>
}

@if (_importResult is not null)
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Import result</h2>
            <span class="state @(_importResult.Succeeded ? "state-ok" : "state-missing")">
                <span class="state-dot"></span>
                @(_importResult.Succeeded ? "Imported" : "Not imported")
            </span>
        </div>

        <dl class="status-list">
            <div>
                <dt>Exit code</dt>
                <dd>@_importResult.ExitCode</dd>
            </div>
            <div>
                <dt>Groups in file</dt>
                <dd>@_importResult.GroupsInFile</dd>
            </div>
            <div>
                <dt>Groups imported</dt>
                <dd>@_importResult.GroupsImported</dd>
            </div>
            <div>
                <dt>Submitted rows scored</dt>
                <dd>@_importResult.SubmittedRowsScored</dd>
            </div>
            <div>
                <dt>Leaderboard status</dt>
                <dd>@(_importResult.LeaderboardStatus ?? "Unavailable")</dd>
            </div>
            <div>
                <dt>Calculated at</dt>
                <dd>@(_importResult.CalculatedAt?.ToString("O") ?? "Unavailable")</dd>
            </div>
        </dl>
    </section>

    <section class="panel">
        <div class="panel-heading">
            <h2>Operation log</h2>
        </div>

        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Level</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _importResult.Logs)
                    {
                        <tr>
                            <td class="log-level log-level-@entry.Level">@entry.Level</td>
                            <td>@entry.Message</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@if (!string.IsNullOrWhiteSpace(_auditStatus))
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Audit</h2>
            <span class="state state-ok">
                <span class="state-dot"></span>
                Recorded
            </span>
        </div>
        <p class="muted">@_auditStatus</p>
    </section>
}

@if (!string.IsNullOrWhiteSpace(_auditError))
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Audit</h2>
            <span class="state state-missing">
                <span class="state-dot"></span>
                Failed
            </span>
        </div>
        <p class="muted">@_auditError</p>
    </section>
}

@code {
    private readonly ResultsImportForm _form = new()
    {
        CompetitionId = "worlds-2026",
        ResultsJsonPath = "tools/sync/data/results/worlds-2026-partial-2026-06-17.json"
    };

    private ResultsImportResult? _importResult;
    private ResultsImportDryRunResult? _dryRunResult;
    private string? _importError;
    private string? _dryRunError;
    private string? _auditStatus;
    private string? _auditError;
    private bool _isImporting;
    private bool _isDryRunning;

    private string RequiredImportConfirmation => $"import {_form.CompetitionId.Trim()}";

    private bool CanDryRun =>
        RuntimeOptions.IsConfigured
        && !string.IsNullOrWhiteSpace(_form.CompetitionId)
        && !string.IsNullOrWhiteSpace(_form.ResultsJsonPath);

    private bool CanImport =>
        CanDryRun
        && string.Equals(
            _form.ConfirmationText.Trim(),
            RequiredImportConfirmation,
            StringComparison.Ordinal);

    private async Task DryRunAsync()
    {
        if (!CanDryRun)
        {
            return;
        }

        _isDryRunning = true;
        _dryRunResult = null;
        _dryRunError = null;
        _importResult = null;
        _importError = null;
        try
        {
            _dryRunResult = await ResultsImporter.DryRunAsync(
                new ResultsImportOptions
                {
                    CompetitionId = _form.CompetitionId.Trim(),
                    ResultsJsonPath = _form.ResultsJsonPath.Trim(),
                    SupabaseUrl = RuntimeOptions.SupabaseUrl,
                    SupabaseSecretKey = RuntimeOptions.SupabaseSecretKey,
                    TriggeredBy = "admin-host"
                },
                CancellationToken.None);
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            _dryRunError = $"Dry run failed: {ex.Message}";
        }
        finally
        {
            _isDryRunning = false;
        }
    }

    private async Task ImportResultsAsync()
    {
        if (!CanImport)
        {
            return;
        }

        _isImporting = true;
        _importResult = null;
        _importError = null;
        _dryRunResult = null;
        _dryRunError = null;
        _auditStatus = null;
        _auditError = null;
        var startedAt = DateTimeOffset.UtcNow;
        try
        {
            var competitionId = _form.CompetitionId.Trim();
            var requiredConfirmation = $"import {competitionId}";
            if (!string.Equals(_form.ConfirmationText.Trim(), requiredConfirmation, StringComparison.Ordinal))
            {
                _importError = $"Import was blocked because confirmation must match {requiredConfirmation}.";
                return;
            }

            _importResult = await ResultsImporter.ImportAsync(
                new ResultsImportOptions
                {
                    CompetitionId = competitionId,
                    ResultsJsonPath = _form.ResultsJsonPath.Trim(),
                    SupabaseUrl = RuntimeOptions.SupabaseUrl,
                    SupabaseSecretKey = RuntimeOptions.SupabaseSecretKey,
                    TriggeredBy = "admin-host"
                },
                CancellationToken.None);

            await TryRecordAuditAsync(
                competitionId,
                _form.ResultsJsonPath.Trim(),
                _importResult,
                startedAt,
                DateTimeOffset.UtcNow);

            if (!_importResult.Succeeded)
            {
                _importError = "Import did not complete. Review the operation log.";
            }
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            _importError = $"Import failed: {ex.Message}";
        }
        finally
        {
            _form.ConfirmationText = string.Empty;
            _isImporting = false;
        }
    }

    private async Task TryRecordAuditAsync(
        string competitionId,
        string resultsJsonPath,
        ResultsImportResult result,
        DateTimeOffset startedAt,
        DateTimeOffset finishedAt)
    {
        try
        {
            var auditId = await AuditService.RecordResultsImportAsync(
                competitionId,
                resultsJsonPath,
                result,
                startedAt,
                finishedAt,
                CancellationToken.None);
            _auditStatus = $"Operation audit recorded as {auditId}.";
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            _auditError = $"Operation completed, but audit history could not be written: {ex.Message}";
        }
    }

    private static string ShortHash(string? hash) =>
        string.IsNullOrWhiteSpace(hash) ? "Unavailable" : hash[..Math.Min(12, hash.Length)];

    private static string ComparedToImportedLabel(ResultsImportDryRunResult result)
    {
        if (!result.CompetitionPublished)
        {
            return "Unavailable";
        }

        if (result.MatchesStoredResults)
        {
            return "Unchanged";
        }

        return string.IsNullOrWhiteSpace(result.StoredResultsHash) ? "First import" : "Changed";
    }

    private sealed class ResultsImportForm
    {
        [Required]
        public string CompetitionId { get; set; } = string.Empty;

        [Required]
        public string ResultsJsonPath { get; set; } = string.Empty;

        [Required]
        public string ConfirmationText { get; set; } = string.Empty;
    }
}
