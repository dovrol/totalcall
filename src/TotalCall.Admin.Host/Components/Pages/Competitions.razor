@page "/competitions"
@using System.ComponentModel.DataAnnotations
@using TotalCall.Operations.Admin
@using TotalCall.Operations.Competitions
@inject AdminCompetitionService CompetitionService
@inject CompetitionConfigFileChecker ConfigChecker
@inject CompetitionDefinitionImporter DefinitionImporter
@inject AdminOperationAuditService AuditService
@inject AdminRuntimeOptions RuntimeOptions

<PageTitle>Competition config</PageTitle>

<section class="page-heading">
    <p class="eyebrow">Competitions</p>
    <h1>Competition operations</h1>
</section>

<section class="panel">
    <div class="panel-heading">
        <h2>Imported competitions</h2>
        <span class="state @(RuntimeOptions.IsConfigured ? "state-ok" : "state-missing")">
            <span class="state-dot"></span>
            @(RuntimeOptions.IsConfigured ? "Configured" : "Missing credentials")
        </span>
    </div>

    @if (!RuntimeOptions.IsConfigured)
    {
        <p class="muted">Competition grid requires server-side Supabase credentials.</p>
    }
    else
    {
        <button class="button-primary" type="button" @onclick="LoadCompetitionsAsync" disabled="@_isLoadingCompetitions">
            @(_isLoadingCompetitions ? "Refreshing" : "Refresh")
        </button>
    }
</section>

@if (!string.IsNullOrWhiteSpace(_competitionLoadError))
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Grid status</h2>
            <span class="state state-missing">
                <span class="state-dot"></span>
                Failed
            </span>
        </div>
        <p class="muted">@_competitionLoadError</p>
    </section>
}

@if (_competitionRows.Count > 0)
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Last @_competitionRows.Count competitions</h2>
        </div>

        <div class="table-wrap">
            <table class="data-table data-table--operations">
                <thead>
                    <tr>
                        <th>Competition</th>
                        <th>Status</th>
                        <th>Lock</th>
                        <th>Config</th>
                        <th>Results</th>
                        <th>Last operation</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _competitionRows)
                    {
                        <tr>
                            <td>
                                <strong>@row.Competition.Name</strong>
                                <span class="table-subtext">@row.Competition.Id</span>
                            </td>
                            <td>
                                <span class="state @CompetitionStatusClass(row.Competition.Status)">
                                    <span class="state-dot"></span>
                                    @row.Competition.Status
                                </span>
                            </td>
                            <td>@FormatDate(row.Competition.PredictionLockAt)</td>
                            <td>
                                <strong>@(row.Competition.ActiveVersion ?? "Unpublished")</strong>
                                <span class="table-subtext">@row.Competition.VersionsCount version(s)</span>
                            </td>
                            <td>
                                <strong>@(row.Competition.OfficialResultsStatus ?? "Not imported")</strong>
                                <span class="table-subtext">@FormatDate(row.Competition.OfficialResultsImportedAt)</span>
                            </td>
                            <td>@FormatOperation(row.LatestOperation)</td>
                            <td>
                                <div class="table-actions">
                                    <a class="button-secondary" href="@CompetitionDetailsHref(row.Competition.Id)">Open</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}
else if (RuntimeOptions.IsConfigured && !_isLoadingCompetitions && string.IsNullOrWhiteSpace(_competitionLoadError))
{
    <section class="panel">
        <p class="muted">No competitions have been imported yet.</p>
    </section>
}

<section class="panel">
    <div class="panel-heading">
        <h2>Local JSON validation</h2>
    </div>

    <EditForm Model="_form" OnValidSubmit="CheckConfigAsync" class="form-stack">
        <DataAnnotationsValidator />
        <div class="field">
            <label for="competition-json-path">Competition JSON path</label>
            <InputText id="competition-json-path" @bind-Value="_form.CompetitionJsonPath" />
            <ValidationMessage For="@(() => _form.CompetitionJsonPath)" />
        </div>
        <button class="button-primary" type="submit" disabled="@_isChecking">
            @(_isChecking ? "Checking" : "Check config")
        </button>
    </EditForm>
</section>

@if (_result is not null)
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Validation result</h2>
            <span class="state @(_result.IsValid ? "state-ok" : "state-missing")">
                <span class="state-dot"></span>
                @(_result.IsValid ? "Valid" : "Invalid")
            </span>
        </div>

        <dl class="status-list">
            <div>
                <dt>Resolved path</dt>
                <dd>@_result.ResolvedPath</dd>
            </div>
            <div>
                <dt>Competition</dt>
                <dd>@DisplayCompetition(_result)</dd>
            </div>
            <div>
                <dt>Config version</dt>
                <dd>@(_result.ConfigVersion ?? "Unavailable")</dd>
            </div>
        </dl>
    </section>

    @if (_result.Errors.Count > 0)
    {
        <section class="panel">
            <div class="panel-heading">
                <h2>Errors</h2>
            </div>

            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Path</th>
                            <th>Code</th>
                            <th>Message</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var error in _result.Errors)
                        {
                            <tr>
                                <td>@error.Path</td>
                                <td>@error.Code</td>
                                <td>@error.Message</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
}

@if (_result?.IsValid == true)
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Publish config</h2>
            <span class="state @(RuntimeOptions.IsConfigured ? "state-neutral" : "state-missing")">
                <span class="state-dot"></span>
                @(RuntimeOptions.IsConfigured ? "Confirmation required" : "Missing credentials")
            </span>
        </div>

        <p class="notice">
            Publishes the validated JSON to the configured Supabase project, creates or reuses an immutable
            competition version, and points the competition at that version.
        </p>

        <EditForm Model="_publishForm" OnValidSubmit="PublishConfigAsync" class="form-stack">
            <DataAnnotationsValidator />
            <div class="field">
                <label for="publish-confirmation">Type @RequiredPublishConfirmation to publish</label>
                <InputText id="publish-confirmation" @bind-Value="_publishForm.ConfirmationText" />
                <ValidationMessage For="@(() => _publishForm.ConfirmationText)" />
            </div>
            <button class="button-primary" type="submit" disabled="@(!CanPublish || _isPublishing)">
                @(_isPublishing ? "Publishing" : "Publish config")
            </button>
        </EditForm>
    </section>
}

@if (!string.IsNullOrWhiteSpace(_publishError))
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Publish status</h2>
            <span class="state state-missing">
                <span class="state-dot"></span>
                Failed
            </span>
        </div>
        <p class="muted">@_publishError</p>
    </section>
}

@if (_publishResult is not null)
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Publish result</h2>
            <span class="state @(_publishResult.Succeeded ? "state-ok" : "state-missing")">
                <span class="state-dot"></span>
                @(_publishResult.Succeeded ? "Published" : "Not published")
            </span>
        </div>

        <dl class="status-list">
            <div>
                <dt>Exit code</dt>
                <dd>@_publishResult.ExitCode</dd>
            </div>
            <div>
                <dt>Version</dt>
                <dd>@(_publishResult.EffectiveConfigVersion ?? _publishResult.ConfigVersion ?? "Unavailable")</dd>
            </div>
            <div>
                <dt>Version id</dt>
                <dd>@(_publishResult.PublishedVersionId ?? "Unavailable")</dd>
            </div>
        </dl>
    </section>

    <section class="panel">
        <div class="panel-heading">
            <h2>Operation log</h2>
        </div>

        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Level</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _publishResult.Logs)
                    {
                        <tr>
                            <td class="log-level log-level-@entry.Level">@entry.Level</td>
                            <td>@entry.Message</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@if (!string.IsNullOrWhiteSpace(_auditStatus))
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Audit</h2>
            <span class="state state-ok">
                <span class="state-dot"></span>
                Recorded
            </span>
        </div>
        <p class="muted">@_auditStatus</p>
    </section>
}

@if (!string.IsNullOrWhiteSpace(_auditError))
{
    <section class="panel">
        <div class="panel-heading">
            <h2>Audit</h2>
            <span class="state state-missing">
                <span class="state-dot"></span>
                Failed
            </span>
        </div>
        <p class="muted">@_auditError</p>
    </section>
}

@code {
    private readonly CompetitionConfigForm _form = new()
    {
        CompetitionJsonPath = "src/TotalCall.Client/wwwroot/data/competitions/worlds-2026.json"
    };
    private readonly CompetitionPublishForm _publishForm = new();

    private IReadOnlyList<AdminCompetitionGridRow> _competitionRows = [];
    private CompetitionConfigFileCheckResult? _result;
    private CompetitionSyncResult? _publishResult;
    private string? _competitionLoadError;
    private string? _publishError;
    private string? _auditStatus;
    private string? _auditError;
    private bool _isLoadingCompetitions;
    private bool _isChecking;
    private bool _isPublishing;

    private string RequiredPublishConfirmation => $"publish {_result?.CompetitionId ?? string.Empty}";

    private bool CanPublish =>
        _result is { IsValid: true, CompetitionId: { Length: > 0 } }
        && RuntimeOptions.IsConfigured
        && string.Equals(
            _publishForm.ConfirmationText.Trim(),
            RequiredPublishConfirmation,
            StringComparison.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        if (RuntimeOptions.IsConfigured)
        {
            await LoadCompetitionsAsync();
        }
    }

    private async Task LoadCompetitionsAsync()
    {
        _isLoadingCompetitions = true;
        _competitionLoadError = null;
        try
        {
            _competitionRows = await CompetitionService.ListAsync(CancellationToken.None);
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            _competitionRows = [];
            _competitionLoadError = $"Competition grid could not be loaded: {ex.Message}";
        }
        finally
        {
            _isLoadingCompetitions = false;
        }
    }

    private async Task CheckConfigAsync()
    {
        _isChecking = true;
        _publishResult = null;
        _publishError = null;
        _auditStatus = null;
        _auditError = null;
        _publishForm.ConfirmationText = string.Empty;
        try
        {
            _result = await ConfigChecker.CheckAsync(_form.CompetitionJsonPath, CancellationToken.None);
        }
        finally
        {
            _isChecking = false;
        }
    }

    private async Task PublishConfigAsync()
    {
        if (!CanPublish)
        {
            return;
        }

        _isPublishing = true;
        _publishResult = null;
        _publishError = null;
        _auditStatus = null;
        _auditError = null;
        var startedAt = DateTimeOffset.UtcNow;
        try
        {
            var latestCheck = await ConfigChecker.CheckAsync(_form.CompetitionJsonPath, CancellationToken.None);
            _result = latestCheck;
            if (!latestCheck.IsValid)
            {
                _publishError = "Publish was blocked because the config is no longer valid.";
                return;
            }

            var latestConfirmation = $"publish {latestCheck.CompetitionId}";
            if (!string.Equals(
                _publishForm.ConfirmationText.Trim(),
                latestConfirmation,
                StringComparison.Ordinal))
            {
                _publishError = $"Publish was blocked because confirmation must match {latestConfirmation}.";
                return;
            }

            _publishResult = await DefinitionImporter.SyncAsync(
                new CompetitionSyncOptions
                {
                    CompetitionJsonPath = latestCheck.ResolvedPath,
                    SupabaseUrl = RuntimeOptions.SupabaseUrl,
                    SupabaseSecretKey = RuntimeOptions.SupabaseSecretKey,
                    TriggeredBy = "admin-host"
                },
                CancellationToken.None);

            await TryRecordAuditAsync(latestCheck, _publishResult, startedAt, DateTimeOffset.UtcNow);

            if (!_publishResult.Succeeded)
            {
                _publishError = "Publish did not complete. Review the operation log.";
            }
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            _publishError = $"Publish failed: {ex.Message}";
        }
        finally
        {
            _publishForm.ConfirmationText = string.Empty;
            _isPublishing = false;
        }
    }

    private async Task TryRecordAuditAsync(
        CompetitionConfigFileCheckResult latestCheck,
        CompetitionSyncResult result,
        DateTimeOffset startedAt,
        DateTimeOffset finishedAt)
    {
        try
        {
            var auditId = await AuditService.RecordCompetitionPublishAsync(
                latestCheck,
                result,
                startedAt,
                finishedAt,
                CancellationToken.None);
            _auditStatus = $"Operation audit recorded as {auditId}.";
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            _auditError = $"Operation completed, but audit history could not be written: {ex.Message}";
        }
    }

    private static string DisplayCompetition(CompetitionConfigFileCheckResult result)
    {
        if (!string.IsNullOrWhiteSpace(result.CompetitionName))
        {
            return result.CompetitionName;
        }

        if (!string.IsNullOrWhiteSpace(result.CompetitionId))
        {
            return result.CompetitionId;
        }

        return "Unavailable";
    }

    private static string CompetitionDetailsHref(string competitionId) =>
        $"/competitions/{Uri.EscapeDataString(competitionId)}";

    private static string FormatDate(DateTimeOffset? value) =>
        value is null ? "Unavailable" : value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private static string FormatOperation(AdminOperationAuditRecord? operation)
    {
        if (operation is null)
        {
            return "None";
        }

        return $"{FormatOperationType(operation.OperationType)} · {operation.Status} · {FormatDate(operation.FinishedAt)}";
    }

    private static string FormatOperationType(string operationType) => operationType switch
    {
        AdminOperationType.CompetitionConfigPublish => "Config publish",
        AdminOperationType.OfficialResultsImport => "Results import",
        _ => operationType
    };

    private static string CompetitionStatusClass(string status) => status switch
    {
        "completed" or "archived" => "state-ok",
        "locked" => "state-neutral",
        _ => "state-ok"
    };

    private sealed class CompetitionConfigForm
    {
        [Required]
        public string CompetitionJsonPath { get; set; } = string.Empty;
    }

    private sealed class CompetitionPublishForm
    {
        [Required]
        public string ConfirmationText { get; set; } = string.Empty;
    }
}
